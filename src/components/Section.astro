---
interface Props {
	id?: string;
	variant?: 'light' | 'soft' | 'scripture' | 'cta-band' | 'dark';
	class?: string;
}

const { id, variant = 'light', class: className } = Astro.props;

const bgMap: Record<string, string> = {
	light: 'var(--color-surface)',
	soft: 'var(--color-surface-low)',
	scripture: 'var(--color-surface)',
	'cta-band': 'var(--color-primary)',
	dark: 'var(--color-inverse-surface)',
};

const paddingMap: Record<string, string> = {
	light: 'py-8 md:py-12 lg:py-16',
	soft: 'py-8 md:py-12 lg:py-16',
	scripture: 'py-10 md:py-14 lg:py-20',
	'cta-band': 'py-8 md:py-10 lg:py-14',
	dark: 'py-8 md:py-12 lg:py-16',
};

const bg = bgMap[variant];
const padding = paddingMap[variant];
---

<section
	id={id}
	class={`${padding} ${className ?? ''}`}
	style={`background-color: ${bg};`}
>
	<div class="max-w-6xl mx-auto px-4 md:px-6" data-reveal>
		<slot />
	</div>
</section>
