---
// Magazine-style pull quote.
// - Mobile (<768px): full-width centered block with a pink left border
// - Desktop (>=768px): floats left at ~42% width so body text wraps to the right
// - Decorative open-quote glyph in FHB pink
//
// Triggered by a `pullQuote` body block ({_type:'pullQuote', quote, attribution?}).
interface Props {
	quote: string;
	attribution?: string;
}
const { quote, attribution } = Astro.props;
---

<aside class="pull-quote" aria-label="Pull quote">
	<span class="pull-quote__mark" aria-hidden="true">“</span>
	<blockquote class="pull-quote__text">{quote}</blockquote>
	{attribution && <cite class="pull-quote__attr">— {attribution}</cite>}
</aside>

<style>
	.pull-quote {
		/* Mobile defaults — full-width centered */
		display: block;
		margin: 2rem auto;
		padding: 1.25rem 1.5rem 1.25rem 1.75rem;
		border-left: 4px solid var(--color-brand, #a04060);
		background-color: var(--color-surface-low, #fbf7f8);
		position: relative;
		max-width: 100%;
	}

	.pull-quote__mark {
		position: absolute;
		top: -0.5rem;
		left: 0.5rem;
		font-family: var(--font-serif, Georgia, serif);
		font-size: 4rem;
		line-height: 1;
		color: var(--color-brand, #a04060);
		opacity: 0.35;
		font-weight: 700;
		pointer-events: none;
	}

	.pull-quote__text {
		margin: 0;
		padding: 0;
		font-family: var(--font-serif, Georgia, serif);
		font-style: italic;
		font-size: 1.375rem; /* 22px */
		line-height: 1.4;
		color: var(--color-ink, #1a1a1a);
		quotes: none;
	}

	.pull-quote__text::before,
	.pull-quote__text::after {
		content: '';
	}

	.pull-quote__attr {
		display: block;
		margin-top: 0.75rem;
		font-family: var(--font-sans, system-ui);
		font-size: 0.75rem;
		font-style: normal;
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--color-muted, #6b5560);
	}

	/* Desktop — float left, magazine style */
	@media (min-width: 768px) {
		.pull-quote {
			float: left;
			width: 42%;
			margin: 0.5rem 2rem 1rem 0;
			padding: 1.5rem 1.75rem 1.5rem 2rem;
		}

		.pull-quote__text {
			font-size: 1.5rem; /* 24px */
		}
	}
</style>
