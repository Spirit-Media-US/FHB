	{
		dollar: '$700K',
		language: 'Japanese',
		flag: '🇯🇵',
		parenthetical: '125M speakers',
		reach: '5.78B',
	},
	{
		dollar: '$750K',
		language: 'Nigerian Pidgin',
		flag: '🇳🇬',
		parenthetical: '121M speakers',
		reach: '5.90B',
	},
	{
		dollar: '$800K',
		language: 'Marathi',
		flag: '🇮🇳',
		parenthetical: '99M speakers',
		reach: '6.00B',
	},
	{
