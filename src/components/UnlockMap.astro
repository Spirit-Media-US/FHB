---
// Shared "country map" / language-unlock section.
// Lives on /partner (the former /nations page was retired → 301 to /partner).
// Each language unlocks for a flat $50,000; reach is per-language.
interface UnlockRow {
	language: string;
	flag: string; // emoji
	parenthetical?: string;
	reach: string; // this language's own reach
	sponsor?: string; // pledge label override (defaults to language)
	highlight?: boolean;
	country?: { slug: string; label: string }; // link to a /bible-in country page (its Translation Opportunity)
}

const COST = '$50,000';

const unlocks: UnlockRow[] = [
	{
		language: 'English',
		flag: '🇺🇸',
		parenthetical: 'Base Edition',
		reach: '1.5B',
		sponsor: 'English',
		highlight: true,
	},
	{ language: 'Spanish', flag: '🇲🇽', reach: '550M', country: { slug: 'mexico', label: 'Mexico' } },
	{
		language: 'Portuguese',
		flag: '🇧🇷',
		parenthetical: 'Brazil + Lusophone Africa',
		reach: '257M',
		country: { slug: 'brazil', label: 'Brazil' },
	},
	{
		language: 'French',
		flag: '🇫🇷',
		parenthetical: 'Includes Francophone Africa',
		reach: '280M',
		country: { slug: 'dr-congo', label: 'DR Congo' },
	},
	{
		language: 'Hindi',
		flag: '🇮🇳',
		parenthetical: "India's growing church",
		reach: '600M',
		country: { slug: 'india', label: 'India' },
	},
	{ language: 'Arabic', flag: '🇪🇬', parenthetical: 'Middle East + N. Africa', reach: '274M' },
	{ language: 'Mandarin', flag: '🇨🇳', parenthetical: "China's underground church", reach: '1.1B' },
	{
		language: 'Indonesian',
		flag: '🇮🇩',
		parenthetical: 'Largest Muslim-majority nation',
		reach: '199M',
	},
	{ language: 'Bengali', flag: '🇧🇩', reach: '272M', country: { slug: 'india', label: 'India' } },
	{ language: 'Urdu', flag: '🇵🇰', reach: '231M', country: { slug: 'india', label: 'India' } },
	{ language: 'Russian', flag: '🇷🇺', reach: '258M' },
	{ language: 'German', flag: '🇩🇪', reach: '135M' },
	{ language: 'Japanese', flag: '🇯🇵', reach: '125M' },
	{
		language: 'Nigerian Pidgin',
		flag: '🇳🇬',
		reach: '121M',
		country: { slug: 'nigeria', label: 'Nigeria' },
	},
	{ language: 'Marathi', flag: '🇮🇳', reach: '99M', country: { slug: 'india', label: 'India' } },
	{ language: 'Telugu', flag: '🇮🇳', reach: '96M', country: { slug: 'india', label: 'India' } },
	{
		language: 'Filipino (Tagalog)',
		flag: '🇵🇭',
		reach: '90M',
		country: { slug: 'philippines', label: 'Philippines' },
	},
	{ language: 'Turkish', flag: '🇹🇷', reach: '88M' },
	{ language: 'Tamil', flag: '🇮🇳', reach: '86M', country: { slug: 'india', label: 'India' } },
	{ language: 'Yue Chinese', flag: '🇭🇰', reach: '86M' },
	{
		language: 'Vietnamese',
		flag: '🇻🇳',
		parenthetical: 'Among the world\u2019s major tongues \u00b7 within reach of most of humanity',
		reach: '85M',
		highlight: true,
	},
	{
		language: 'Swahili',
		flag: '🇰🇪',
		parenthetical: 'East Africa\u2019s lingua franca',
		reach: '80M',
		country: { slug: 'kenya', label: 'Kenya' },
	},
];

// Spam-safe mailto: the address is split across data-* and assembled on click,
// so the raw kevin@… never appears in the served HTML (no href, no visible text).
const pledgeOnclick =
	"event.preventDefault();window.location.href='mailto:'+this.dataset.e+'@'+this.dataset.d+'?subject='+encodeURIComponent(this.dataset.subj)";
const pledgeSubject = (row: UnlockRow) => `Pledge to Sponsor ${row.sponsor || row.language}`;
---

<section class="py-12 md:py-16 px-4 md:px-6" style="background-color: var(--color-soft);">
	<div class="max-w-3xl mx-auto" data-reveal>
		<header class="mb-8 text-center">
			<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-sans); color: var(--color-gold);">
				Unlock Map
			</p>
			<h2 class="text-3xl md:text-4xl font-light" style="font-family: var(--font-serif); color: var(--color-ink);">
				$50,000 a language — every dollar a doorway.
			</h2>
			<p class="mt-4 leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">
				Each language opens for a one-time <strong style="color: var(--color-primary);">$50,000</strong> —
				full translation, print, digital, and audio. Ranked by reach, these tongues already put the Bible
				within reach of <strong style="color: var(--color-primary);">most of humanity</strong> &mdash; and the list keeps growing.
			</p>
		</header>

		<div class="overflow-hidden rounded-2xl border" style="border-color: var(--color-outline-variant); background: var(--color-surface);">
			<div class="hidden md:grid grid-cols-[88px_48px_180px_150px_1fr] gap-3 px-5 py-3" style="background: var(--color-surface-low); font-family: var(--font-sans); font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-ink);">
				<span>Cost</span>
				<span></span>
				<span>Unlock</span>
				<span>Reach</span>
				<span class="text-right">Sponsor</span>
			</div>

			{unlocks.map((u) => (
				<div
					class="grid grid-cols-[52px_1fr] md:grid-cols-[88px_48px_180px_150px_1fr] gap-3 items-center px-5 py-4"
					style={`border-top: 1px solid var(--color-outline-variant); ${u.highlight ? 'background: var(--color-surface-low);' : ''}`}
				>
					<span class="hidden md:inline" style="font-family: var(--font-sans); font-size: 14px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.02em;">
						{COST}
					</span>
					<span style="font-size: 40px; line-height: 1; text-align: center;" aria-hidden="true">{u.flag}</span>
					<div>
						<p class="md:hidden" style="font-family: var(--font-sans); font-size: 12px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.02em; margin: 0 0 2px;">
							{COST}
						</p>
						<p style="font-family: var(--font-sans); font-size: 15px; font-weight: 600; color: var(--color-ink); margin: 0;">
							{u.language}
						</p>
						{u.parenthetical && (
							<p style="font-family: var(--font-sans); font-size: 13px; color: var(--color-muted); margin: 2px 0 0;">
								{u.parenthetical}
							</p>
						)}
						<!-- Mobile: reach + pledge inline beneath the language -->
						<div class="md:hidden flex items-center justify-between gap-3 mt-2">
							<span style="font-family: var(--font-sans); font-size: 14px; font-weight: 700; color: var(--color-ink);">
								{u.reach}
								{u.country && (<a href={`/bible-in/${u.country.slug}/#translation-opportunity`} style="font-family: var(--font-sans); font-size: 12px; font-weight: 600; color: var(--color-primary); text-decoration: none; margin-left: 8px;">{u.country.label} &rarr;</a>)}
							</span>
							<a href="#" data-e="kevin" data-d="spiritmediapublishing.com" data-subj={pledgeSubject(u)} onclick={pledgeOnclick} style="font-family: var(--font-sans); font-size: 13px; font-weight: 600; color: var(--color-primary); text-decoration: none;">
								Pledge to Sponsor {u.sponsor || u.language} →
							</a>
						</div>
					</div>
					<span class="hidden md:block text-left whitespace-nowrap" style="font-family: var(--font-sans); font-size: 14px; font-weight: 700; color: var(--color-ink);">
						{u.reach}
						{u.country && (
							<a href={`/bible-in/${u.country.slug}/#translation-opportunity`} style="font-size: 12px; font-weight: 600; color: var(--color-primary); text-decoration: none; margin-left: 8px;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">
								{u.country.label} &rarr;
							</a>
						)}
					</span>
					<a
						href="#"
						data-e="kevin"
						data-d="spiritmediapublishing.com"
						data-subj={pledgeSubject(u)}
						onclick={pledgeOnclick}
						class="hidden md:block text-right"
						style="font-family: var(--font-sans); font-size: 13px; font-weight: 600; color: var(--color-primary); text-decoration: none;"
						onmouseover="this.style.textDecoration='underline'"
						onmouseout="this.style.textDecoration='none'"
					>
						Pledge to Sponsor {u.sponsor || u.language} →
					</a>
				</div>
			))}
		</div>

		<p class="text-center mt-6 text-sm" style="font-family: var(--font-sans); color: var(--color-muted);">
			Reach is the number of people who can finally read the Father&rsquo;s heart in their own tongue.
		</p>
		<div class="flex justify-center mt-5">
			<a
				href="#"
				data-e="kevin"
				data-d="spiritmediapublishing.com"
				data-subj="Pledge to Sponsor a Language — Father&rsquo;s Heart Bible"
				onclick={pledgeOnclick}
				class="inline-flex items-center px-8 py-3.5 text-base font-semibold no-underline transition-all duration-200"
				style="font-family: var(--font-sans); background-color: #FFD9E0; color: #4A4A4A; border-radius: var(--radius, 8px);"
				aria-label="Email to pledge to sponsor a language"
				onmouseover="this.style.opacity='0.9'"
				onmouseout="this.style.opacity='1'"
			>
				Pledge to Sponsor a Language
			</a>
		</div>
	</div>
</section>
