---
// Shared "country map" / language-unlock section.
// Used on /nations and /partner so the two never drift apart.
// 20 cumulative unlocks — donor goal mapped to language + reach.
interface UnlockRow {
	dollar: string;
	language: string;
	flag: string; // emoji
	parenthetical?: string;
	reach: string;
	highlight?: boolean;
}

const unlocks: UnlockRow[] = [
	{
		dollar: '$100K',
		language: 'Base English First Edition launch — 20,000 Bibles + audio',
		flag: '🇺🇸',
		reach: '1.5B',
		highlight: true,
	},
	{
		dollar: '$150K',
		language: 'Spanish',
		flag: '🇪🇸',
		parenthetical: '550M speakers',
		reach: '2.05B',
	},
	{
		dollar: '$200K',
		language: 'Portuguese',
		flag: '🇧🇷',
		parenthetical: '257M — Brazil + Lusophone Africa',
