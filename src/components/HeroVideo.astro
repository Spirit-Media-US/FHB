---
interface Props {
	videoSrc?: string;
	posterSrc?: string;
	headline?: string;
	subheadline?: string;
	ctaLabel?: string;
	ctaHref?: string;
}

const {
	videoSrc,
	posterSrc,
	headline = "A Translation That Reveals the Father's Heart",
	subheadline = 'Experience Scripture as it was always meant to be heard — intimate, personal, and alive.',
	ctaLabel = 'Download Free',
	ctaHref = '/download',
} = Astro.props;
---

<section
	class="relative flex items-center justify-center overflow-hidden min-h-[420px] md:min-h-[65vh]"
	style="background-color: var(--color-deep);"
>
	<!-- Background video -->
	{videoSrc && (
		<video
			class="absolute inset-0 w-full h-full object-cover"
			src={videoSrc}
			poster={posterSrc}
			autoplay
			muted
			loop
			playsinline
			aria-hidden="true"
		/>
	)}

	<!-- Fallback poster if no video -->
	{!videoSrc && posterSrc && (
		<img
			src={posterSrc}
			alt=""
			class="absolute inset-0 w-full h-full object-cover"
			aria-hidden="true"
		/>
	)}

	<!-- Dark overlay -->
	<div
		class="absolute inset-0"
		style="background: linear-gradient(to bottom, rgba(47,49,49,0.5) 0%, rgba(47,49,49,0.7) 100%);"
		aria-hidden="true"
	></div>

	<!-- Content -->
	<div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
		<h1
			class="text-4xl md:text-7xl font-light leading-tight mb-6 tracking-tight"
			style="font-family: var(--font-headline); color: #fff;"
		>
			{headline}
		</h1>
		{subheadline && (
			<p
				class="text-lg md:text-xl mb-10 leading-relaxed"
				style="font-family: var(--font-body); color: rgba(255,255,255,0.8);"
			>
				{subheadline}
			</p>
		)}
		<a
			href={ctaHref}
			class="inline-flex items-center px-8 py-3.5 text-sm font-semibold uppercase no-underline tracking-[0.08em] transition-all duration-200"
			style="font-family: var(--font-body); background-color: var(--color-surface-lowest); color: var(--color-primary); border-radius: 0.125rem;"
			onmouseover="this.style.opacity='0.9'"
			onmouseout="this.style.opacity='1'"
		>
			{ctaLabel}
		</a>
	</div>
</section>
