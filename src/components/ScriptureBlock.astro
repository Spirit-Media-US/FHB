---
interface Props {
	text: string;
	reference?: string;
	translation?: string;
	dark?: boolean;
}

const { text, reference, translation, dark = false } = Astro.props;
---

<div class="text-center max-w-2xl mx-auto">
	<blockquote class="m-0">
		<p
			class="text-2xl md:text-4xl font-light leading-relaxed mb-6"
			style={`font-family: var(--font-headline); color: ${dark ? 'rgba(255,255,255,0.92)' : 'var(--color-on-surface)'};`}
		>
			"{text}"
		</p>
		{reference && (
			<footer>
				<cite class="not-italic text-xs tracking-[0.15em] uppercase" style={`font-family: var(--font-body); color: ${dark ? 'rgba(255,255,255,0.45)' : 'var(--color-on-surface-variant)'};`}>
					— {reference}{translation ? ` · ${translation}` : ''}
				</cite>
			</footer>
		)}
	</blockquote>
</div>
