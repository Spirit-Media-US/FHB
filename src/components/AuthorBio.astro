---
// End-of-post author bio card. Mobile-first:
// - Mobile (<640px): stacked — photo on top, text below, both centered
// - Desktop (>=640px): photo left, text right
//
// Currently hardcoded for Kevin White (the only FHB author). When the
// author registry grows, switch on `author` and look up the matching
// entry. For non-Kevin authors, the component renders nothing (so we
// don't ship a generic placeholder card).
interface Props {
	author: string;
}
const { author } = Astro.props;

// Author registry — extend when FHB welcomes more bylines.
// `photoUrl` is a direct Sanity CDN URL; the renderer appends size + format
// params at request time. Set per-author so the leadership page's portrait
// can differ from the blog author-bio card (different framing requirements).
const AUTHORS: Record<
	string,
	{
		displayName: string;
		role: string;
		bio: string;
		photoUrl: string;
		profileUrl: string;
	}
> = {
	'Kevin White': {
		displayName: 'Kevin White',
		role: "Founder, Spirit Media Publishing · Father's Heart Bible™",
		bio: "Kevin White is leading the translation and publishing process of the Father's Heart Bible™, a translation centered on revealing God's heart as Father through every passage. He pastors readers toward the love of our Father — in plain English — and writes here about Scripture, sonship, and the modern Father-heart movement.",
		photoUrl:
			'https://cdn.sanity.io/images/rusi1hyi/production/565f785ee2ed1aa17d785c5613c640a2f44360dd-1920x1935.jpg',
		profileUrl: '/the-fathers-heart-bible/leadership/',
	},
};

const entry = AUTHORS[author];
const photoUrl = entry?.photoUrl || null;
---

{entry && (
	<section class="author-bio" aria-label={`About ${entry.displayName}`}>
		<div class="author-bio__inner">
			{photoUrl && (
				<a href={entry.profileUrl} class="author-bio__photo-link" aria-label={`Read more about ${entry.displayName}`}>
					<img
						src={`${photoUrl}?w=320&h=320&fit=crop&crop=focalpoint&auto=format`}
						alt={`Portrait of ${entry.displayName}`}
						class="author-bio__photo"
						loading="lazy"
						decoding="async"
						width="160"
						height="160"
					/>
				</a>
			)}
			<div class="author-bio__text">
				<p class="author-bio__label">About the author</p>
				<h3 class="author-bio__name">
					<a href={entry.profileUrl}>{entry.displayName}</a>
				</h3>
				<p class="author-bio__role">{entry.role}</p>
				<p class="author-bio__copy">{entry.bio}</p>
			</div>
		</div>
	</section>
)}

<style>
	.author-bio {
		margin: 3rem 0 1rem;
		padding: 2rem 1.5rem;
		background-color: var(--color-surface-low, #fbf7f8);
		border-top: 1px solid var(--color-hairline, #ead7dd);
		border-bottom: 1px solid var(--color-hairline, #ead7dd);
	}

	.author-bio__inner {
		max-width: 48rem;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.25rem;
		text-align: center;
	}

	.author-bio__photo {
		width: 96px;
		height: 96px;
		border-radius: 50%;
		object-fit: cover;
		display: block;
	}

	.author-bio__photo-link {
		display: inline-block;
		line-height: 0;
	}

	.author-bio__label {
		margin: 0;
		font-family: var(--font-sans, system-ui);
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-muted, #6b5560);
	}

	.author-bio__name {
		margin: 0.25rem 0 0.125rem;
		font-family: var(--font-serif, Georgia, serif);
		font-size: 1.5rem;
		font-weight: 500;
		color: var(--color-ink, #1a1a1a);
	}

	.author-bio__name a {
		color: inherit;
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s;
	}

	.author-bio__name a:hover {
		border-color: var(--color-brand, #a04060);
	}

	.author-bio__role {
		margin: 0 0 0.75rem;
		font-family: var(--font-sans, system-ui);
		font-size: 0.85rem;
		color: var(--color-muted, #6b5560);
		max-width: 32rem;
	}

	.author-bio__copy {
		margin: 0;
		font-family: var(--font-serif, Georgia, serif);
		font-size: 1rem;
		line-height: 1.6;
		color: var(--color-ink, #1a1a1a);
		max-width: 36rem;
	}

	@media (min-width: 640px) {
		.author-bio {
			padding: 2.5rem 2rem;
		}

		.author-bio__inner {
			flex-direction: row;
			align-items: center;
			text-align: left;
			gap: 2rem;
		}

		.author-bio__photo {
			width: 128px;
			height: 128px;
			flex-shrink: 0;
		}
	}
</style>
