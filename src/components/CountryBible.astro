---
// CountryBible — reusable template for the /bible-in/<country> hub.
// Each country page (src/pages/bible-in/<slug>.astro) supplies a data object;
// this component renders the full SEO/AEO layout: hero (flag + country colors),
// direct-answer paragraph, key takeaway, "at a glance" facts, faith/Bible state,
// "why FHB" blocks, scripture sampler, keep-reading links, FAQ, and read-first
// CTAs. Architecture rules (read-first CTA, English-first) live in
// memory/project_fhb_country_pages.md. Mirror the /verses + /guides patterns.
import { NATIONS } from '../data/nations';
import Layout from '../layouts/Layout.astro';

export interface CountryStat {
	label: string;
	value: string;
}
export interface CountrySource {
	label: string;
	url: string;
}
export interface CountryVerse {
	ref: string;
	slug: string; // /read book slug
	ch: number;
	text: string;
}
export interface CountryFaq {
	question: string;
	answer: string;
}
export interface CountryWhyBlock {
	heading: string;
	bodyHtml: string;
}
export interface CountryLanguage {
	language: string;
	speakers: string; // e.g. "97 million"
	status: 'Available' | 'On the roadmap' | 'Translation needed';
}
export interface CountryKnownFor {
	label: string;
	text: string;
}
export interface CountryPhoto {
	src: string; // Sanity CDN base URL
	alt: string;
}

export interface Props {
	slug: string;
	country: string;
	flag: string; // emoji flag, e.g. "🇮🇳"
	flagImg?: string; // flag image URL (e.g. flagcdn) for national-pride display
	countryWikipedia?: string; // Wikipedia URL → schema sameAs for the Country node (AEO entity binding)
	lastUpdated?: string; // human display, e.g. "June 2026" (freshness signal)
	lastUpdatedIso?: string; // ISO date, e.g. "2026-06-13" → schema dateModified
	colorPrimary: string; // hex, e.g. "#FF9933" (saffron)
	colorSecondary: string; // hex, e.g. "#138808" (green)
	colorAccent?: string; // third flag color for dramatic section + bottom CTA (e.g. navy). Default FHB deep.
	tintWarm?: string; // light shade of primary (e.g. light saffron) for section/card fills
	tintCool?: string; // light shade of secondary (e.g. light green)
	tintBlue?: string; // light shade of accent (e.g. light blue)
	title: string; // <title>
	description: string; // meta description
	h1: string;
	heroSubhead: string;
	heroBase: string; // Sanity CDN base
	heroAlt: string;
	directAnswerHtml: string;
	keyTakeaway: string;
	glanceIntroHtml: string;
	stats: CountryStat[];
	knownForHeading?: string;
	knownForIntroHtml?: string;
	knownFor?: CountryKnownFor[];
	gallery?: CountryPhoto[];
	galleryCreditHtml?: string;
	galleryBottom?: CountryPhoto[];
	galleryBottomCreditHtml?: string;
	faithHeading: string;
	faithBodyHtml: string; // multi-paragraph allowed
	sources: CountrySource[];
	faithsHeading?: string;
	faithsIntroHtml?: string;
	faithsBlocks?: CountryWhyBlock[];
	painsHeading?: string;
	painsIntroHtml?: string;
	painStats?: CountryStat[];
	painsBodyHtml?: string;
	painsSources?: CountrySource[];
	whyHeading: string;
	whyBlocks: CountryWhyBlock[];
	globalHeading?: string;
	globalIntroHtml?: string;
	globalStats?: CountryStat[];
	globalBlocks?: CountryWhyBlock[];
	resourcesHeading?: string;
	resourcesIntroHtml?: string;
	resources?: CountrySource[];
	opportunityHeading?: string;
	opportunityIntroHtml?: string;
	languages?: CountryLanguage[];
	verses: CountryVerse[];
	keepReadingHtml: string;
	faqs: CountryFaq[];
	ctaMidHeading: string;
	ctaMidBodyHtml: string;
	ctaBottomBodyHtml: string;
}

const {
	slug,
	country,
	flag,
	flagImg,
	countryWikipedia,
	lastUpdated,
	lastUpdatedIso,
	colorPrimary,
	colorSecondary,
	colorAccent = 'var(--color-deep)',
	tintWarm = 'var(--color-surface-low)',
	tintCool = 'var(--color-surface)',
	tintBlue = 'var(--color-surface-low)',
	title,
	description,
	h1,
	heroSubhead,
	heroBase,
	heroAlt,
	directAnswerHtml,
	keyTakeaway,
	glanceIntroHtml,
	stats,
	knownForHeading,
	knownForIntroHtml,
	knownFor = [],
	gallery = [],
	galleryCreditHtml,
	galleryBottom = [],
	galleryBottomCreditHtml,
	faithHeading,
	faithBodyHtml,
	sources,
	faithsHeading,
	faithsIntroHtml,
	faithsBlocks = [],
	painsHeading,
	painsIntroHtml,
	painStats = [],
	painsBodyHtml,
	painsSources = [],
	whyHeading,
	whyBlocks,
	globalHeading,
	globalIntroHtml,
	globalStats = [],
	globalBlocks = [],
	resourcesHeading,
	resourcesIntroHtml,
	resources = [],
	opportunityHeading,
	opportunityIntroHtml,
	languages = [],
	verses,
	keepReadingHtml,
	faqs,
	ctaMidHeading,
	ctaMidBodyHtml,
	ctaBottomBodyHtml,
} = Astro.props;

const PAGE_URL = `https://fathersheartbible.com/bible-in/${slug}/`;
const otherNations = NATIONS.filter((n) => n.slug !== slug);
const HERO_IMG = `${heroBase}?w=1400&h=560&fit=crop&crop=entropy&fm=webp&q=72`;
const OG_IMG = `${heroBase}?w=1200&h=630&fit=crop&crop=entropy&fm=jpg&q=80`;

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://fathersheartbible.com/' },
		{
			'@type': 'ListItem',
			position: 2,
			name: 'The Bible Around the World',
			item: 'https://fathersheartbible.com/bible-in/',
		},
		{ '@type': 'ListItem', position: 3, name: country, item: PAGE_URL },
	],
};
const countryNode = {
	'@type': 'Country',
	name: country,
	...(countryWikipedia ? { sameAs: countryWikipedia } : {}),
};
const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: h1,
	description,
	url: PAGE_URL,
	inLanguage: 'en',
	...(lastUpdatedIso ? { dateModified: lastUpdatedIso } : {}),
	about: countryNode,
	spatialCoverage: countryNode,
	isPartOf: {
		'@type': 'WebSite',
		name: "Father's Heart Bible™",
		url: 'https://fathersheartbible.com/',
	},
};
const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((f) => ({
		'@type': 'Question',
		name: f.question,
		acceptedAnswer: { '@type': 'Answer', text: f.answer },
	})),
};
const jsonLd = [collectionSchema, breadcrumbSchema, faqSchema];
---

<Layout
	title={title}
	description={description}
	image={OG_IMG}
	imageAlt={heroAlt}
	darkHero={true}
	jsonLd={jsonLd}
	preloadImageMobile={HERO_IMG.replace('w=1400', 'w=640')}
	preloadImageDesktop={HERO_IMG}
>
	<main id="main-content">
		<!-- Hero -->
		<section class="relative w-full overflow-hidden min-h-[560px] lg:min-h-[calc(46vh_+_2in)]">
			<img src={HERO_IMG} srcset={`${HERO_IMG.replace('w=1400', 'w=640')} 640w, ${HERO_IMG} 1400w`} sizes="(max-width: 1023px) 640px, 1400px" alt={heroAlt} class="absolute inset-0 w-full h-full object-cover" style="object-position: center top;" fetchpriority="high" decoding="async" />
			<div class="absolute inset-0 z-10" style="background: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.32) 45%, rgba(0,0,0,0.4) 100%);" aria-hidden="true"></div>
			<div class="absolute inset-x-0 bottom-0 z-20 px-6 pb-10 lg:px-8 lg:pb-14">
				<div class="mx-auto max-w-4xl">
					<p class="text-sm font-semibold uppercase tracking-widest mb-2" style="color: #fff; font-family: var(--font-sans);">The Bible Around the World</p>
					<h1 class="text-4xl md:text-5xl lg:text-6xl font-light leading-tight" style="font-family: var(--font-serif); color: #fff;">{h1}{flagImg && (<img src={flagImg} alt={`Flag of ${country}`} class="inline-block align-baseline" style="height: 0.62em; width: auto; margin-left: 0.3em; border: 2px solid rgba(255,255,255,0.92); border-radius: 3px; box-shadow: 0 3px 14px rgba(0,0,0,0.45);" loading="eager" decoding="async" />)}</h1>
					<p class="mt-4 max-w-2xl text-lg leading-relaxed" style="font-family: var(--font-sans); color: rgba(255,255,255,0.92);">{heroSubhead}</p>
				</div>
			</div>
			<div class="absolute inset-x-0 bottom-0 z-30 h-1.5" style={`background: linear-gradient(to right, ${colorPrimary} 0%, ${colorPrimary} 50%, ${colorSecondary} 50%, ${colorSecondary} 100%);`} aria-hidden="true"></div>
		</section>

		<!-- Breadcrumb + direct answer -->
		<section class="px-6 pt-9 pb-2 lg:px-8" style="background-color: var(--color-surface-low);">
			<div class="mx-auto max-w-3xl">
				<nav aria-label="Breadcrumb" class="mb-6 text-sm" style="color: var(--color-muted); font-family: var(--font-sans);">
					<a href="/" class="hover:underline">Home</a><span class="px-1.5" aria-hidden="true">/</span>
					<a href="/bible-in/" class="hover:underline">The Bible Around the World</a><span class="px-1.5" aria-hidden="true">/</span>
					<span class="inline-flex items-center gap-1.5" style="color: var(--color-ink);">{flagImg && <img src={flagImg} alt="" width="18" height="12" class="rounded-[2px]" style="width: 18px; height: auto; border: 1px solid var(--color-hairline);" loading="lazy" decoding="async" aria-hidden="true" />}{country}</span>
				</nav>
				<p class="text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={directAnswerHtml}></p>
				{lastUpdated && (
					<p class="mt-3 text-xs" style="font-family: var(--font-sans); color: var(--color-muted);">Last updated {lastUpdated}</p>
				)}
				<div class="mt-6 rounded-xl px-5 py-4" style={`background-color: ${tintWarm}; border-left: 4px solid ${colorPrimary};`}>
					<p class="text-base font-semibold leading-relaxed" style="font-family: var(--font-sans); color: var(--color-ink);"><span class="font-bold uppercase text-sm tracking-widest mr-2" style="color: var(--color-brand);">Key takeaway</span>{keyTakeaway}</p>
				</div>
			</div>
		</section>

		<!-- At a glance -->
		<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface);">
			<div class="mx-auto max-w-4xl">
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{country} at a glance</h2>
				<p class="mt-4 max-w-3xl text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={glanceIntroHtml}></p>
				<dl class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-5">
					{stats.map((s) => (
						<div class="rounded-2xl p-5" style={`background-color: ${tintWarm}; border: 1px solid rgba(0,0,0,0.06);`}>
							<dt class="text-xs font-semibold uppercase tracking-widest" style="color: var(--color-muted); font-family: var(--font-sans);">{s.label}</dt>
							<dd class="mt-2 text-2xl font-medium leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{s.value}</dd>
						</div>
					))}
				</dl>
			</div>
		</section>

		<!-- What the country is known for (national pride) -->
		{knownFor.length > 0 && (
			<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface-low);">
				<div class="mx-auto max-w-4xl">
					<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{knownForHeading || `What ${country} is known for`}</h2>
					{knownForIntroHtml && (
						<p class="mt-4 max-w-3xl text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={knownForIntroHtml}></p>
					)}
					<div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-5">
						{knownFor.map((k) => (
							<div class="rounded-2xl p-5" style={`background-color: ${tintCool}; border: 1px solid rgba(0,0,0,0.06);`}>
								<h3 class="text-lg font-medium leading-snug" style="font-family: var(--font-serif); color: var(--color-ink);">{k.label}</h3>
								<p class="mt-2 text-base leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">{k.text}</p>
							</div>
						))}
					</div>
				</div>
			</section>
		)}

		<!-- Photo gallery row (before Faith section) -->
		{gallery.length > 0 && (
			<section class="px-6 pt-6 pb-10 lg:px-8 lg:pb-14" style="background-color: var(--color-surface-low);">
				<div class="mx-auto max-w-5xl">
					<div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
						{gallery.map((p) => (
							<img src={`${p.src}?w=600&h=420&fit=crop&crop=entropy&fm=webp&q=70`} srcset={`${p.src}?w=400&h=280&fit=crop&crop=entropy&fm=webp&q=68 400w, ${p.src}?w=600&h=420&fit=crop&crop=entropy&fm=webp&q=70 600w`} sizes="(max-width: 767px) 45vw, 23vw" alt={p.alt} width="600" height="420" class="w-full h-36 md:h-48 object-cover rounded-xl" style="border: 1px solid rgba(0,0,0,0.06);" loading="lazy" decoding="async" />
						))}
					</div>
					{galleryCreditHtml && (
						<p class="mt-3 text-xs" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={galleryCreditHtml}></p>
					)}
				</div>
			</section>
		)}

		<!-- Faith & the Bible -->
		<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface);">
			<div class="mx-auto max-w-3xl">
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{faithHeading}</h2>
				<div class="mt-5 space-y-5 text-base lg:text-lg leading-relaxed prose-fhb" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={faithBodyHtml}></div>
				{sources.length > 0 && (
					<p class="mt-6 text-sm" style="font-family: var(--font-sans); color: var(--color-muted);">
						Sources: {sources.map((s, i) => (<>{i > 0 && <span aria-hidden="true"> · </span>}<a href={s.url} target="_blank" rel="noopener noreferrer" style="color: var(--color-brand);" class="hover:underline">{s.label}</a></>))}
					</p>
				)}
			</div>
		</section>

		<!-- What pains the country (the ache) -->
		{(painsBodyHtml || painStats.length > 0) && (
			<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface-low);">
				<div class="mx-auto max-w-3xl">
					<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{painsHeading || `What pains ${country}`}</h2>
					{painsIntroHtml && (
						<p class="mt-4 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={painsIntroHtml}></p>
					)}
					{painStats.length > 0 && (
						<dl class="mt-7 grid grid-cols-2 md:grid-cols-3 gap-5">
							{painStats.map((s) => (
								<div class="rounded-2xl p-5" style={`background-color: ${tintBlue}; border: 1px solid rgba(0,0,0,0.06);`}>
									<dt class="text-2xl font-medium leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{s.value}</dt>
									<dd class="mt-2 text-sm leading-snug" style="font-family: var(--font-sans); color: var(--color-muted);">{s.label}</dd>
								</div>
							))}
						</dl>
					)}
					{painsBodyHtml && (
						<div class="mt-6 space-y-5 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={painsBodyHtml}></div>
					)}
					{painsSources.length > 0 && (
						<p class="mt-6 text-sm" style="font-family: var(--font-sans); color: var(--color-muted);">
							Sources: {painsSources.map((s, i) => (<>{i > 0 && <span aria-hidden="true"> · </span>}<a href={s.url} target="_blank" rel="noopener noreferrer" style="color: var(--color-brand);" class="hover:underline">{s.label}</a></>))}
						</p>
					)}
				</div>
			</section>
		)}

		<!-- How "our Father" meets the country (world religions + hope).
		     AUTHORING RULE: each faithsBlock must answer a specific ache from the
		     "What pains <country>" section above (debt→home-with-no-ledger,
		     despair→hope, isolation→belonging) AND the country's dominant
		     faith/worldview. Pick the framing variant per country (other-faith /
		     nominal-Christian / secular); never reuse India's Hindu-contrast verbatim. -->
		{faithsBlocks.length > 0 && (
			<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface);">
				<div class="mx-auto max-w-3xl">
					<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{faithsHeading || `What "our Father" offers ${country}`}</h2>
					{faithsIntroHtml && (
						<p class="mt-4 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={faithsIntroHtml}></p>
					)}
					<div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-5">
						{faithsBlocks.map((b) => (
							<div class="rounded-2xl p-5" style={`background-color: ${tintCool}; border: 1px solid rgba(0,0,0,0.06); border-left: 4px solid ${colorSecondary};`}>
								<h3 class="text-xl font-medium leading-snug" style="font-family: var(--font-serif); color: var(--color-ink);">{b.heading}</h3>
								<p class="mt-2 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={b.bodyHtml}></p>
							</div>
						))}
					</div>
				</div>
			</section>
		)}

		<!-- Why FHB -->
		<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface-low);">
			<div class="mx-auto max-w-3xl">
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{whyHeading}</h2>
				<div class="mt-8 space-y-8">
					{whyBlocks.map((b) => (
						<div>
							<h3 class="text-xl font-medium leading-snug" style="font-family: var(--font-serif); color: var(--color-ink);">{b.heading}</h3>
							<p class="mt-3 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={b.bodyHtml}></p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Translation opportunity (languages + populations) -->
		{languages.length > 0 && (
			<section id="translation-opportunity" class="px-6 py-12 lg:px-8 lg:py-16 scroll-mt-24" style={`background-color: ${tintBlue};`}>
				<div class="mx-auto max-w-3xl">
					<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{opportunityHeading || `The opportunity in ${country}`}</h2>
					{opportunityIntroHtml && (
						<p class="mt-4 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={opportunityIntroHtml}></p>
					)}
					<ul class="mt-7 divide-y" style="border-top: 1px solid var(--color-hairline); border-bottom: 1px solid var(--color-hairline);">
						{languages.map((l) => {
							const tone =
								l.status === 'Available'
									? '#138808'
									: l.status === 'On the roadmap'
										? '#C77B0E'
										: 'var(--color-muted)';
							return (
								<li class="flex items-center justify-between gap-4 py-3.5" style="border-color: var(--color-hairline);">
									<div>
										<span class="text-lg font-medium" style="font-family: var(--font-serif); color: var(--color-ink);">{l.language}</span>
										<span class="ml-2 text-sm" style="font-family: var(--font-sans); color: var(--color-muted);">{l.speakers} speakers</span>
									</div>
									<span class="shrink-0 text-xs font-semibold uppercase tracking-wide rounded-full px-3 py-1" style={`color: ${tone}; border: 1px solid ${tone};`}>{l.status}</span>
								</li>
							);
						})}
					</ul>
					<p class="mt-6 text-sm leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">Every language is a door. If you feel called to help open one, you can <a href="/partner" style="color: var(--color-brand);" class="hover:underline">sponsor a translation</a> &mdash; or simply <a href="https://fathersheartbible.com/read" style="color: var(--color-brand);" class="hover:underline">start reading the editions available today</a>.</p>
				</div>
			</section>
		)}

		<!-- Country and the world (diaspora + language spread + strategic role +
		     how this nation carries FHB out). Shows global/strategic significance. -->
		{(globalBlocks.length > 0 || globalStats.length > 0) && (
			<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface);">
				<div class="mx-auto max-w-4xl">
					<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{globalHeading || `${country} and the world`}</h2>
					{globalIntroHtml && (
						<p class="mt-4 max-w-3xl text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={globalIntroHtml}></p>
					)}
					{globalStats.length > 0 && (
						<dl class="mt-7 grid grid-cols-2 md:grid-cols-3 gap-5">
							{globalStats.map((s) => (
								<div class="rounded-2xl p-5" style={`background-color: ${tintWarm}; border: 1px solid rgba(0,0,0,0.06);`}>
									<dt class="text-2xl font-medium leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{s.value}</dt>
									<dd class="mt-2 text-sm leading-snug" style="font-family: var(--font-sans); color: var(--color-muted);">{s.label}</dd>
								</div>
							))}
						</dl>
					)}
					{globalBlocks.length > 0 && (
						<div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-5">
							{globalBlocks.map((b) => (
								<div class="rounded-2xl p-5" style={`background-color: ${tintBlue}; border: 1px solid rgba(0,0,0,0.06); border-left: 4px solid ${colorSecondary};`}>
									<h3 class="text-lg font-medium leading-snug" style="font-family: var(--font-serif); color: var(--color-ink);">{b.heading}</h3>
									<p class="mt-2 text-base leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={b.bodyHtml}></p>
								</div>
							))}
						</div>
					)}
				</div>
			</section>
		)}

		<!-- Scripture sampler -->
		<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface-low);">
			<div class="mx-auto max-w-3xl">
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">Hear the Father&rsquo;s voice</h2>
				<p class="mt-4 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">A few of the most-read passages in the world, in the Father&rsquo;s Heart Bible&trade; &mdash; tap any reference to read and listen free.</p>
				<div class="mt-7 space-y-5">
					{verses.map((v) => (
						<a href={`https://fathersheartbible.com/read/${v.slug}/${v.ch}`} class="block rounded-2xl p-5 no-underline transition-opacity hover:opacity-90" style={`background-color: ${tintWarm}; border: 1px solid rgba(0,0,0,0.06);`}>
							<p class="text-lg leading-relaxed" style="font-family: var(--font-serif); color: var(--color-ink);">&ldquo;{v.text}&rdquo;</p>
							<span class="inline-flex items-center gap-1.5 mt-3 text-sm font-semibold" style="color: var(--color-brand); font-family: var(--font-sans);">{v.ref}<span aria-hidden="true">&rarr;</span></span>
						</a>
					))}
				</div>
			</div>
		</section>

		<!-- Mid CTA (read-first) — cream section with a saffron button. -->
		<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface);">
			<div class="mx-auto max-w-2xl text-center">
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{ctaMidHeading}</h2>
				<p class="mt-4 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={ctaMidBodyHtml}></p>
				<a href="https://fathersheartbible.com/read" class="inline-flex items-center gap-2 mt-6 px-8 py-3.5 text-base font-semibold no-underline transition-all duration-200" style="background-color: #FFD9E0; color: #4A4A4A; font-family: var(--font-sans);">Read FHB free<span aria-hidden="true">&rarr;</span></a>
			</div>
		</section>

		<!-- Keep reading -->
		<section class="px-6 py-12 lg:px-8 lg:py-14" style="background-color: var(--color-surface);">
			<div class="mx-auto max-w-3xl">
				<h2 class="text-xl md:text-2xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">Keep reading</h2>
				<p class="mt-4 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={keepReadingHtml}></p>
			</div>
		</section>

		<!-- Resources (authority links) -->
		{resources.length > 0 && (
			<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface-low);">
				<div class="mx-auto max-w-3xl">
					<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{resourcesHeading || `Learn more about ${country}`}</h2>
					{resourcesIntroHtml && (
						<p class="mt-4 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={resourcesIntroHtml}></p>
					)}
					<ul class="mt-7 grid grid-cols-1 md:grid-cols-2 gap-3">
						{resources.map((r) => (
							<li>
								<a href={r.url} target="_blank" rel="noopener noreferrer" class="flex items-center justify-between gap-3 rounded-xl px-5 py-4 no-underline transition-opacity hover:opacity-90" style={`background-color: ${tintCool}; border: 1px solid rgba(0,0,0,0.06);`}>
									<span class="text-base font-medium leading-snug" style="font-family: var(--font-sans); color: var(--color-ink);">{r.label}</span>
									<span class="shrink-0 text-sm font-semibold" style="color: var(--color-brand);" aria-hidden="true">&nearr;</span>
								</a>
							</li>
						))}
					</ul>
				</div>
			</section>
		)}

		<!-- FAQ -->
		<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface);">
			<div class="mx-auto max-w-3xl">
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">Frequently asked questions</h2>
				<div class="mt-7 space-y-4">
					{faqs.map((f) => (
						<details class="rounded-2xl px-5 py-4" style={`background-color: ${tintWarm}; border: 1px solid rgba(0,0,0,0.06);`}>
							<summary class="cursor-pointer text-lg font-medium leading-snug" style="font-family: var(--font-serif); color: var(--color-ink);">{f.question}</summary>
							<p class="mt-3 text-base leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">{f.answer}</p>
						</details>
					))}
				</div>
			</div>
		</section>

		<!-- Photo gallery row (before bottom CTA) -->
		{galleryBottom.length > 0 && (
			<section class="px-6 pt-10 pb-4 lg:px-8 lg:pt-14" style="background-color: var(--color-surface-low);">
				<div class="mx-auto max-w-5xl">
					<div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
						{galleryBottom.map((p) => (
							<img src={`${p.src}?w=600&h=420&fit=crop&crop=entropy&fm=webp&q=70`} srcset={`${p.src}?w=400&h=280&fit=crop&crop=entropy&fm=webp&q=68 400w, ${p.src}?w=600&h=420&fit=crop&crop=entropy&fm=webp&q=70 600w`} sizes="(max-width: 767px) 45vw, 23vw" alt={p.alt} width="600" height="420" class="w-full h-36 md:h-48 object-cover rounded-xl" style="border: 1px solid rgba(0,0,0,0.06);" loading="lazy" decoding="async" />
						))}
					</div>
					{galleryBottomCreditHtml && (
						<p class="mt-3 text-xs" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={galleryBottomCreditHtml}></p>
					)}
				</div>
			</section>
		)}

		<!-- Bottom CTA (read-first) -->
		<section class="px-6 py-14 lg:px-8 lg:py-20" style="background-color: var(--color-surface-low);">
			<div class="mx-auto max-w-2xl text-center">
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">Read the Father&rsquo;s Heart Bible&trade; free</h2>
				<p class="mt-4 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={ctaBottomBodyHtml}></p>
				<a href="https://fathersheartbible.com/read" class="inline-flex items-center gap-2 mt-6 px-8 py-3.5 text-base font-semibold no-underline transition-all duration-200" style="background-color: #FFD9E0; color: #4A4A4A; font-family: var(--font-sans);">Start reading<span aria-hidden="true">&rarr;</span></a>
				<p class="mt-6 text-sm" style="font-family: var(--font-sans); color: var(--color-muted);">Believe in the mission? <a href="/partner" style="color: var(--color-brand);" class="hover:underline">Help take it to the nations &rarr;</a></p>
			</div>
		</section>

		<!-- Footnote (above the shared global footer): country-hub discoverability + cross-links -->
		<section class="px-6 py-6 lg:px-8" style="background-color: var(--color-surface); border-top: 1px solid var(--color-hairline);">
			<div class="mx-auto max-w-4xl text-center">
				<p class="text-xs leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">
					<span class="font-semibold" style="color: var(--color-ink);">The Father&rsquo;s Heart Bible&trade; around the world</span> &mdash; read free online, country by country.
					{otherNations.length > 0 && (
						<span>{' '}Also explore: {otherNations.map((n, i) => (<>{i > 0 && <span aria-hidden="true"> &middot; </span>}<a href={`/bible-in/${n.slug}/`} style="color: var(--color-brand);" class="hover:underline">{n.country}</a></>))}.</span>
					)}
					{' '}<a href="/bible-in/" style="color: var(--color-brand);" class="hover:underline font-semibold">Browse all nations &rarr;</a>
				</p>
			</div>
		</section>
	</main>
</Layout>
