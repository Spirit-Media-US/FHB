---
import { previewsForLanguages } from '../data/translation-previews';
import Layout from '../layouts/Layout.astro';
// CountryBible — reusable template for the /bible-in/<country> hub.
// Each country page (src/pages/bible-in/<slug>.astro) supplies a data object;
// this component renders the full SEO/AEO layout: hero (flag + country colors),
// direct-answer paragraph, key takeaway, "at a glance" facts, faith/Bible state,
// "why FHB" blocks, scripture sampler, keep-reading links, FAQ, and read-first
// CTAs. Architecture rules (read-first CTA, English-first) live in
// memory/project_fhb_country_pages.md. Mirror the /verses + /guides patterns.
import AuthorBio from './AuthorBio.astro';
import TranslationPreview from './TranslationPreview.astro';

export interface CountryStat {
	label: string;
	value: string;
}
export interface CountrySource {
	label: string;
	url: string;
}
export interface CountryVerse {
	ref: string;
	slug: string; // /read book slug
	ch: number;
	text: string;
}
export interface CountryFaq {
	question: string;
	answer: string;
}
export interface CountryWhyBlock {
	heading: string;
	bodyHtml: string;
}
export interface CountryLanguage {
	language: string;
	speakers: string; // e.g. "97 million"
	status: 'Available' | 'On the roadmap' | 'Translation needed';
}
export interface CountryKnownFor {
	label: string;
	text: string;
}
export interface CountryPhoto {
	src: string; // Sanity CDN base URL
	alt: string;
}

export interface Props {
	slug: string;
	country: string;
	flag: string; // emoji flag, e.g. "🇮🇳"
	flagImg?: string; // flag image URL (e.g. flagcdn) for national-pride display
	countryWikipedia?: string; // Wikipedia URL → schema sameAs for the Country node (AEO entity binding)
	lastUpdated?: string; // human display, e.g. "June 2026" (freshness signal)
	lastUpdatedIso?: string; // ISO date, e.g. "2026-06-13" → schema dateModified
	colorPrimary: string; // hex, e.g. "#FF9933" (saffron)
	colorSecondary: string; // hex, e.g. "#138808" (green)
	colorAccent?: string; // third flag color for dramatic section + bottom CTA (e.g. navy). Default FHB deep.
	tintWarm?: string; // light shade of primary (e.g. light saffron) for section/card fills
	tintCool?: string; // light shade of secondary (e.g. light green)
	tintBlue?: string; // light shade of accent (e.g. light blue)
	title: string; // <title>
	description: string; // meta description
	h1: string;
	heroSubhead: string;
	heroBase: string; // Sanity CDN base
	heroAlt: string;
	// Sanity crop mode for the hero (default 'entropy'). Use a focal point when
	// entropy picks the wrong region, e.g. 'focalpoint&fp-x=0.49&fp-y=0.3'.
	heroCrop?: string;
	// Optional Sanity brightness adjustment for the hero (-100..100). Positive
	// lightens a too-dark hero image, e.g. heroBrightness={18}.
	heroBrightness?: number;
	directAnswerHtml: string;
	keyTakeaway: string;
	glanceIntroHtml: string;
	stats: CountryStat[];
	knownForHeading?: string;
	knownForIntroHtml?: string;
	knownFor?: CountryKnownFor[];
	gallery?: CountryPhoto[];
	galleryCreditHtml?: string;
	galleryBottom?: CountryPhoto[];
	galleryBottomCreditHtml?: string;
	faithHeading: string;
	faithBodyHtml: string; // multi-paragraph allowed
	sources: CountrySource[];
	faithsHeading?: string;
	faithsIntroHtml?: string;
	faithsBlocks?: CountryWhyBlock[];
	painsHeading?: string;
	painsIntroHtml?: string;
	painStats?: CountryStat[];
	painsBodyHtml?: string;
	painsSources?: CountrySource[];
	whyHeading: string;
	whyBlocks: CountryWhyBlock[];
	globalHeading?: string;
	globalIntroHtml?: string;
	globalStats?: CountryStat[];
	globalBlocks?: CountryWhyBlock[];
	wordHeading?: string; // "His Word will not return void" promise section
	wordBodyHtml?: string;
	resourcesHeading?: string;
	resourcesIntroHtml?: string;
	resources?: CountrySource[];
	opportunityHeading?: string;
	opportunityIntroHtml?: string;
	languages?: CountryLanguage[];
	// Side-by-side FHB-English | target-language Scripture previews (Gen 1 / John 3 etc.)
	translationPreviews?: any[];
	// Optional: override the featured $50,000 sponsor cards with explicit items
	// (e.g. English print + ComfortLeather™ on the USA page, where the language
	// is already free to READ online but PUBLISHING it still needs sponsorship).
	// When set, all roadmap/needed languages drop to "Also available" below.
	// `reach` (optional) drives the cost-per-reader math when `speakers` isn't a
	// number (e.g. ComfortLeather™ "premium keepsake" still reaches 1.5B readers).
	sponsorFeatured?: { label: string; speakers: string; note?: string; reach?: string }[];
	sponsorIntroHtml?: string;
	sponsorVisionHtml?: string;
	verses: CountryVerse[];
	keepReadingHtml: string;
	faqs: CountryFaq[];
	ctaMidHeading: string;
	ctaMidBodyHtml: string;
	ctaBottomBodyHtml: string;
}

const {
	slug,
	country,
	flag,
	flagImg,
	countryWikipedia,
	lastUpdated,
	lastUpdatedIso,
	colorPrimary,
	colorSecondary,
	colorAccent = 'var(--color-deep)',
	tintWarm = 'var(--color-surface-low)',
	tintCool = 'var(--color-surface)',
	tintBlue = 'var(--color-surface-low)',
	title,
	description,
	h1,
	heroSubhead,
	heroBase,
	heroAlt,
	heroCrop = 'entropy',
	heroBrightness,
	directAnswerHtml,
	keyTakeaway,
	glanceIntroHtml,
	stats,
	knownForHeading,
	knownForIntroHtml,
	knownFor = [],
	gallery = [],
	galleryCreditHtml,
	galleryBottom = [],
	galleryBottomCreditHtml,
	faithHeading,
	faithBodyHtml,
	sources,
	faithsHeading,
	faithsIntroHtml,
	faithsBlocks = [],
	painsHeading,
	painsIntroHtml,
	painStats = [],
	painsBodyHtml,
	painsSources = [],
	whyHeading,
	whyBlocks,
	globalHeading,
	globalIntroHtml,
	globalStats = [],
	globalBlocks = [],
	wordHeading,
	wordBodyHtml,
	resourcesHeading,
	resourcesIntroHtml,
	resources = [],
	opportunityHeading,
	opportunityIntroHtml,
	languages = [],
	translationPreviews = [],
	sponsorFeatured,
	sponsorIntroHtml,
	sponsorVisionHtml,
	verses,
	keepReadingHtml,
	faqs,
	ctaMidHeading,
	ctaMidBodyHtml,
	ctaBottomBodyHtml,
} = Astro.props;

// Previews: explicit prop wins; otherwise auto-derive from this country's language list.
const _autoPreviews = previewsForLanguages((languages || []).map((l) => l.language));
const _previews =
	translationPreviews && translationPreviews.length ? translationPreviews : _autoPreviews;

const PAGE_URL = `https://fathersheartbible.com/bible-in/${slug}/`;

// --- Sponsor-a-translation maths (bottom section) ---
// Each language unlocks for a one-time $50,000 (translation + print + digital +
// audio). Cost-per-reader = $50,000 / speakers, parsed from each language's
// `speakers` string ("550 million", "1.7 million"). Available editions skipped.
const TRANSLATION_COST = 50000;
function parseReaders(s: string): number | null {
	const m = (s || '').match(/([\d.]+)\s*(billion|million)/i);
	if (m) return parseFloat(m[1]) * (m[2].toLowerCase() === 'billion' ? 1e9 : 1e6);
	const digits = (s || '').replace(/[^\d]/g, '');
	return digits ? parseInt(digits, 10) : null;
}
function perReaderLabel(readers: number): string {
	const cents = (TRANSLATION_COST / readers) * 100;
	if (cents < 0.01) return 'less than 0.01¢ per reader';
	if (cents < 1) return `${cents.toFixed(2)}¢ per reader`;
	if (cents < 10) return `${cents.toFixed(1)}¢ per reader`;
	if (cents < 100) return `${Math.round(cents)}¢ per reader`;
	return `$${(cents / 100).toFixed(2)} per reader`;
}
const sponsorLangs = languages
	.filter((l) => l.status !== 'Available')
	.map((l) => ({ ...l, readers: parseReaders(l.speakers) }))
	.filter((l): l is typeof l & { readers: number } => l.readers != null);
const primaryRoadmapLang =
	languages.find((l) => l.status === 'On the roadmap')?.language || country;
// Feature the top/roadmap language(s); smaller "needed" languages are Phase 2.
const featuredSponsor = sponsorLangs.filter((l) => l.status === 'On the roadmap');
const featured = featuredSponsor.length ? featuredSponsor : sponsorLangs;
const phase2 = featuredSponsor.length
	? sponsorLangs.filter((l) => l.status === 'Translation needed')
	: [];
// Explicit featured cards override (USA: English print + ComfortLeather™).
const hasCustomFeatured = !!(sponsorFeatured && sponsorFeatured.length);
const featuredCards = hasCustomFeatured
	? sponsorFeatured.map((s) => ({
			language: s.label,
			speakers: s.speakers,
			note: s.note,
			readers: parseReaders(s.reach || s.speakers),
		}))
	: featured.map((l) => ({
			language: l.language,
			speakers: l.speakers,
			note: undefined,
			readers: l.readers,
		}));
// When featured cards are custom, every actual language drops to "Also available".
const alsoAvailable = hasCustomFeatured ? sponsorLangs : phase2;
const SPONSOR_VIDEO_ID = 'eD06eSXd2uU';
// Spam-safe mailto (matches /partner UnlockMap): address assembled on click so
// kevin@… never appears in the served HTML.
const pledgeOnclick =
	"event.preventDefault();window.location.href='mailto:'+this.dataset.e+'@'+this.dataset.d+'?subject='+encodeURIComponent(this.dataset.subj)";
const HERO_BRI = heroBrightness != null ? `&bri=${heroBrightness}` : '';
const HERO_IMG = `${heroBase}?w=1400&h=560&fit=crop&crop=${heroCrop}${HERO_BRI}&fm=webp&q=72`;
const OG_IMG = `${heroBase}?w=1200&h=630&fit=crop&crop=${heroCrop}&fm=jpg&q=80`;

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://fathersheartbible.com/' },
		{
			'@type': 'ListItem',
			position: 2,
			name: 'The Bible Around the World',
			item: 'https://fathersheartbible.com/bible-in/',
		},
		{ '@type': 'ListItem', position: 3, name: country, item: PAGE_URL },
	],
};
const countryNode = {
	'@type': 'Country',
	name: country,
	...(countryWikipedia ? { sameAs: countryWikipedia } : {}),
};
// Author entity (E-E-A-T) — mirrors GroupBible/the /guides Person schema (sameAs to
// Kevin's external profiles); engines weight author presence when choosing between
// equally-structured pages.
const KEVIN_WHITE_AUTHOR = {
	'@type': 'Person',
	'@id': 'https://kevinwhite.us/#person',
	name: 'Kevin White',
	url: 'https://kevinwhite.us',
	jobTitle: 'Founder & CEO, Spirit Media Publishing',
	affiliation: {
		'@type': 'Organization',
		'@id': 'https://spiritmediapublishing.com/#organization',
		name: 'Spirit Media Publishing',
	},
	sameAs: [
		'https://kevinwhite.us',
		'https://kevinwhite.us/about/',
		'https://www.linkedin.com/in/kevinwhiteus/',
		'https://www.youtube.com/@KevinWhiteus',
		'https://spiritmediapublishing.com',
	],
};
// ItemList schema for the verse sampler — maximally extractable for AI engines.
const versesItemList = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: `Bible verses to read in the Father's Heart Bible™`,
	itemListOrder: 'https://schema.org/ItemListOrderAscending',
	numberOfItems: verses.length,
	itemListElement: verses.map((v, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		name: v.ref,
		url: `https://fathersheartbible.com/read/${v.slug}/${v.ch}`,
		description: v.text,
	})),
};
const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: h1,
	description,
	url: PAGE_URL,
	inLanguage: 'en',
	isAccessibleForFree: true,
	author: KEVIN_WHITE_AUTHOR,
	speakable: {
		'@type': 'SpeakableSpecification',
		cssSelector: ['#direct-answer', '#key-takeaway'],
	},
	...(lastUpdatedIso ? { dateModified: lastUpdatedIso } : {}),
	about: countryNode,
	spatialCoverage: countryNode,
	isPartOf: {
		'@type': 'WebSite',
		name: "Father's Heart Bible™",
		url: 'https://fathersheartbible.com/',
	},
};
const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((f) => ({
		'@type': 'Question',
		name: f.question,
		acceptedAnswer: { '@type': 'Answer', text: f.answer },
	})),
};
const jsonLd = [collectionSchema, breadcrumbSchema, faqSchema, versesItemList];
---

<Layout
	youtube
	title={title}
	description={description}
	image={OG_IMG}
	imageAlt={heroAlt}
	darkHero={true}
	jsonLd={jsonLd}
	preloadImageMobile={HERO_IMG.replace('w=1400', 'w=640')}
	preloadImageDesktop={HERO_IMG}
>
	<main id="main-content">
		<!-- Hero -->
		<section class="relative w-full overflow-hidden min-h-[560px] lg:min-h-[calc(46vh_+_2in)]">
			<img src={HERO_IMG} srcset={`${HERO_IMG.replace('w=1400', 'w=640')} 640w, ${HERO_IMG} 1400w`} sizes="(max-width: 1023px) 640px, 1400px" alt={heroAlt} class="absolute inset-0 w-full h-full object-cover" style="object-position: center top;" fetchpriority="high" decoding="async" />
			<div class="absolute inset-0 z-10" style="background: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.32) 45%, rgba(0,0,0,0.4) 100%);" aria-hidden="true"></div>
			<div class="absolute inset-x-0 bottom-0 z-20 px-6 pb-10 lg:px-8 lg:pb-14">
				<div class="mx-auto max-w-4xl">
					<p class="text-sm font-semibold uppercase tracking-widest mb-2" style="color: #fff; font-family: var(--font-sans);">The Bible Around the World</p>
					<h1 class="text-4xl md:text-5xl lg:text-6xl font-light leading-tight" style="font-family: var(--font-serif); color: #fff;">{h1}{flagImg && (<img src={flagImg} alt={`Flag of ${country}`} class="inline-block align-baseline" style="height: 0.62em; width: auto; margin-left: 0.3em; border: 2px solid rgba(255,255,255,0.92); border-radius: 3px; box-shadow: 0 3px 14px rgba(0,0,0,0.45);" loading="eager" decoding="async" />)}</h1>
					<p class="mt-4 max-w-2xl text-lg leading-relaxed" style="font-family: var(--font-sans); color: rgba(255,255,255,0.92);">{heroSubhead}</p>
				</div>
			</div>
			<div class="absolute inset-x-0 bottom-0 z-30 h-1.5" style={`background: linear-gradient(to right, ${colorPrimary} 0%, ${colorPrimary} 50%, ${colorSecondary} 50%, ${colorSecondary} 100%);`} aria-hidden="true"></div>
		</section>

		<!-- Breadcrumb + direct answer -->
		<section class="px-6 pt-9 pb-2 lg:px-8" style="background-color: var(--color-surface-low);">
			<div class="mx-auto max-w-3xl">
				<nav aria-label="Breadcrumb" class="mb-6 text-sm" style="color: var(--color-muted); font-family: var(--font-sans);">
					<a href="/" class="hover:underline">Home</a><span class="px-1.5" aria-hidden="true">/</span>
					<a href="/bible-in/" class="hover:underline">The Bible Around the World</a><span class="px-1.5" aria-hidden="true">/</span>
					<span class="inline-flex items-center gap-1.5" style="color: var(--color-ink);">{flagImg && <img src={flagImg} alt="" width="18" height="12" class="rounded-[2px]" style="width: 18px; height: auto; border: 1px solid var(--color-hairline);" loading="lazy" decoding="async" aria-hidden="true" />}{country}</span>
				</nav>
				<p id="direct-answer" class="text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={directAnswerHtml}></p>
				{lastUpdated && (
					<p class="mt-3 text-xs" style="font-family: var(--font-sans); color: var(--color-muted);">Last updated {lastUpdated}</p>
				)}
				<div class="mt-6 rounded-xl px-5 py-4" style={`background-color: ${tintWarm}; border-left: 4px solid ${colorPrimary};`}>
					<p id="key-takeaway" class="text-base font-semibold leading-relaxed" style="font-family: var(--font-sans); color: var(--color-ink);"><span class="font-bold uppercase text-sm tracking-widest mr-2" style="color: var(--color-brand);">Key takeaway</span>{keyTakeaway}</p>
				</div>
			</div>
		</section>

		<!-- At a glance -->
		<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface);">
			<div class="mx-auto max-w-4xl">
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{country} at a glance</h2>
				<p class="mt-4 max-w-3xl text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={glanceIntroHtml}></p>
				<dl class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-5">
					{stats.map((s) => (
						<div class="rounded-2xl p-5" style={`background-color: ${tintWarm}; border: 1px solid rgba(0,0,0,0.06);`}>
							<dt class="text-xs font-semibold uppercase tracking-widest" style="color: var(--color-muted); font-family: var(--font-sans);">{s.label}</dt>
							<dd class="mt-2 text-2xl font-medium leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{s.value}</dd>
						</div>
					))}
				</dl>
			</div>
		</section>

		<!-- What the country is known for (national pride) -->
		{knownFor.length > 0 && (
			<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface-low);">
				<div class="mx-auto max-w-4xl">
					<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{knownForHeading || `What ${country} is known for`}</h2>
					{knownForIntroHtml && (
						<p class="mt-4 max-w-3xl text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={knownForIntroHtml}></p>
					)}
					<div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-5">
						{knownFor.map((k) => (
							<div class="rounded-2xl p-5" style={`background-color: ${tintCool}; border: 1px solid rgba(0,0,0,0.06);`}>
								<h3 class="text-lg font-medium leading-snug" style="font-family: var(--font-serif); color: var(--color-ink);">{k.label}</h3>
								<p class="mt-2 text-base leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">{k.text}</p>
							</div>
						))}
					</div>
				</div>
			</section>
		)}

		<!-- Photo gallery row (before Faith section) -->
		{gallery.length > 0 && (
			<section class="px-6 pt-6 pb-10 lg:px-8 lg:pb-14" style="background-color: var(--color-surface-low);">
				<div class="mx-auto max-w-5xl">
					<div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
						{gallery.map((p) => (
							<img src={`${p.src}?w=600&h=420&fit=crop&crop=entropy&fm=webp&q=70`} srcset={`${p.src}?w=400&h=280&fit=crop&crop=entropy&fm=webp&q=68 400w, ${p.src}?w=600&h=420&fit=crop&crop=entropy&fm=webp&q=70 600w`} sizes="(max-width: 767px) 45vw, 23vw" alt={p.alt} width="600" height="420" class="w-full h-36 md:h-48 object-cover rounded-xl" style="border: 1px solid rgba(0,0,0,0.06);" loading="lazy" decoding="async" />
						))}
					</div>
					{galleryCreditHtml && (
						<p class="mt-3 text-xs" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={galleryCreditHtml}></p>
					)}
				</div>
			</section>
		)}

		<!-- Faith & the Bible -->
		<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface);">
			<div class="mx-auto max-w-3xl">
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{faithHeading}</h2>
				<div class="mt-5 space-y-5 text-base lg:text-lg leading-relaxed prose-fhb" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={faithBodyHtml}></div>
				{sources.length > 0 && (
					<p class="mt-6 text-sm" style="font-family: var(--font-sans); color: var(--color-muted);">
						Sources: {sources.map((s, i) => (<>{i > 0 && <span aria-hidden="true"> · </span>}<a href={s.url} target="_blank" rel="noopener noreferrer" style="color: var(--color-brand);" class="hover:underline">{s.label}</a></>))}
					</p>
				)}
			</div>
		</section>

		<!-- What pains the country (the ache) -->
		{(painsBodyHtml || painStats.length > 0) && (
			<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface-low);">
				<div class="mx-auto max-w-3xl">
					<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{painsHeading || `What pains ${country}`}</h2>
					{painsIntroHtml && (
						<p class="mt-4 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={painsIntroHtml}></p>
					)}
					{painStats.length > 0 && (
						<dl class="mt-7 grid grid-cols-2 md:grid-cols-3 gap-5">
							{painStats.map((s) => (
								<div class="rounded-2xl p-5" style={`background-color: ${tintBlue}; border: 1px solid rgba(0,0,0,0.06);`}>
									<dt class="text-2xl font-medium leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{s.value}</dt>
									<dd class="mt-2 text-sm leading-snug" style="font-family: var(--font-sans); color: var(--color-muted);">{s.label}</dd>
								</div>
							))}
						</dl>
					)}
					{painsBodyHtml && (
						<div class="mt-6 space-y-5 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={painsBodyHtml}></div>
					)}
					{painsSources.length > 0 && (
						<p class="mt-6 text-sm" style="font-family: var(--font-sans); color: var(--color-muted);">
							Sources: {painsSources.map((s, i) => (<>{i > 0 && <span aria-hidden="true"> · </span>}<a href={s.url} target="_blank" rel="noopener noreferrer" style="color: var(--color-brand);" class="hover:underline">{s.label}</a></>))}
						</p>
					)}
				</div>
