---
interface Props {
	headline: string;
	body?: string;
	primaryLabel: string;
	primaryHref: string;
	secondaryLabel?: string;
	secondaryHref?: string;
	dark?: boolean;
}

const {
	headline,
	body,
	primaryLabel,
	primaryHref,
	secondaryLabel,
	secondaryHref,
	dark = false,
} = Astro.props;

const bg = dark ? 'var(--color-deep)' : 'var(--color-brand)';
const headlineColor = '#fff';
const bodyColor = dark ? 'rgba(255,255,255,0.65)' : 'rgba(255,255,255,0.85)';
---

<section class="py-16 md:py-20" style={`background-color: ${bg};`}>
	<div class="max-w-3xl mx-auto px-6 text-center">
		<h2
			class="text-3xl md:text-4xl font-light mb-4"
			style={`font-family: var(--font-serif); color: ${headlineColor};`}
		>
			{headline}
		</h2>
		{body && (
			<p
				class="text-lg mb-10 leading-relaxed"
				style={`font-family: var(--font-sans); color: ${bodyColor};`}
			>
				{body}
			</p>
		)}
		<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
			<a
				href={primaryHref}
				class="inline-flex items-center px-8 py-3.5 text-base font-semibold no-underline rounded transition-all duration-200"
				style="font-family: var(--font-sans); background-color: var(--color-gold); color: var(--color-deep);"
				onmouseover="this.style.filter='brightness(1.08)'"
				onmouseout="this.style.filter='none'"
			>
				{primaryLabel}
			</a>
			{secondaryLabel && secondaryHref && (
				<a
					href={secondaryHref}
					class="inline-flex items-center px-8 py-3.5 text-base font-semibold no-underline rounded border transition-all duration-200"
					style="font-family: var(--font-sans); color: #fff; border-color: rgba(255,255,255,0.4);"
					onmouseover="this.style.borderColor='rgba(255,255,255,0.8)'"
					onmouseout="this.style.borderColor='rgba(255,255,255,0.4)'"
				>
					{secondaryLabel}
				</a>
			)}
		</div>
	</div>
</section>
