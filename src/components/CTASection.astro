---
interface Props {
	headline: string;
	body?: string;
	primaryLabel: string;
	primaryHref: string;
	secondaryLabel?: string;
	secondaryHref?: string;
	dark?: boolean;
}

const {
	headline,
	body,
	primaryLabel,
	primaryHref,
	secondaryLabel,
	secondaryHref,
	dark = false,
} = Astro.props;

const bg = dark ? 'var(--color-inverse-surface)' : 'linear-gradient(135deg, var(--color-primary), var(--color-primary-container))';
const headlineColor = '#fff';
const bodyColor = dark ? 'rgba(255,255,255,0.65)' : 'rgba(255,255,255,0.85)';
---

<section class="py-20 md:py-28" style={dark ? `background-color: ${bg};` : `background: ${bg};`}>
	<div class="max-w-3xl mx-auto px-6 text-center">
		<h2
			class="text-3xl md:text-5xl font-light mb-4 tracking-tight"
			style={`font-family: var(--font-headline); color: ${headlineColor};`}
		>
			{headline}
		</h2>
		{body && (
			<p
				class="text-lg mb-10 leading-relaxed"
				style={`font-family: var(--font-body); color: ${bodyColor};`}
			>
				{body}
			</p>
		)}
		<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
			<a
				href={primaryHref}
				class="inline-flex items-center px-8 py-3.5 text-sm font-semibold uppercase no-underline tracking-[0.08em] transition-all duration-200"
				style="font-family: var(--font-body); background-color: var(--color-surface-lowest); color: var(--color-primary); border-radius: 0.125rem;"
				onmouseover="this.style.opacity='0.9'"
				onmouseout="this.style.opacity='1'"
			>
				{primaryLabel}
			</a>
			{secondaryLabel && secondaryHref && (
				<a
					href={secondaryHref}
					class="inline-flex items-center px-8 py-3.5 text-sm font-semibold uppercase no-underline tracking-[0.08em] transition-all duration-200"
					style="font-family: var(--font-body); color: #fff; border: 1px solid rgba(255,255,255,0.2); border-radius: 0.125rem;"
					onmouseover="this.style.borderColor='rgba(255,255,255,0.5)'"
					onmouseout="this.style.borderColor='rgba(255,255,255,0.2)'"
				>
					{secondaryLabel}
				</a>
			)}
		</div>
	</div>
</section>
