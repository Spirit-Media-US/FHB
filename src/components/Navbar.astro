---
import { sanityClient, urlFor } from '../lib/sanity';

interface NavLink {
	label: string;
	href: string;
}

const siteSettings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    siteName,
    logo,
    navLinks
  }
`);

const siteName = siteSettings?.siteName || "Father's Heart Bible";
const logoImage = siteSettings?.logo;
const logoUrl = logoImage ? urlFor(logoImage).width(200).url() : null;

// Visible header brand always carries the trademark. siteName itself stays
// plain (it also feeds the og:site_name meta, which we keep ™-free).
const brandName = `${siteName}`.replace(/™$/, '') + '™';
// White FHB wordmark shown to the right of the brand text. The PNG is white;
// setNavColors keeps it white over the dark hero and tints it brand-color
// on the scrolled/light glass header.
const brandLogoUrl =
	'https://cdn.sanity.io/images/rusi1hyi/production/bf8e5685f1b30a651457f26abfa2ca1fa30cd784-900x450.png?w=400&auto=format';

const navLinks: NavLink[] = [
	{ label: 'Home', href: '/' },
	{ label: 'About FHB', href: '/the-fathers-heart-bible/' },
	{ label: 'Read FHB', href: 'https://join.fathersheartbible.com/read' },
	{ label: 'Partner With Us', href: '/partner/' },
	{ label: 'Blog', href: '/blog/' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
	<nav class="max-w-6xl mx-auto px-6 py-6 flex items-center justify-between">
		<!-- Logo -->
		<a href="/" id="nav-logo" class="no-underline shrink-0 flex flex-row items-center gap-2.5">
			{logoUrl && (
				<img
					src={logoUrl}
					alt=""
					aria-hidden="true"
					class="h-12 md:h-16 w-auto"
					style="filter: brightness(0) saturate(100%) invert(5%) sepia(20%) saturate(500%) hue-rotate(290deg) brightness(20%) contrast(100%);"
				/>
			)}
			<span
				class="text-xs font-semibold tracking-[0.15em] uppercase whitespace-nowrap"
				style="font-family: var(--font-body); color: var(--color-primary);"
			>{brandName}</span>
			<img
				id="nav-brand-logo"
				src={brandLogoUrl}
				alt=""
				aria-hidden="true"
				class="h-8 md:h-10 w-auto"
				style="filter: brightness(0) saturate(100%) invert(5%) sepia(20%) saturate(500%) hue-rotate(290deg) brightness(20%) contrast(100%);"
			/>
		</a>

		<!-- Desktop nav -->
		<ul class="hidden lg:flex items-center gap-4 xl:gap-7 list-none m-0 p-0">
			{navLinks.map(link => (
				link.href === '/the-fathers-heart-bible' ? (
					<li class="relative group">
						<a
							href={link.href}
							class="text-xs font-semibold uppercase no-underline transition-colors duration-200 tracking-[0.1em]"
							style={`font-family: var(--font-body); color: var(--color-on-surface-variant);`}
						>
							{link.label}
						</a>
						<div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
							<div class="py-2 px-1 min-w-[180px]" style="background-color: var(--color-surface-lowest); border: 1px solid var(--color-outline-variant); box-shadow: 0 4px 16px rgba(0,0,0,0.08);">
								<a
									href="/the-fathers-heart-bible/lead-translator/"
									class="block px-4 py-2 text-xs font-semibold uppercase no-underline tracking-[0.1em] transition-colors duration-200"
									style={`font-family: var(--font-body); color: var(--color-on-surface-variant);`}
									onmouseover="this.style.color='var(--color-primary)'"
									onmouseout="this.style.color='var(--color-on-surface-variant)'"
								>
									Lead Translator
								</a>
							</div>
						</div>
					</li>
				) : (
					<li>
						<a
							href={link.href}
							class="text-xs font-semibold uppercase no-underline transition-colors duration-200 tracking-[0.1em]"
							style={`font-family: var(--font-body); color: var(--color-on-surface-variant);`}
						>
							{link.label}
						</a>
					</li>
				)
			))}
		</ul>

		<!-- CTA button -->
		<a
			id="nav-cta"
			href="https://join.fathersheartbible.com/read"
			class="hidden lg:inline-flex items-center px-5 py-2 text-xs font-semibold uppercase no-underline transition-all duration-200 tracking-[0.08em]"
			style="font-family: var(--font-body); background: #FFD9E0; color: #4A4A4A;"
			onmouseover="this.style.opacity='0.85';"
			onmouseout="this.style.opacity='1';"
		>
			Read FHB →
		</a>

		<!-- Mobile hamburger -->
		<button
			id="mobile-menu-btn"
			class="lg:hidden flex flex-col gap-1.5 p-2 cursor-pointer bg-transparent border-none"
			aria-label="Toggle menu"
			aria-expanded="false"
		>
			<span class="block w-6 h-0.5 transition-all duration-300 origin-center" style="background-color: var(--color-on-surface);" id="bar1"></span>
			<span class="block w-6 h-0.5 transition-all duration-300" style="background-color: var(--color-on-surface);" id="bar2"></span>
			<span class="block w-6 h-0.5 transition-all duration-300 origin-center" style="background-color: var(--color-on-surface);" id="bar3"></span>
		</button>
	</nav>

	<!-- Mobile menu -->
	<div id="mobile-menu" class="lg:hidden hidden" style="background-color: var(--color-surface-lowest); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);">
		<ul class="flex flex-col items-center gap-4 py-5 list-none m-0 px-6">
			{navLinks.map(link => (
				<li class="flex flex-col items-center gap-3">
					<a
						href={link.href}
						class="text-xs font-semibold uppercase no-underline transition-colors duration-200 tracking-[0.1em]"
						style={`font-family: var(--font-body); color: var(--color-on-surface-variant);`}
					>
						{link.label}
					</a>
					{link.href === '/the-fathers-heart-bible' && (
						<a
							href="/the-fathers-heart-bible/lead-translator/"
							class="text-xs font-medium uppercase no-underline transition-colors duration-200 tracking-[0.1em]"
							style={`font-family: var(--font-body); color: var(--color-muted); opacity: 0.7;`}
						>
							Lead Translator
						</a>
					)}
				</li>
			))}
			<li>
				<a
					href="https://join.fathersheartbible.com/read"
					class="inline-flex items-center px-6 py-2.5 text-xs font-semibold uppercase no-underline tracking-[0.08em]"
					style="font-family: var(--font-body); background: #FFD9E0; color: #4A4A4A;"
				>
					Read FHB →
				</a>
			</li>
		</ul>
	</div>
</header>

<script>
	const header = document.getElementById('site-header');
	const menuBtn = document.getElementById('mobile-menu-btn');
	const mobileMenu = document.getElementById('mobile-menu');
	const bar1 = document.getElementById('bar1');
	const bar2 = document.getElementById('bar2');
	const bar3 = document.getElementById('bar3');
	let menuOpen = false;

	const darkHero = document.body.dataset.darkHero === 'true';

	function setNavColors(scrolled: boolean) {
		if (!header) return;
		const logo = document.getElementById('nav-logo');
		const logoText = logo?.querySelector<HTMLElement>('span');
		const brandLogo = document.getElementById('nav-brand-logo');
		const BRAND_FILTER = 'brightness(0) saturate(100%) invert(5%) sepia(20%) saturate(500%) hue-rotate(290deg) brightness(20%) contrast(100%)';
		const ctaBtn = document.getElementById('nav-cta');
		const links = Array.from(header.querySelectorAll<HTMLElement>('nav a, nav span')).filter(
			el => el !== logo && !logo?.contains(el) && el !== ctaBtn
		);
		const bars = [bar1, bar2, bar3];
		const darkBgVisible = darkHero;
		if (scrolled || !darkBgVisible) {
			// Glass/canvas background — use primary/variant for links + bars + logo text
			links.forEach(el => { el.style.color = 'var(--color-on-surface-variant)'; });
			bars.forEach(el => { if (el) el.style.backgroundColor = 'var(--color-on-surface)'; });
			if (logoText) logoText.style.color = 'var(--color-primary)';
			if (brandLogo) brandLogo.style.filter = BRAND_FILTER; // tint white logo to brand color
		} else {
			// Transparent over dark hero — white text + bars + logo text + white logo
			links.forEach(el => { el.style.color = 'rgba(255,255,255,0.92)'; });
			bars.forEach(el => { if (el) el.style.backgroundColor = 'rgba(255,255,255,0.85)'; });
			if (logoText) logoText.style.color = 'rgba(255,255,255,0.92)';
			if (brandLogo) brandLogo.style.filter = 'brightness(0) invert(1)'; // render logo white over dark hero
		}
	}

	function handleScroll() {
		if (!header) return;
		const scrolled = window.scrollY > 40;
		if (scrolled) {
			header.style.backgroundColor = 'rgba(255,255,255,0.7)';
			header.style.backdropFilter = 'blur(20px)';
			(header.style as any)['-webkit-backdrop-filter'] = 'blur(20px)';
			header.style.boxShadow = '0 1px 40px rgba(26,28,28,0.05)';
		} else {
			header.style.backgroundColor = 'transparent';
			header.style.backdropFilter = 'none';
			(header.style as any)['-webkit-backdrop-filter'] = 'none';
			header.style.boxShadow = 'none';
		}
		setNavColors(scrolled);
	}
	window.addEventListener('scroll', handleScroll, { passive: true });
	window.addEventListener('resize', handleScroll, { passive: true });
	// Defer initial paint so the inline <script> doesn't block HTML parse —
	// brief flash of default bar/link colors on darkHero pages, but FCP/LCP
	// for the hero is no longer gated by ~300ms of synchronous DOM work.
	requestAnimationFrame(handleScroll);

	menuBtn?.addEventListener('click', () => {
		menuOpen = !menuOpen;
		mobileMenu?.classList.toggle('hidden');
		menuBtn?.setAttribute('aria-expanded', String(menuOpen));
		if (menuOpen) {
			bar1!.style.transform = 'rotate(45deg) translate(3px, 3px)';
			bar2!.style.opacity = '0';
			bar3!.style.transform = 'rotate(-45deg) translate(3px, -3px)';
		} else {
			bar1!.style.transform = 'none';
			bar2!.style.opacity = '1';
			bar3!.style.transform = 'none';
		}
	});
</script>
