---
import { sanityClient } from '../lib/sanity';

interface NavLink {
	label: string;
	href: string;
}

const siteSettings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    siteName,
    logo,
    navLinks
  }
`);

const siteName = siteSettings?.siteName || "Father's Heart Bible";

const navLinks: NavLink[] = siteSettings?.navLinks || [
	{ label: "The Father's Heart Bible", href: '/the-fathers-heart-bible' },
	{ label: 'Samples', href: '/samples' },
	{ label: 'Download', href: '/download' },
	{ label: 'Join the Movement', href: '/join' },
	{ label: 'Partner With Us', href: '/partner' },
	{ label: 'About', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
	<nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
		<!-- Logo -->
		<a href="/" class="no-underline shrink-0">
			<img
				src="https://cdn.sanity.io/images/rusi1hyi/production/bf8e5685f1b30a651457f26abfa2ca1fa30cd784-900x450.png"
				alt={siteName}
				class="h-20 w-auto"
				style="filter: brightness(0) saturate(100%) invert(39%) sepia(19%) saturate(1043%) hue-rotate(349deg) brightness(95%) contrast(85%);"
			/>
		</a>

		<!-- Desktop nav -->
		<ul class="hidden lg:flex items-center gap-7 list-none m-0 p-0">
			{navLinks.slice(0, 5).map(link => (
				<li>
					<a
						href={link.href}
						class="text-sm font-medium no-underline transition-colors duration-200"
						style={`font-family: var(--font-sans); color: var(--color-brand); letter-spacing: 0.04em;`}
					>
						{link.label}
					</a>
				</li>
			))}
		</ul>

		<!-- CTA button -->
		<a
			href="/download"
			class="hidden lg:inline-flex items-center px-5 py-2 text-sm font-semibold no-underline transition-all duration-200 rounded"
			style="font-family: var(--font-sans); background-color: var(--color-brand); color: #fff; letter-spacing: 0.03em;"
			onmouseover="this.style.backgroundColor='var(--color-brand-dark)'"
			onmouseout="this.style.backgroundColor='var(--color-brand)'"
		>
			Download Free
		</a>

		<!-- Mobile hamburger -->
		<button
			id="mobile-menu-btn"
			class="lg:hidden flex flex-col gap-1.5 p-2 cursor-pointer bg-transparent border-none"
			aria-label="Toggle menu"
			aria-expanded="false"
		>
			<span class="block w-6 h-0.5 transition-all duration-300 origin-center" style="background-color: var(--color-ink);" id="bar1"></span>
			<span class="block w-6 h-0.5 transition-all duration-300" style="background-color: var(--color-ink);" id="bar2"></span>
			<span class="block w-6 h-0.5 transition-all duration-300 origin-center" style="background-color: var(--color-ink);" id="bar3"></span>
		</button>
	</nav>

	<!-- Mobile menu -->
	<div id="mobile-menu" class="lg:hidden hidden border-t" style="background-color: var(--color-canvas); border-color: var(--color-hairline);">
		<ul class="flex flex-col items-center gap-6 py-8 list-none m-0 px-6">
			{navLinks.map(link => (
				<li>
					<a
						href={link.href}
						class="text-sm font-medium no-underline transition-colors duration-200"
						style={`font-family: var(--font-sans); color: var(--color-brand); letter-spacing: 0.04em;`}
					>
						{link.label}
					</a>
				</li>
			))}
			<li>
				<a
					href="/download"
					class="inline-flex items-center px-6 py-2.5 text-sm font-semibold no-underline rounded"
					style="font-family: var(--font-sans); background-color: var(--color-brand); color: #fff;"
				>
					Download Free
				</a>
			</li>
		</ul>
	</div>
</header>

<script>
	const header = document.getElementById('site-header');
	const menuBtn = document.getElementById('mobile-menu-btn');
	const mobileMenu = document.getElementById('mobile-menu');
	const bar1 = document.getElementById('bar1');
	const bar2 = document.getElementById('bar2');
	const bar3 = document.getElementById('bar3');
	let menuOpen = false;

	const darkHero = document.body.dataset.darkHero === 'true';

	function setNavColors(scrolled: boolean) {
		if (!header) return;
		const links = header.querySelectorAll<HTMLElement>('a, span');
		const bars = [bar1, bar2, bar3];
		if (scrolled || !darkHero) {
			// Solid background — use brand brown for links
			links.forEach(el => { el.style.color = 'var(--color-brand)'; });
			bars.forEach(el => { if (el) el.style.backgroundColor = 'var(--color-ink)'; });
		} else {
			// Transparent on dark hero — use white
			links.forEach(el => { el.style.color = 'rgba(255,255,255,0.92)'; });
			bars.forEach(el => { if (el) el.style.backgroundColor = 'rgba(255,255,255,0.85)'; });
		}
	}

	function handleScroll() {
		if (!header) return;
		const scrolled = window.scrollY > 40;
		if (scrolled) {
			header.style.backgroundColor = 'var(--color-canvas)';
			header.style.boxShadow = '0 1px 12px rgba(28,26,23,0.08)';
		} else {
			header.style.backgroundColor = 'transparent';
			header.style.boxShadow = 'none';
		}
		setNavColors(scrolled);
	}
	window.addEventListener('scroll', handleScroll, { passive: true });
	handleScroll();

	menuBtn?.addEventListener('click', () => {
		menuOpen = !menuOpen;
		mobileMenu?.classList.toggle('hidden');
		menuBtn?.setAttribute('aria-expanded', String(menuOpen));
		if (menuOpen) {
			bar1!.style.transform = 'rotate(45deg) translate(3px, 3px)';
			bar2!.style.opacity = '0';
			bar3!.style.transform = 'rotate(-45deg) translate(3px, -3px)';
		} else {
			bar1!.style.transform = 'none';
			bar2!.style.opacity = '1';
			bar3!.style.transform = 'none';
		}
	});
</script>
