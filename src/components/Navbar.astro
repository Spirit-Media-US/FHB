---
import { sanityClient } from '../lib/sanity';

interface NavLink {
	label: string;
	href: string;
}

// Fetch siteSettings for branding
const siteSettings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    siteName,
    logo
  }
`);

const siteName = siteSettings?.siteName || "Father's Heart Bible";

const navLinks: NavLink[] = [
	{ label: 'About', href: '/about' },
	{ label: 'Read the Preface', href: '/sample' },
	{ label: 'Partner', href: '/partner' },
	{ label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
	<nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
		<a href="/" class="group flex items-center gap-2 no-underline">
			<span class="text-xl md:text-2xl font-semibold tracking-tight transition-colors" style="font-family: var(--font-serif); color: var(--color-charcoal);">
				{siteName}
			</span>
		</a>

		<ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
			{navLinks.map(link => (
				<li>
					<a
						href={link.href}
						class="text-sm font-medium tracking-wide uppercase no-underline transition-colors duration-200"
						style={`font-family: var(--font-sans); color: ${currentPath === link.href ? 'var(--color-accent-dark)' : 'var(--color-warm-gray)'}; letter-spacing: 0.08em;`}
					>
						{link.label}
					</a>
				</li>
			))}
		</ul>

		<!-- Mobile hamburger -->
		<button
			id="mobile-menu-btn"
			class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer bg-transparent border-none"
			aria-label="Toggle menu"
			aria-expanded="false"
		>
			<span class="block w-6 h-0.5 transition-all duration-300 origin-center" style="background-color: var(--color-charcoal);" id="bar1"></span>
			<span class="block w-6 h-0.5 transition-all duration-300" style="background-color: var(--color-charcoal);" id="bar2"></span>
			<span class="block w-6 h-0.5 transition-all duration-300 origin-center" style="background-color: var(--color-charcoal);" id="bar3"></span>
		</button>
	</nav>

	<!-- Mobile menu -->
	<div id="mobile-menu" class="md:hidden hidden" style="background-color: var(--color-cream);">
		<ul class="flex flex-col items-center gap-6 py-8 list-none m-0 px-6">
			{navLinks.map(link => (
				<li>
					<a
						href={link.href}
						class="text-sm font-medium tracking-wide uppercase no-underline transition-colors duration-200"
						style={`font-family: var(--font-sans); color: ${currentPath === link.href ? 'var(--color-accent-dark)' : 'var(--color-warm-gray)'}; letter-spacing: 0.08em;`}
					>
						{link.label}
					</a>
				</li>
			))}
		</ul>
	</div>
</header>

<script>
	const header = document.getElementById('site-header');
	const menuBtn = document.getElementById('mobile-menu-btn');
	const mobileMenu = document.getElementById('mobile-menu');
	const bar1 = document.getElementById('bar1');
	const bar2 = document.getElementById('bar2');
	const bar3 = document.getElementById('bar3');
	let menuOpen = false;

	// Scroll: add background on scroll
	function handleScroll() {
		if (!header) return;
		if (window.scrollY > 40) {
			header.style.backgroundColor = 'var(--color-cream)';
			header.style.boxShadow = '0 1px 12px rgba(30,27,24,0.06)';
		} else {
			header.style.backgroundColor = 'transparent';
			header.style.boxShadow = 'none';
		}
	}
	window.addEventListener('scroll', handleScroll, { passive: true });
	handleScroll();

	// Mobile menu toggle
	menuBtn?.addEventListener('click', () => {
		menuOpen = !menuOpen;
		mobileMenu?.classList.toggle('hidden');
		menuBtn?.setAttribute('aria-expanded', String(menuOpen));
		if (menuOpen) {
			bar1!.style.transform = 'rotate(45deg) translate(3px, 3px)';
			bar2!.style.opacity = '0';
			bar3!.style.transform = 'rotate(-45deg) translate(3px, -3px)';
		} else {
			bar1!.style.transform = 'none';
			bar2!.style.opacity = '1';
			bar3!.style.transform = 'none';
		}
	});
</script>
