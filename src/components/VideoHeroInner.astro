---
interface Props {
	videoSrc: string;
	heading: string;
	subheading?: string;
	primaryCtaLabel?: string;
	primaryCtaHref?: string;
	secondaryCtaLabel?: string;
	secondaryCtaHref?: string;
}

const {
	videoSrc,
	heading,
	subheading,
	primaryCtaLabel,
	primaryCtaHref,
	secondaryCtaLabel,
	secondaryCtaHref,
} = Astro.props;
---

<section
	class="relative flex items-end justify-center overflow-hidden min-h-[840px] md:min-h-screen"
	style="background-color: var(--color-inverse-surface); margin-top: -1px;"
>
	<video
		class="absolute inset-0 w-full h-full object-cover"
		src={videoSrc}
		autoplay
		muted
		loop
		playsinline
		aria-hidden="true"
		style="opacity: 1;"
	/>
	<div class="relative z-10 text-center px-6 max-w-3xl mx-auto pb-16 md:pb-24">
		<h1
			class="text-4xl md:text-6xl font-medium leading-snug tracking-tight"
			style="font-family: var(--font-headline); color: #FFFFFF;"
		>
			{heading}
		</h1>
	</div>
</section>

{(subheading || primaryCtaLabel) && (
	<section style="background-color: var(--color-canvas);" class="py-16 md:py-20 px-6">
		<div class="max-w-2xl mx-auto text-center">
			{subheading && (
				<p
					class="text-lg md:text-xl leading-relaxed mb-10"
					style="font-family: var(--font-body); color: var(--color-muted);"
				>
					{subheading}
				</p>
			)}
			{primaryCtaLabel && primaryCtaHref && (
				<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
					<a
						href={primaryCtaHref}
						class="inline-flex items-center px-8 py-3.5 text-base font-semibold no-underline transition-all duration-200"
						style="font-family: var(--font-body); background: linear-gradient(135deg, var(--color-primary), var(--color-primary-container)); color: var(--color-on-primary);"
						onmouseover="this.style.opacity='0.9'"
						onmouseout="this.style.opacity='1'"
					>
						{primaryCtaLabel}
					</a>
					{secondaryCtaLabel && secondaryCtaHref && (
						<a
							href={secondaryCtaHref}
							class="inline-flex items-center px-8 py-3.5 text-base font-medium no-underline border transition-all duration-200"
							style="font-family: var(--font-body); color: var(--color-primary); border-color: var(--color-primary);"
							onmouseover="this.style.backgroundColor='var(--color-primary)'; this.style.color='var(--color-on-primary)';"
							onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--color-primary)';"
						>
							{secondaryCtaLabel}
						</a>
					)}
				</div>
			)}
		</div>
	</section>
)}
