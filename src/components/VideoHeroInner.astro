---
interface Props {
	videoSrc: string;
	heading: string;
	subheading?: string;
	primaryCtaLabel?: string;
	primaryCtaHref?: string;
	secondaryCtaLabel?: string;
	secondaryCtaHref?: string;
}

const {
	videoSrc,
	heading,
	subheading,
	primaryCtaLabel,
	primaryCtaHref,
	secondaryCtaLabel,
	secondaryCtaHref,
} = Astro.props;
---

<section
	class="relative flex items-end justify-center overflow-hidden min-h-[840px] md:min-h-screen"
	style="background-color: var(--color-inverse-surface); margin-top: -1px;"
>
	<video
		class="absolute inset-0 w-full h-full object-cover"
		src={videoSrc}
		autoplay
		muted
		loop
		playsinline
		aria-hidden="true"
		style="opacity: 1;"
	/>
	<div class="relative z-10 text-center px-6 max-w-3xl mx-auto pb-16 md:pb-24">
		<h1
			class="text-4xl md:text-7xl font-light leading-tight mb-6 tracking-tight"
			style="font-family: var(--font-headline); color: var(--color-primary);"
		>
			{heading}
		</h1>
		{subheading && (
			<p
				class="text-lg md:text-xl mb-10 leading-relaxed"
				style="font-family: var(--font-body); color: var(--color-on-surface-variant);"
			>
				{subheading}
			</p>
		)}
		{primaryCtaLabel && primaryCtaHref && (
			<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
				<a
					href={primaryCtaHref}
					class="inline-flex items-center px-8 py-3.5 text-sm font-semibold uppercase no-underline tracking-[0.08em] transition-all duration-200"
					style="font-family: var(--font-body); background: linear-gradient(135deg, var(--color-primary), var(--color-primary-container)); color: var(--color-on-primary); border-radius: 0.125rem;"
					onmouseover="this.style.opacity='0.9'"
					onmouseout="this.style.opacity='1'"
				>
					{primaryCtaLabel}
				</a>
				{secondaryCtaLabel && secondaryCtaHref && (
					<a
						href={secondaryCtaHref}
						class="inline-flex items-center px-8 py-3.5 text-sm font-medium uppercase no-underline tracking-[0.08em] transition-all duration-200"
						style="font-family: var(--font-body); color: var(--color-primary); border: 1px solid rgba(48,1,23,0.2); border-radius: 0.125rem;"
						onmouseover="this.style.borderColor='rgba(48,1,23,0.5)'"
						onmouseout="this.style.borderColor='rgba(48,1,23,0.2)'"
					>
						{secondaryCtaLabel}
					</a>
				)}
			</div>
		)}
	</div>
</section>
