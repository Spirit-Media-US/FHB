---
interface Props {
	videoSrc?: string;
	imageSrc?: string;
	imagePosition?: string;
	showLogo?: boolean;
	headingLift?: string;
	heading: string;
	subheading?: string;
	primaryCtaLabel?: string;
	primaryCtaHref?: string;
	secondaryCtaLabel?: string;
	secondaryCtaHref?: string;
}

const {
	videoSrc,
	imageSrc,
	imagePosition = 'center',
	showLogo = true,
	headingLift = '0',
	heading,
	subheading,
	primaryCtaLabel,
	primaryCtaHref,
	secondaryCtaLabel,
	secondaryCtaHref,
} = Astro.props;

// When there's no CTA (e.g. /partner), the subheading's bottom margin + the
// section's bottom padding would render as dead white space. Collapse them.
const hasCta = !!(primaryCtaLabel && primaryCtaHref);

// Responsive hero: derive mobile/desktop widths from the Sanity URL's w= param
// so phones don't download the full-width hero (e.g. /partner shipped a 1920w
// image to 390px screens → ~10s mobile LCP). 720w mobile, 1280w desktop.
const hasW = imageSrc && /[?&]w=\d+/.test(imageSrc);
const heroSrcset = hasW
	? `${imageSrc.replace(/([?&])w=\d+/, '$1w=720')} 720w, ${imageSrc.replace(/([?&])w=\d+/, '$1w=1280')} 1280w`
	: undefined;
const heroSrcMain = hasW ? imageSrc.replace(/([?&])w=\d+/, '$1w=1280') : imageSrc;
---

<section
	class="relative flex items-end justify-center overflow-hidden min-h-[600px] lg:min-h-[calc(50vh_+_2in)]"
	style="background-color: var(--color-inverse-surface); margin-top: -1px;"
>
	{imageSrc ? (
		<img
			class="absolute inset-0 w-full h-full object-cover"
			src={heroSrcMain}
			srcset={heroSrcset}
			sizes="100vw"
			alt=""
			aria-hidden="true"
			fetchpriority="high"
			decoding="async"
			style={`opacity: 1; object-position: ${imagePosition};`}
		/>
	) : (
		<video
			class="absolute inset-0 w-full h-full object-cover"
			src={videoSrc}
			autoplay
			muted
			loop
			playsinline
			aria-hidden="true"
			style="opacity: 1;"
		/>
	)}
	<!-- Dark overlay: darker at top (so the transparent header's white logo/nav/CTA
	     stay legible) and at bottom (behind the white hero logo + heading), lighter
	     through the middle so the imagery still reads. -->
	<div
		class="absolute inset-0 z-[1]"
		style="background: linear-gradient(to bottom, rgba(0,0,0,0.50) 0%, rgba(0,0,0,0.18) 32%, rgba(0,0,0,0.30) 65%, rgba(0,0,0,0.62) 100%);"
		aria-hidden="true"
	></div>
	<div class="relative z-10 text-center px-6 max-w-3xl mx-auto pb-10 md:pb-16 lg:pb-24">
		{showLogo && (
			<img
				src="/fhb-logo-white-400.png"
				srcset="/fhb-logo-white-240.png 240w, /fhb-logo-white-400.png 400w"
				sizes="(max-width: 768px) 160px, (max-width: 1024px) 240px, 320px"
				width="400"
				height="195"
				alt="Father's Heart Bible"
				fetchpriority="high"
				decoding="async"
				class="h-14 md:h-20 lg:h-28 w-auto mx-auto mb-4 md:mb-6" data-hero-entrance
			/>
		)}
		<h1
			class="text-4xl md:text-6xl font-medium leading-snug tracking-tight"
			style={`font-family: var(--font-headline); color: #FFFFFF; margin-bottom: ${headingLift};`} data-hero-entrance
		>
			{heading}
		</h1>
	</div>
</section>

{(subheading || primaryCtaLabel) && (
	<section style="background-color: var(--color-canvas);" class={`px-4 md:px-6 ${hasCta ? 'py-8 md:py-12' : 'pt-8 md:pt-12 pb-0'}`}>
		<div class="max-w-2xl mx-auto text-center" data-reveal>
			{subheading && (
				<p
					class={`text-lg md:text-xl leading-relaxed ${hasCta ? 'mb-10' : 'mb-0'}`}
					style="font-family: var(--font-body); color: var(--color-muted);"
				>
					{subheading}
				</p>
			)}
			{primaryCtaLabel && primaryCtaHref && (
				<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
					<a
						href={primaryCtaHref}
						class="inline-flex items-center px-8 py-3.5 text-base font-semibold no-underline transition-all duration-200"
						style="font-family: var(--font-body); background: #FFD9E0; color: #4A4A4A;"
						onmouseover="this.style.opacity='0.9'"
						onmouseout="this.style.opacity='1'"
					>
						{primaryCtaLabel}
					</a>
					{secondaryCtaLabel && secondaryCtaHref && (
						<a
							href={secondaryCtaHref}
							class="inline-flex items-center px-8 py-3.5 text-base font-medium no-underline transition-all duration-200"
							style="font-family: var(--font-body); background: #FFD9E0; color: #4A4A4A;"
							onmouseover="this.style.opacity='0.9';"
							onmouseout="this.style.opacity='1';"
						>
							{secondaryCtaLabel}
						</a>
					)}
				</div>
			)}
		</div>
	</section>
)}
