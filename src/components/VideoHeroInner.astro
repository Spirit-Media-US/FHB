---
interface Props {
	videoSrc?: string;
	imageSrc?: string;
	heading: string;
	subheading?: string;
	primaryCtaLabel?: string;
	primaryCtaHref?: string;
	secondaryCtaLabel?: string;
	secondaryCtaHref?: string;
}

const {
	videoSrc,
	imageSrc,
	heading,
	subheading,
	primaryCtaLabel,
	primaryCtaHref,
	secondaryCtaLabel,
	secondaryCtaHref,
} = Astro.props;
---

<section
	class="relative flex items-end justify-center overflow-hidden min-h-[600px] lg:min-h-[calc(50vh_+_2in)]"
	style="background-color: var(--color-inverse-surface); margin-top: -1px;"
>
	{imageSrc ? (
		<img
			class="absolute inset-0 w-full h-full object-cover"
			src={imageSrc}
			alt=""
			aria-hidden="true"
			fetchpriority="high"
			decoding="async"
			style="opacity: 1;"
		/>
	) : (
		<video
			class="absolute inset-0 w-full h-full object-cover"
			src={videoSrc}
			autoplay
			muted
			loop
			playsinline
			aria-hidden="true"
			style="opacity: 1;"
		/>
	)}
	<div class="relative z-10 text-center px-6 max-w-3xl mx-auto pb-10 md:pb-16 lg:pb-24">
		<img
			src="/fhb-logo-white-400.png"
			srcset="/fhb-logo-white-240.png 240w, /fhb-logo-white-400.png 400w"
			sizes="(max-width: 768px) 160px, (max-width: 1024px) 240px, 320px"
			width="400"
			height="195"
			alt="Father's Heart Bible"
			fetchpriority="high"
			decoding="async"
			class="h-14 md:h-20 lg:h-28 w-auto mx-auto mb-4 md:mb-6" data-hero-entrance
		/>
		<h1
			class="text-4xl md:text-6xl font-medium leading-snug tracking-tight"
			style="font-family: var(--font-headline); color: #FFFFFF;" data-hero-entrance
		>
			{heading}
		</h1>
	</div>
</section>

{(subheading || primaryCtaLabel) && (
	<section style="background-color: var(--color-canvas);" class="py-8 md:py-12 px-4 md:px-6">
		<div class="max-w-2xl mx-auto text-center" data-reveal>
			{subheading && (
				<p
					class="text-lg md:text-xl leading-relaxed mb-10"
					style="font-family: var(--font-body); color: var(--color-muted);"
				>
					{subheading}
				</p>
			)}
			{primaryCtaLabel && primaryCtaHref && (
				<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
					<a
						href={primaryCtaHref}
						class="inline-flex items-center px-8 py-3.5 text-base font-semibold no-underline transition-all duration-200"
						style="font-family: var(--font-body); background: linear-gradient(135deg, var(--color-primary), var(--color-primary-container)); color: var(--color-on-primary);"
						onmouseover="this.style.opacity='0.9'"
						onmouseout="this.style.opacity='1'"
					>
						{primaryCtaLabel}
					</a>
					{secondaryCtaLabel && secondaryCtaHref && (
						<a
							href={secondaryCtaHref}
							class="inline-flex items-center px-8 py-3.5 text-base font-medium no-underline border transition-all duration-200"
							style="font-family: var(--font-body); color: var(--color-primary); border-color: var(--color-primary);"
							onmouseover="this.style.backgroundColor='var(--color-primary)'; this.style.color='var(--color-on-primary)';"
							onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--color-primary)';"
						>
							{secondaryCtaLabel}
						</a>
					)}
				</div>
			)}
		</div>
	</section>
)}
