---
// Donor feed — recent public donations with name, amount, message, reactions,
// and an optional public reply from FHB (Kevin & Shelly, posted via the
// community moderation panel). Shows the first 5; "Load more supporters"
// reveals 5 more per click (donor-wall pattern). Re-renders whenever
// ProgressBar fires the donations:updated event.

interface Props {
	campaign?: string;
}
const { campaign = 'fhb' } = Astro.props;

const INITIAL = 3;
const STEP = 5;
const TOOLS_API = 'https://tools-api.spiritmediapublishing.com';

// The three positive reactions visitors can tap (order = display order).
const REACTIONS = [
	{ key: 'love', emoji: '❤️', label: 'Love' },
	{ key: 'amen', emoji: '🙌', label: 'Amen' },
	{ key: 'fire', emoji: '🔥', label: 'Fired up' },
];

let initial: any = { recent: [] };
try {
	const res = await fetch(`${TOOLS_API}/api/donations/public?campaign=${campaign}`);
	if (res.ok) initial = await res.json();
} catch {}

const full: any[] = initial.recent || [];
const firstBatch = full.slice(0, INITIAL);
const remaining = Math.max(0, full.length - INITIAL);

// Show gifts as # of Bibles ($5 = 1 Bible) rather than dollars — keeps the feed
// mission-framed and avoids donors comparing dollar amounts.
const fmt = (c: number) => {
	const n = Math.floor(c / 500);
	return n === 1 ? '1 Bible' : `${n.toLocaleString('en-US')} Bibles`;
};
// Privacy: show first name(s) + last initial only (e.g. "Ryan S.", "Mickey and Suzan C.").
const displayName = (name: string) => {
	const parts = (name || '').trim().split(/\s+/).filter(Boolean);
	if (parts.length <= 1) return parts[0] || 'A supporter';
	return `${parts.slice(0, -1).join(' ')} ${parts[parts.length - 1].charAt(0).toUpperCase()}.`;
};
const dateAgo = (iso: string) => {
	if (!iso) return '';
	const then = new Date(iso).getTime();
	const days = Math.max(0, Math.floor((Date.now() - then) / 86_400_000));
	if (days === 0) return 'today';
	if (days === 1) return '1 day ago';
	if (days < 30) return `${days} days ago`;
	const months = Math.floor(days / 30);
	if (months === 1) return '1 month ago';
	return `${months} months ago`;
};
---

<div data-donor-feed data-initial={INITIAL} data-step={STEP} data-api={TOOLS_API} class="space-y-4">
	<script type="application/json" data-donor-data set:html={JSON.stringify(full)}></script>
	{full.length === 0 ? (
		<p style="color: var(--color-muted); font-family: var(--font-sans);">Be the first to partner with us.</p>
	) : (
		<>
			<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: var(--color-brand); font-family: var(--font-sans);">
				Recent Supporters
			</p>
			<ul class="space-y-3" data-donor-list style="list-style: none; padding: 0; margin: 0;">
				{firstBatch.map((d: any) => (
					<li style="background-color: var(--color-surface); border: 1px solid var(--color-outline-variant); border-radius: 12px; padding: 16px 20px;">
						<div class="flex items-baseline justify-between gap-3">
							<p class="font-semibold" style="font-family: var(--font-sans); color: var(--color-ink);">{displayName(d.public_name)}</p>
							<p class="text-sm font-semibold whitespace-nowrap" style="font-family: var(--font-sans); color: var(--color-brand);">{fmt(d.amount_cents)}</p>
						</div>
						{d.public_message && (
							<p class="mt-2 leading-relaxed" style="font-family: var(--font-serif); color: var(--color-muted); font-size: 0.95rem;">
								{d.public_message}
							</p>
						)}
						{d.reply && d.reply.text && (
							<div class="mt-3 pl-3" style="border-left: 2px solid var(--color-brand);">
								<p class="text-xs font-semibold" style="font-family: var(--font-sans); color: var(--color-brand);">{d.reply.author || 'Kevin & Shelly'} replied</p>
								<p class="mt-0.5 leading-relaxed" style="font-family: var(--font-serif); color: var(--color-ink); font-size: 0.95rem;">{d.reply.text}</p>
							</div>
						)}
						<div class="mt-3 flex items-center gap-2" data-react-row data-pid={d.pid}>
							{REACTIONS.map((r) => (
								<button type="button" data-react data-pid={d.pid} data-kind={r.key}
									aria-label={r.label}
									class="react-btn inline-flex items-center gap-1 rounded-full transition-colors"
									style="padding: 4px 10px; border: 1px solid var(--color-outline-variant); background-color: var(--color-surface-low); font-family: var(--font-sans); font-size: 0.85rem; cursor: pointer; line-height: 1;">
									<span aria-hidden="true">{r.emoji}</span>
									<span data-count style="color: var(--color-muted); font-weight: 600;">{(d.reactions?.[r.key] || 0) > 0 ? d.reactions[r.key] : ''}</span>
								</button>
							))}
						</div>
											</li>
				))}
			</ul>
			{remaining > 0 && (
				<button data-load-more type="button" class="w-full" style="margin-top: 4px; padding: 12px 16px; background-color: transparent; border: 1px solid var(--color-outline-variant); border-radius: 12px; color: var(--color-brand); font-family: var(--font-sans); font-weight: 600; font-size: 0.9rem; cursor: pointer;">
					Load more supporters
				</button>
			)}
		</>
	)}
</div>

<style>
	.react-btn[data-tapped="true"] {
		background-color: #FFD9E0 !important;
		border-color: #E89DB0 !important;
	}
	.react-btn:hover {
		border-color: var(--color-brand);
	}
</style>

<script>
	const INITIAL = 3;
	const STEP = 5;
	const TOOLS_API = 'https://tools-api.spiritmediapublishing.com';
	const REACTIONS = [
		{ key: 'love', emoji: '❤️', label: 'Love' },
		{ key: 'amen', emoji: '🙌', label: 'Amen' },
		{ key: 'fire', emoji: '🔥', label: 'Fired up' },
	];
	let current: any[] = [];
	let visible = INITIAL;

	function fmtMoney(cents: number) {
		const n = Math.floor(cents / 500);
		return n === 1 ? '1 Bible' : `${n.toLocaleString('en-US')} Bibles`;
	}
	function dateAgo(iso: string) {
		if (!iso) return '';
		const days = Math.max(0, Math.floor((Date.now() - new Date(iso).getTime()) / 86_400_000));
		if (days === 0) return 'today';
		if (days === 1) return '1 day ago';
		if (days < 30) return `${days} days ago`;
		const months = Math.floor(days / 30);
		return months === 1 ? '1 month ago' : `${months} months ago`;
	}
	function escapeHtml(s: string) {
		return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] || c));
	}
	function displayName(name: string) {
		const parts = (name || '').trim().split(/\s+/).filter(Boolean);
		if (parts.length <= 1) return parts[0] || 'A supporter';
		return `${parts.slice(0, -1).join(' ')} ${parts[parts.length - 1].charAt(0).toUpperCase()}.`;
	}
	function tapped(pid: string, kind: string) {
		try { return localStorage.getItem(`fhbReact:${pid}:${kind}`) === '1'; } catch { return false; }
	}
	function reactionButtons(d: any) {
		return REACTIONS.map((r) => {
			const count = d.reactions?.[r.key] || 0;
			const isTapped = tapped(d.pid, r.key);
			return `<button type="button" data-react data-pid="${d.pid}" data-kind="${r.key}" aria-label="${r.label}" data-tapped="${isTapped ? 'true' : 'false'}" class="react-btn inline-flex items-center gap-1 rounded-full transition-colors" style="padding: 4px 10px; border: 1px solid var(--color-outline-variant); background-color: var(--color-surface-low); font-family: var(--font-sans); font-size: 0.85rem; cursor: pointer; line-height: 1;"><span aria-hidden="true">${r.emoji}</span><span data-count style="color: var(--color-muted); font-weight: 600;">${count > 0 ? count : ''}</span></button>`;
		}).join('');
	}

	function render() {
		const root = document.querySelector('[data-donor-feed]');
		if (!root) return;
		if (!current || current.length === 0) {
			root.innerHTML = `<p style="color: var(--color-muted); font-family: var(--font-sans);">Be the first to partner with us.</p>`;
			return;
		}
		const shown = current.slice(0, visible);
		const remaining = Math.max(0, current.length - visible);
		root.innerHTML = `
			<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: var(--color-brand); font-family: var(--font-sans);">Recent Supporters</p>
			<ul class="space-y-3" data-donor-list style="list-style: none; padding: 0; margin: 0;">
				${shown.map((d: any) => `
					<li style="background-color: var(--color-surface); border: 1px solid var(--color-outline-variant); border-radius: 12px; padding: 16px 20px;">
						<div class="flex items-baseline justify-between gap-3">
							<p class="font-semibold" style="font-family: var(--font-sans); color: var(--color-ink);">${escapeHtml(displayName(d.public_name))}</p>
							<p class="text-sm font-semibold whitespace-nowrap" style="font-family: var(--font-sans); color: var(--color-brand);">${fmtMoney(d.amount_cents)}</p>
						</div>
						${d.public_message ? `<p class="mt-2 leading-relaxed" style="font-family: var(--font-serif); color: var(--color-muted); font-size: 0.95rem;">${escapeHtml(d.public_message)}</p>` : ''}
						${d.reply && d.reply.text ? `<div class="mt-3 pl-3" style="border-left: 2px solid var(--color-brand);"><p class="text-xs font-semibold" style="font-family: var(--font-sans); color: var(--color-brand);">${escapeHtml(d.reply.author || 'Kevin & Shelly')} replied</p><p class="mt-0.5 leading-relaxed" style="font-family: var(--font-serif); color: var(--color-ink); font-size: 0.95rem;">${escapeHtml(d.reply.text)}</p></div>` : ''}
						<div class="mt-3 flex items-center gap-2" data-react-row data-pid="${d.pid}">${reactionButtons(d)}</div>
					</li>
				`).join('')}
			</ul>
			${remaining > 0 ? `<button data-load-more type="button" class="w-full" style="margin-top: 4px; padding: 12px 16px; background-color: transparent; border: 1px solid var(--color-outline-variant); border-radius: 12px; color: var(--color-brand); font-family: var(--font-sans); font-weight: 600; font-size: 0.9rem; cursor: pointer;">Load more supporters</button>` : ''}
		`;
	}

	function init() {
		const root = document.querySelector('[data-donor-feed]');
		if (!root) return;
		const json = root.querySelector('[data-donor-data]')?.textContent;
		if (json) {
			try { current = JSON.parse(json) || []; } catch { current = []; }
			render();
		}
	}

	// Reaction tap — optimistic, one tap per reaction per donation per browser.
	document.addEventListener('click', async (e) => {
		const btn = (e.target as HTMLElement)?.closest('[data-react]') as HTMLElement | null;
		if (!btn) return;
		const pid = btn.dataset.pid || '';
		const kind = btn.dataset.kind || '';
		if (!pid || !kind || tapped(pid, kind)) return;
		// Optimistic: bump the count + mark tapped immediately.
		const countEl = btn.querySelector('[data-count]') as HTMLElement | null;
		const prev = parseInt(countEl?.textContent || '0', 10) || 0;
		if (countEl) countEl.textContent = String(prev + 1);
		btn.dataset.tapped = 'true';
		try { localStorage.setItem(`fhbReact:${pid}:${kind}`, '1'); } catch {}
		try {
			const res = await fetch(`${TOOLS_API}/api/donations/react`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ pid, kind }),
			});
			if (res.ok) {
				const data = await res.json();
				const server = data?.reactions?.[kind];
				if (countEl && Number.isFinite(server)) countEl.textContent = server > 0 ? String(server) : '';
			} else {
				throw new Error('react failed');
			}
		} catch {
			// Roll back on failure.
			if (countEl) countEl.textContent = prev > 0 ? String(prev) : '';
			btn.dataset.tapped = 'false';
			try { localStorage.removeItem(`fhbReact:${pid}:${kind}`); } catch {}
		}
	});

	// Load more (delegated — survives re-render)
	document.addEventListener('click', (e) => {
		const btn = (e.target as HTMLElement)?.closest('[data-load-more]');
		if (!btn) return;
		visible += STEP;
		render();
	});

	// Live refresh from ProgressBar's poll — keep however many the visitor expanded.
	window.addEventListener('donations:updated', (e: any) => {
		current = e.detail?.recent || [];
		render();
	});

	document.addEventListener('astro:page-load', init);
	if (document.readyState !== 'loading') init();
	else document.addEventListener('DOMContentLoaded', init);
</script>
