---
// Live progress bar pulling from tools-api donations endpoint.
// Hydrates client-side every 30s while the page is open so a fresh
// donation appears in real time without a refresh.

interface Props {
	campaign?: string;
}
const { campaign = 'fhb' } = Astro.props;

// Server-side fetch for first paint
let initial = {
	goal_cents: 10000000,
	raised_cents: 0,
	supporter_count: 0,
	label: "Father's Heart Bible™",
};
try {
	const res = await fetch(
		`https://tools-api.spiritmediapublishing.com/api/donations/public?campaign=${campaign}`,
	);
	if (res.ok) initial = await res.json();
} catch {}

const fmt = (c: number) => `$${(c / 100).toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
const pct = Math.min(
	100,
	Math.round((initial.raised_cents / Math.max(initial.goal_cents, 1)) * 100),
);
---

<div
	class="donation-progress"
	data-campaign={campaign}
	data-goal-cents={initial.goal_cents}
	style="background-color: var(--color-surface); border: 1px solid var(--color-outline-variant); border-radius: 16px; padding: 28px 28px 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.04);"
>
	<div class="flex items-baseline justify-between mb-2">
		<p class="text-3xl md:text-4xl font-light" style="font-family: var(--font-serif); color: var(--color-ink);">
			<span data-progress-raised>{fmt(initial.raised_cents)}</span>
		</p>
		<p class="text-sm" style="color: var(--color-muted); font-family: var(--font-sans);">
			<span data-progress-pct>{pct}</span>% of <span data-progress-goal>{fmt(initial.goal_cents)}</span> goal
		</p>
	</div>
	<div class="w-full rounded-full overflow-hidden" style="background-color: var(--color-outline-variant); height: 8px;">
		<div data-progress-fill style={`width: ${pct}%; height: 100%; background-color: var(--color-brand); transition: width 600ms ease;`}></div>
	</div>
	<p class="mt-3 text-sm" style="color: var(--color-muted); font-family: var(--font-sans);">
		<span data-progress-supporters>{initial.supporter_count}</span> supporter<span data-progress-supporters-plural>{initial.supporter_count === 1 ? '' : 's'}</span>
	</p>
</div>

<script>
	function fmtMoney(cents: number) {
		return `$${(cents / 100).toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
	}

	async function refreshProgress() {
		const root = document.querySelector('[data-campaign]') as HTMLElement | null;
		if (!root) return;
		const campaign = root.dataset.campaign || 'fhb';
		try {
			const res = await fetch(`https://tools-api.spiritmediapublishing.com/api/donations/public?campaign=${campaign}`);
			if (!res.ok) return;
			const d = await res.json();
			const pct = Math.min(100, Math.round((d.raised_cents / Math.max(d.goal_cents, 1)) * 100));
			const set = (sel: string, val: string) => {
				const el = root.querySelector(`[${sel}]`) as HTMLElement | null;
				if (el) el.textContent = val;
			};
			set('data-progress-raised', fmtMoney(d.raised_cents));
			set('data-progress-goal', fmtMoney(d.goal_cents));
			set('data-progress-pct', String(pct));
			set('data-progress-supporters', String(d.supporter_count));
			set('data-progress-supporters-plural', d.supporter_count === 1 ? '' : 's');
			const fill = root.querySelector('[data-progress-fill]') as HTMLElement | null;
			if (fill) fill.style.width = `${pct}%`;
			// Surface to other components on the page (DonorFeed listens for this)
			window.dispatchEvent(new CustomEvent('donations:updated', { detail: d }));
		} catch {}
	}

	// Poll every 30s while page is visible
	let timer: number | null = null;
	function start() {
		if (timer) return;
		timer = window.setInterval(refreshProgress, 30_000);
	}
	function stop() {
		if (timer) { window.clearInterval(timer); timer = null; }
	}
	document.addEventListener('astro:page-load', () => {
		refreshProgress();
		start();
	});
	document.addEventListener('visibilitychange', () => {
		if (document.hidden) stop();
		else { refreshProgress(); start(); }
	});
	if (document.readyState !== 'loading') {
		refreshProgress();
		start();
	}
</script>
