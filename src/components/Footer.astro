---
import { sanityClient } from '../lib/sanity';

const siteSettings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    siteName,
    publisherName,
    email,
    phone,
    facebook,
    instagram,
    youtube,
    footerQuote
  }
`);

const year = new Date().getFullYear();
const companyName = siteSettings?.siteName || "Father's Heart Bible";
const publisher = siteSettings?.publisherName || 'Spirit Media Inc';
const email = siteSettings?.email;
const phone = siteSettings?.phone;
const facebook = siteSettings?.facebook;
const instagram = siteSettings?.instagram;
const youtube = siteSettings?.youtube;
const footerQuote =
	siteSettings?.footerQuote || 'I will be their Father, and they will be my sons and daughters.';
---

<footer style="background-color: var(--color-inverse-surface);">
	<div class="max-w-6xl mx-auto px-6 pt-14 pb-8">
		<!-- Scripture quote -->
		<div class="text-center mb-10">
			<blockquote
				class="text-2xl md:text-3xl font-light leading-relaxed"
				style="font-family: var(--font-headline); color: var(--color-inverse-on-surface);"
			>
				"{footerQuote}"
			</blockquote>
			<cite
				class="block mt-4 text-xs not-italic tracking-[0.15em] uppercase"
				style="font-family: var(--font-body); color: var(--color-outline);"
			>
				— Revelation 21:7
			</cite>
		</div>

		<!-- Links grid -->
		<div class="flex flex-wrap justify-center gap-x-8 gap-y-3 mb-10 text-xs tracking-[0.08em] uppercase" style="font-family: var(--font-body);">
			<a href="/" class="no-underline transition-opacity duration-200" style="color: var(--color-outline);" onmouseover="this.style.color='var(--color-inverse-on-surface)'" onmouseout="this.style.color='var(--color-outline)'">Home</a>
			<a href="/the-fathers-heart-bible" class="no-underline transition-opacity duration-200" style="color: var(--color-outline);" onmouseover="this.style.color='var(--color-inverse-on-surface)'" onmouseout="this.style.color='var(--color-outline)'">About FHB</a>
			<a href="/samples" class="no-underline transition-opacity duration-200" style="color: var(--color-outline);" onmouseover="this.style.color='var(--color-inverse-on-surface)'" onmouseout="this.style.color='var(--color-outline)'">Samples</a>
			<a href="/join" class="no-underline transition-opacity duration-200" style="color: var(--color-outline);" onmouseover="this.style.color='var(--color-inverse-on-surface)'" onmouseout="this.style.color='var(--color-outline)'">Join the Movement</a>
			<a href="/partner" class="no-underline transition-opacity duration-200" style="color: var(--color-outline);" onmouseover="this.style.color='var(--color-inverse-on-surface)'" onmouseout="this.style.color='var(--color-outline)'">Partner With Us</a>
			<a href="/about" class="no-underline transition-opacity duration-200" style="color: var(--color-outline);" onmouseover="this.style.color='var(--color-inverse-on-surface)'" onmouseout="this.style.color='var(--color-outline)'">About</a>
		</div>

		<!-- Contact -->
		<div class="flex flex-wrap justify-center gap-6 mb-10" style="font-family: var(--font-body);">
			<a
				href="mailto:hello@fathersheartbible.com"
				class="inline-flex items-center px-6 py-2.5 text-xs font-semibold uppercase no-underline tracking-[0.08em] transition-all duration-200"
				style="background: linear-gradient(135deg, var(--color-primary), var(--color-primary-container)); color: var(--color-on-primary); border-radius: 0.125rem;"
				onmouseover="this.style.opacity='0.85'"
				onmouseout="this.style.opacity='1'"
			>
				Contact Us
			</a>
			{phone && (
				<a href={`tel:${phone}`} class="no-underline transition-colors duration-200 text-sm" style="color: var(--color-outline);" onmouseover="this.style.color='var(--color-inverse-on-surface)'" onmouseout="this.style.color='var(--color-outline)'">{phone}</a>
			)}
		</div>

		<!-- Social -->
		{(facebook || instagram || youtube) && (
			<div class="flex items-center justify-center gap-6 mb-10">
				{facebook && (
					<a href={facebook} target="_blank" rel="noopener noreferrer" title="Facebook" style="color: var(--color-outline);" onmouseover="this.style.color='var(--color-inverse-on-surface)'" onmouseout="this.style.color='var(--color-outline)'">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.879V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
						</svg>
					</a>
				)}
				{instagram && (
					<a href={instagram} target="_blank" rel="noopener noreferrer" title="Instagram" style="color: var(--color-outline);" onmouseover="this.style.color='var(--color-inverse-on-surface)'" onmouseout="this.style.color='var(--color-outline)'">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.914 4.914 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.913 4.913 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.466.182-.8.398-1.15.748-.35.35-.566.684-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.684.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.684.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
						</svg>
					</a>
				)}
				{youtube && (
					<a href={youtube} target="_blank" rel="noopener noreferrer" title="YouTube" style="color: var(--color-outline);" onmouseover="this.style.color='var(--color-inverse-on-surface)'" onmouseout="this.style.color='var(--color-outline)'">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M19.615 3.175c-3.673-1.73-13.156-1.73-16.829 0C.61 4.905 0 8.236 0 12s.61 7.095 2.786 8.825c3.673 1.73 13.156 1.73 16.829 0C23.39 19.095 24 15.764 24 12s-.61-7.095-2.785-8.825zm-10.615 12.825V8.25l6 4v4.75h-6z" />
						</svg>
					</a>
				)}
			</div>
		)}

		<!-- Copyright -->
		<div class="flex flex-col md:flex-row items-center justify-between gap-3 text-xs pt-8" style="font-family: var(--font-body); color: var(--color-outline); border-top: 1px solid rgba(132,115,119,0.15);">
			<p>&copy; {year} Father's Heart Bible. All rights reserved.</p>
			<p>Powered by <a href="https://spiritmediapublishing.com" target="_blank" rel="noopener noreferrer" class="no-underline transition-colors duration-200" style="color: var(--color-inverse-primary);" onmouseover="this.style.color='var(--color-inverse-on-surface)'" onmouseout="this.style.color='var(--color-inverse-primary)'">Spirit Media</a></p>
		</div>
	</div>
</footer>
