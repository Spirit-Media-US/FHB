---
import { sanityClient } from '../lib/sanity';
import MailtoLink from './MailtoLink.astro';

const siteSettings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    footerQuote,
    email
  }
`);

const year = new Date().getFullYear();
const footerQuote =
	siteSettings?.footerQuote || 'I will be their Father, and they will be my sons and daughters.';
const contactEmail = siteSettings?.email || 'hello@fathersheartbible.com';
---

<footer style="background-color: var(--color-inverse-surface);">
	<div class="max-w-6xl mx-auto px-4 md:px-6 py-8 md:py-10" data-reveal="fade">
		<!-- Scripture quote -->
		<div class="text-center mb-6">
			<blockquote
				class="text-xl md:text-2xl font-light leading-relaxed"
				style="font-family: var(--font-headline); color: var(--color-inverse-on-surface);"
			>
				"{footerQuote}"
			</blockquote>
			<cite
				class="block mt-2 text-xs not-italic tracking-[0.15em] uppercase"
				style="font-family: var(--font-body); color: var(--color-inverse-primary);"
			>
				— Revelation 21:7
			</cite>
		</div>

		<!-- Nav + Contact -->
		<div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 mb-6 text-sm tracking-[0.08em] uppercase" style="font-family: var(--font-body);">
			<a href="/" class="no-underline" style="color: var(--color-inverse-on-surface); opacity: 0.6;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">Home</a>
			<a href="/the-fathers-heart-bible" class="no-underline" style="color: var(--color-inverse-on-surface); opacity: 0.6;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">About FHB</a>
			<a href="/samples" class="no-underline" style="color: var(--color-inverse-on-surface); opacity: 0.6;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">Samples</a>
			<a href="/join" class="no-underline" style="color: var(--color-inverse-on-surface); opacity: 0.6;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">Join</a>
			<a href="/partner" class="no-underline" style="color: var(--color-inverse-on-surface); opacity: 0.6;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">Partner</a>
			<MailtoLink email={contactEmail} class="no-underline" style="color: var(--color-inverse-on-surface); opacity: 0.6;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">Contact</MailtoLink>
		</div>

		<!-- Copyright -->
		<div class="flex flex-col md:flex-row items-center justify-between gap-2 text-sm pt-4" style="font-family: var(--font-body); color: var(--color-inverse-on-surface); opacity: 0.5; border-top: 1px solid rgba(241,241,241,0.1);">
			<p>&copy; {year} Father's Heart Bible. All rights reserved.</p>
			<div class="flex items-center gap-4">
				<a href="/privacy" class="no-underline transition-colors duration-200 text-sm" style="color: var(--color-inverse-on-surface); opacity: 0.6;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">Privacy</a>
				<a href="/terms" class="no-underline transition-colors duration-200 text-sm" style="color: var(--color-inverse-on-surface); opacity: 0.6;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">Terms</a>
				<span style="opacity: 0.3;">·</span>
				<p>Powered by <a href="https://spiritmediapublishing.com" target="_blank" rel="noopener noreferrer" class="no-underline transition-colors duration-200" style="color: var(--color-inverse-primary);" onmouseover="this.style.color='var(--color-inverse-on-surface)'" onmouseout="this.style.color='var(--color-inverse-primary)'">Spirit Media Publishing</a></p>
			</div>
		</div>
	</div>
</footer>
