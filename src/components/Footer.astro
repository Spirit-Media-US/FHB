---
import { sanityClient } from '../lib/sanity';

// Fetch siteSettings for dynamic footer content
const siteSettings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    siteName,
    publisherName,
    email,
    phone,
    facebook,
    instagram,
    youtube,
    partnerPageUrl,
    footerQuote
  }
`);

const year = new Date().getFullYear();
const companyName = siteSettings?.siteName || "Father's Heart Bible";
const publisher = siteSettings?.publisherName || "Spirit Media Inc";
const email = siteSettings?.email;
const phone = siteSettings?.phone;
const facebook = siteSettings?.facebook;
const instagram = siteSettings?.instagram;
const youtube = siteSettings?.youtube;
const footerQuote = siteSettings?.footerQuote || "I will be their Father, and they will be my sons and daughters.";
---

<footer style="background-color: var(--color-ink);">
	<div class="max-w-6xl mx-auto px-6 py-16">
		<!-- Scripture quote -->
		<div class="text-center mb-12">
			<blockquote class="text-xl md:text-2xl italic leading-relaxed" style="font-family: var(--font-serif); color: var(--color-stone);">
				"{footerQuote}"
			</blockquote>
			<cite class="block mt-3 text-sm not-italic tracking-wide" style="font-family: var(--font-sans); color: var(--color-warm-gray);">
				— Revelation 21:7
			</cite>
		</div>

		<!-- Divider -->
		<div class="w-16 h-px mx-auto mb-12" style="background-color: var(--color-charcoal);"></div>

		<!-- Links & info -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
			<!-- Navigation & Contact -->
			<div class="flex flex-col gap-4">
				<div class="flex flex-col md:flex-row items-start md:items-center gap-6 text-sm" style="color: var(--color-warm-gray); font-family: var(--font-sans);">
					<div class="flex gap-4">
						<a href="/about" class="no-underline transition-colors duration-200 hover:text-[var(--color-stone)]" style="color: var(--color-warm-gray);">About</a>
						<a href="/sample" class="no-underline transition-colors duration-200 hover:text-[var(--color-stone)]" style="color: var(--color-warm-gray);">Preface</a>
						<a href="/partner" class="no-underline transition-colors duration-200 hover:text-[var(--color-stone)]" style="color: var(--color-warm-gray);">Partner</a>
						<a href="/contact" class="no-underline transition-colors duration-200 hover:text-[var(--color-stone)]" style="color: var(--color-warm-gray);">Contact</a>
					</div>
				</div>
			</div>

			<!-- Contact Info -->
			<div class="text-sm" style="color: var(--color-warm-gray); font-family: var(--font-sans);">
				{email && (
					<p class="mb-2">
						<a href={`mailto:${email}`} class="no-underline transition-colors duration-200 hover:text-[var(--color-stone)]" style="color: var(--color-warm-gray);">
							{email}
						</a>
					</p>
				)}
				{phone && (
					<p>
						<a href={`tel:${phone}`} class="no-underline transition-colors duration-200 hover:text-[var(--color-stone)]" style="color: var(--color-warm-gray);">
							{phone}
						</a>
					</p>
				)}
			</div>
		</div>

		<!-- Social Links -->
		{(facebook || instagram || youtube) && (
			<div class="flex items-center justify-center gap-6 mb-8">
				{facebook && (
					<a href={facebook} target="_blank" rel="noopener noreferrer" class="transition-colors duration-200 hover:text-[var(--color-stone)]" style="color: var(--color-warm-gray);" title="Facebook">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.879V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
						</svg>
					</a>
				)}
				{instagram && (
					<a href={instagram} target="_blank" rel="noopener noreferrer" class="transition-colors duration-200 hover:text-[var(--color-stone)]" style="color: var(--color-warm-gray);" title="Instagram">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.914 4.914 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.913 4.913 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.466.182-.8.398-1.15.748-.35.35-.566.684-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.684.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.684.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
						</svg>
					</a>
				)}
				{youtube && (
					<a href={youtube} target="_blank" rel="noopener noreferrer" class="transition-colors duration-200 hover:text-[var(--color-stone)]" style="color: var(--color-warm-gray);" title="YouTube">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M19.615 3.175c-3.673-1.73-13.156-1.73-16.829 0C.61 4.905 0 8.236 0 12s.61 7.095 2.786 8.825c3.673 1.73 13.156 1.73 16.829 0C23.39 19.095 24 15.764 24 12s-.61-7.095-2.785-8.825zm-10.615 12.825V8.25l6 4v4.75h-6z" />
						</svg>
					</a>
				)}
			</div>
		)}

		<!-- Copyright & Publisher -->
		<div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm" style="color: var(--color-warm-gray); font-family: var(--font-sans);">
			<p>
				&copy; {year} {companyName} · {companyName} LLC
			</p>
			<p>
				Published by {publisher}
			</p>
		</div>
	</div>
</footer>

<script>
  const el = document.getElementById('footer-year');
  if (el) el.textContent = new Date().getFullYear().toString();
</script>
