---
// Reusable "How-To Hub" card grid — the same cards shown on the /guides/ hub,
// rendered at the bottom of blog pages so the cluster cross-links both ways.
// Pulls from the shared src/data/guides.ts so the list never drifts.
//
// Props:
//   heading   — optional section heading (omit to render just the grid, e.g. on the hub)
//   eyebrow   — small label above the heading (default "The How-To Hub")
//   exclude   — slug to drop (e.g. hide the current guide when used on a guide page)
import { GUIDES } from '../data/guides';

interface Props {
	heading?: string;
	eyebrow?: string;
	exclude?: string;
	bg?: string;
}
const {
	heading,
	eyebrow = 'The How-To Hub',
	exclude,
	bg = 'var(--color-surface-low)',
} = Astro.props;
const cards = GUIDES.filter((g) => g.slug !== exclude);
// Keep heading order valid: when there's NO section heading above the grid (the
// /guides hub), the card titles sit directly under the page <h1> and must be
// <h2> (else h1→h3 skips a level — a11y heading-order fail). When a section
// <h2> heading IS rendered (blog pages), the cards are its <h3> children.
const CardHeading = heading ? 'h3' : 'h2';
---

<section class="px-6 py-12 lg:px-8 lg:py-16" style={`background-color: ${bg};`}>
	<div class="mx-auto max-w-4xl">
		{heading && (
			<div class="text-center mb-8">
				{eyebrow && (
					<p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-brand); font-family: var(--font-sans);">{eyebrow}</p>
				)}
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{heading}</h2>
			</div>
		)}
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
			{cards.map((g) => (
				<a href={`/guides/${g.slug}/`} class="block rounded-2xl overflow-hidden no-underline transition-all hover:opacity-95" style="background-color: var(--color-surface-lowest); border: 1px solid var(--color-hairline);">
					<img src={`${g.img}?w=800&h=460&fit=crop&crop=entropy&fm=webp&q=70`} alt={g.title} width="800" height="460" class="w-full h-44 object-cover" loading="lazy" decoding="async" />
					<div class="p-5">
						<CardHeading class="text-xl font-medium leading-snug" style="font-family: var(--font-serif); color: var(--color-ink);">{g.title}</CardHeading>
						<p class="mt-2 text-base leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">{g.blurb}</p>
						<span class="inline-flex items-center gap-1.5 mt-4 text-sm font-semibold" style="color: var(--color-brand); font-family: var(--font-sans);">Read the guide <span aria-hidden="true">&rarr;</span></span>
					</div>
				</a>
			))}
		</div>
	</div>
</section>
