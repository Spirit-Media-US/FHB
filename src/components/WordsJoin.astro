---
// "Receive each message" — email (+ optional mobile) capture for the
// Messages from the Father series. Posts to /words-join (CF Pages Function →
// GHL upsert on the SMP location, tagged messages-from-the-father).
// Growth engine for the series: every post and the hub carry this form.
interface Props {
	compact?: boolean;
}
const { compact = false } = Astro.props;
---

<aside
	class:list={['words-join my-12 px-6 rounded-2xl text-center', compact ? 'py-8' : 'py-10 lg:px-10 lg:py-12']}
	style="background-color: #fdf2f5; border: 1px solid #f9d6e0;"
>
	<p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: #a04060; font-family: var(--font-sans);">
		Messages from the Father
	</p>
	<p class="text-2xl md:text-3xl font-light leading-tight max-w-2xl mx-auto" style="font-family: var(--font-serif); color: var(--color-ink);">
		Receive each message as it comes
	</p>
	<p class="mt-3 max-w-xl mx-auto text-base leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">
		New words are delivered by email &mdash; and by text if you leave a mobile number. Unsubscribe anytime.
	</p>
	<form class="words-join-form mt-6 mx-auto max-w-md flex flex-col gap-3" novalidate>
		<input
			type="email"
			name="email"
			required
			autocomplete="email"
			placeholder="Your email"
			class="w-full rounded-full px-5 py-3 text-sm"
			style="border: 1px solid #f9d6e0; background-color: var(--color-surface); color: var(--color-ink); font-family: var(--font-sans);"
		/>
		<input
			type="tel"
			name="phone"
			autocomplete="tel"
			placeholder="Mobile number (optional, for text delivery)"
			class="w-full rounded-full px-5 py-3 text-sm"
			style="border: 1px solid #f9d6e0; background-color: var(--color-surface); color: var(--color-ink); font-family: var(--font-sans);"
		/>
		<!-- honeypot -->
		<input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;height:0;width:0;opacity:0;" />
		<button
			type="submit"
			class="inline-flex items-center justify-center gap-2 px-7 py-3 rounded-full text-sm font-semibold transition-opacity hover:opacity-90"
			style="background-color: #FFD9E0; color: #4A4A4A; font-family: var(--font-sans); border: none; cursor: pointer;"
		>
			Send me each message
			<span aria-hidden="true">&rarr;</span>
		</button>
		<p class="words-join-status text-sm min-h-5" style="font-family: var(--font-sans); color: var(--color-muted);" aria-live="polite"></p>
	</form>
</aside>

<script>
	for (const form of document.querySelectorAll<HTMLFormElement>('.words-join-form')) {
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const status = form.querySelector<HTMLElement>('.words-join-status');
			const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
			const data = Object.fromEntries(new FormData(form).entries());
			const email = String(data.email || '').trim();
			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
				if (status) status.textContent = 'Please enter a valid email address.';
				return;
			}
			if (button) button.disabled = true;
			if (status) status.textContent = 'One moment…';
			try {
				const res = await fetch('/words-join', {
					method: 'POST',
					headers: { 'content-type': 'application/json' },
					body: JSON.stringify({
						email,
						phone: String(data.phone || '').trim(),
						website: String(data.website || ''),
						page: location.pathname,
					}),
				});
				if (!res.ok) throw new Error(String(res.status));
				form.reset();
				if (status) status.textContent = 'You’re in. The next message will come to your inbox.';
			} catch {
				if (status)
					status.textContent = 'Something went wrong — please try again in a moment.';
				if (button) button.disabled = false;
			}
		});
	}
</script>
