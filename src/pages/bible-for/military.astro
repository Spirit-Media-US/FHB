	h1={`The Bible for the Military`}
	heroEyebrow={`A Father For`}
	heroSubhead={`The mission asks for everything — your strength, your nerve, your time, the years away from the people you love. Here's the truth under the uniform: wherever you are deployed, you are not beyond your Father's reach. He goes with you, and He never leaves His post.`}
	heroBase={`https://cdn.sanity.io/images/rusi1hyi/production/7897521da975af184c679fedb9d2c92c27302382-1100x803.jpg`}
