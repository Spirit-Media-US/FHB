	offersBlocks={[
		{ heading: `A prize that never fades`, bodyHtml: `Train and compete with everything you have — but <a href="https://fathersheartbible.com/read/1-corinthians/9" style="color: var(--color-brand);" class="hover:underline">run for the crown that lasts forever</a>, not the one that tarnishes in a trophy case. Your Father's reward outlasts every season.` },
		{ heading: `Strength when your tank is empty`, bodyHtml: `When you've got nothing left, <a href="https://fathersheartbible.com/read/isaiah/40" style="color: var(--color-brand);" class="hover:underline">those who hope in your Father renew their strength</a> — they run and don't grow weary. His power picks up where yours runs out.` },
		{ heading: `Courage before the whistle`, bodyHtml: `When the nerves hit and the fear of failing looms, hear it: <a href="https://fathersheartbible.com/read/joshua/1" style="color: var(--color-brand);" class="hover:underline">your Father is with you wherever you go</a>. You don't step onto the field alone.` },
		{ heading: `Freedom from the crowd's approval`, bodyHtml: `When you compete for <a href="https://fathersheartbible.com/read/galatians/1" style="color: var(--color-brand);" class="hover:underline">your Father's approval</a> instead of everyone else's, the pressure to please the crowd finally loosens its grip. You're already accepted.` },
