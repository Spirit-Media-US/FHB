	offersBlocks={[
		{ heading: `A Father's compassion over you`, bodyHtml: `The tenderness you reach for is His first: <a href="https://fathersheartbible.com/read/psalms/103" style="color: var(--color-brand);" class="hover:underline">"as a father shows compassion to his children, so your Father shows compassion"</a> to you. You are fathered before you father.` },
		{ heading: `Adoption that ends the orphan ache`, bodyHtml: `You received <a href="https://fathersheartbible.com/read/romans/8" style="color: var(--color-brand);" class="hover:underline">the Spirit of adoption</a>, crying "Abba, Father." Whatever your dad gave or withheld, you have a perfect Father now — and a new name.` },
		{ heading: `Healing for the father-wound`, bodyHtml: `However far off you feel, <a href="https://fathersheartbible.com/read/luke/15" style="color: var(--color-brand);" class="hover:underline">the Father runs to embrace you</a>. The ache you carry from your own father is exactly what His running love came to heal.` },
