---
// /bible-for/pastors — group #2 in the "A Father For" series. Data only;
// rendered by <GroupBible>. Pastors are group 2 of the church-professional 5,
// so they carry the declaration: "You are a beloved son or daughter — not a
// slave, not a servant, not a tool, not a performer." Mirrors worship-leaders.
import GroupBible from '../../components/GroupBible.astro';

const verses = [
	{
		ref: 'Matthew 11:28',
		slug: 'matthew',
		ch: 11,
		text: 'Come to me, all who labor and are heavy laden, and I will give you rest.',
		note: 'You carry the weight of everyone else’s burdens. The One you point them to says: come and rest in Me first.',
	},
	{
		ref: '2 Corinthians 12:9',
		slug: '2-corinthians',
		ch: 12,
		text: 'My grace is sufficient for you, for my power is made perfect in weakness.',
		note: 'Your weakness is not disqualifying — it is the very place His power comes to rest on you.',
	},
	{
		ref: 'Isaiah 40:11',
		slug: 'isaiah',
		ch: 40,
		text: 'He will tend his flock like a shepherd; he will gather the lambs in his arms, and gently lead those that are with young.',
		note: 'You shepherd a flock — but you are also a lamb the Shepherd carries close to His heart.',
	},
	{
		ref: 'Matthew 6:6',
		slug: 'matthew',
		ch: 6,
		text: 'But when you pray, go into your room and shut the door and pray to your Father who is in secret. And your Father who sees in secret will reward you.',
		note: 'Before the platform, there is a closed door — and a Father who meets you where no one is watching.',
	},
	{
		ref: '2 Corinthians 1:3',
		slug: '2-corinthians',
		ch: 1,
		text: 'Blessed be the Father of mercies and God of all comfort, who comforts us in all our affliction.',
		note: 'You comfort everyone else. The Father of mercies is the One who comforts you.',
	},
	{
		ref: 'Galatians 1:10',
		slug: 'galatians',
		ch: 1,
		text: 'For am I now seeking the approval of man, or of God? If I were still trying to please man, I would not be a servant of Christ.',
		note: 'You will never please every member — and you were never meant to. You answer to a Father, not a crowd.',
	},
	{
		ref: 'John 21:17',
		slug: 'john',
		ch: 21,
		text: 'He said to him the third time, “Do you love me?” … Jesus said to him, “Feed my sheep.”',
		note: 'After Peter’s worst failure, he was not disqualified — he was restored, loved, and recommissioned.',
	},
	{
		ref: '1 Peter 5:4',
		slug: '1-peter',
		ch: 5,
		text: 'And when the chief Shepherd appears, you will receive the unfading crown of glory.',
		note: 'You are an under-shepherd, not the Chief. The weight of the whole flock was never yours to carry alone.',
	},
	{
		ref: 'Zephaniah 3:17',
		slug: 'zephaniah',
		ch: 3,
		text: 'Your Father is in your midst, a mighty one who will save; he will rejoice over you with gladness; he will quiet you by his love; he will exult over you with loud singing.',
		note: 'You speak over your people every week. Your Father is singing over you.',
	},
];

const faqs = [
	{
		question: 'What are good Bible verses for discouraged or burned-out pastors?',
		answer:
			"Matthew 11:28 (come to me and rest), 2 Corinthians 12:9 (my grace is sufficient, power perfected in weakness), Isaiah 40:11 (he gently leads), 2 Corinthians 1:3 (the Father of mercies comforts us), and John 21 (Jesus restoring Peter after failure) all speak directly to weary pastors. Read and hear them free in the Father's Heart Bible™ at fathersheartbible.com/read.",
	},
	{
		question: 'How can a pastor avoid burnout?',
		answer:
			"Burnout grows when a pastor pours out without first being filled — and when isolation hides the strain. You cannot give what you have not received. Pastors who last tend to guard a hidden life with the Father (Matthew 6:6), refuse to carry the flock alone (1 Peter 5:4 — Christ is the chief Shepherd), and let people-pleasing go (Galatians 1:10). Many begin by reading the Father's Heart Bible™ daily simply to be fathered, not to prepare a sermon.",
	},
	{
		question: 'What does the Bible say about pastors and failure?',
		answer:
			"Scripture is honest about leaders who fail — and it is full of restoration. Jesus reinstated Peter after his denial (John 21), and 2 Corinthians 12:9 says God's power is made perfect in weakness. Failure is not the end of your story with the Father; in the Father's Heart Bible™ you can read these passages free and hear a Father who restores, not just a God who requires.",
	},
	{
		question: 'Is there a free online Bible with audio for pastors?',
		answer:
			"Yes. The Father's Heart Bible™ is free to read and listen to online — no account, no purchase, no app. Open fathersheartbible.com/read on any phone or computer and read or hear any book, useful for study, devotion, or simply being fathered before you preach.",
	},
	{
		question: "What makes the Father's Heart Bible™ different for pastors?",
		answer:
			"It is the first English translation to reveal God as Father wherever Scripture reveals Him as Father — so the One you preach every week has a Father's face. For pastors, that reframes everything: you come to the text first as a beloved son or daughter being fathered, not only as a professional preparing to feed others.",
	},
	{
		question: 'What does the Bible say about resting as a pastor?',
		answer:
			"Rest is not laziness in Scripture — it is trust. Jesus invites the heavy-laden to come to Him for rest (Matthew 11:28), and Psalm 23 pictures the Shepherd making His own lie down. Even pastors need a Shepherd. The Father's Heart Bible™ lets you hear those passages as a Father's invitation, free with audio.",
	},
	{
		question: 'What does the Bible say to a pastor who wants to quit?',
		answer:
			"You are in good company — even Elijah, after a great victory, sat down under a tree and asked God to take his life (1 Kings 19). God did not rebuke him; He let him sleep, fed him, and spoke to him gently in a whisper. If you are at that point, the Father's Heart Bible™ lets you read that story and Jesus' invitation to the weary (Matthew 11:28) free, with audio — and meet a Father who restores His servants rather than discarding them.",
	},
];
---

<GroupBible
	slug="pastors"
	group="Pastors"
	groupLower="pastors"
	lastUpdated="June 2026"
	lastUpdatedIso="2026-06-14"
	title="Bible Verses for Pastors — Read Free with Audio | Father's Heart Bible™"
	description="Bible verses & encouragement for pastors facing burnout, free with audio. Meet the Father in the Father's Heart Bible™ — before you're a shepherd, you're a son."
	h1="The Bible for Pastors"
	heroEyebrow="A Father For"
	heroSubhead="For the ones who carry everyone else’s weight: a Bible that lets you be fathered before you shepherd — because even the shepherd needs a Shepherd."
	heroBase="https://cdn.sanity.io/images/rusi1hyi/production/141479390101f73507ff3662dec8e5c8e1427284-1100x733.jpg"
	heroAlt="A pastor standing alone in an empty sanctuary"
	heroObjectPosition="center center"
	directAnswerHtml={`<strong style=\"color: var(--color-ink);\">If you pastor, the Father&rsquo;s Heart Bible&trade; is for you.</strong> You preach grace, carry burdens, sit with the dying, and answer the phone at midnight &mdash; often while running on empty yourself. The <a href=\"https://fathersheartbible.com/read\" style=\"color: var(--color-brand);\" class=\"hover:underline\">Father&rsquo;s Heart Bible&trade;</a> is a fresh English translation you can read and <em>listen to</em> free on any phone &mdash; and it reveals the God you preach as <em>Father</em>, from Genesis to Revelation. Whether you&rsquo;re searching for &ldquo;Bible verses for pastors,&rdquo; &ldquo;encouragement for discouraged pastors,&rdquo; or a way through pastoral burnout, it begins in one place: before you are a shepherd, you are a son.`}
	keyTakeaway="Even the shepherd needs a Shepherd. You cannot give what you have not received — so before you feed anyone else, your Father invites you to be fathered, fed, and rested in His love."
	painsHeading="The weight pastors carry"
	painsIntroHtml={`Behind the Sunday smile and the steady counsel, many pastors are quietly breaking. The hours, the criticism, the isolation, and the impossible expectation to be everything to everyone are taking a sobering toll &mdash; and pastors are far less likely than anyone in their church to have someone shepherding <em>them</em>.`}
	painStats={[
		{ value: '~1 in 3', label: 'Protestant pastors seriously considered quitting full-time ministry in the past year' },
		{ value: '60%', label: 'have significantly doubted their calling' },
		{ value: '18%', label: 'have contemplated self-harm or suicide within the past year' },
		{ value: '43%', label: 'say they feel lonely and isolated in the work' },
		{ value: '56%', label: 'name the immense stress of the job as a reason they think about leaving' },
		{ value: '75%', label: 'of pastors who fell morally pointed to secrecy and isolation as the critical factor' },
	]}
	painsBodyHtml={`<p>Loneliness is the thread running through nearly all of it. The person everyone leans on often has no one to lean on; the one who absolves and counsels has nowhere to confess. Add financial strain, comparison with the church down the road, and the slow erosion of a private life with God beneath the public demands, and many pastors arrive at a quiet, frightening question: <em>am I loved here, or only needed?</em></p><p>These are not signs of weak faith or failed calling. They are the symptoms of a son or daughter who has been pouring out without being filled &mdash; a shepherd with no Shepherd. There is a Father who sees it, and who is after the pastor before He is after the performance.</p>`}
	painsSources={[
		{ label: 'Barna — pastors considering quitting', url: 'https://www.barna.com/research/pastors-quitting-ministry/' },
		{ label: 'Soul Shepherding — pastor stress statistics', url: 'https://www.soulshepherding.org/pastors-under-stress/' },
		{ label: 'NIMER — pastoral burnout, failure & restoration', url: 'https://nimer.ca/pastoral-burnout-failure-and-the-value-of-restoration/' },
	]}
	declarationHtml={`You are a <span style=\"color: var(--color-gold);\">beloved son</span> or <span style=\"color: var(--color-gold);\">daughter</span>.<br />Not a slave. Not a servant. Not a tool. Not a performer.`}
	aFatherHeading="A Father for pastors"
	aFatherBodyHtml={`<p>The answer to a worn-out pastor is not a better system, a bigger church, or more discipline. It is not even a stronger devotional life as a duty. The answer is a <strong style=\"color: var(--color-ink);\">Father</strong> &mdash; a holy Father for a beloved son or daughter who happens to carry a flock.</p><p>You spend your life fathering a congregation: feeding, protecting, grieving, and rejoicing with them. But you cannot give a fathering you are not receiving. Before you were ordained, before you were installed, before your first sermon, you were a child of God &mdash; and that is still the truest thing about you.</p><p>So you wake up tomorrow not first to shepherd, and not first to produce a sermon &mdash; but to be <em>loved</em> by your Father. Ministry is what overflows after. Your Father is not grading your preaching; He is delighting in His child. The shepherd, at last, has a Shepherd.</p>`}
	gallery={[
		{ src: 'https://cdn.sanity.io/images/rusi1hyi/production/0fb4302a36ba8085a28023897423a9b0521a351c-1100x733.jpg', alt: 'A pastor preaching from a lectern in church' },
		{ src: 'https://cdn.sanity.io/images/rusi1hyi/production/15e336010cb44b1ef3c457e25609ea2e7bdaaab0-1100x733.jpg', alt: 'A pastor comforting a distressed young man on a bench' },
		{ src: 'https://cdn.sanity.io/images/rusi1hyi/production/07e59e1e2259efeafc60661d6c2102e866838889-1100x733.jpg', alt: 'A pastor holding a Bible, deep in thought' },
		{ src: 'https://cdn.sanity.io/images/rusi1hyi/production/1efe4f82c64fc99e7626e93f7ac3017c874343b5-1100x733.jpg', alt: 'A pastor with arms open in blessing over a kneeling congregation' },
	]}
	galleryCreditHtml={`Photos via <a href=\"https://www.pexels.com/\" target=\"_blank\" rel=\"noopener noreferrer\" style=\"color: var(--color-brand);\" class=\"hover:underline\">Pexels</a>.`}
	voiceHeading="Bible verses for pastors: the Father's voice"
	voiceIntroHtml={`Nine Bible verses for pastors in the Father&rsquo;s Heart Bible&trade; &mdash; each one a word from the Father to the one who shepherds everyone else. Tap any reference to read and listen free.`}
	verses={verses}
	pullQuote="Before you are a shepherd, you are a son. Before you are a pastor, you are loved."
	offersHeading="What “our Father” offers you"
	offersIntroHtml={`Pastors give and give. Here is what the Father gives <em>you</em> &mdash; not for your ministry, but for being His.`}
	offersBlocks={[
		{ heading: 'Rest for the heavy-laden', bodyHtml: `To the one carrying every burden, Jesus says <a href=\"https://fathersheartbible.com/read/matthew/11\" style=\"color: var(--color-brand);\" class=\"hover:underline\">&ldquo;come to me&hellip; and I will give you rest.&rdquo;</a> You were never meant to be the source &mdash; only a son who drinks first.` },
		{ heading: 'Grace that meets your weakness', bodyHtml: `Where you hide your cracks, the Father says <a href=\"https://fathersheartbible.com/read/2-corinthians/12\" style=\"color: var(--color-brand);\" class=\"hover:underline\">&ldquo;my grace is sufficient for you.&rdquo;</a> Your weakness is not a disqualification; it is where His power rests.` },
		{ heading: 'A Shepherd for the shepherd', bodyHtml: `You tend the flock &mdash; and <a href=\"https://fathersheartbible.com/read/isaiah/40\" style=\"color: var(--color-brand);\" class=\"hover:underline\">He gathers you in His arms</a> and gently leads you. The chief Shepherd carries the weight you were never meant to carry alone.` },
		{ heading: 'A name beyond the role', bodyHtml: `When the title is stripped away, you are still His <a href=\"https://fathersheartbible.com/read/galatians/1\" style=\"color: var(--color-brand);\" class=\"hover:underline\">beloved child</a>, not His employee. Your worth is your sonship, not your numbers, your reviews, or your last sermon.` },
	]}
	whyHeading="Why the Father's Heart Bible™ for pastors"
	whyBlocks={[
		{ heading: 'You meet the God you preach — as Father', bodyHtml: `Every other Bible names Him &ldquo;God.&rdquo; The Father&rsquo;s Heart Bible&trade; reveals Him as <em>Father</em> wherever Scripture does &mdash; from <a href=\"https://fathersheartbible.com/read/genesis/1\" style=\"color: var(--color-brand);\" class=\"hover:underline\">Genesis 1</a> onward. When the One you preach has a Father&rsquo;s face, your study becomes communion before it becomes content.` },
		{ heading: 'It refills the shepherd', bodyHtml: `Free to <a href=\"https://fathersheartbible.com/read\" style=\"color: var(--color-brand);\" class=\"hover:underline\">read online</a> with audio on every chapter, it&rsquo;s built for the pastor&rsquo;s real week &mdash; come to be fathered before you open the commentaries, and let Scripture feed <em>you</em> before you feed anyone else.` },
		{ heading: 'From performance to sonship', bodyHtml: `The pressure to please everyone fades when you remember whose you are. Reading the Word in the Father&rsquo;s own voice keeps your identity anchored &mdash; start with our <a href=\"/guides/how-to-pray/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">how-to-pray guide</a> or the <a href=\"/verses/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">verses by topic</a>.` },
	]}
	voicesHeading="What the great preachers found in the Father"
	voicesIntroHtml={`The preachers the world has learned from didn&rsquo;t find their strength in the pulpit &mdash; they found a Father. In their own words:`}
	voices={[
		{ quote: 'God loves you as though you are the only person in the world, and He loves everyone the way He loves you.', name: 'Billy Graham', role: 'the most widely heard evangelist in history', photo: 'https://cdn.sanity.io/images/rusi1hyi/production/a44c11246e4b8c31c1b8d35672186329650bcfb4-500x688.jpg' },
		{ quote: 'There is heaven in the depth of that word — Father.', name: 'Charles Spurgeon', role: 'the 19th-century “Prince of Preachers”', photo: 'https://cdn.sanity.io/images/rusi1hyi/production/e48a128da123135241be9c95cf35b37498d94ea5-500x617.jpg' },
		{ quote: 'God is most glorified in us when we are most satisfied in Him.', name: 'John Piper', role: 'pastor and founder of Desiring God', photo: 'https://cdn.sanity.io/images/rusi1hyi/production/1d84c8621591549e90a30e01569d738db9d7dd06-500x580.jpg' },
	]}
	voicesCreditHtml={`Photos via <a href="https://commons.wikimedia.org/" target="_blank" rel="noopener noreferrer" style="color: var(--color-brand);" class="hover:underline">Wikimedia Commons</a> &mdash; Billy Graham (Warren K. Leffler, public domain), Charles Spurgeon (Alexander Melville, public domain), John Piper (Micah Chiang, CC BY 2.0).`}
	pdf={{
		title: 'Daily Affirmations',
		description: "A 31-day journey of affirmations in the Father's voice and yours — intimacy, identity, and inheritance.",
		coverUrl: 'https://assets.spiritmediapublishing.com/FHB/daily-affirmations-cover.webp',
		fileUrl: 'https://assets.spiritmediapublishing.com/FHB/daily-affirmations.pdf',
		buttonText: 'Download the PDF',
	}}
	wordHeading="His Word will not return void"
	wordBodyHtml={`<p>When our Father said, &ldquo;Let there be light,&rdquo; there was light. His Word does what He sends it to do. The same Word you preach week after week will not come back empty &mdash; not in the people who seem unmoved, and not in <em>you</em>.</p><p class=\"mt-4\" style=\"color: var(--color-ink);\">&ldquo;My word&hellip; will not return to me empty, but will accomplish that which I purpose.&rdquo; <span style=\"color: var(--color-muted);\">&mdash; Isaiah 55:11</span></p>`}
	fatherSaysHeading="What the Father says over you"
	fatherSaysHtml={`<p>&ldquo;Beloved, before you ever preached a word for Me, I delighted in you. You are not My hired hand; you are My child. I did not call you because I needed a worker &mdash; I called you because I love you, and I wanted you near.</p><p>Put down the weight of the whole flock for a moment. You are not the Good Shepherd; I am. You do not have to be everything to everyone &mdash; you only have to come to Me and be fed. Let Me restore what criticism has worn down. Let Me love you in the secret place no congregation sees. Then go and shepherd &mdash; not to earn My approval, but because you already have it. I am your Father, and you are Mine.&rdquo;</p>`}
	prayerHeading="A prayer for pastors"
	prayerHtml={`<p>Our Father, we thank You and praise You for all pastors &mdash; the ones who carry what no one sees, who feed others while running on empty, who stand in the gap year after year. Let them hear Your whisper above every criticism and every demand. Let them encounter Your love &mdash; not as a doctrine they preach, but as a weight they feel &mdash; and experience Your delight over them, apart from any sermon, any number, any outcome.</p><p>Give them grace to prioritize intimacy with You above their performance, to guard the secret place, and to receive their identity as Your sons and daughters before they ever step behind a pulpit. Father, be the Shepherd of these shepherds. Carry what they cannot. Lift the loneliness. Set them free from the need to please everyone, and let them answer to You alone.</p><p>I pray Your protection over them from the enemy, from temptation, from moral failure, and from despair. Let them know there is no condemnation in You &mdash; that when they fall, You restore, as You restored Peter. Let them know You, their Father, as their true inheritance and reward, for every other gift pales beside the gift of You. And may they wake up every single day under the pour of their heavenly Father&rsquo;s heart for them.</p><p>In Jesus&rsquo; name, amen.</p>`}
	galleryBottom={[
		{ src: 'https://cdn.sanity.io/images/rusi1hyi/production/29a32301b22b2b799c679044baf0228c874886d1-1100x733.jpg', alt: 'A man praying alone in a shaft of light inside a church' },
		{ src: 'https://cdn.sanity.io/images/rusi1hyi/production/e5efca85c9beddef7d76740694eb63b511642d80-1100x733.jpg', alt: 'A pastor preaching from an ornate pulpit' },
		{ src: 'https://cdn.sanity.io/images/rusi1hyi/production/aab9f171e48f9449c12ae24c4769fb86b00aba96-1100x734.jpg', alt: 'A woman pastor speaking, with a choir behind her' },
		{ src: 'https://cdn.sanity.io/images/rusi1hyi/production/53cdf6b15e700a310a34d8ff39bd0f366516819a-1100x733.jpg', alt: 'A weary man with his head in his hands' },
	]}
	galleryBottomCreditHtml={`Photos via <a href=\"https://www.pexels.com/\" target=\"_blank\" rel=\"noopener noreferrer\" style=\"color: var(--color-brand);\" class=\"hover:underline\">Pexels</a>.`}
	keepReadingHtml={`Begin with the <a href=\"https://fathersheartbible.com/read\" style=\"color: var(--color-brand);\" class=\"hover:underline\">whole Bible free online with audio</a>, learn <a href=\"/the-fathers-heart-bible/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">why the Father&rsquo;s Heart Bible&trade; exists</a>, or get oriented with our <a href=\"/guides/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">Bible reading guides</a> &mdash; including <a href=\"/guides/how-to-pray/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">how to pray</a> and <a href=\"/guides/where-to-start-reading-the-bible/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">where to start</a>. Or meet a fellow worker in <a href=\"/bible-for/worship-leaders/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">the Bible for worship leaders</a>.`}
	faqs={faqs}
	ctaBottomHeading="Be fathered before you shepherd"
	ctaBottomBodyHtml={`Watch the story behind the Father&rsquo;s Heart Bible&trade; &mdash; the translation that lets you meet the One you preach as Father. Then come and be fed, so what you give your people overflows from what you&rsquo;ve received.`}
