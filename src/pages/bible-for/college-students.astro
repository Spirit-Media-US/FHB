	verses={[
		{ ref: `Luke 15:20`, slug: `luke`, ch: 15, text: `While he was still a long way off, his father saw him and felt compassion, and ran to him and embraced him and kissed him.`, note: `However far from home or from God you feel, the Father is the one who runs to you — you can always come home.` },
		{ ref: `Jeremiah 29:11`, slug: `jeremiah`, ch: 29, text: `For I know the plans I have for you, declares the Father — plans for your welfare and not for harm, to give you a future and a hope.`, note: `When the path ahead is foggy, your Father already holds a future for you, and it is good.` },
		{ ref: `Psalm 139:14`, slug: `psalms`, ch: 139, text: `I praise You, Father, for I am fearfully and wonderfully made; wonderful are Your works, and my soul knows it well.`, note: `Your worth isn't measured by grades, looks, or follows — your Father wove you on purpose, and called it wonderful.` },
		{ ref: `Romans 8:38`, slug: `romans`, ch: 8, text: `For I am sure that neither death nor life, nor things present nor things to come, will be able to separate us from the love of God our Father.`, note: `Not your doubts, not your distance, not your worst night — nothing can cut you off from your Father's love.` },
		{ ref: `Matthew 11:28`, slug: `matthew`, ch: 11, text: `Come to Me, all who are weary and burdened, and I will give you rest.`, note: `For the exhausted, over-caffeinated, all-nighter season — your Father offers the rest no schedule can give.` },
