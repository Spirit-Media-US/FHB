	offersBlocks={[
		{ heading: `Rest for a weary soul`, bodyHtml: `When the work has worn you down, hear the invitation: <a href="https://fathersheartbible.com/read/matthew/11" style="color: var(--color-brand);" class="hover:underline">come to Me, all who are weary and burdened, and I will give you rest</a>. Your Father offers the rest no day off ever fully delivers.` },
		{ heading: `Meaning in ordinary work`, bodyHtml: `Even the task no one sees counts, because <a href="https://fathersheartbible.com/read/colossians/3" style="color: var(--color-brand);" class="hover:underline">whatever you do, you do it for your Father and not for people</a>. He turns the most ordinary workday into something that matters.` },
		{ heading: `Steadiness when plans feel out of control`, bodyHtml: `When the future of your job feels uncertain, <a href="https://fathersheartbible.com/read/proverbs/16" style="color: var(--color-brand);" class="hover:underline">commit whatever you do to your Father, and He will establish your plans</a>. You don't have to carry the outcome alone.` },
		{ heading: `Labor that is never in vain`, bodyHtml: `When your work feels like it disappears, remember that <a href="https://fathersheartbible.com/read/1-corinthians/15" style="color: var(--color-brand);" class="hover:underline">your labor in your Father is not in vain</a>. Nothing offered to Him is ever wasted.` },
	]}
