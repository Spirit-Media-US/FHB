	},
	{
		ref: 'John 4:23',
		slug: 'john',
		ch: 4,
		text: 'But the hour is coming, and is now here, when the true worshipers will worship the Father in spirit and truth, for the Father is seeking such people to worship him.',
		note: 'True worship leads to the Father — He is the destination of every set you lead, not the feeling in the room.',
	},
	{
		ref: '1 John 4:19',
		slug: '1-john',
		ch: 4,
		text: 'We love because our Father first loved us.',
		note: 'You can only give what you have received. His love comes first; your worship is the overflow.',
	},
	{
		ref: 'Psalm 100:2',
		slug: 'psalms',
		ch: 100,
		text: 'Serve your Father with gladness! Come into his presence with singing!',
		note: 'Worship is not a performance to dread but a glad coming-in — gladness, not pressure, is the posture.',
	},
	{
		ref: 'Psalm 18:19',
		slug: 'psalms',
		ch: 18,
		text: 'He brought me out into a broad place; he rescued me, because he delighted in me.',
		note: 'When you brace for the critique of every set, hear this: your Father delights in you, not your performance.',
	},
