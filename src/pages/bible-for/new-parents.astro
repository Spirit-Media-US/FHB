	verses={[
		{ ref: `Psalm 127:3`, slug: `psalms`, ch: 127, text: `Behold, children are a heritage from your Father, the fruit of the womb a reward from His hand.`, note: `Your child is not a burden you earned — they are a gift your Father placed in your arms.` },
		{ ref: `Psalm 139:13-14`, slug: `psalms`, ch: 139, text: `For You formed my inmost being; You knit me together in my mother's womb. I praise You, for I am fearfully and wonderfully made.`, note: `The God who designed your baby cell by cell is the same Father holding you now.` },
		{ ref: `Isaiah 40:11`, slug: `isaiah`, ch: 40, text: `Like a shepherd your Father tends His flock; He gathers the lambs in His arms and carries them close, and gently leads those who have young.`, note: `He doesn't rush you. He gently leads parents with little ones — at your pace, not the world's.` },
		{ ref: `Isaiah 40:29`, slug: `isaiah`, ch: 40, text: `Your Father gives strength to the weary, and to those who have no might He increases power.`, note: `When you're running on empty, His strength is the one tank that doesn't run dry.` },
		{ ref: `1 Peter 5:7`, slug: `1-peter`, ch: 5, text: `Cast all your anxiety on your Father, because He cares for you.`, note: `Every 3am worry — hand it to Him. He's awake, and He cares about the smallest one.` },
		{ ref: `Lamentations 3:22-23`, slug: `lamentations`, ch: 3, text: `Your Father's mercies never come to an end; they are new every morning — great is His faithfulness.`, note: `However hard yesterday was, His mercy is brand new with this morning's first cry.` },
