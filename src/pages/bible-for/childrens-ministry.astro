	offersBlocks={[
		{ heading: `A welcome for you, too`, bodyHtml: `You make room for the children. Jesus says <a href="https://fathersheartbible.com/read/matthew/19" style="color: var(--color-brand);" class="hover:underline">“let the little children come to me”</a> — and you are invited in first, to receive His kingdom like a child before you teach a single one.` },
		{ heading: `Arms that gather you in`, bodyHtml: `You hold the lambs every Sunday. The Shepherd <a href="https://fathersheartbible.com/read/isaiah/40" style="color: var(--color-brand);" class="hover:underline">gathers you in His arms</a> and gently leads you — the carrier is also carried.` },
		{ heading: `A promise over the long years`, bodyHtml: `You may never see the harvest. But <a href="https://fathersheartbible.com/read/proverbs/22" style="color: var(--color-brand);" class="hover:underline">the seed planted in a child</a> is kept by your Father across decades you cannot see — no Sunday is wasted.` },
		{ heading: `The name “child,” not “help”`, bodyHtml: `When the volunteer slot is empty and you fill it again, remember you are <a href="https://fathersheartbible.com/read/galatians/4" style="color: var(--color-brand);" class="hover:underline">no longer a servant but a son or daughter</a> — an heir, not the church’s spare pair of hands.` },
