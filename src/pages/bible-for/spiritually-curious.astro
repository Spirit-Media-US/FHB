	offersBlocks={[
		{ heading: `A welcome, not a verdict`, bodyHtml: `The most famous story Jesus told is about <a href="https://fathersheartbible.com/read/luke/15" style="color: var(--color-brand);" class="hover:underline">a father who runs to the child who left</a> — no lecture, no probation. Read it and judge for yourself what kind of God it describes.` },
		{ heading: `Belonging instead of fear`, bodyHtml: `If faith was sold to you as fear and rules, this says that was never the heart of it: <a href="https://fathersheartbible.com/read/romans/8" style="color: var(--color-brand);" class="hover:underline">not a spirit of slavery to fear</a>, but belonging — the freedom to call God "Father."` },
		{ heading: `Room for honest doubt`, bodyHtml: `Paul stood among skeptics and said God is <a href="https://fathersheartbible.com/read/acts/17" style="color: var(--color-brand);" class="hover:underline">not far from any one of us</a> — that the seeking itself is honored. You don't have to arrive certain. You're allowed to just look.` },
