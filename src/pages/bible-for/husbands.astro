	offersBlocks={[
		{ heading: `A love you receive first`, bodyHtml: `Before any command to love your wife, the Father says <a href="https://fathersheartbible.com/read/1-john/4" style="color: var(--color-brand);" class="hover:underline">“we love because He first loved us.”</a> You were filled before you were ever asked to pour out.` },
		{ heading: `A name beyond the paycheck`, bodyHtml: `When the provider pressure presses in, He calls you <a href="https://fathersheartbible.com/read/galatians/4" style="color: var(--color-brand);" class="hover:underline">son and heir</a>, not employee. Your worth was never your income — it’s your sonship.` },
		{ heading: `Gentleness for the harshness`, bodyHtml: `Where you’ve been short or cold, He doesn’t shame you; He fills you, so you can <a href="https://fathersheartbible.com/read/colossians/3" style="color: var(--color-brand);" class="hover:underline">love without harshness.</a> A fathered man has patience to spare.` },
