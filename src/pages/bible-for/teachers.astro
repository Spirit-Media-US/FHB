	offersBlocks={[
		{ heading: `Rest for the weary`, bodyHtml: `You don't have to earn a break: <a href="https://fathersheartbible.com/read/matthew/11" style="color: var(--color-brand);" class="hover:underline">come to your Father weary</a>, and He gives you rest for your soul — gentle, unhurried, no performance required.` },
		{ heading: `Strength that gets renewed`, bodyHtml: `The energy teaching drains, your Father restores: <a href="https://fathersheartbible.com/read/isaiah/40" style="color: var(--color-brand);" class="hover:underline">wait on Him and your strength is renewed</a> — so you can run and not grow weary, walk and not faint.` },
		{ heading: `A reward for unseen work`, bodyHtml: `Even when no one says thank you, <a href="https://fathersheartbible.com/read/colossians/3" style="color: var(--color-brand);" class="hover:underline">your Father sees every hour</a> you give and promises the reward and harvest that people overlook.` },
		{ heading: `Peace for the anxious mind`, bodyHtml: `You don't have to carry it alone: <a href="https://fathersheartbible.com/read/philippians/4" style="color: var(--color-brand);" class="hover:underline">hand your worries to your Father</a>, and His peace — the kind that doesn't even make sense — guards your heart and mind.` },
	]}
	whyHeading={`Why the Father's Heart Bible™ for teachers`}
	whyBlocks={[
		{ heading: `You meet God as a Father, not a rulebook`, bodyHtml: `Most Bibles can read like one more list of expectations on an already-full plate. The Father's Heart Bible™ reveals God as a <em>Father</em> wherever Scripture does — from <a href="https://fathersheartbible.com/read/genesis/1" style="color: var(--color-brand);" class="hover:underline">Genesis 1</a> on. So instead of one more voice asking you to give more, you meet the One who wants to fill you first.` },
		{ heading: `It's free, on your phone, with audio`, bodyHtml: `No account, no purchase, no app. <a href="https://fathersheartbible.com/read" style="color: var(--color-brand);" class="hover:underline">Read it free online</a> with audio on every chapter — listen on the commute, during prep, or in the quiet after the last student leaves. The Father's voice fits right into your real day.` },
		{ heading: `It speaks to what you're actually facing`, bodyHtml: `Burned out? Undervalued? Pouring out with nothing left? Start with our <a href="/verses/" style="color: var(--color-brand);" class="hover:underline">verses by topic</a> or learn to talk to Him with our <a href="/guides/how-to-pray/" style="color: var(--color-brand);" class="hover:underline">how-to-pray guide</a> — the Word meets you right where you are.` },
