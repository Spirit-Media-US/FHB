		{ value: `23%`, label: `of teachers say they are likely to leave their job by the end of the school year (RAND, 2024)` },
		{ value: `77%`, label: `of teachers report frequent job-related stress (RAND, 2021)` },
		{ value: `$66,397`, label: `average U.S. public school teacher salary — teachers earn about 26% less than comparable college graduates (NEA, 2023-24)` },
