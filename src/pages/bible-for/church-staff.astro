	verses={[
		{ ref: `Colossians 3:23`, slug: `colossians`, ch: 3, text: `Whatever you do, work heartily, as for your Father and not for men, knowing that from Him you will receive the inheritance as your reward.`, note: `Every unseen task is seen by your Father — you work for an Audience of One who never overlooks you.` },
		{ ref: `Hebrews 6:10`, slug: `hebrews`, ch: 6, text: `For your Father is not unjust; He will not overlook your work and the love you have shown for His name in serving the saints, as you still do.`, note: `He is not unjust. The hours no committee thanked you for, your Father has not forgotten.` },
		{ ref: `Matthew 6:4`, slug: `matthew`, ch: 6, text: `so that your giving may be in secret. And your Father who sees in secret will reward you.`, note: `The good you do where no one is watching is exactly what your Father sees and rewards.` },
		{ ref: `Galatians 6:9`, slug: `galatians`, ch: 6, text: `And let us not grow weary of doing good, for in due season we will reap, if we do not give up.`, note: `For the staff running on empty: the harvest is coming — don't quit in the unseen season.` },
		{ ref: `Matthew 11:28`, slug: `matthew`, ch: 11, text: `Come to Me, all who labor and are heavy laden, and I will give you rest.`, note: `You set up rest for everyone else's worship. Your Father invites you, the laborer, to come and rest in Him.` },
		{ ref: `Zephaniah 3:17`, slug: `zephaniah`, ch: 3, text: `Your Father is in your midst, a mighty one who will save; He will rejoice over you with gladness; He will quiet you by His love; He will exult over you with loud singing.`, note: `You serve the worship of the room. Your Father is the One singing — over you.` },
