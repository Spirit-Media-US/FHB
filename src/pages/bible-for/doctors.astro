	offersBlocks={[
		{ heading: `Rest your shift can't give`, bodyHtml: `When you're weary and weighed down, <a href="https://fathersheartbible.com/read/matthew/11" style="color: var(--color-brand);" class="hover:underline">come to your Father for rest</a> — the soul-deep kind that no day off fully delivers, because His yoke is easy and His burden is light.` },
		{ heading: `Strength when your reserves run out`, bodyHtml: `Your tank empties; His never does. <a href="https://fathersheartbible.com/read/isaiah/40" style="color: var(--color-brand);" class="hover:underline">Wait on your Father</a> and He renews the strength burnout drains — He gives power to the weak and never grows tired Himself.` },
		{ heading: `Grace exactly where you're weakest`, bodyHtml: `You don't have to be unbreakable. <a href="https://fathersheartbible.com/read/2-corinthians/12" style="color: var(--color-brand);" class="hover:underline">His grace is enough</a>, and His power is made perfect in your weakness — so the place you feel you're failing is the very place He shows up.` },
		{ heading: `Arms underneath you`, bodyHtml: `However far you feel you could fall, <a href="https://fathersheartbible.com/read/deuteronomy/33" style="color: var(--color-brand);" class="hover:underline">underneath you are His everlasting arms</a>. The Father who carries everyone is already carrying you.` },
