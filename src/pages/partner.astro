---
import DonationForm from '../components/donations/DonationForm.astro';
import DonorFeed from '../components/donations/DonorFeed.astro';
import ProgressBar from '../components/donations/ProgressBar.astro';
import ImageGrid from '../components/ImageGrid.astro';
import Section from '../components/Section.astro';
import UnlockMap from '../components/UnlockMap.astro';
import VideoHeroInner from '../components/VideoHeroInner.astro';
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity';

const pageData = await sanityClient.fetch(`*[_type =="page" && slug =="partner"][0] {
    seoTitle, seoDescription
  }`);

const seoTitle = pageData?.seoTitle || "Partner With Us | Father's Heart Bible";
const seoDescription =
	pageData?.seoDescription ||
	"Become a monthly partner — $100/month sponsors 20 Bibles every month and helps take the Father's Heart Bible to the nations. 500 partners reach $50,000/month.";
const heroHeading = 'Partner With Us';
const heroSubheading = "Partner with us to take the Father's Heart Bible to the nations.";

// Featured blog card shown in place of the (coming-soon) partner video.
// Same card style as the /blog index — fetched from Sanity so title/excerpt/cover stay live.
const visionPost =
	await sanityClient.fetch(`*[_type == "blogPost" && slug.current == "the-fathers-vision"][0] {
    "slug": "/blog/" + slug.current,
    title,
    excerpt,
    "image": coalesce(heroImage.asset->url + "?w=800&auto=format", "/fhb-logo.png"),
    "author": coalesce(author, "Kevin White"),
    "date": publishDate,
    tags
  }`);
const MONTHS = [
	'January',
	'February',
	'March',
	'April',
	'May',
	'June',
	'July',
	'August',
	'September',
	'October',
	'November',
	'December',
];
const visionDate = visionPost?.date
	? (() => {
			const d = new Date(visionPost.date);
			return `${MONTHS[d.getUTCMonth()]} ${d.getUTCDate()}, ${d.getUTCFullYear()}`;
		})()
	: '';

// Why your partnership matters — woven into the consolidated "Why this matters" section.
const whyMatters = [
	{
		heading: 'Complete & publish the canon',
		body: 'The full canon — Genesis to Revelation — published digitally (YouVersion, Bible Gateway, and more) and in paperback, hardback, eBook, and audiobook.',
	},
	{
		heading: 'Produce the ComfortLeather™ edition',
		body: 'A premium print Bible that can be held, given, and treasured — crafted to last a lifetime.',
	},
	{
		heading: 'Reach the nations',
		body: "Translate the Father's Heart Bible™ into the top 20 languages — within reach of about 75% of humanity, in a language they understand, within 24 months.",
	},
];

// What makes this Bible different — short trust signals.
const whyDifferent = [
	'Reveals the Father where Scripture reveals Him — from Genesis to Revelation.',
	'Speaks directly to identity, intimacy, and belonging — the deep hunger of this generation.',
	'Written not to inform but to create encounter — a Bible that changes how readers know God.',
	'Rooted in the historic Christian and Trinitarian faith — trustworthy and spiritually serious.',
];

// Impact, measured in Bibles throughout. $5 = 1 Bible.
const impactStats = [
	{ amount: '$5', impact: "Places one Father's Heart Bible™ into a reader's hands." },
	{ amount: '$100/mo', impact: 'Sponsors 20 Bibles every month as a monthly partner.' },
	{ amount: '$50,000', impact: 'Translates and releases the Bible into an entire language.' },
];

// $50,000 milestone ladder — the memorable unit of this campaign.
const milestones = [
	{
		amount: '$50,000',
		title: 'English — digital & print',
		body: 'Publishes the digital editions (YouVersion, Bible Gateway, and more) and releases paperback, hardback, eBook, and audiobook worldwide.',
	},
	{
		amount: '$50,000',
		title: 'The ComfortLeather™ edition',
		body: 'Prints and distributes the premium ComfortLeather™ Bible — the flagship edition built to be treasured.',
	},
	{
		amount: '$50,000 each',
		title: 'Every language after that',
		body: 'Each new language — full translation, print and digital release, and audio narration — is unlocked for $50,000.',
	},
];

// Lead languages with reader reach (from the campaign vision).
const languageReach = [
	{ language: 'English', readers: '1.5 billion readers' },
	{ language: 'Spanish', readers: '550 million readers' },
	{ language: 'Mandarin', readers: '1.1 billion readers' },
	{ language: 'Hindi', readers: '600 million readers' },
];

// Production timeline.
const timeline = [
	{ when: 'June 2026', what: "Public Review · Founder's Clubs open" },
	{ when: 'July 2026', what: 'Canon locked · formatting and design' },
	{ when: 'August 2026', what: 'Digital Bibles published' },
	{ when: 'September 2026', what: 'Paperback & Hardback published' },
	{ when: 'October 2026', what: 'eBook and audiobook published' },
	{ when: 'November 2026', what: 'ComfortLeather™ Edition published', emphasis: true },
	{ when: 'December 31, 2026', what: '20,000 copies distributed across all formats' },
	{ when: '2027', what: 'International language translations until top 20 languages' },
	{
		when: '2028',
		what: "Study Bibles editions published for men, women, and students. Children's Bible + more languages",
	},
];
---

<Layout
	title={seoTitle}
	description={seoDescription}
	image="https://assets.spiritmediapublishing.com/FHB/share/fhb-og-partner.jpg?v=2"
	imageAlt="Father's Heart Bible — Open Your Heart to Me as Your Father"
	darkHero={true}
	jsonLd={{
		"@context": "https://schema.org",
		"@graph": [
			{ "@type": "WebPage", "name": seoTitle, "description": seoDescription, "url": "https://fathersheartbible.com/partner" },
			{ "@type": "BreadcrumbList", "itemListElement": [
				{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fathersheartbible.com/" },
				{ "@type": "ListItem", "position": 2, "name": "Partner With Us", "item": "https://fathersheartbible.com/partner" }
			]}
		]
	}}
>
	<main>

		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 1 — HERO (video placeholder until hero video ships)
		     ═══════════════════════════════════════════════════════════ -->
		<VideoHeroInner
			imageSrc="https://cdn.sanity.io/images/rusi1hyi/production/a323755d51d350e216d2fb38cd857df127609f67-1537x1023.png?w=1920&q=80&auto=format"
			showLogo={false}
			headingLift="1in"
			heading={heroHeading}
			subheading={heroSubheading}
		/>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 2 — GIVE (pitch + the math + progress + form + feed)
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="light">
			<!-- The math, as animated counters — immediately under the hero. -->
			<div class="max-w-4xl mx-auto mb-10 grid grid-cols-1 sm:grid-cols-3 gap-6 text-center" data-stagger>
				<div class="p-6 rounded-2xl" style="background-color: var(--color-soft); border: 1px solid var(--color-hairline);">
					<p class="text-4xl font-light mb-2" style="font-family: var(--font-serif); color: var(--color-brand);">
						<span data-counter="500">0</span>
					</p>
					<p class="text-sm" style="font-family: var(--font-sans); color: var(--color-muted);">monthly partners</p>
				</div>
				<div class="p-6 rounded-2xl" style="background-color: var(--color-soft); border: 1px solid var(--color-hairline);">
					<p class="text-4xl font-light mb-2" style="font-family: var(--font-serif); color: var(--color-brand);">
						<span data-counter="100" data-prefix="$">$0</span><span class="text-xl" style="color: var(--color-muted);">/mo</span>
					</p>
					<p class="text-sm" style="font-family: var(--font-sans); color: var(--color-muted);">each — sponsors 20 Bibles/month</p>
				</div>
				<div class="p-6 rounded-2xl" style="background-color: var(--color-soft); border: 1px solid var(--color-hairline);">
					<p class="text-4xl font-light mb-2" style="font-family: var(--font-serif); color: var(--color-brand);">
						<span data-counter="50000" data-prefix="$">$0</span><span class="text-xl" style="color: var(--color-muted);">/mo</span>
					</p>
					<p class="text-sm" style="font-family: var(--font-sans); color: var(--color-muted);">first milestone, together</p>
				</div>
			</div>

			<!-- Pitch — pink text panel left, video placeholder right. -->
			<div class="max-w-5xl mx-auto mb-12" data-reveal>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-stretch">
					<div class="p-7 md:p-9 rounded-2xl flex flex-col justify-center" style="background: #FFD9E0;">
						<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-sans); color: #4A4A4A;">
							Monthly Partnership · First Milestone $50,000/month
						</p>
						<h2 class="text-2xl md:text-3xl font-light leading-tight mb-4" style="font-family: var(--font-serif); color: var(--color-ink);">
							500 partners at $100/month takes the Father&rsquo;s Heart Bible to the nations.
						</h2>
						<p class="text-base leading-relaxed" style="font-family: var(--font-sans); color: #4A4A4A;">
							At $5 a Bible, <strong style="color: var(--color-ink);">$100/month sponsors 20 Bibles every month</strong>.
							Partners who give <strong style="color: var(--color-ink);">$100 or more a month receive a free ComfortLeather&trade; edition</strong>.
							Give more if you can; if you need to give less, every gift matters.
						</p>
					</div>
					<!-- Featured blog card (stands in for the partner video until it ships). -->
					{visionPost ? (
						<a href={visionPost.slug} class="group rounded-2xl border overflow-hidden transition-shadow hover:shadow-md flex flex-col" style="background-color: var(--color-surface); border-color: var(--color-hairline);">
							<div class="overflow-hidden" style="aspect-ratio: 16/9;">
								<img src={visionPost.image} alt={visionPost.title} width="800" height="450" loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" style="object-position: center top;" />
							</div>
							<div class="p-6 flex flex-col flex-1">
								<div class="flex flex-wrap gap-1.5 mb-3">
									{(visionPost.tags || []).slice(0, 2).map((t: string) => (
										<span class="text-xs font-semibold rounded-full px-2.5 py-0.5" style="color: var(--color-muted); background-color: var(--color-surface-low);">{t}</span>
									))}
								</div>
								<h3 class="text-xl font-bold mb-2 leading-snug" style="font-family: var(--font-serif); color: var(--color-brand);">{visionPost.title}</h3>
								<p class="text-sm mb-4 leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">{visionPost.excerpt || ''}</p>
								<div class="mt-auto flex items-center justify-between text-sm" style="color: var(--color-muted); font-family: var(--font-sans);">
									<span>{visionPost.author} · {visionDate}</span>
									<span class="font-semibold group-hover:underline" style="color: var(--color-brand);">Read →</span>
								</div>
							</div>
						</a>
					) : (
						<div class="rounded-2xl overflow-hidden flex items-center justify-center min-h-[260px]" style="background: var(--color-surface-low); border: 1px solid var(--color-outline-variant);">
							<div class="text-center px-6">
								<div class="mx-auto mb-3 flex items-center justify-center rounded-full" style="width: 56px; height: 56px; background: var(--color-surface); border: 1px solid var(--color-outline-variant);">
									<svg width="22" height="22" viewBox="0 0 24 24" fill="var(--color-primary)" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
								</div>
								<p class="text-sm font-semibold" style="font-family: var(--font-sans); color: var(--color-muted);">Partner video coming soon</p>
							</div>
						</div>
					)}
				</div>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12 items-start">
				<!-- Left column: progress + donor feed -->
				<div class="lg:col-span-2 space-y-8" data-reveal>
					<ProgressBar campaign="fhb" />
					<DonorFeed campaign="fhb" />
				</div>
				<!-- Right column: donation form -->
				<div id="donate" class="lg:col-span-3 scroll-mt-24" data-reveal>
					<DonationForm />

					<!-- Prefer to give by check? — mail option right under the form. -->
					<div class="mt-6 rounded-2xl p-6" style="background-color: var(--color-soft); border: 1px solid var(--color-hairline);">
						<p class="text-xs font-semibold tracking-widest uppercase mb-2" style="font-family: var(--font-sans); color: var(--color-brand);">
							Prefer to give by check?
						</p>
						<p class="text-sm leading-relaxed mb-3" style="font-family: var(--font-sans); color: var(--color-muted);">
							Make your check payable to <strong style="color: var(--color-ink);">Spirit Media Charities</strong> and mail it to:
						</p>
						<address class="not-italic text-sm leading-relaxed mb-3" style="font-family: var(--font-sans); color: var(--color-ink);">
							Spirit Media Charities<br />
							205 S Academy St #3251<br />
							Cary, NC 27519
						</address>
						<p class="text-xs leading-relaxed mb-3" style="font-family: var(--font-sans); color: var(--color-muted); opacity: 0.85;">
							Please write <strong style="color: var(--color-ink);">&ldquo;FHB&rdquo;</strong> in the memo line so your gift supports the Father&rsquo;s Heart Bible&trade;.
						</p>
						<p class="text-xs leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted); opacity: 0.7;">
							All gifts are tax-deductible as allowed by the IRS.
						</p>
					</div>
				</div>
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 3 — WHAT YOUR PARTNERSHIP UNLOCKS (ComfortLeather reward)
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="soft">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-14 items-center max-w-4xl mx-auto">
				<div class="flex justify-center" data-reveal>
					<img
						src="https://cdn.sanity.io/images/rusi1hyi/production/8b5d1c39f892218c978d3e3caf5720e09833bbc4-1024x1024.png?w=560&fm=webp&q=80&auto=format"
						alt="The ComfortLeather™ Edition of the Father's Heart Bible"
						width="420" height="420" loading="lazy" decoding="async"
						class="w-full max-w-sm rounded-2xl"
					/>
				</div>
				<div data-reveal>
					<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-sans); color: var(--color-gold);">What your partnership unlocks</p>
					<h2 class="text-3xl md:text-4xl font-light leading-tight mb-5" style="font-family: var(--font-serif); color: var(--color-ink);">A free ComfortLeather&trade; edition</h2>
					<p class="leading-relaxed mb-4" style="font-family: var(--font-sans); color: var(--color-muted);">
						Every partner who gives <strong style="color: var(--color-ink);">$100 or more a month</strong> receives a
						free ComfortLeather&trade; Father&rsquo;s Heart Bible&trade; — the flagship edition,
						bound in supple leather and crafted to be held, gifted, and treasured for a lifetime.
					</p>
					<p class="leading-relaxed mb-6" style="font-family: var(--font-sans); color: var(--color-muted);">
						It&rsquo;s our way of placing the very Bible you&rsquo;re helping send to the nations into your own hands.
					</p>
					<a href="#donate" class="inline-flex items-center px-8 py-3.5 text-base font-semibold no-underline transition-all duration-200" style="font-family: var(--font-sans); background-color: #FFD9E0; color: #4A4A4A; border-radius: 8px;" onmouseover="this.style.opacity='0.92'" onmouseout="this.style.opacity='1'">Become a Monthly Partner →</a>
				</div>
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 4 — THE 24-MONTH VISION ($50k ladder + timeline + langs + map)
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="light">
			<div class="max-w-4xl mx-auto">
				<header class="text-center mb-10" data-reveal>
					<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-sans); color: var(--color-gold);">
						The 24-Month Vision
					</p>
					<h2 class="text-3xl md:text-4xl font-light" style="font-family: var(--font-serif); color: var(--color-ink);">
						Every $50,000 takes the Bible further.
					</h2>
					<p class="mt-4 leading-relaxed max-w-2xl mx-auto" style="font-family: var(--font-sans); color: var(--color-muted);">
						$50,000 is the unit that moves this mission forward — English first, then the
						ComfortLeather&trade; edition, then a new language at a time, on toward the top 20
						languages — within reach of about <strong>75% of humanity within 24 months</strong>.
					</p>
				</header>

				<!-- $50k milestone ladder -->
				<div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-12" data-stagger>
					{milestones.map(({ amount, title, body }) => (
						<div class="p-6 rounded-2xl" style="background: #FFD9E0;">
							<p class="text-2xl font-light mb-1" style="font-family: var(--font-serif); color: var(--color-brand);">{amount}</p>
							<h3 class="font-semibold mb-2" style="font-family: var(--font-sans); color: var(--color-ink);">{title}</h3>
							<p class="text-sm leading-relaxed" style="font-family: var(--font-sans); color: #4A4A4A;">{body}</p>
						</div>
					))}
				</div>

				<!-- Production timeline -->
				<div class="mb-12" data-reveal>
					<p class="text-xs font-semibold tracking-widest uppercase mb-4 text-center" style="font-family: var(--font-sans); color: var(--color-primary);">
						Production Timeline
					</p>
					<ol class="rounded-2xl overflow-hidden border" style="list-style: none; padding: 0; margin: 0; border-color: var(--color-outline-variant); background: var(--color-surface);">
						{timeline.map(({ when, what, emphasis }) => (
							<li class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-2 md:gap-6 px-5 py-4" style={`border-bottom: 1px solid var(--color-outline-variant); ${emphasis ? 'background: var(--color-surface-low);' : ''}`}>
								<span style="font-family: var(--font-sans); font-size: 13px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.04em;">{when}</span>
								<span style={`font-family: var(--font-sans); line-height: 1.55; ${emphasis ? 'color: var(--color-ink); font-weight: 600;' : 'color: var(--color-muted);'}`}>{what}</span>
							</li>
						))}
					</ol>
				</div>

				<!-- Per-language reach -->
				<div data-reveal>
					<p class="text-xs font-semibold tracking-widest uppercase mb-4 text-center" style="font-family: var(--font-sans); color: var(--color-primary);">
						Each language, $50,000 — the reach it opens
					</p>
					<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
						{languageReach.map(({ language, readers, note }) => (
							<div class="p-5 rounded-2xl text-center" style="background: #FFD9E0;">
								<p class="text-lg font-semibold mb-1" style="font-family: var(--font-serif); color: var(--color-ink);">{language}</p>
								<p class="text-sm leading-snug" style="font-family: var(--font-sans); color: #4A4A4A;">{readers}</p>
								{note && <p class="text-xs mt-2" style="font-family: var(--font-sans); color: var(--color-brand);">{note}</p>}
							</div>
						))}
					</div>
					<p class="text-sm text-center mt-5 leading-relaxed max-w-2xl mx-auto" style="font-family: var(--font-sans); color: var(--color-muted);">
						Families, businesses, and foundations are invited to <strong style="color: var(--color-ink);">sponsor a whole language for $50,000</strong> —
						underwriting its full translation, release, and audio narration.
					</p>
					<div class="flex justify-center mt-6">
						<a
							href="#"
							data-e="kevin"
							data-d="spiritmediapublishing.com"
							class="inline-flex items-center px-8 py-3.5 text-base font-semibold no-underline transition-all duration-200"
							style="font-family: var(--font-sans); background-color: #FFD9E0; color: #4A4A4A;"
							aria-label="Email to pledge to sponsor a language"
							onclick="event.preventDefault();window.location.href='mailto:'+this.dataset.e+'@'+this.dataset.d+'?subject='+encodeURIComponent('Pledge to Sponsor a Language — Father’s Heart Bible')"
							onmouseover="this.style.opacity='0.9'"
							onmouseout="this.style.opacity='1'"
						>
							Pledge to Sponsor a Language
						</a>
					</div>
				</div>
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 4.5 — THE COUNTRY / LANGUAGE UNLOCK MAP
		     ═══════════════════════════════════════════════════════════ -->
		<UnlockMap />


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 5 — WHY THIS MATTERS (impact + what makes it different)
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="soft">
			<div class="max-w-5xl mx-auto">
				<div class="text-center mb-12" data-reveal>
					<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-sans); color: var(--color-gold);">
						Why It Matters
					</p>
					<h2 class="text-3xl md:text-4xl font-light" style="font-family: var(--font-serif); color: var(--color-ink);">
						Every gift places the Father&rsquo;s Word in someone&rsquo;s hands.
					</h2>
				</div>

				<!-- Impact in Bibles -->
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto mb-16" data-stagger>
					{impactStats.map(({ amount, impact }) => (
						<div class="p-8 text-center" style="background: #FFD9E0;">
							<p class="text-3xl font-light mb-4" style="font-family: var(--font-serif); color: var(--color-brand);">{amount}</p>
							<div class="w-8 h-0.5 mx-auto mb-4" style="background-color: var(--color-gold);"></div>
							<p class="text-sm leading-relaxed" style="font-family: var(--font-sans); color: #4A4A4A;">{impact}</p>
						</div>
					))}
				</div>

				<!-- What partnership funds + what makes it different -->
				<div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-start">
					<div data-reveal>
						<h3 class="text-2xl font-light leading-tight mb-6" style="font-family: var(--font-serif); color: var(--color-ink);">
							What your partnership funds
						</h3>
						<div class="space-y-6">
							{whyMatters.map(({ heading, body }) => (
								<div class="flex gap-4 items-start">
									<div class="mt-1.5 w-1.5 h-1.5 rounded-full shrink-0" style="background-color: var(--color-gold);"></div>
