---
import DonationForm from '../components/donations/DonationForm.astro';
import DonorFeed from '../components/donations/DonorFeed.astro';
import ProgressBar from '../components/donations/ProgressBar.astro';
import Footer from '../components/Footer.astro';
import ImageGrid from '../components/ImageGrid.astro';
import Navbar from '../components/Navbar.astro';
import ScriptureBlock from '../components/ScriptureBlock.astro';
import Section from '../components/Section.astro';
import UnlockMap from '../components/UnlockMap.astro';
import VideoHeroInner from '../components/VideoHeroInner.astro';
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity';

const [pageData, media, partnerData] = await Promise.all([
	sanityClient.fetch(`*[_type =="page" && slug =="partner"][0] {
    seoTitle, seoDescription,
    heroHeading, heroSubheading,
    heroPrimaryCtaLabel, heroPrimaryCtaHref
  }`),
	sanityClient.fetch(
		`*[_type =="siteSettings"][0] { partnerPageVideo, bookCoverUrl, donateUrl, communityUrl }`,
	),
	sanityClient.fetch(
		`*[_type =="partnerContent"][0] { whyMatters, scope, whyDifferent, impactStats }`,
	),
]);

const seoTitle = pageData?.seoTitle || "Partner With Us | Father's Heart Bible";
const seoDescription =
	pageData?.seoDescription ||
	"Partner with the Father's Heart Bible project and help bring this transformational translation to the world. Your support makes a difference.";
const heroHeading = 'Partner With Us';
const heroSubheading = 'Be part of what the Father is doing.';
// Donate Now button removed from hero — donation form is in the next section,
// no need to send the donor scrolling past it to a CTA that's already visible.
const heroPrimaryCtaLabel = '';
const heroPrimaryCtaHref = '';
const bookCoverUrl = media?.bookCoverUrl || '';
// Always scroll to the embedded Stripe form in Section 1.5 — never depend on
// the Sanity donateUrl field (it was the legacy Givebutter URL pre-migration).
const donateUrl = '#donate';
const communityUrl = media?.communityUrl || '/join';

const whyMatters = partnerData?.whyMatters ?? [
	{
		heading: 'Complete the translation',
		body: 'The full canon — Genesis to Revelation — requires sustained support to complete and bring to publication.',
	},
	{
		heading: 'Produce physical editions',
		body: 'Premium print Bibles that can be held, given, and treasured require real production investment.',
	},
	{
		heading: 'Distribute more widely',
		body: "Every gift helps place the Father's Heart Bible™ into the hands of those who are ready to receive it.",
	},
	{
		heading: 'Expand future reach',
		body: 'Audio, study editions, and language translations — future expressions of this work require a foundation to stand on.',
	},
];

const scope = partnerData?.scope ?? [
	{
		title: 'Translation',
		body: "The ongoing interpretive work of rendering the full Biblical canon with the Father's heart in view.",
	},
	{
		title: 'Publishing',
		body: 'Editorial, design, and production preparation for the flagship premium print edition.',
	},
	{
		title: 'Production',
		body: 'Physical Bible printing, binding, and manufacturing to bring this translation into tangible form.',
	},
	{
		title: 'Distribution',
		body: 'Getting Bibles into the hands of readers — including those who could not otherwise access them.',
	},
	{
		title: 'Future Reach',
		body: "Study editions, audio, and translations that extend the Father's voice into more languages and formats.",
	},
];

const whyDifferent = partnerData?.whyDifferent ?? [
	'Reveals the Father where Scripture reveals Him — from Genesis to Revelation.',
	'Speaks directly to identity, intimacy, and belonging — the deep hunger of this generation.',
	'Written not to inform but to create encounter — a Bible that changes how readers know God.',
	'Rooted in the historic Christian and Trinitarian faith — trustworthy and spiritually serious.',
];

const impactStats = partnerData?.impactStats ?? [
	{ amount: '$33', impact: "Helps put one Father's Heart Bible™ into the hands of a reader." },
	{ amount: '$100', impact: 'Helps place three Bibles where they are most needed.' },
	{ amount: '$500', impact: 'Supports a meaningful portion of translation and production work.' },
];
---

<Layout
	title={seoTitle}
	description={seoDescription}
	darkHero={true}
	jsonLd={{
		"@context": "https://schema.org",
		"@graph": [
			{ "@type": "WebPage", "name": seoTitle, "description": seoDescription, "url": "https://fathersheartbible.com/partner" },
			{ "@type": "BreadcrumbList", "itemListElement": [
				{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fathersheartbible.com/" },
				{ "@type": "ListItem", "position": 2, "name": "Partner With Us", "item": "https://fathersheartbible.com/partner" }
			]}
		]
	}}
>
	<Navbar />
	<main>

		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 1 — HERO (no CTA — donation form is right below)
		     ═══════════════════════════════════════════════════════════ -->
		<VideoHeroInner
			imageSrc="https://cdn.sanity.io/images/rusi1hyi/production/a323755d51d350e216d2fb38cd857df127609f67-1537x1023.png?w=1920&q=80&auto=format"
			showLogo={false}
			headingLift="1in"
			heading={heroHeading}
			subheading={heroSubheading}
		/>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 1.5 — DONATION FLOW (pitch + progress + form + feed)
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="light" id="donate">
			<!-- Pitch banner — campaign goal + math + headline. Sets the
			     frame before the donor scans the amount tiers. -->
			<div class="max-w-4xl mx-auto mb-10" data-reveal>
				<div class="p-6 md:p-8 rounded-2xl text-center" style="background: #FFD9E0; color: #4A4A4A;">
					<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="opacity: 0.85; font-family: var(--font-sans);">
						First Edition Launch · Goal $100,000
					</p>
					<h2 class="text-2xl md:text-3xl font-light leading-tight mb-4" style="font-family: var(--font-serif);">
						$5 places a Father&rsquo;s Heart Bible into a reader&rsquo;s hands.
					</h2>
					<p class="text-base md:text-lg leading-relaxed max-w-2xl mx-auto" style="font-family: var(--font-sans); opacity: 0.95;">
						Help us launch our First Edition — 20,000 Bibles strong.
						Give $50 or more and become a <strong>Founding Supporter</strong>,
						receiving a numbered Founder&rsquo;s First Edition — a collector&rsquo;s copy
						only available through this campaign.
					</p>
				</div>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12 items-start">
				<!-- Left column: progress + donor feed -->
				<div class="lg:col-span-2 space-y-8" data-reveal>
					<ProgressBar campaign="fhb" />
					<DonorFeed campaign="fhb" />
				</div>
				<!-- Right column: donation form -->
				<div class="lg:col-span-3" data-reveal>
					<DonationForm />
				</div>
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 1.6 — DONOR TIERS + FOUNDER'S FIRST EDITION
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="soft">
			<div class="max-w-4xl mx-auto">
				<header class="text-center mb-10" data-reveal>
					<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-sans); color: var(--color-gold);">
						Donor Tiers
					</p>
					<h2 class="text-3xl md:text-4xl font-light" style="font-family: var(--font-serif); color: var(--color-ink);">
						What every gift unlocks
					</h2>
				</header>

				<div class="overflow-hidden rounded-2xl border" style="border-color: var(--color-outline-variant); background: var(--color-surface);" data-reveal>
					<table class="w-full text-left" style="font-family: var(--font-sans); border-collapse: collapse;">
						<thead>
							<tr style="background: var(--color-surface-low); color: var(--color-ink);">
								<th class="px-4 py-3 text-xs font-semibold tracking-widest uppercase">Gift</th>
								<th class="px-4 py-3 text-xs font-semibold tracking-widest uppercase">Tier</th>
								<th class="px-4 py-3 text-xs font-semibold tracking-widest uppercase">Reward</th>
							</tr>
						</thead>
						<tbody style="color: var(--color-muted);">
							<tr style="border-top: 1px solid var(--color-outline-variant);">
								<td class="px-4 py-4 font-semibold" style="color: var(--color-ink);">$5–$49</td>
								<td class="px-4 py-4">Sponsor</td>
								<td class="px-4 py-4">Name on the public donor wall at fathersheartbible.com/founders</td>
							</tr>
							<tr style="border-top: 1px solid var(--color-outline-variant);">
								<td class="px-4 py-4 font-semibold" style="color: var(--color-ink);">$50–$99</td>
								<td class="px-4 py-4">Founding Supporter</td>
								<td class="px-4 py-4">Numbered Founder&rsquo;s First Edition Bible · donor wall</td>
							</tr>
							<tr style="border-top: 1px solid var(--color-outline-variant);">
								<td class="px-4 py-4 font-semibold" style="color: var(--color-ink);">$100–$249</td>
								<td class="px-4 py-4">Founding Partner</td>
								<td class="px-4 py-4">Founder&rsquo;s First Edition · signed thank-you letter from Kevin · donor wall</td>
							</tr>
							<tr style="border-top: 1px solid var(--color-outline-variant);">
								<td class="px-4 py-4 font-semibold" style="color: var(--color-ink);">$250–$999</td>
								<td class="px-4 py-4">Founding Patron</td>
								<td class="px-4 py-4">Founder&rsquo;s First Edition with personalized bookplate · signed letter · donor wall</td>
							</tr>
							<tr style="border-top: 1px solid var(--color-outline-variant);">
								<td class="px-4 py-4 font-semibold" style="color: var(--color-ink);">$1,000+</td>
								<td class="px-4 py-4">Founder</td>
								<td class="px-4 py-4">Founder&rsquo;s First Edition with bookplate · name printed in every retail edition&rsquo;s acknowledgments · invitation to launch event</td>
							</tr>
						</tbody>
					</table>
				</div>

				<aside class="mt-8 p-6 rounded-2xl border" style="border-color: var(--color-outline-variant); background: var(--color-surface-low);" data-reveal>
					<p class="text-xs font-semibold tracking-widest uppercase mb-2" style="font-family: var(--font-sans); color: var(--color-gold);">
						The Founder&rsquo;s First Edition
					</p>
					<p class="leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">
						A numbered collector&rsquo;s edition of the First Edition Father&rsquo;s Heart Bible.
						Same content as the retail Bible, with markers that distinguish it as the
						founding-donor-only release. Strictly capped at 750 copies. Never reprinted in this form.
					</p>
				</aside>
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 1.7 — HOW THE CAMPAIGN RUNS
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="light">
			<div class="max-w-4xl mx-auto">
				<header class="mb-8" data-reveal>
					<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-sans); color: var(--color-gold);">
						Campaign Mechanics
					</p>
					<h2 class="text-3xl md:text-4xl font-light" style="font-family: var(--font-serif); color: var(--color-ink);">
						How this campaign runs
					</h2>
				</header>
				<ul class="space-y-4" style="font-family: var(--font-sans); color: var(--color-muted);" data-reveal>
					<li class="flex gap-4">
						<span aria-hidden="true" style="color: var(--color-primary); font-weight: 700; flex-shrink: 0;">·</span>
						<span><strong style="color: var(--color-ink);">Early-bird Founders #1–100.</strong> The first 100 Founding Supporters receive Founder&rsquo;s First Editions numbered 1 through 100 — the lowest, most collectible numbers.</span>
					</li>
					<li class="flex gap-4">
						<span aria-hidden="true" style="color: var(--color-primary); font-weight: 700; flex-shrink: 0;">·</span>
						<span><strong style="color: var(--color-ink);">Public donor wall.</strong> Every donor&rsquo;s name (with permission) listed publicly at fathersheartbible.com/founders.</span>
					</li>
					<li class="flex gap-4">
						<span aria-hidden="true" style="color: var(--color-primary); font-weight: 700; flex-shrink: 0;">·</span>
						<span><strong style="color: var(--color-ink);">Permanent acknowledgments.</strong> Every donor of $250+ printed in the acknowledgments of every retail edition, permanently.</span>
					</li>
					<li class="flex gap-4">
						<span aria-hidden="true" style="color: var(--color-primary); font-weight: 700; flex-shrink: 0;">·</span>
						<span><strong style="color: var(--color-ink);">Numbered limited edition.</strong> Founder&rsquo;s First Editions strictly capped at 750; never reprinted in that form.</span>
					</li>
					<li class="flex gap-4">
						<span aria-hidden="true" style="color: var(--color-primary); font-weight: 700; flex-shrink: 0;">·</span>
						<span><strong style="color: var(--color-ink);">Behind-the-scenes access.</strong> Founding Patrons and Founders receive weekly campaign-period updates.</span>
					</li>
					<li class="flex gap-4">
						<span aria-hidden="true" style="color: var(--color-primary); font-weight: 700; flex-shrink: 0;">·</span>
						<span><strong style="color: var(--color-ink);">Bulk gifting tier.</strong> Sponsor 10 Bibles for $40 — placed in ministries, prisons, foster systems, or recipients of your choice.</span>
					</li>
					<li class="flex gap-4">
						<span aria-hidden="true" style="color: var(--color-primary); font-weight: 700; flex-shrink: 0;">·</span>
						<span><strong style="color: var(--color-ink);">Launch event.</strong> Founders ($1,000+) invited to the in-person launch event when the First Edition ships.</span>
					</li>
				</ul>
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 1.75 — PRODUCTION TIMELINE
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="soft">
			<div class="max-w-3xl mx-auto">
				<header class="mb-8" data-reveal>
					<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-sans); color: var(--color-gold);">
						Production Timeline
					</p>
					<h2 class="text-3xl md:text-4xl font-light" style="font-family: var(--font-serif); color: var(--color-ink);">
						What ships when
					</h2>
				</header>
				<ol class="rounded-2xl overflow-hidden border" style="list-style: none; padding: 0; margin: 0; border-color: var(--color-outline-variant); background: var(--color-surface);" data-reveal>
					<li class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-2 md:gap-6 px-5 py-4" style="border-bottom: 1px solid var(--color-outline-variant);">
						<span style="font-family: var(--font-sans); font-size: 13px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.04em;">June 2026</span>
						<span style="font-family: var(--font-sans); color: var(--color-muted); line-height: 1.55;">Public Review · Founder&rsquo;s Clubs open</span>
					</li>
					<li class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-2 md:gap-6 px-5 py-4" style="border-bottom: 1px solid var(--color-outline-variant);">
						<span style="font-family: var(--font-sans); font-size: 13px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.04em;">July 2026</span>
						<span style="font-family: var(--font-sans); color: var(--color-muted); line-height: 1.55;">Canon locked · formatting and design</span>
					</li>
					<li class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-2 md:gap-6 px-5 py-4" style="border-bottom: 1px solid var(--color-outline-variant);">
						<span style="font-family: var(--font-sans); font-size: 13px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.04em;">August 2026</span>
						<span style="font-family: var(--font-sans); color: var(--color-muted); line-height: 1.55;">Digital Bibles published</span>
					</li>
					<li class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-2 md:gap-6 px-5 py-4" style="border-bottom: 1px solid var(--color-outline-variant);">
						<span style="font-family: var(--font-sans); font-size: 13px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.04em;">September 2026</span>
						<span style="font-family: var(--font-sans); color: var(--color-muted); line-height: 1.55;">Paperback &amp; Hardback published</span>
					</li>
					<li class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-2 md:gap-6 px-5 py-4" style="border-bottom: 1px solid var(--color-outline-variant);">
						<span style="font-family: var(--font-sans); font-size: 13px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.04em;">October 2026</span>
						<span style="font-family: var(--font-sans); color: var(--color-muted); line-height: 1.55;">eBook and audiobook published</span>
					</li>
					<li class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-2 md:gap-6 px-5 py-4" style="border-bottom: 1px solid var(--color-outline-variant); background: var(--color-surface-low);">
						<span style="font-family: var(--font-sans); font-size: 13px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.04em;">November 2026</span>
						<span style="font-family: var(--font-sans); color: var(--color-ink); font-weight: 600; line-height: 1.55;">ComfortLeather&trade; Edition published</span>
					</li>
					<li class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-2 md:gap-6 px-5 py-4" style="border-bottom: 1px solid var(--color-outline-variant);">
						<span style="font-family: var(--font-sans); font-size: 13px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.04em;">December 31, 2026</span>
						<span style="font-family: var(--font-sans); color: var(--color-muted); line-height: 1.55;">20,000 copies distributed across all formats</span>
					</li>
					<li class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-2 md:gap-6 px-5 py-4" style="border-bottom: 1px solid var(--color-outline-variant);">
						<span style="font-family: var(--font-sans); font-size: 13px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.04em;">2027</span>
						<span style="font-family: var(--font-sans); color: var(--color-muted); line-height: 1.55;">Study Bibles published · international language translations</span>
					</li>
					<li class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-2 md:gap-6 px-5 py-4">
						<span style="font-family: var(--font-sans); font-size: 13px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.04em;">2028</span>
						<span style="font-family: var(--font-sans); color: var(--color-muted); line-height: 1.55;">Men&rsquo;s, Women&rsquo;s, Student, and Children&rsquo;s Bibles published · more international language translations</span>
					</li>
				</ol>
			</div>
		</Section>


			<!-- ═══════════════════════════════════════════════════════════
				     SECTION 1.78 — PREMIUM (COMFORTLEATHER) EDITION
				     ═══════════════════════════════════════════════════════════ -->
				<Section variant="light">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-14 items-center max-w-4xl mx-auto">
						<div class="flex justify-center" data-reveal>
							<img
								src="https://cdn.sanity.io/images/rusi1hyi/production/9618d5a555e40892802d587d0faa740a513035df-1024x1024.png?w=560&fm=webp&q=80&auto=format"
								alt="The ComfortLeather Edition of the Father's Heart Bible"
								width="420" height="420" loading="lazy" decoding="async"
								class="w-full max-w-sm rounded-2xl"
							/>
						</div>
						<div data-reveal>
							<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-sans); color: var(--color-gold);">ComfortLeather&trade; Edition · Holiday 2026</p>
							<h2 class="text-3xl md:text-4xl font-light leading-tight mb-5" style="font-family: var(--font-serif); color: var(--color-ink);">The Founder&rsquo;s Premium Edition</h2>
							<p class="leading-relaxed mb-4" style="font-family: var(--font-sans); color: var(--color-muted);">The flagship Father&rsquo;s Heart Bible&trade; — bound in supple ComfortLeather&trade;, individually numbered, and crafted to be held, gifted, and treasured for a lifetime.</p>
							<p class="leading-relaxed mb-6" style="font-family: var(--font-sans); color: var(--color-muted);">Founding Supporters ($50+) receive a numbered <strong style="color: var(--color-ink);">Founder&rsquo;s First Edition</strong> — a collector&rsquo;s copy available only through this launch campaign.</p>
							<a href="#donate" class="inline-flex items-center px-8 py-3.5 text-base font-semibold no-underline transition-all duration-200" style="font-family: var(--font-sans); background-color: #FFD9E0; color: #4A4A4A; border-radius: 8px;" onmouseover="this.style.opacity='0.92'" onmouseout="this.style.opacity='1'">Become a Founding Supporter →</a>
						</div>
					</div>
				</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 1.8 — PHASE 2: GLOBAL TRANSLATION EXPANSION
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="soft">
			<div class="max-w-4xl mx-auto">
				<header class="mb-8 text-center" data-reveal>
					<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-sans); color: var(--color-gold);">
						Beyond the First Edition
					</p>
					<h2 class="text-3xl md:text-4xl font-light" style="font-family: var(--font-serif); color: var(--color-ink);">
						Phase 2 — Global Translation Expansion
					</h2>
				</header>
				<p class="leading-relaxed mb-5 max-w-3xl mx-auto" style="font-family: var(--font-sans); color: var(--color-muted);" data-reveal>
					Phase 2 begins after the English First Edition launches in fall 2026.
					Every <strong>$50,000</strong> unlocks one of the top 20 languages —
					full translation, print and digital release, and audio narration in the
					target language.
				</p>
				<p class="leading-relaxed mb-8 max-w-3xl mx-auto" style="font-family: var(--font-sans); color: var(--color-muted);" data-reveal>
					Together, the top 20 languages reach about <strong>5.6 billion people</strong>
					— roughly <strong>75% of humanity</strong>.
				</p>
				<div class="max-w-3xl mx-auto p-6 rounded-2xl border" style="border-color: var(--color-outline-variant); background: var(--color-surface);" data-reveal>
					<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-sans); color: var(--color-primary);">
						Priority Order
					</p>
					<p class="text-sm mb-4" style="font-family: var(--font-sans); color: var(--color-muted);">
