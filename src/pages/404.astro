---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity';
import '../styles/global.css';

// Fetch siteSettings for siteName
const siteSettings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    siteName
  }
`);

const siteName = siteSettings?.siteName || "Father's Heart Bible";
const pageTitle = `404 — Page Not Found · ${siteName}`;
---

<Layout title={pageTitle}>
	<Navbar />
	<main class="min-h-screen flex items-center justify-center pt-20" style="background-color: var(--color-cream);">
		<div class="text-center px-6">
			<h1 class="text-7xl md:text-9xl font-light mb-4" style="font-family: var(--font-serif); color: var(--color-stone);">404</h1>
			<p class="text-xl mb-8" style="font-family: var(--font-sans); color: var(--color-warm-gray);">This page doesn't exist — but you are not lost.</p>
			<a
				href="/"
				class="inline-block px-8 py-3.5 text-sm font-semibold tracking-[0.1em] uppercase no-underline rounded-sm transition-all duration-300"
				style="font-family: var(--font-sans); background-color: var(--color-accent); color: var(--color-cream);"
			>
				Go Home
			</a>
		</div>
	</main>
	<Footer />
</Layout>
