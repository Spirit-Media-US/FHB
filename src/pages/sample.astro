---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import Layout from '../layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity';
import '../styles/global.css';

// Fetch the preface/sample page content from Sanity
const pageData = await sanityClient.fetch(`
  *[_type == "page" && slug == "sample"][0] {
    title,
    metaDescription,
    heroHeadline,
    heroSubheading,
    body
  }
`);

// Fetch siteSettings for dynamic titles if not in page content
const siteSettings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    siteName
  }
`);

const {
  title = `Preface — ${siteSettings?.siteName || "Father's Heart Bible"}`,
  metaDescription = `Read the preface to the ${siteSettings?.siteName || "Father's Heart Bible"} — why this translation exists and how it reveals God's heart throughout Scripture.`,
  heroHeadline = 'Preface',
  heroSubheading = 'From the Lead Translator',
  body = []
} = pageData || {};

// Helper function to render portable text content
function renderPortableText(blocks: any[]) {
  if (!blocks || !Array.isArray(blocks)) return '';
  
  return blocks.map((block: any) => {
    if (block._type === 'block') {
      const style = block.style || 'normal';
      
      // Render inline marks
      const renderSpans = (spans: any[]) => {
        if (!spans) return '';
        return spans.map((span: any) => {
          let text = span.text || '';
          
          // Apply inline formatting
          if (span.marks?.includes('em')) text = `<em>${text}</em>`;
          if (span.marks?.includes('strong')) text = `<strong>${text}</strong>`;
          
          return text;
        }).join('');
      };
      
      const content = renderSpans(block.children);
      
      switch (style) {
        case 'h1':
          return `<h3 class="preface-h3">${content}</h3>`;
        case 'h2':
          return `<h3 class="preface-h3">${content}</h3>`;
        case 'h3':
          return `<h3 class="preface-h3">${content}</h3>`;
        case 'blockquote':
          return `<blockquote class="preface-blockquote">${content}</blockquote>`;
        default:
          return `<p class="preface-p">${content}</p>`;
      }
    } else if (block._type === 'image') {
      return `<figure class="preface-figure"><img src="${urlFor(block).url()}" alt="${block.alt || 'Content image'}" /></figure>`;
    }
    return '';
  }).join('');
}

const renderedBody = renderPortableText(body);
---

<Layout title={title} description={metaDescription}>
	<Navbar />

	<!-- Header -->
	<section class="pt-32 pb-16 md:pt-40 md:pb-20" style="background: linear-gradient(160deg, var(--color-ink) 0%, var(--color-charcoal) 100%);">
		<div class="max-w-2xl mx-auto px-6 text-center">
			<p class="text-xs font-medium tracking-[0.2em] uppercase mb-6" style="font-family: var(--font-sans); color: var(--color-accent-light);">
				{heroSubheading}
			</p>
			<h1 class="text-4xl md:text-6xl font-light mb-6" style="font-family: var(--font-serif); color: var(--color-cream);">
				{heroHeadline}
			</h1>
			<div class="w-16 h-px mx-auto" style="background-color: var(--color-accent);"></div>
		</div>
	</section>

	<!-- Preface content from Sanity -->
	<article class="py-16 md:py-24" style="background-color: var(--color-cream);">
		<div class="max-w-2xl mx-auto px-6">
			<style>
				.preface-h3 {
					font-family: var(--font-serif);
					font-size: 1.75rem;
					font-weight: 400;
					color: var(--color-ink);
					margin-top: 3.5rem;
					margin-bottom: 1.5rem;
					text-align: center;
				}
				.preface-h3:first-child {
					margin-top: 0;
				}
				.preface-p {
					font-family: var(--font-serif);
					font-size: 1.125rem;
					line-height: 1.85;
					color: var(--color-charcoal);
					margin-bottom: 1.25rem;
				}
				.preface-p em {
					color: var(--color-ink);
				}
				.preface-p strong {
					color: var(--color-accent-dark);
				}
				.preface-blockquote {
					font-family: var(--font-serif);
					font-size: 1.25rem;
					font-style: italic;
					color: var(--color-ink);
					margin: 2rem 0;
					padding: 0;
					text-align: center;
					font-weight: 500;
				}
				.preface-figure {
					margin: 3rem 0;
				}
				.preface-figure img {
					max-width: 100%;
					height: auto;
				}
				.preface-content ul {
					list-style: none;
					padding: 0;
					margin: 1.5rem 0;
				}
				.preface-content ul li {
					font-family: var(--font-serif);
					font-size: 1.125rem;
					line-height: 1.85;
					color: var(--color-charcoal);
					padding-left: 1.5rem;
					margin-bottom: 0.5rem;
					position: relative;
				}
				.preface-content ul li::before {
					content: '';
					position: absolute;
					left: 0;
					top: 0.75rem;
					width: 6px;
					height: 6px;
					border-radius: 50%;
					background-color: var(--color-accent);
				}
				.section-divider {
					width: 3rem;
					height: 1px;
					background-color: var(--color-stone);
					margin: 3rem auto;
				}
			</style>

			<div class="preface-content">
				{body && body.length > 0 ? (
					<Fragment set:html={renderedBody} />
				) : (
					<!-- Fallback content if Sanity is not yet populated -->
					<div>
						<h3 class="preface-h3">Coming Soon</h3>
						<p class="preface-p">The preface content will be displayed here once it is added to the Sanity CMS.</p>
					</div>
				)}
			</div>
		</div>
	</article>
	<Footer />
</Layout>
