import CountryBible from '../../components/CountryBible.astro';

const verses = [
	{
		ref: 'Luke 15:20',
		slug: 'luke',
		ch: 15,
		text: 'And he arose and came to his father. But while he was still a long way off, his father saw him and felt compassion, and ran and embraced him and kissed him.',
	},
	{
		ref: 'Psalm 68:5',
		slug: 'psalms',
		ch: 68,
		text: 'A father to the fatherless, a defender of widows, is God in his holy dwelling.',
	},
	{
		ref: 'John 3:16',
		slug: 'john',
		ch: 3,
		text: 'For our Father so loved the world, that he gave his one and only Son, that whoever believes in him should not perish but have eternal life.',
	},
];

const stats = [
	{ label: 'People', value: '130 million' },
	{ label: 'Language', value: 'Spanish (largest)' },
	{ label: 'Christians', value: '~115 million' },
	{ label: 'Spanish worldwide', value: '550 million' },
];

const faqs = [
	{
		question: 'Can I read the Bible online free in Mexico?',
		answer:
			"Yes. The Father's Heart Bible™ is free to read online with audio — no account, no purchase, no app. It is currently in English; a Spanish edition is our highest translation priority, so all of Mexico can read it in its own language.",
	},
	{
		question: "Is the Father's Heart Bible available in Spanish?",
		answer:
			"Not yet — but Spanish is the very first new language on our roadmap. Mexico is the largest Spanish-speaking nation on earth, and a Spanish Father's Heart Bible™ would reach not only Mexico but some 550 million Spanish speakers worldwide.",
	},
	{
		question: 'What is the most popular Bible translation in Mexico?',
		answer:
			'The Reina-Valera — especially the 1960 revision (RVR1960) — is the most widely used Spanish Bible in Mexico and across the Spanish-speaking world. Newer versions like the Nueva Versión Internacional (NVI) are also common. Nearly all Bible reading in Mexico is in Spanish.',
	},
	{
		question: 'I already have a Bible — why another translation?',
		answer:
			"Mexico is deeply Christian, yet many relate to God at a distance — through ritual, tradition, or devotion mediated by others. The Father's Heart Bible™ renders God as Father wherever Scripture reveals Him that way, turning a revered book into a Father speaking directly to a son or daughter.",
	},
