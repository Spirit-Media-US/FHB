---
// /bible-in — "The Bible Around the World" hub. Lists every live country page
// as a card (from NATIONS). Targets "bible in <country>" intent and the brand's
// "to the nations" language. Add a country by shipping /bible-in/<slug>.astro
// and adding a row to src/data/nations.ts. Read-first per the architecture
// rules in memory/project_fhb_country_pages.md.
import { NATIONS } from '../../data/nations';
import Layout from '../../layouts/Layout.astro';

const PAGE_URL = 'https://fathersheartbible.com/bible-in/';
const TITLE = "The Bible Around the World — Read Free Online | Father's Heart Bible™";
const DESCRIPTION =
	"Read the Bible free online, country by country. The Father's Heart Bible™ reveals God as Father — free with audio, in English now, more languages coming.";

const HERO_BASE =
	'https://cdn.sanity.io/images/rusi1hyi/production/9f29bfca381f5c99ffa6ee6cd00f02572f0f7b96-5864x2503.jpg';
const HERO_ALT = 'Readers around the world with Scripture';
const HERO_IMG = `${HERO_BASE}?w=1400&h=560&fit=crop&crop=entropy&fm=webp&q=72`;
const OG_IMG = `${HERO_BASE}?w=1200&h=630&fit=crop&crop=entropy&fm=jpg&q=80`;

const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'The Bible Around the World',
	description: DESCRIPTION,
	url: PAGE_URL,
	inLanguage: 'en',
	isPartOf: {
		'@type': 'WebSite',
		name: "Father's Heart Bible™",
		url: 'https://fathersheartbible.com/',
	},
	mainEntity: {
		'@type': 'ItemList',
		itemListElement: NATIONS.map((n, i) => ({
			'@type': 'ListItem',
			position: i + 1,
			name: n.title,
			url: `https://fathersheartbible.com/bible-in/${n.slug}/`,
		})),
	},
};
const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://fathersheartbible.com/' },
		{ '@type': 'ListItem', position: 2, name: 'The Bible Around the World', item: PAGE_URL },
	],
};
// Hub FAQ — visible AND FAQPage schema (AEO). Answers target real global-Bible queries.
const FAQS = [
	{
		q: 'What is the most translated book in the world?',
		a: 'The Bible — by far. The full Bible has been translated into more than 700 languages, and at least some Scripture exists in over 3,600 languages, reaching the majority of people on earth. Read it free in English with audio at <a href="https://fathersheartbible.com/read" style="color: var(--color-brand);" class="hover:underline">fathersheartbible.com/read</a>.',
	},
	{
		q: "How many people still don't have the Bible in their own language?",
		a: 'Hundreds of millions. While 795 languages have a complete Bible, more than 1,800 languages have only the New Testament, and over 1,000 languages still have no Scripture at all — together spoken by well over a billion people. Many can read it today in English, and new translations are on the way.',
	},
	{
		q: 'Can I read the Bible free online in my country?',
		a: 'Yes — the Father\'s Heart Bible™ is free to read and hear online in every country, on any phone or computer, with no account, no purchase, and no app. Some nations restrict printing or distribution, but wherever there is internet, you can <a href="https://fathersheartbible.com/read" style="color: var(--color-brand);" class="hover:underline">start reading now</a>.',
	},
	{
		q: 'Which countries restrict the Bible?',
		a: 'A number of nations control or restrict the printing, sale, or distribution of the Bible — among them China, Iran, and other states with tight religious controls — though outright possession is rarely illegal. Even where access is hard, reading free online is often still possible. See each country page above for its specific situation.',
	},
	{
		q: "How can I help bring the Bible to a language that doesn't have it?",
		a: 'Each country page shows the languages still waiting for a translation that reveals God as Father, and how a sponsored translation reaches the most people for the lowest cost per reader. Explore the nations above to see where the need — and the opportunity — is greatest.',
	},
];
const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: FAQS.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
	})),
};
const jsonLd = [collectionSchema, breadcrumbSchema, faqSchema];
---

<Layout
	title={TITLE}
	description={DESCRIPTION}
	image={OG_IMG}
	darkHero={true}
	jsonLd={jsonLd}
	preloadImageMobile={HERO_IMG.replace('w=1400', 'w=640')}
	preloadImageDesktop={HERO_IMG}
>
	<main id="main-content">
		<section class="relative w-full overflow-hidden min-h-[560px] lg:min-h-[calc(46vh_+_2in)]">
			<img src={HERO_IMG} srcset={`${HERO_IMG.replace('w=1400', 'w=640')} 640w, ${HERO_IMG} 1400w`} sizes="(max-width: 1023px) 640px, 1400px" alt={HERO_ALT} class="absolute inset-0 w-full h-full object-cover" style="object-position: center top;" fetchpriority="high" decoding="async" />
			<div class="absolute inset-0 z-10" style="background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.22) 40%, rgba(0,0,0,0.3) 100%);" aria-hidden="true"></div>
		</section>

		<section class="px-6 pt-10 pb-2 lg:px-8" style="background-color: var(--color-surface-low);">
			<div class="mx-auto max-w-3xl">
				<nav aria-label="Breadcrumb" class="mb-5 text-sm" style="color: var(--color-muted); font-family: var(--font-sans);">
					<a href="/" class="hover:underline">Home</a><span class="px-1.5" aria-hidden="true">/</span>
					<span style="color: var(--color-ink);">The Bible Around the World</span>
				</nav>
				<p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-brand); font-family: var(--font-sans);">The Bible Around the World</p>
				<h1 class="text-4xl md:text-5xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">The Bible, nation by nation</h1>
				<p class="mt-5 text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">
					The <a href="https://fathersheartbible.com/read" style="color: var(--color-brand);" class="hover:underline">Father&rsquo;s Heart Bible&trade;</a> is free to read and hear online &mdash; a fresh translation that reveals God as a loving Father. Explore what Scripture looks like country by country, who&rsquo;s reading it, and how to begin wherever you are.
				</p>
			</div>
		</section>

		<section class="px-6 py-10 lg:px-8 lg:py-14" style="background-color: var(--color-surface);">
			<div class="mx-auto max-w-4xl">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{NATIONS.map((n) => (
						<a href={`/bible-in/${n.slug}/`} class="block rounded-2xl overflow-hidden no-underline transition-all hover:opacity-95" style="background-color: var(--color-surface-lowest); border: 1px solid var(--color-hairline);">
							<img src={`${n.img}?w=800&h=460&fit=crop&crop=entropy&fm=webp&q=70`} alt={n.title} width="800" height="460" class="w-full h-44 object-cover" loading="lazy" decoding="async" />
							<div class="p-5">
								<h2 class="text-xl font-medium leading-snug" style="font-family: var(--font-serif); color: var(--color-ink);">{n.title}</h2>
								<p class="mt-2 text-base leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">{n.blurb}</p>
								<span class="inline-flex items-center gap-1.5 mt-4 text-sm font-semibold" style="color: var(--color-brand); font-family: var(--font-sans);">Read more <span aria-hidden="true">&rarr;</span></span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>

		<section id="hub-faq" class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface); scroll-margin-top: 1.5rem;">
			<div class="mx-auto max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color: var(--color-gold); font-family: var(--font-sans);">Questions &amp; answers</p>
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">The Bible around the world</h2>
				<dl class="mt-8 space-y-7">
					{FAQS.map((f) => (
						<div>
							<dt class="text-lg font-medium leading-snug" style="font-family: var(--font-serif); color: var(--color-ink);">{f.q}</dt>
							<dd class="mt-2 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={f.a}></dd>
						</div>
					))}
				</dl>
			</div>
		</section>

		<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface-low);">
			<div class="mx-auto max-w-2xl text-center">
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">Read the Father&rsquo;s Heart Bible&trade; free</h2>
				<p class="mt-4 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">Wherever you are, start now &mdash; the whole Bible, free online with audio, in a fresh translation that reveals God as a loving Father.</p>
				<a href="https://fathersheartbible.com/read" class="inline-flex items-center gap-2 mt-6 px-8 py-3.5 text-base font-semibold no-underline transition-all duration-200" style="background-color: #FFD9E0; color: #4A4A4A; font-family: var(--font-sans);">Read FHB<span aria-hidden="true">&rarr;</span></a>
			</div>
		</section>
	</main>
</Layout>
