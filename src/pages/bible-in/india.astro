	glanceIntroHtml={`India is a nation of staggering scale and variety &mdash; the most populous country on earth and one of the most linguistically rich places in human history. It&rsquo;s a land where faith is woven into daily life, and where the Bible already travels in dozens of tongues.`}
	stats={stats}
	knownForHeading="What India is known for"
	knownForIntroHtml={`India is one of civilization&rsquo;s great originators &mdash; a land that gave the world enduring ideas, flavors, and beauty long before it gave the world its software engineers.`}
	knownFor={[
		{ label: 'The cradle of zero and chess', text: 'India gave mathematics the concept of zero and the decimal system, and gave the world chess, now played in nearly every country on earth.' },
		{ label: 'A civilization of festivals', text: 'From the lights of Diwali to the colors of Holi, India celebrates more public festivals than almost any nation — joy is a way of life.' },
		{ label: 'The Taj Mahal & ancient wonders', text: 'A monument to love that draws millions of pilgrims and travelers each year, beside thousands of temples, forts, and sacred rivers.' },
		{ label: 'The world’s largest democracy', text: 'Nearly a billion eligible voters make India the largest democratic exercise humanity has ever undertaken.' },
		{ label: 'Cuisine that conquered the globe', text: 'India’s spices and dishes are loved on every continent — a generosity of flavor that mirrors its hospitality.' },
		{ label: 'Bollywood & a culture of story', text: 'India produces more films than any other country, telling stories of love, family, and longing to billions of viewers.' },
	]}
	gallery={[
		{ src: 'https://cdn.sanity.io/images/rusi1hyi/production/cdab8e222229a20360ac942d20cf6e0f4e5a332b-3366x2244.jpg', alt: 'The Taj Mahal in Agra, India' },
		{ src: 'https://cdn.sanity.io/images/rusi1hyi/production/50d898efc3124d337746de63a811f6c25b9ab4b5-3264x2448.jpg', alt: 'Houseboat on the palm-lined backwaters of Kerala, India' },
		{ src: 'https://cdn.sanity.io/images/rusi1hyi/production/5d0f1ee95e5529c4f02e25adbc6be6eb9c8e120b-3072x2048.jpg', alt: 'The Kullu Valley in the Indian Himalayas, Himachal Pradesh' },
		{ src: 'https://cdn.sanity.io/images/rusi1hyi/production/7e959f9c1598aeea59f02300cc9c836ffc0ebf01-4032x2688.jpg', alt: 'An Indian family on the coast at sunset' },
