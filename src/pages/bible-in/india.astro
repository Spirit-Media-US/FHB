		{ src: 'https://cdn.sanity.io/images/rusi1hyi/production/418bd3e768b3278d0e137b57824dc9e88c4ad867-2892x1908.jpg', alt: 'A young woman in Rajasthan, India' },
		{ src: 'https://cdn.sanity.io/images/rusi1hyi/production/5e8219ec0e1bc25e33dffb89764d873ad9d91897-2967x2278.jpg', alt: 'A woman from a tribal community in India' },
