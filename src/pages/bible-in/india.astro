---
// /bible-in/india — first country page in the "Bible Around the World" hub.
// Data only; rendered by <CountryBible>. English-first, read-first per the
// architecture rules in memory/project_fhb_country_pages.md. All stats are
// cited in the `sources` array. To add a country: copy this file, swap the
// data, and add a row to src/data/nations.ts.
import CountryBible from '../../components/CountryBible.astro';

const verses = [
	{
		ref: 'Isaiah 41:10',
		slug: 'isaiah',
		ch: 41,
		text: 'Fear not, for I am with you; be not dismayed, for I am your Father. I will strengthen you, I will help you, I will uphold you with my righteous right hand.',
	},
	{
		ref: 'Jeremiah 29:11',
		slug: 'jeremiah',
		ch: 29,
		text: 'For I know the plans I have for you, declares your Father — plans for peace and not for harm, to give you a future and a hope.',
	},
	{
		ref: 'John 3:16',
		slug: 'john',
		ch: 3,
		text: 'For our Father so loved the world, that he gave his one and only Son, that whoever believes in him should not perish but have eternal life.',
	},
];

const stats = [
	{ label: 'People', value: '1.4 billion' },
	{ label: 'Official languages', value: '22 + English' },
	{ label: 'English users', value: '2nd most on earth' },
	{ label: 'Christians', value: '~28 million' },
];

const faqs = [
	{
		question: 'Can I read the Bible online free in India?',
		answer:
			"Yes. The Father's Heart Bible is free to read online in India — no account, no purchase, no app required. Open fathersheartbible.com/read on any phone, tablet, or computer and start in Genesis, John, or any book you like, with audio you can listen to as you read.",
	},
	{
		question: 'Is there an audio Bible I can listen to in India?',
		answer:
			"Yes. Every chapter of the Father's Heart Bible comes with free audio, so you can listen to Scripture on your phone — useful on the go or in any setting where reading aloud is easier than reading from a screen. Audio Bible demand is rising fast worldwide, with more than 1.3 billion audio-Bible listens recorded in 2024.",
	},
	{
		question: "Is the Father's Heart Bible available in Hindi?",
		answer:
			"Not yet — the Father's Heart Bible is currently available in English, which India's very large English-reading population can use today. Hindi, spoken by roughly 600 million people, is among the first translations on our roadmap, alongside other major world languages.",
	},
	{
		question: 'What is the most-read Bible verse in the world?',
		answer:
			'Isaiah 41:10 — "Fear not, for I am with you" — was the most-engaged-with verse worldwide in 2025 on the YouVersion Bible App, followed by Jeremiah 29:11 and Romans 12:2. You can read and hear all of them free in the Father\'s Heart Bible.',
	},
	{
		question: "What makes the Father's Heart Bible different from other Bibles?",
		answer:
			"It is the first English translation to reveal God as Father wherever Scripture reveals Him as Father — from Genesis 1:1 to John 3:16 — instead of a distant, generic 'God.' For many readers in India and around the world, that single change turns the Bible from a book about a deity into a letter from a loving Father.",
	},
];
---

<CountryBible
	slug="india"
	country="India"
	flag="🇮🇳"
	colorPrimary="#FF9933"
	colorSecondary="#138808"
	title="The Bible in India — Read Free Online with Audio | Father's Heart Bible"
	description="Read the Bible free online in India, with audio. The Father's Heart Bible reveals God as Father — free on any phone, no app needed. English now, Hindi on the way."
	h1="The Bible in India"
	heroSubhead="A free online Bible with audio for one of the world's largest English-reading nations — revealing God as a loving Father, on any phone."
	heroBase="https://cdn.sanity.io/images/rusi1hyi/production/82a0a4ceff7d68b1489b2085f692af2ed4f0e58c-6016x4016.jpg"
	heroAlt="Friends reading Scripture together"
	directAnswerHtml={`<strong style=\"color: var(--color-ink);\">Yes &mdash; you can read the Bible free online in India right now.</strong> The <a href=\"https://fathersheartbible.com/read\" style=\"color: var(--color-brand);\" class=\"hover:underline\">Father&rsquo;s Heart Bible</a> is a fresh English translation you can read and <em>listen to</em> free on any phone, with no app to install and no account to create. India is home to the world&rsquo;s second-largest English-using population, so for hundreds of millions of readers it is available today &mdash; and Hindi is among the first new translations on our roadmap. Whether you&rsquo;re searching for &ldquo;read the Bible online,&rdquo; a &ldquo;free Bible with audio,&rdquo; or simply where to begin, you can start in the next breath.`}
	keyTakeaway="The Bible is free to read and hear online in India today in English — and the Father's Heart Bible reads it in the Father's own voice, not as a distant God."
	glanceIntroHtml={`India is a nation of staggering scale and variety &mdash; the most populous country on earth and one of the most linguistically rich places in human history. It&rsquo;s a land where faith is woven into daily life, and where the Bible already travels in dozens of tongues.`}
	stats={stats}
	faithHeading="Faith and the Bible in India"
	faithBodyHtml={`<p>India is one of the most religious societies on earth. Hindus make up about 79.8% of the population, Muslims 14.2%, and Christians roughly 2.3% &mdash; but in a nation of 1.4 billion, that small percentage is still around <strong>28 million Christians</strong>, more than the entire population of many countries.</p><p>The appetite for Scripture is enormous and growing. In 2024 India received about <strong>1.8 million printed Bibles</strong> &mdash; second in the world only to Brazil &mdash; and the Bible Society of India now produces audio Scripture in <strong>69 languages</strong>, from Hindi and Bengali to Punjabi, Marathi and beyond. Globally, digital Bible distribution has now overtaken print for the first time, and audio is surging: more than 1.3 billion audio-Bible listens were recorded in a single year.</p><p>India&rsquo;s linguistic reality shapes everything. The Constitution recognizes 22 official languages plus English, the census counts over 1,600 mother tongues, and Hindi alone has more than 500 million speakers. English is the bridge language of education and the internet here &mdash; which is exactly why a clear, free English Bible meets a real and present need, while translations like Hindi open the door to hundreds of millions more.</p>`}
	sources={[
		{ label: 'Pew Research — religion in India', url: 'https://www.pewresearch.org/short-reads/2021/09/21/key-findings-about-the-religious-composition-of-india/' },
		{ label: 'Bible Society of India', url: 'https://www.bsind.org/' },
		{ label: 'Bible distribution 2024 (Christian Today)', url: 'https://www.christiantoday.com/news/digital-bible-distribution-outstrips-print-worldwide-for-the-first-time' },
	]}
	whyHeading="Why the Father's Heart Bible for India"
	whyBlocks={[
		{ heading: 'God revealed as Father, not a distant deity', bodyHtml: `In a culture rich with names and images for the divine, the Father&rsquo;s Heart Bible offers something no English Bible has before: it reveals God as <em>Father</em> wherever Scripture reveals Him that way &mdash; from <a href=\"https://fathersheartbible.com/read/genesis/1\" style=\"color: var(--color-brand);\" class=\"hover:underline\">Genesis 1:1</a> onward. Not a remote power to appease, but a Father who loves His sons and daughters.` },
		{ heading: 'Free, with audio, on any phone', bodyHtml: `No purchase, no app, no sign-up. The whole Bible is free to <a href=\"https://fathersheartbible.com/read\" style=\"color: var(--color-brand);\" class=\"hover:underline\">read online</a> with audio on every chapter &mdash; built to work on a basic smartphone, which is how most of India reads the internet.` },
		{ heading: 'A starting point for every reader', bodyHtml: `New to the Bible? Our <a href=\"/guides/where-to-start-reading-the-bible/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">where-to-start guide</a> and <a href=\"/guides/how-to-read-the-bible/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">how-to-read-the-Bible guide</a> walk you through the first steps, so you&rsquo;re never lost on page one.` },
	]}
	opportunityHeading="The translation opportunity in India"
	opportunityIntroHtml={`English reaches a remarkable share of India, but it is a second language for most. India&rsquo;s heart languages are spoken by hundreds of millions who have never had a Bible that calls God <em>Father</em> in their own tongue. Here is the scale of what&rsquo;s still ahead &mdash; and where a sponsored translation reaches the most people.`}
	languages={[
		{ language: 'English', speakers: '125 million+', status: 'Available' },
		{ language: 'Hindi', speakers: '600 million', status: 'On the roadmap' },
		{ language: 'Bengali', speakers: '97 million', status: 'Translation needed' },
		{ language: 'Marathi', speakers: '83 million', status: 'Translation needed' },
		{ language: 'Telugu', speakers: '81 million', status: 'Translation needed' },
		{ language: 'Tamil', speakers: '69 million', status: 'Translation needed' },
		{ language: 'Gujarati', speakers: '55 million', status: 'Translation needed' },
		{ language: 'Urdu', speakers: '50 million', status: 'Translation needed' },
	]}
	verses={verses}
	keepReadingHtml={`Begin with the <a href=\"https://fathersheartbible.com/read\" style=\"color: var(--color-brand);\" class=\"hover:underline\">whole Bible free online with audio</a>, learn <a href=\"/the-fathers-heart-bible/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">why the Father&rsquo;s Heart Bible exists</a>, or get oriented with our <a href=\"/guides/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">Bible reading guides</a> &mdash; including <a href=\"/guides/where-to-start-reading-the-bible/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">where to start</a>, <a href=\"/guides/how-to-pray/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">how to pray</a>, and <a href=\"/guides/what-is-the-gospel/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">what the gospel is</a>. Browse Scripture by theme on our <a href=\"/verses/\" style=\"color: var(--color-brand);\" class=\"hover:underline\">Bible verses by topic</a> pages.`}
	faqs={faqs}
	ctaMidHeading="Start reading in your own language today"
	ctaMidBodyHtml={`India&rsquo;s English readers can open the Father&rsquo;s Heart Bible this minute &mdash; free, with audio, on any phone. Hear Scripture in the Father&rsquo;s own voice.`}
	ctaBottomBodyHtml={`From Genesis to Revelation, free online with audio &mdash; a fresh translation that reveals God as a loving Father to every beloved son and daughter, in India and around the world.`}
/>
