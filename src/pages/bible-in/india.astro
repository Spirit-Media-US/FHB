---
// /bible-in/india — first country page in the "Bible Around the World" hub.
// Data only; rendered by <CountryBible>. English-first, read-first per the
// architecture rules in memory/project_fhb_country_pages.md. All stats are
// cited in the `sources` array. To add a country: copy this file, swap the
// data, and add a row to src/data/nations.ts.
import CountryBible from '../../components/CountryBible.astro';

const verses = [
	{
		ref: 'Isaiah 41:10',
		slug: 'isaiah',
		ch: 41,
		text: 'Fear not, for I am with you; be not dismayed, for I am your Father. I will strengthen you, I will help you, I will uphold you with my righteous right hand.',
	},
	{
		ref: 'Jeremiah 29:11',
		slug: 'jeremiah',
		ch: 29,
		text: 'For I know the plans I have for you, declares your Father — plans for peace and not for harm, to give you a future and a hope.',
	},
	{
		ref: 'John 3:16',
		slug: 'john',
		ch: 3,
		text: 'For our Father so loved the world, that he gave his one and only Son, that whoever believes in him should not perish but have eternal life.',
	},
];

const stats = [
	{ label: 'People', value: '1.4 billion' },
	{ label: 'Official languages', value: '22 + English' },
	{ label: 'English users', value: '2nd most on earth' },
	{ label: 'Christians', value: '~28 million' },
];

const faqs = [
	{
		question: 'How many Christians are there in India?',
		answer:
			"Christianity is India's third-largest religion. Christians are about 2.3% of the population — but in a nation of 1.4 billion, that is still roughly 28 million men, women, and children, more than the entire population of many countries. You can read and hear the Scriptures they treasure free in the Father's Heart Bible™ at fathersheartbible.com/read.",
	},
	{
		question: 'Is the Bible legal in India, and is Christianity growing?',
		answer:
			"Yes — the Bible is legal to own and read across India, and the church is among the country's fastest-growing, though several states have 'anti-conversion' laws and believers can face local pressure. Wherever you are in India, the Father's Heart Bible™ is free to read online with audio — no account, no app — at fathersheartbible.com/read.",
	},
	{
		question: 'Can I read the Bible online free in India?',
		answer:
			"Yes. The Father's Heart Bible™ is free to read online in India — no account, no purchase, no app required. Open fathersheartbible.com/read on any phone, tablet, or computer and start in Genesis, John, or any book you like, with audio you can listen to as you read.",
	},
	{
		question: 'Is there an audio Bible I can listen to in India?',
		answer:
			"Yes. Every chapter of the Father's Heart Bible™ comes with free audio, so you can listen to Scripture on your phone — useful on the go or in any setting where reading aloud is easier than reading from a screen. Audio Bible demand is rising fast worldwide, with more than 1.3 billion audio-Bible listens recorded in 2024.",
	},
	{
		question: "Is the Father's Heart Bible™ available in Hindi?",
		answer:
			"Not yet — the Father's Heart Bible™ is currently available in English, which India's very large English-reading population can use today. Hindi, spoken by roughly 600 million people, is among the first translations on our roadmap, alongside other major world languages.",
	},
	{
		question: 'What is the most-read Bible verse in the world?',
		answer:
			'Isaiah 41:10 — "Fear not, for I am with you" — was the most-engaged-with verse worldwide in 2025 on the YouVersion Bible App, followed by Jeremiah 29:11 and Romans 12:2. You can read and hear all of them free in the Father\'s Heart Bible.',
	},
	{
		question: "What makes the Father's Heart Bible™ different from other Bibles?",
		answer:
			"It is the first English translation to reveal God as Father wherever Scripture reveals Him as Father — from Genesis 1:1 to John 3:16 — instead of a distant, generic 'God.' For many readers in India and around the world, that single change turns the Bible from a book about a deity into a letter from a loving Father.",
	},
];
