	]}
	verses={verses}
	keepReadingHtml={`Begin with the <a href="https://fathersheartbible.com/read" style="color: var(--color-brand);" class="hover:underline">whole Bible free online with audio</a>, learn <a href="/the-fathers-heart-bible/" style="color: var(--color-brand);" class="hover:underline">why the Father&rsquo;s Heart Bible&trade; exists</a>, or get oriented with our <a href="/guides/" style="color: var(--color-brand);" class="hover:underline">Bible reading guides</a> &mdash; including <a href="/guides/where-to-start-reading-the-bible/" style="color: var(--color-brand);" class="hover:underline">where to start</a> and <a href="/guides/what-is-the-gospel/" style="color: var(--color-brand);" class="hover:underline">what the gospel is</a>. Browse Scripture by theme on our <a href="/verses/" style="color: var(--color-brand);" class="hover:underline">Bible verses by topic</a> pages.`}
	faqs={faqs}
	ctaMidHeading="Meet the Father in the book you already love"
	ctaMidBodyHtml={`Brazil knows the Bible. Now read it in the Father&rsquo;s own voice &mdash; free, with audio, on any phone.`}
	ctaBottomBodyHtml={`From Genesis to Revelation, free online with audio &mdash; a fresh translation that reveals God as a loving Father to every beloved son and daughter, in Brazil and around the world.`}
