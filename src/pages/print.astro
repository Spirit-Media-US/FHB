---
import Section from '../components/Section.astro';
import VideoHeroInner from '../components/VideoHeroInner.astro';
import Layout from '../layouts/Layout.astro';

// COMPACT editions on Amazon, each in paperback (asin) and hardback (hbAsin).
const editions = [
	{
		color: 'Plum',
		slug: 'plum',
		asin: 'B0H6S2MCY9',
		hbAsin: 'B0H86787P1',
		img: 'https://assets.spiritmediapublishing.com/FHB/print/edition-plum.webp',
	},
	{
		color: 'Charcoal',
		slug: 'charcoal',
		asin: 'B0H6S72QPD',
		hbAsin: 'B0H86Z7Y9B',
		img: 'https://assets.spiritmediapublishing.com/FHB/print/edition-charcoal.webp',
	},
	{
		color: 'White',
		slug: 'white',
		asin: 'B0H6S51GHR',
		hbAsin: 'B0H86GKMBP',
		img: 'https://assets.spiritmediapublishing.com/FHB/print/edition-white.webp',
	},
];

// LARGE PRINT editions. Paperbacks and hardbacks are both live on Amazon. Same
// retail as Compact ($39.99 PB / $44.99 HB), so LP shares the bulk ladder.
// Reuses the Compact cover art (same design, larger trim) until LP product
// shots are shot.
const lpEditions = [
	{
		color: 'Plum',
		slug: 'lp_plum',
		asin: 'B0H8XC43KR',
		hbAsin: 'B0H8XYPMQS',
		img: 'https://assets.spiritmediapublishing.com/FHB/print/edition-plum.webp',
	},
	{
		color: 'Charcoal',
		slug: 'lp_charcoal',
		asin: 'B0H8XQ2LGL',
		hbAsin: 'B0H8XM9VDC',
		img: 'https://assets.spiritmediapublishing.com/FHB/print/edition-charcoal.webp',
	},
	{
		color: 'White',
		slug: 'lp_white',
		asin: 'B0H8XPWH6T',
		hbAsin: 'B0H8XDZQ1Z',
		img: 'https://assets.spiritmediapublishing.com/FHB/print/edition-white.webp',
	},
];

// Digital editions. eBook is live on Amazon (Kindle) + Barnes & Noble (Nook) at
// $9.99, AND sold direct here ($7.49, our own fulfillment). Audiobook coming soon.
const ebookAsin = 'B0H8R2YP66';
const EBOOK_AMAZON = '$9.99';
const EBOOK_NOOK = '$9.99';
const EBOOK_NOOK_URL =
	'https://www.barnesandnoble.com/w/fathers-heart-bible-spirit-media-publishing/1150585116?ean=2940196931611';
const EBOOK_DIRECT = '$7.49';

// Volume ladder — the COMBINED total across all editions and bindings sets
// the tier. ONE consistent discount % applies to both bindings, each off its
// own retail (unit = paperback off $39.99, unitHb = hardback off $44.99).
// MUST match functions/print-checkout.ts TIERS.
const tiers = [
	{ qty: 25, pct: 15, unit: 33.99, unitHb: 38.24 },
	{ qty: 50, pct: 20, unit: 31.99, unitHb: 35.99 },
	{ qty: 100, pct: 25, unit: 29.99, unitHb: 33.74 },
	{ qty: 250, pct: 30, unit: 27.99, unitHb: 31.49 },
	{ qty: 500, pct: 35, unit: 25.99, unitHb: 29.24 },
	{ qty: 1000, pct: 40, unit: 23.99, unitHb: 26.99 },
];

const RETAIL = '$39.99';
const RETAIL_HB = '$44.99';

// Interior sample excerpts (Genesis) — direct PDF, hosted on R2.
const SAMPLE_REGULAR =
	'https://assets.spiritmediapublishing.com/FHB/print-samples/FHB-Genesis-sample-regular-7.5pt.pdf';
const SAMPLE_LP =
	'https://assets.spiritmediapublishing.com/FHB/print-samples/FHB-Genesis-sample-largeprint-14pt.pdf';

// Print FAQ — rendered as a no-JS <details> accordion + FAQPage JSON-LD (AEO).
const READ_URL = '/read';
const CAMPAIGN_URL = '/a-bible-for-the-whole-world/';
const LINK = 'color: var(--color-brand); text-decoration: underline;';
const TRANSLATION_URL = '/the-fathers-heart-bible/translation-philosophy/';
const CONTACT = 'mailto:hello@spiritmediapublishing.com?subject=Father%27s%20Heart%20Bible%20print';
const printFaq = [
	{
		q: 'Is there a cheaper version?',
		a: `Not yet. Right now the Father’s Heart Bible™ is printed on demand on premium white paper (as required by the industry) — and with paper costs up about 25% over the last two years and the 800–1,100 pages it takes to print a full Bible, the cost per copy runs high. More affordable offset-printed editions will be added in the future. In the meantime, you can read or listen to the whole Bible free at <a href="${READ_URL}" style="${LINK}">fathersheartbible.com/read</a>.`,
	},
	{
		q: 'Why is the Father’s Heart Bible™ thicker than other bibles?',
		a: `For now it’s printed on demand on a premium, heavier white paper (as required by the industry), and a complete Bible runs 800–1,100 pages — so the print-on-demand edition is thick. Slimmer, thinline editions on lighter paper from offset printing will be added in the future. Until then, you can read or listen to the whole Bible free at <a href="${READ_URL}" style="${LINK}">fathersheartbible.com/read</a>.`,
	},
	{
		q: 'Will the Father’s Heart Bible™ be published in other languages?',
		a: `Yes! The English edition is available now — everywhere books are sold worldwide — and free to read or listen to at <a href="${READ_URL}" style="${LINK}">fathersheartbible.com/read</a>. We sense our Father pressing us on to translate the Father’s Heart Bible™ into the world’s 25 most-spoken languages, reaching roughly 75% of humanity — and we won’t stop there. Our Bible for the Whole World campaign will continue until every one of the 8+ billion souls on earth can hold a Father’s Heart Bible in their hands.`,
		link: { href: CAMPAIGN_URL, label: 'Full details →' },
	},
	{
		q: 'Why are you charging for the Father’s Heart Bible™?',
		a: `The Father’s Heart Bible™ is actually free to read or listen to at <a href="${READ_URL}" style="${LINK}">fathersheartbible.com/read</a>, and in time it will be free on every major digital Bible platform. Print editions are priced only to cover the real costs of printing and distribution — and a portion of every copy sold helps fund our Bible for the Whole World campaign.`,
		link: { href: CAMPAIGN_URL, label: 'Learn more →' },
	},
	{
		q: 'What’s included in each edition?',
		a: `The Regular Print editions are the complete Bible, plus Receive the Father notes per book where space allows. The Large Print editions are New Testament+ — Genesis, Psalms, Proverbs, and the complete New Testament in full, plus a Father-focused survey of every other Old Testament book. Every edition, in every color and binding, is the same translation.`,
	},
	{
		q: 'How is the Father’s Heart Bible™ different from other translations?',
		a: `Father’s Heart Bible™: An Intimate Translation is a fresh Bible translation from the original Hebrew, Aramaic, and Greek that lets you hear God as He truly is — not a distant deity, but your Father. Read about <a href="${TRANSLATION_URL}" style="${LINK}">our translation approach</a>, or start reading free at <a href="${READ_URL}" style="${LINK}">fathersheartbible.com/read</a>.`,
	},
	{
		q: 'How long does shipping take?',
		a: `Single copies ship from Amazon on Amazon’s standard delivery timelines. Bulk orders through Spirit Media Publishing typically arrive in 3–4 weeks — <a href="${CONTACT}" style="${LINK}">reach out</a> if you need them sooner.`,
	},
	{
		q: 'Can I return my order?',
		a: `Copies bought on Amazon follow Amazon’s return policy. For bulk orders placed directly with us, <a href="${CONTACT}" style="${LINK}">reach out</a> and we’ll make it right.`,
	},
];
// Plain-text answers for FAQPage JSON-LD.
const stripHtml = (s: string) => s.replace(/<[^>]+>/g, '');
const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: printFaq.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: { '@type': 'Answer', text: stripHtml(f.a) },
	})),
};

// Book + Offer structured data — the /print page is the commerce surface, so the
// purchasable price range lives here (ebook direct $7.49 → hardback $44.99).
const bookSchema = {
	'@context': 'https://schema.org',
	'@type': 'Book',
	name: "Father's Heart Bible: An Intimate Translation",
	url: 'https://fathersheartbible.com/print/',
	inLanguage: 'en-US',
	author: { '@type': 'Person', name: 'Kevin White', url: 'https://kevinwhite.us' },
	publisher: {
		'@type': 'Organization',
		name: 'Spirit Media Publishing',
		url: 'https://spiritmediapublishing.com',
	},
	image: 'https://assets.spiritmediapublishing.com/FHB/share/fhb-og-print-group.jpg',
	offers: {
		'@type': 'AggregateOffer',
		priceCurrency: 'USD',
		lowPrice: '7.49',
		highPrice: '44.99',
		offerCount: 4,
		availability: 'https://schema.org/InStock',
		url: 'https://fathersheartbible.com/print/',
	},
};
const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://fathersheartbible.com/' },
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Now in Print',
			item: 'https://fathersheartbible.com/print/',
		},
	],
};

// FHB scripture cards — the Father's voice from first page to last (text pulled
// from the reader content).
const verses = [
	{
		ref: 'Genesis 1:1',
		text: 'In the beginning, our Heavenly Father created the heavens and the earth.',
		hl: ['our Heavenly Father'],
	},
	{
		ref: 'John 3:16',
		text: 'For our Father so loved the world, that he gave his one and only Son, that whoever believes in him should not perish but have eternal life.',
		hl: ['our Father'],
	},
	{
		ref: '2 Corinthians 6:18',
		text: 'I will be a Father to you and you will be sons and daughters to me, says our Father, the Almighty.',
		hl: ['a Father', 'sons and daughters', 'our Father'],
	},
];
// Wrap the Father-identity phrases in a light-pink highlighter mark.
function markFather(text: string, phrases: string[]): string {
	let out = text;
	for (const p of phrases) {
		out = out.replace(
			p,
			`<mark style="background:#ffd6e4;color:inherit;padding:0.02em 0.2em;border-radius:3px;">${p}</mark>`,
		);
	}
	return out;
}
---

<Layout
	title="Now in Print — Father's Heart Bible™: An Intimate Translation"
	description="The Father's Heart Bible™ is now in print — a fresh translation that reveals God as your Father. Buy a single copy, or order in bulk for your church."
	image="https://assets.spiritmediapublishing.com/FHB/share/fhb-og-print-group.jpg"
	imageAlt="Eight friends holding the Father's Heart Bible™ print edition in three colors and two bindings"
	darkHero={true}
	jsonLd={[bookSchema, breadcrumbSchema, faqSchema]}
>
	<main>
		<!-- ═══════════════ HERO ═══════════════ (shared component — same size as other pages) -->
		<VideoHeroInner
			imageSrc="https://assets.spiritmediapublishing.com/FHB/print/print-hero-group.webp"
			imagePosition="center top"
			headingLift="0.5in"
			heading="Now in Print"
			subheading="Order a copy for yourself, or in bulk to share."
		/>

		<!-- Campaign note (directly under the hero subheading) -->
		<section style="background-color: var(--color-canvas);" class="px-4 md:px-6 pt-2 pb-8 md:pb-12">
			<p class="max-w-2xl mx-auto text-center" style="font-family: var(--font-body); color: var(--color-muted); font-size: 0.95rem; line-height: 1.55;">A portion of every copy sold helps fund our Bible for the Whole World campaign. <a href={CAMPAIGN_URL} style="color: var(--color-brand); text-decoration: underline; font-weight: 600;">Learn More</a></p>
		</section>

		<!-- ═══════════════ THREE EDITIONS ═══════════════ -->
		<Section variant="light">
			<div class="text-center mb-10">
				<p style="font-family: var(--font-sans); color: var(--color-brand); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 0.5rem;">Single Copies from Amazon</p>
				<h2 style="font-family: var(--font-headline); color: var(--color-ink); font-size: 2rem; font-weight: 600; margin: 0;">Regular Print — Whole Bible: 3 colors, 2 bindings</h2>
				<p style="margin-top: 0.75rem;"><a href={SAMPLE_REGULAR} target="_blank" rel="noopener" style="font-family: var(--font-sans); color: var(--color-brand); text-decoration: underline; font-weight: 600; font-size: 0.9rem;">See a Regular Print sample (PDF) →</a></p>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-8 md:gap-10 max-w-4xl mx-auto">
				{editions.map((e) => (
					<div class="flex flex-col items-center text-center rounded-2xl p-6" style="background: var(--color-soft, #faf6f2); border: 1px solid var(--color-hairline);">
						<img src={e.img} alt={`Father's Heart Bible — ${e.color} edition`} width="700" height="1170" loading="lazy" decoding="async" class="block" style="width: 180px; height: auto; filter: drop-shadow(0 12px 24px rgba(0,0,0,0.18));" />
						<h3 style="font-family: var(--font-headline); color: var(--color-ink); font-size: 1.25rem; font-weight: 600; margin: 1.25rem 0 1rem;">{e.color} Edition</h3>
						<div class="flex flex-col gap-2 w-full" style="max-width: 13rem;">
							<a
								href={`https://www.amazon.com/dp/${e.asin}`}
								target="_blank"
								rel="noopener"
								class="inline-flex items-center justify-center rounded-full font-semibold"
								style="font-family: var(--font-sans); background: #ffe9f0; color: var(--color-brand); border: 1.5px solid var(--color-brand); padding: 0.7rem 1.4rem; text-decoration: none; font-size: 0.9rem;"
							>Paperback · {RETAIL} →</a>
							<a
								href={`https://www.amazon.com/dp/${e.hbAsin}`}
								target="_blank"
								rel="noopener"
								class="inline-flex items-center justify-center rounded-full font-semibold"
								style="font-family: var(--font-sans); background: #fff; color: var(--color-brand); border: 1.5px solid var(--color-brand); padding: 0.7rem 1.4rem; text-decoration: none; font-size: 0.9rem;"
							>Hardback · {RETAIL_HB} →</a>
						</div>
					</div>
				))}
			</div>

			<!-- Large Print -->
			<div class="text-center mt-14 mb-8">
				<p style="font-family: var(--font-sans); color: var(--color-brand); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 0.5rem;">Also in Large Print from Amazon</p>
				<h3 style="font-family: var(--font-headline); color: var(--color-ink); font-size: 2rem; font-weight: 600; margin: 0;">Large Print — New Testament+*: 3 colors, 2 bindings</h3>
				<p style="font-family: var(--font-body); color: var(--color-muted); font-size: 0.95rem; line-height: 1.55; margin: 0.75rem auto 0; max-width: 34rem;">*Genesis, Psalms, Proverbs, and the complete New Testament in full, plus a Father-focused survey of every other Old Testament book.</p>
				<p style="margin-top: 0.75rem;"><a href={SAMPLE_LP} target="_blank" rel="noopener" style="font-family: var(--font-sans); color: var(--color-brand); text-decoration: underline; font-weight: 600; font-size: 0.9rem;">See a Large Print sample (PDF) →</a></p>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-8 md:gap-10 max-w-4xl mx-auto">
				{lpEditions.map((e) => (
					<div class="flex flex-col items-center text-center rounded-2xl p-6" style="background: var(--color-soft, #faf6f2); border: 1px solid var(--color-hairline);">
						<img src={e.img} alt={`Father's Heart Bible Large Print — ${e.color} edition`} width="700" height="1170" loading="lazy" decoding="async" class="block" style="width: 180px; height: auto; filter: drop-shadow(0 12px 24px rgba(0,0,0,0.18));" />
						<h3 style="font-family: var(--font-headline); color: var(--color-ink); font-size: 1.25rem; font-weight: 600; margin: 1.25rem 0 1rem;">{e.color} Edition</h3>
						<div class="flex flex-col gap-2 w-full" style="max-width: 13rem;">
							<a
								href={`https://www.amazon.com/dp/${e.asin}`}
								target="_blank"
								rel="noopener"
								class="inline-flex items-center justify-center rounded-full font-semibold"
								style="font-family: var(--font-sans); background: #ffe9f0; color: var(--color-brand); border: 1.5px solid var(--color-brand); padding: 0.7rem 1.4rem; text-decoration: none; font-size: 0.9rem;"
							>Paperback · {RETAIL} →</a>
							<a
								href={`https://www.amazon.com/dp/${e.hbAsin}`}
								target="_blank"
								rel="noopener"
								class="inline-flex items-center justify-center rounded-full font-semibold"
								style="font-family: var(--font-sans); background: #fff; color: var(--color-brand); border: 1.5px solid var(--color-brand); padding: 0.7rem 1.4rem; text-decoration: none; font-size: 0.9rem;"
							>Hardback · {RETAIL_HB} →</a>
						</div>
					</div>
				))}
			</div>
			<p class="text-center" style="font-family: var(--font-sans); color: var(--color-muted); font-size: 0.9rem; margin-top: 2rem;">Large Print paperbacks and hardbacks ship from Amazon — and are available in bulk below.</p>

			<!-- Available everywhere books are sold — retailer strip -->
			<div class="text-center" style="margin-top: 2.5rem; padding-top: 1.75rem; border-top: 1px solid var(--color-hairline);">
				<p style="font-family: var(--font-sans); color: var(--color-muted); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; margin: 0 0 1.1rem;">Available everywhere books are sold</p>
				<div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-5">
					<a href={"https://www.amazon.com/s?k=Father%27s+Heart+Bible&i=stripbooks&crid=3UMQWME49FJDP&sprefix=father%27s+heart+bible%2Cstripbooks%2C108&ref=nb_sb_noss_1"} target="_blank" rel="noopener" aria-label="Shop the Father's Heart Bible on Amazon" style="display: inline-flex;">
						<img src="https://assets.spiritmediapublishing.com/FHB/print/logo-amazon.png" alt="Amazon" width="67" height="42" loading="lazy" decoding="async" style="height: 42px; width: auto;" />
					</a>
					<a href={"https://www.barnesandnoble.com/search?q=Father%27s%20Heart%20Bible&attributes.mfield_bnb__seoKeywords=Fathers-Heart-Bible%2FSpirit-Media-Publishing&filtersPreset=formatsEditions"} target="_blank" rel="noopener" aria-label="Shop the Father's Heart Bible at Barnes & Noble" style="display: inline-flex;">
						<img src="https://assets.spiritmediapublishing.com/FHB/print/logo-barnes-noble.png" alt="Barnes & Noble Booksellers" width="120" height="30" loading="lazy" decoding="async" style="height: 30px; width: auto;" />
					</a>
				</div>
			</div>
		</Section>

		<!-- ═══════════════ SCRIPTURE CARDS (Hear the Father — own soft-brown section) ═══════════════ -->
		<Section variant="warm">
			<div class="text-center mb-8">
				<p style="font-family: var(--font-sans); color: var(--color-brand); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 0.5rem;">Hear the Father</p>
				<h2 style="font-family: var(--font-headline); color: var(--color-ink); font-size: 2rem; font-weight: 600; margin: 0;">His voice, from the first page to the last</h2>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
				{verses.map((v) => (
					<div class="rounded-2xl p-7 flex flex-col" style="background: #fff; border: 1px solid var(--color-hairline);">
						<p style="font-family: var(--font-serif); font-style: italic; font-size: 1.08rem; line-height: 1.65; color: var(--color-ink); margin: 0; flex: 1;" set:html={`“${markFather(v.text, v.hl)}”`}></p>
						<p style="font-family: var(--font-sans); font-weight: 700; font-size: 0.78rem; letter-spacing: 0.03em; color: var(--color-brand); margin: 1.25rem 0 0;">{v.ref} · Father's Heart Bible™</p>
					</div>
				))}
			</div>
		</Section>

		<!-- ═══════════════ BULK ORDERS ═══════════════ -->
		<Section variant="soft">
			<div class="max-w-3xl mx-auto">
				<div class="text-center mb-8">
					<p style="font-family: var(--font-sans); color: var(--color-brand); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 0.5rem;">Bulk Order Discounts</p>
					<h2 style="font-family: var(--font-headline); color: var(--color-ink); font-size: 2rem; font-weight: 600; margin: 0;">Order in Bulk and Save</h2>
					<p style="font-family: var(--font-body); color: var(--color-muted); font-size: 1.05rem; line-height: 1.6; margin: 1rem auto 0; max-width: 44rem;">Bring the Father's heart to your whole business, congregation, or community.<br />Mix and match editions and bindings — your combined total sets the discount.</p>
					<p style="font-family: var(--font-sans); color: var(--color-ink); font-size: 0.9rem; font-weight: 600; margin: 0.75rem auto 0; max-width: 32rem;">Bulk orders are direct through Spirit Media Publishing — not Amazon.</p>
				</div>

				<div class="rounded-2xl p-6 md:p-8" style="background: #fff; border: 1px solid var(--color-hairline);" data-bulk>
					<p style="font-family: var(--font-sans); font-weight: 700; font-size: 0.85rem; color: var(--color-ink); margin: 0 0 0.6rem;">Volume discounts — the more you order, the more you save</p>
					<div class="grid grid-cols-2 sm:grid-cols-3 gap-2 mb-6">
						{tiers.map((t) => (
							<div class="tier-card rounded-xl text-center" data-tier-min={t.qty} style="padding: 0.7rem 0.4rem; border: 1.5px solid #ffd0e0; background: #ffe9f0;">
								<span style="display: block; font-size: 0.72rem; font-weight: 800; letter-spacing: 0.02em; color: #a0004c;">Save {t.pct}%</span>
								<span style="display: block; font-size: 1.15rem; font-weight: 700; color: var(--color-ink); margin-top: 0.1rem; line-height: 1.1;">{t.qty.toLocaleString()}+</span>
								<span style="display: block; font-size: 0.7rem; color: var(--color-muted); margin-top: 0.2rem; white-space: nowrap;">PB <s style="opacity: 0.6;">{RETAIL}</s> <span style="color: var(--color-ink); font-weight: 700;">${t.unit.toFixed(2)}</span></span>
								<span style="display: block; font-size: 0.7rem; color: var(--color-muted); white-space: nowrap;">HB <s style="opacity: 0.6;">{RETAIL_HB}</s> <span style="color: var(--color-ink); font-weight: 700;">${t.unitHb.toFixed(2)}</span></span>
							</div>
						))}
					</div>

					<p style="font-family: var(--font-sans); font-weight: 700; font-size: 0.85rem; color: var(--color-ink); margin: 0 0 0.6rem;">Choose how many of each edition</p>
					<div style="display: flex; flex-direction: column; gap: 0.65rem;">
						<p style="font-family: var(--font-sans); font-weight: 800; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-brand); margin: 0.2rem 0 -0.1rem;">Compact</p>
