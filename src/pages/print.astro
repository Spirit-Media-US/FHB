---
import Section from '../components/Section.astro';
import VideoHeroInner from '../components/VideoHeroInner.astro';
import Layout from '../layouts/Layout.astro';

// Three paperback editions live on Amazon. Hardback editions follow once published.
const editions = [
	{
		color: 'Plum',
		slug: 'plum',
		asin: 'B0H6S2MCY9',
		img: 'https://assets.spiritmediapublishing.com/FHB/print/edition-plum.webp',
	},
	{
		color: 'Charcoal',
		slug: 'charcoal',
		asin: 'B0H6S72QPD',
		img: 'https://assets.spiritmediapublishing.com/FHB/print/edition-charcoal.webp',
	},
	{
		color: 'White',
		slug: 'white',
		asin: 'B0H6S51GHR',
		img: 'https://assets.spiritmediapublishing.com/FHB/print/edition-white.webp',
	},
];

// Bulk tiers — per-unit price MUST match functions/print-checkout.ts PRICE_CENTS.
// ⚠️ PLACEHOLDER prices off the $39.99 retail — Kevin sets the real numbers.
const tiers = [
	{ qty: 25, unit: 32.99 },
	{ qty: 50, unit: 29.99 },
	{ qty: 100, unit: 27.99 },
	{ qty: 250, unit: 25.99 },
];

const RETAIL = '$39.99';
---

<Layout
	title="Now in Print — Father's Heart Bible™: An Intimate Translation"
	description="The Father's Heart Bible™: An Intimate Translation is now in print — a fresh Bible translation that reveals God as your Father. Buy a copy, or order in bulk for your church. Come home to your Father."
	image="https://assets.spiritmediapublishing.com/FHB/share/fhb-og-print.jpg"
	imageAlt="Friends reading the Father's Heart Bible™ print edition — now in three editions"
	darkHero={true}
>
	<main>
		<!-- ═══════════════ HERO ═══════════════ (shared component — same size as other pages) -->
		<VideoHeroInner
			imageSrc="https://assets.spiritmediapublishing.com/FHB/print/partner-hero.webp"
			heading="Now in Print"
			subheading="Order a copy for yourself, or in bulk for your church."
		/>

		<!-- ═══════════════ THREE EDITIONS ═══════════════ -->
		<Section variant="light">
			<div class="text-center mb-10">
				<p style="font-family: var(--font-sans); color: var(--color-brand); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 0.5rem;">Single Copies</p>
				<h2 style="font-family: var(--font-headline); color: var(--color-ink); font-size: 2rem; font-weight: 600; margin: 0;">Three paperback editions</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-8 md:gap-10 max-w-4xl mx-auto">
				{editions.map((e) => (
					<div class="flex flex-col items-center text-center rounded-2xl p-6" style="background: var(--color-soft, #faf6f2); border: 1px solid var(--color-hairline);">
						<img src={e.img} alt={`Father's Heart Bible — ${e.color} paperback edition`} width="700" height="1170" loading="lazy" decoding="async" class="block" style="width: 180px; height: auto; filter: drop-shadow(0 12px 24px rgba(0,0,0,0.18));" />
						<h3 style="font-family: var(--font-headline); color: var(--color-ink); font-size: 1.25rem; font-weight: 600; margin: 1.25rem 0 0.25rem;">{e.color} Edition</h3>
						<p style="font-family: var(--font-sans); color: var(--color-muted); font-size: 0.95rem; margin: 0 0 1rem;">Paperback · {RETAIL}</p>
						<a
							href={`https://www.amazon.com/dp/${e.asin}`}
							target="_blank"
							rel="noopener"
							class="inline-flex items-center justify-center rounded-full font-semibold"
							style="font-family: var(--font-sans); background: var(--color-brand); color: #fff; padding: 0.7rem 1.4rem; text-decoration: none; font-size: 0.95rem;"
						>Buy on Amazon →</a>
					</div>
				))}
			</div>
			<p class="text-center" style="font-family: var(--font-sans); color: var(--color-muted); font-size: 0.9rem; margin-top: 2rem;">Hardback editions coming soon.</p>
		</Section>

		<!-- ═══════════════ BULK ORDERS ═══════════════ -->
		<Section variant="soft">
			<div class="max-w-3xl mx-auto">
				<div class="text-center mb-8">
					<p style="font-family: var(--font-sans); color: var(--color-brand); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 0.5rem;">Bulk &amp; Church Orders</p>
					<h2 style="font-family: var(--font-headline); color: var(--color-ink); font-size: 2rem; font-weight: 600; margin: 0;">Order in quantity</h2>
					<p style="font-family: var(--font-body); color: var(--color-muted); font-size: 1.05rem; line-height: 1.6; margin: 1rem auto 0; max-width: 32rem;">Bring the Father's heart to your whole congregation, group, or outreach. Choose an edition and a quantity — checkout is secure.</p>
				</div>

				<div class="rounded-2xl p-6 md:p-8" style="background: #fff; border: 1px solid var(--color-hairline);" data-bulk>
					<!-- Color -->
					<p style="font-family: var(--font-sans); font-weight: 700; font-size: 0.85rem; color: var(--color-ink); margin: 0 0 0.6rem;">1 · Choose an edition</p>
					<div class="flex flex-wrap gap-2 mb-6" role="group" aria-label="Choose an edition">
						{editions.map((e, i) => (
							<button type="button" class="bulk-color rounded-full font-semibold" data-color={e.slug} aria-pressed={i === 0 ? 'true' : 'false'} style="font-family: var(--font-sans); font-size: 0.9rem; padding: 0.5rem 1.1rem; border: 1.5px solid var(--color-hairline); background: #fff; color: var(--color-ink); cursor: pointer;">{e.color}</button>
						))}
					</div>

					<!-- Quantity -->
					<p style="font-family: var(--font-sans); font-weight: 700; font-size: 0.85rem; color: var(--color-ink); margin: 0 0 0.6rem;">2 · Choose a quantity</p>
					<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
						{tiers.map((t, i) => (
							<button type="button" class="bulk-tier rounded-xl text-center" data-tier={t.qty} data-total={(t.qty * t.unit).toFixed(2)} aria-pressed={i === 0 ? 'true' : 'false'} style="font-family: var(--font-sans); padding: 0.9rem 0.5rem; border: 1.5px solid var(--color-hairline); background: #fff; cursor: pointer;">
								<span style="display: block; font-size: 1.35rem; font-weight: 700; color: var(--color-ink);">{t.qty}</span>
								<span style="display: block; font-size: 0.8rem; color: var(--color-muted);">copies · ${t.unit.toFixed(2)} ea</span>
							</button>
						))}
					</div>

					<!-- Summary + checkout -->
					<div class="flex flex-wrap items-center justify-between gap-4 pt-4" style="border-top: 1px solid var(--color-hairline);">
						<div>
							<span style="font-family: var(--font-sans); color: var(--color-muted); font-size: 0.85rem;">Total · free shipping</span>
							<div data-total-out style="font-family: var(--font-headline); color: var(--color-ink); font-size: 1.6rem; font-weight: 700;"></div>
						</div>
						<button type="button" data-checkout class="inline-flex items-center justify-center rounded-full font-semibold" style="font-family: var(--font-sans); background: var(--color-brand); color: #fff; padding: 0.8rem 1.8rem; border: 0; cursor: pointer; font-size: 1rem;">Checkout →</button>
					</div>
					<p data-bulk-msg style="font-family: var(--font-sans); font-size: 0.85rem; color: var(--color-muted); margin: 0.75rem 0 0; display: none;"></p>
				</div>
				<p class="text-center" style="font-family: var(--font-sans); color: var(--color-muted); font-size: 0.8rem; margin-top: 1rem;">Free shipping included · sales tax calculated at checkout · one edition per bulk order. Need more than 250? <a href="mailto:hello@spiritmediapublishing.com?subject=FHB%20bulk%20order%20(250%2B)" style="color: var(--color-brand); text-decoration: underline;">Contact us</a>.</p>
			</div>
		</Section>
	</main>
</Layout>

<script is:inline>
	(() => {
		const root = document.querySelector('[data-bulk]');
		if (!root) return;
		let color = 'plum';
		let tier = 25;
		let total = '824.75';
		const fmt = (n) => '$' + Number(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
		const out = root.querySelector('[data-total-out]');
		const msg = root.querySelector('[data-bulk-msg]');
		const paint = () => { if (out) out.textContent = fmt(total); };
		const setPressed = (nodes, match) => nodes.forEach((n) => {
			const on = match(n);
			n.setAttribute('aria-pressed', on ? 'true' : 'false');
			n.style.borderColor = on ? 'var(--color-brand)' : 'var(--color-hairline)';
			n.style.background = on ? 'rgba(182,0,87,0.06)' : '#fff';
		});
		const colors = [...root.querySelectorAll('.bulk-color')];
		const tprices = [...root.querySelectorAll('.bulk-tier')];
		colors.forEach((b) => b.addEventListener('click', () => { color = b.dataset.color; setPressed(colors, (n) => n === b); }));
		tprices.forEach((b) => b.addEventListener('click', () => { tier = Number(b.dataset.tier); total = b.dataset.total; setPressed(tprices, (n) => n === b); paint(); }));
		setPressed(colors, (n) => n.dataset.color === color);
		setPressed(tprices, (n) => Number(n.dataset.tier) === tier);
		paint();

		const btn = root.querySelector('[data-checkout]');
		btn?.addEventListener('click', async () => {
			btn.disabled = true; btn.textContent = 'Starting checkout…';
			try {
				const r = await fetch('/print-checkout', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ color, tier }) });
				const d = await r.json();
				if (d.url) { window.location.href = d.url; return; }
				if (msg) { msg.style.display = 'block'; msg.textContent = d.disabled ? 'Bulk checkout is opening soon — check back shortly.' : 'Sorry, something went wrong starting checkout. Please try again.'; }
			} catch {
				if (msg) { msg.style.display = 'block'; msg.textContent = 'Network error — please try again.'; }
			}
			btn.disabled = false; btn.textContent = 'Checkout →';
		});
	})();
</script>
