---
import Section from '../components/Section.astro';
import VideoHeroInner from '../components/VideoHeroInner.astro';
import Layout from '../layouts/Layout.astro';

// Three editions on Amazon, each in paperback (asin) and hardback (hbAsin).
const editions = [
	{
		color: 'Plum',
		slug: 'plum',
		asin: 'B0H6S2MCY9',
		hbAsin: 'B0H86787P1',
		img: 'https://assets.spiritmediapublishing.com/FHB/print/edition-plum.webp',
	},
	{
		color: 'Charcoal',
		slug: 'charcoal',
		asin: 'B0H6S72QPD',
		hbAsin: 'B0H86Z7Y9B',
		img: 'https://assets.spiritmediapublishing.com/FHB/print/edition-charcoal.webp',
	},
	{
		color: 'White',
		slug: 'white',
		asin: 'B0H6S51GHR',
		hbAsin: 'B0H86GKMBP',
		img: 'https://assets.spiritmediapublishing.com/FHB/print/edition-white.webp',
	},
];

// Volume ladder — the COMBINED total across all editions and bindings sets
// the tier. ONE consistent discount % applies to both bindings, each off its
// own retail (unit = paperback off $39.99, unitHb = hardback off $44.99).
// HB 1000+ is floored at a flat $27.00 (a true 40% would be $26.99).
// MUST match functions/print-checkout.ts TIERS.
const tiers = [
	{ qty: 25, pct: 15, unit: 33.99, unitHb: 38.24 },
	{ qty: 50, pct: 20, unit: 31.99, unitHb: 35.99 },
	{ qty: 100, pct: 25, unit: 29.99, unitHb: 33.74 },
	{ qty: 250, pct: 30, unit: 27.99, unitHb: 31.49 },
	{ qty: 500, pct: 35, unit: 25.99, unitHb: 29.24 },
	{ qty: 1000, pct: 40, unit: 23.99, unitHb: 27.0 },
];

const RETAIL = '$39.99';
const RETAIL_HB = '$44.99';

// FHB scripture cards — the Father's voice from first page to last (text pulled
// from the reader content).
const verses = [
	{
		ref: 'Genesis 1:1',
		text: 'In the beginning, our Heavenly Father created the heavens and the earth.',
		hl: ['our Heavenly Father'],
	},
	{
		ref: 'John 3:16',
		text: 'For our Father so loved the world, that he gave his one and only Son, that whoever believes in him should not perish but have eternal life.',
		hl: ['our Father'],
	},
	{
		ref: '2 Corinthians 6:18',
		text: 'I will be a Father to you and you will be sons and daughters to me, says our Father, the Almighty.',
		hl: ['a Father', 'sons and daughters', 'our Father'],
	},
];
// Wrap the Father-identity phrases in a light-pink highlighter mark.
function markFather(text: string, phrases: string[]): string {
	let out = text;
	for (const p of phrases) {
		out = out.replace(
			p,
			`<mark style="background:#ffd6e4;color:inherit;padding:0.02em 0.2em;border-radius:3px;">${p}</mark>`,
		);
	}
	return out;
}
---

<Layout
	title="Now in Print — Father's Heart Bible™: An Intimate Translation"
	description="The Father's Heart Bible™: An Intimate Translation is now in print — a fresh Bible translation that reveals God as your Father. Buy a copy, or order in bulk for your church. Come home to your Father."
	image="https://assets.spiritmediapublishing.com/FHB/share/fhb-og-print.jpg"
	imageAlt="Friends reading the Father's Heart Bible™ print edition — now in three editions"
	darkHero={true}
>
	<main>
		<!-- ═══════════════ HERO ═══════════════ (shared component — same size as other pages) -->
		<VideoHeroInner
			imageSrc="https://assets.spiritmediapublishing.com/FHB/print/partner-hero.webp"
			heading="Now in Print"
			subheading="Order a copy for yourself, or in bulk to share."
		/>

		<!-- ═══════════════ THREE EDITIONS ═══════════════ -->
		<Section variant="light">
			<div class="text-center mb-10">
				<p style="font-family: var(--font-sans); color: var(--color-brand); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 0.5rem;">Single Copies</p>
				<h2 style="font-family: var(--font-headline); color: var(--color-ink); font-size: 2rem; font-weight: 600; margin: 0;">Three editions, two bindings</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-8 md:gap-10 max-w-4xl mx-auto">
				{editions.map((e) => (
					<div class="flex flex-col items-center text-center rounded-2xl p-6" style="background: var(--color-soft, #faf6f2); border: 1px solid var(--color-hairline);">
						<img src={e.img} alt={`Father's Heart Bible — ${e.color} edition`} width="700" height="1170" loading="lazy" decoding="async" class="block" style="width: 180px; height: auto; filter: drop-shadow(0 12px 24px rgba(0,0,0,0.18));" />
						<h3 style="font-family: var(--font-headline); color: var(--color-ink); font-size: 1.25rem; font-weight: 600; margin: 1.25rem 0 1rem;">{e.color} Edition</h3>
						<div class="flex flex-col gap-2 w-full" style="max-width: 13rem;">
							<a
								href={`https://www.amazon.com/dp/${e.asin}`}
								target="_blank"
								rel="noopener"
								class="inline-flex items-center justify-center rounded-full font-semibold"
								style="font-family: var(--font-sans); background: var(--color-brand); color: #fff; padding: 0.7rem 1.4rem; text-decoration: none; font-size: 0.9rem;"
							>Paperback · {RETAIL} →</a>
							<a
								href={`https://www.amazon.com/dp/${e.hbAsin}`}
								target="_blank"
								rel="noopener"
								class="inline-flex items-center justify-center rounded-full font-semibold"
								style="font-family: var(--font-sans); background: #fff; color: var(--color-brand); border: 1.5px solid var(--color-brand); padding: 0.7rem 1.4rem; text-decoration: none; font-size: 0.9rem;"
							>Hardback · {RETAIL_HB} →</a>
						</div>
					</div>
				))}
			</div>
			<p class="text-center" style="font-family: var(--font-sans); color: var(--color-muted); font-size: 0.9rem; margin-top: 2rem;">Both bindings ship from Amazon.</p>
		</Section>

		<!-- ═══════════════ SCRIPTURE CARDS ═══════════════ -->
		<Section variant="soft" class="!pb-2 md:!pb-4">
			<div class="text-center mb-8">
				<p style="font-family: var(--font-sans); color: var(--color-brand); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 0.5rem;">Hear the Father</p>
				<h2 style="font-family: var(--font-headline); color: var(--color-ink); font-size: 2rem; font-weight: 600; margin: 0;">His voice, from the first page to the last</h2>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
				{verses.map((v) => (
					<div class="rounded-2xl p-7 flex flex-col" style="background: #fff; border: 1px solid var(--color-hairline);">
						<p style="font-family: var(--font-serif); font-style: italic; font-size: 1.08rem; line-height: 1.65; color: var(--color-ink); margin: 0; flex: 1;" set:html={`“${markFather(v.text, v.hl)}”`}></p>
						<p style="font-family: var(--font-sans); font-weight: 700; font-size: 0.78rem; letter-spacing: 0.03em; color: var(--color-brand); margin: 1.25rem 0 0;">{v.ref} · Father's Heart Bible™</p>
					</div>
				))}
			</div>
		</Section>

		<!-- ═══════════════ BULK ORDERS ═══════════════ -->
		<Section variant="soft" class="!pt-2 md:!pt-4">
			<div class="max-w-3xl mx-auto">
				<div class="text-center mb-8">
					<p style="font-family: var(--font-sans); color: var(--color-brand); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 0.5rem;">Bulk Order Discounts</p>
					<h2 style="font-family: var(--font-headline); color: var(--color-ink); font-size: 2rem; font-weight: 600; margin: 0;">Order in Bulk and Save</h2>
					<p style="font-family: var(--font-body); color: var(--color-muted); font-size: 1.05rem; line-height: 1.6; margin: 1rem auto 0; max-width: 32rem;">Bring the Father's heart to your whole business, congregation, or community. Mix and match editions and bindings — your combined total sets the discount.</p>
				</div>

				<div class="rounded-2xl p-6 md:p-8" style="background: #fff; border: 1px solid var(--color-hairline);" data-bulk>
					<p style="font-family: var(--font-sans); font-weight: 700; font-size: 0.85rem; color: var(--color-ink); margin: 0 0 0.6rem;">Volume discounts — the more you order, the more you save</p>
					<div class="grid grid-cols-3 gap-2 mb-6">
						{tiers.map((t) => (
							<div class="tier-card rounded-xl text-center" data-tier-min={t.qty} style="padding: 0.7rem 0.4rem; border: 1.5px solid #ffd0e0; background: #ffe9f0;">
								<span style="display: block; font-size: 0.72rem; font-weight: 800; letter-spacing: 0.02em; color: #a0004c;">Save {t.pct}%</span>
								<span style="display: block; font-size: 1.15rem; font-weight: 700; color: var(--color-ink); margin-top: 0.1rem; line-height: 1.1;">{t.qty.toLocaleString()}+</span>
								<span style="display: block; font-size: 0.74rem; color: var(--color-muted); margin-top: 0.15rem;">PB ${t.unit.toFixed(2)} ea</span>
								<span style="display: block; font-size: 0.74rem; color: var(--color-muted);">HB ${t.unitHb.toFixed(2)} ea</span>
							</div>
						))}
					</div>

					<p style="font-family: var(--font-sans); font-weight: 700; font-size: 0.85rem; color: var(--color-ink); margin: 0 0 0.6rem;">Choose how many of each edition</p>
					<div style="display: flex; flex-direction: column; gap: 0.65rem;">
						{editions.map((e) => (
							<div class="flex items-center gap-3">
								<img src={e.img} alt="" width="700" height="1170" loading="lazy" decoding="async" style="width: 68px; height: auto; filter: drop-shadow(0 4px 10px rgba(0,0,0,0.18));" />
								<span style="flex: 1; font-family: var(--font-sans); font-weight: 600; color: var(--color-ink);">English Paperback ({e.color} Edition)</span>
								<div style="display: inline-flex; align-items: center; border: 1.5px solid var(--color-hairline); border-radius: 999px; overflow: hidden;">
									<button type="button" class="qty-step" data-color={e.slug} data-dir="-1" aria-label={`Fewer ${e.color} paperback`} style="font-family: var(--font-sans); width: 2.2rem; height: 2.2rem; border: 0; background: #fff; color: var(--color-ink); font-size: 1.15rem; cursor: pointer;">−</button>
									<input type="number" class="qty-in" data-color={e.slug} value="0" min="0" step="1" inputmode="numeric" aria-label={`${e.color} paperback quantity`} style="width: 3.2rem; text-align: center; border: 0; background: #fff; font-family: var(--font-sans); font-size: 1rem; color: var(--color-ink); -moz-appearance: textfield;" />
									<button type="button" class="qty-step" data-color={e.slug} data-dir="1" aria-label={`More ${e.color} paperback`} style="font-family: var(--font-sans); width: 2.2rem; height: 2.2rem; border: 0; background: #fff; color: var(--color-ink); font-size: 1.15rem; cursor: pointer;">+</button>
								</div>
							</div>
						))}
						{editions.map((e) => (
							<div class="flex items-center gap-3">
								<img src={e.img} alt="" width="700" height="1170" loading="lazy" decoding="async" style="width: 68px; height: auto; filter: drop-shadow(0 4px 10px rgba(0,0,0,0.18));" />
								<span style="flex: 1; font-family: var(--font-sans); font-weight: 600; color: var(--color-ink);">English Hardback ({e.color} Edition)</span>
								<div style="display: inline-flex; align-items: center; border: 1.5px solid var(--color-hairline); border-radius: 999px; overflow: hidden;">
									<button type="button" class="qty-step" data-color={`${e.slug}_hb`} data-dir="-1" aria-label={`Fewer ${e.color} hardback`} style="font-family: var(--font-sans); width: 2.2rem; height: 2.2rem; border: 0; background: #fff; color: var(--color-ink); font-size: 1.15rem; cursor: pointer;">−</button>
									<input type="number" class="qty-in" data-color={`${e.slug}_hb`} value="0" min="0" step="1" inputmode="numeric" aria-label={`${e.color} hardback quantity`} style="width: 3.2rem; text-align: center; border: 0; background: #fff; font-family: var(--font-sans); font-size: 1rem; color: var(--color-ink); -moz-appearance: textfield;" />
									<button type="button" class="qty-step" data-color={`${e.slug}_hb`} data-dir="1" aria-label={`More ${e.color} hardback`} style="font-family: var(--font-sans); width: 2.2rem; height: 2.2rem; border: 0; background: #fff; color: var(--color-ink); font-size: 1.15rem; cursor: pointer;">+</button>
								</div>
							</div>
						))}
					</div>

					<div class="flex flex-wrap items-center justify-between gap-4 pt-4 mt-5" style="border-top: 1px solid var(--color-hairline);">
						<div>
							<span style="font-family: var(--font-sans); color: var(--color-muted); font-size: 0.85rem;"><span data-count>0</span> copies · <span data-save style="color: #a0004c; font-weight: 700;">—</span> · free shipping</span>
							<div data-total-out style="font-family: var(--font-headline); color: var(--color-ink); font-size: 1.6rem; font-weight: 700;">$0.00</div>
						</div>
						<button type="button" data-checkout class="inline-flex items-center justify-center rounded-full font-semibold" style="font-family: var(--font-sans); background: var(--color-brand); color: #fff; padding: 0.8rem 1.8rem; border: 0; cursor: pointer; font-size: 1rem;">Checkout →</button>
					</div>
					<p data-bulk-msg style="font-family: var(--font-sans); font-size: 0.85rem; color: var(--color-muted); margin: 0.75rem 0 0; display: none;"></p>
				</div>
				<p class="text-center" style="font-family: var(--font-sans); color: var(--color-muted); font-size: 0.8rem; margin-top: 1rem;">25-copy minimum · free shipping · sales tax calculated at checkout · mix editions and bindings freely. Need more than 1,000? <a href="mailto:hello@spiritmediapublishing.com?subject=FHB%20bulk%20order%20(1000%2B)" style="color: var(--color-brand); text-decoration: underline;">Contact us</a>.</p>
			</div>
		</Section>

		<!-- ═══════════════ PEOPLE BAND (variety of readers with FHB) ═══════════════ -->
		<div class="grid grid-cols-1 sm:grid-cols-3">
			<img src="https://assets.spiritmediapublishing.com/FHB/print/print-band-white.webp" alt="A man reading the White edition of the Father's Heart Bible in a cafe" width="800" height="800" loading="lazy" decoding="async" class="w-full aspect-square object-cover block" />
			<img src="https://assets.spiritmediapublishing.com/FHB/print/people-2.webp" alt="A father and son reading the Father's Heart Bible together" width="800" height="800" loading="lazy" decoding="async" class="w-full aspect-square object-cover block" />
			<img src="https://assets.spiritmediapublishing.com/FHB/print/people-3.webp" alt="A grandmother and granddaughter reading the Father's Heart Bible" width="800" height="800" loading="lazy" decoding="async" class="w-full aspect-square object-cover block" />
		</div>
	</main>
</Layout>

<script is:inline>
	(() => {
		const root = document.querySelector('[data-bulk]');
		if (!root) return;
		const MIN = 25;
		// Combined total → tier. One consistent % for both bindings, each off its
		// own retail (unit = paperback, unitHb = hardback). Mirrors print-checkout.ts.
		const RETAIL_PB = 39.99;
		const RETAIL_HB = 44.99;
		const TIERS = [
			{ min: 1000, pct: 40, unit: 23.99, unitHb: 27.0 },
			{ min: 500, pct: 35, unit: 25.99, unitHb: 29.24 },
			{ min: 250, pct: 30, unit: 27.99, unitHb: 31.49 },
			{ min: 100, pct: 25, unit: 29.99, unitHb: 33.74 },
			{ min: 50, pct: 20, unit: 31.99, unitHb: 35.99 },
			{ min: 25, pct: 15, unit: 33.99, unitHb: 38.24 },
		];
		const tierFor = (t) => TIERS.find((x) => t >= x.min) || null;
		const fmt = (n) => '$' + Number(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
		const counts = { plum: 0, charcoal: 0, white: 0, plum_hb: 0, charcoal_hb: 0, white_hb: 0 };
		const PB_KEYS = ['plum', 'charcoal', 'white'];
		const HB_KEYS = ['plum_hb', 'charcoal_hb', 'white_hb'];
		const out = root.querySelector('[data-total-out]');
		const countEl = root.querySelector('[data-count]');
		const saveEl = root.querySelector('[data-save]');
		const msg = root.querySelector('[data-bulk-msg]');
		const btn = root.querySelector('[data-checkout]');
		const cards = [...root.querySelectorAll('.tier-card')];
		const highlight = (min) => cards.forEach((c) => {
			const on = min !== null && Number(c.dataset.tierMin) === min;
			c.style.borderColor = on ? 'var(--color-brand)' : '#ffd0e0';
			c.style.background = on ? '#ffd0e0' : '#ffe9f0';
		});

		function recompute() {
			const pbTotal = PB_KEYS.reduce((s, k) => s + counts[k], 0);
			const hbTotal = HB_KEYS.reduce((s, k) => s + counts[k], 0);
			const total = pbTotal + hbTotal;
			const tier = tierFor(total);
			highlight(tier ? tier.min : null);
			if (countEl) countEl.textContent = String(total);
			if (tier) {
				const saved = pbTotal * (RETAIL_PB - tier.unit) + hbTotal * (RETAIL_HB - tier.unitHb);
				if (saveEl) saveEl.textContent = 'Save ' + tier.pct + '% (' + fmt(saved) + ')';
				if (out) out.textContent = fmt(pbTotal * tier.unit + hbTotal * tier.unitHb);
				if (btn) { btn.disabled = false; btn.style.opacity = '1'; btn.style.cursor = 'pointer'; }
				if (msg) msg.style.display = 'none';
			} else {
				if (saveEl) saveEl.textContent = '—';
				if (out) out.textContent = '$0.00';
				if (btn) { btn.disabled = true; btn.style.opacity = '0.5'; btn.style.cursor = 'not-allowed'; }
				if (msg) {
					msg.style.display = 'block';
					msg.textContent = total === 0
						? 'Add copies above to begin (25-copy minimum for bulk pricing).'
						: 'Add ' + (MIN - total) + ' more to reach the 25-copy minimum.';
				}
			}
		}

		const inputs = [...root.querySelectorAll('.qty-in')];
		const inputFor = (c) => inputs.find((i) => i.dataset.color === c);
		inputs.forEach((inp) => inp.addEventListener('input', () => {
			let v = parseInt(inp.value, 10); if (!Number.isFinite(v) || v < 0) v = 0;
			counts[inp.dataset.color] = v; recompute();
		}));
		root.querySelectorAll('.qty-step').forEach((b) => b.addEventListener('click', () => {
			const c = b.dataset.color; const dir = Number(b.dataset.dir);
			counts[c] = Math.max(0, counts[c] + dir);
			const inp = inputFor(c); if (inp) inp.value = String(counts[c]);
			recompute();
		}));
		recompute();

		btn?.addEventListener('click', async () => {
			if (btn.disabled) return;
			const label = btn.textContent;
			btn.disabled = true; btn.textContent = 'Starting checkout…';
			try {
				const r = await fetch('/print-checkout', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ counts }) });
				const d = await r.json();
				if (d.url) { window.location.href = d.url; return; }
				if (msg) { msg.style.display = 'block'; msg.textContent = d.disabled ? 'Bulk checkout is opening soon — check back shortly.' : (d.error === 'below_minimum' ? 'A 25-copy minimum is required for bulk pricing.' : 'Sorry, something went wrong starting checkout. Please try again.'); }
			} catch {
				if (msg) { msg.style.display = 'block'; msg.textContent = 'Network error — please try again.'; }
			}
			btn.disabled = false; btn.textContent = label;
		});
	})();
</script>
