<script is:inline>
	(() => {
		const root = document.querySelector('[data-bulk]');
		if (!root) return;
		const MIN = 25;
		// Combined total → tier. One consistent % for both bindings, each off its
		// own retail (unit = paperback, unitHb = hardback). Mirrors print-checkout.ts.
		const RETAIL_PB = 39.99;
		const RETAIL_HB = 44.99;
		const TIERS = [
			{ min: 1000, pct: 40, unit: 23.99, unitHb: 26.99 },
			{ min: 500, pct: 35, unit: 25.99, unitHb: 29.24 },
			{ min: 250, pct: 30, unit: 27.99, unitHb: 31.49 },
			{ min: 100, pct: 25, unit: 29.99, unitHb: 33.74 },
			{ min: 50, pct: 20, unit: 31.99, unitHb: 35.99 },
			{ min: 25, pct: 15, unit: 33.99, unitHb: 38.24 },
		];
		const tierFor = (t) => TIERS.find((x) => t >= x.min) || null;
		const fmt = (n) => '$' + Number(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
		const counts = {
			plum: 0, charcoal: 0, white: 0, plum_hb: 0, charcoal_hb: 0, white_hb: 0,
			lp_plum: 0, lp_charcoal: 0, lp_white: 0, lp_plum_hb: 0, lp_charcoal_hb: 0, lp_white_hb: 0,
		};
		const PB_KEYS = ['plum', 'charcoal', 'white', 'lp_plum', 'lp_charcoal', 'lp_white'];
		const HB_KEYS = ['plum_hb', 'charcoal_hb', 'white_hb', 'lp_plum_hb', 'lp_charcoal_hb', 'lp_white_hb'];
		const out = root.querySelector('[data-total-out]');
		const countEl = root.querySelector('[data-count]');
		const saveEl = root.querySelector('[data-save]');
		const msg = root.querySelector('[data-bulk-msg]');
		const btn = root.querySelector('[data-checkout]');
		const cards = [...root.querySelectorAll('.tier-card')];
		const highlight = (min) => cards.forEach((c) => {
			const on = min !== null && Number(c.dataset.tierMin) === min;
			c.style.borderColor = on ? 'var(--color-brand)' : '#ffd0e0';
			c.style.background = on ? '#ffd0e0' : '#ffe9f0';
		});

		function recompute() {
			const pbTotal = PB_KEYS.reduce((s, k) => s + counts[k], 0);
			const hbTotal = HB_KEYS.reduce((s, k) => s + counts[k], 0);
			const total = pbTotal + hbTotal;
			const tier = tierFor(total);
			highlight(tier ? tier.min : null);
			if (countEl) countEl.textContent = String(total);
			if (tier) {
				const saved = pbTotal * (RETAIL_PB - tier.unit) + hbTotal * (RETAIL_HB - tier.unitHb);
				if (saveEl) saveEl.textContent = 'Save ' + tier.pct + '% (' + fmt(saved) + ')';
				if (out) out.textContent = fmt(pbTotal * tier.unit + hbTotal * tier.unitHb);
				if (btn) { btn.disabled = false; btn.style.opacity = '1'; btn.style.cursor = 'pointer'; }
				if (msg) msg.style.display = 'none';
			} else {
				if (saveEl) saveEl.textContent = '—';
				if (out) out.textContent = '$0.00';
				if (btn) { btn.disabled = true; btn.style.opacity = '0.5'; btn.style.cursor = 'not-allowed'; }
				if (msg) {
					msg.style.display = 'block';
					msg.textContent = total === 0
						? 'Add copies above to begin (25-copy minimum for bulk pricing).'
						: 'Add ' + (MIN - total) + ' more to reach the 25-copy minimum.';
				}
			}
		}

		const inputs = [...root.querySelectorAll('.qty-in')];
		const inputFor = (c) => inputs.find((i) => i.dataset.color === c);
		inputs.forEach((inp) => inp.addEventListener('input', () => {
			let v = parseInt(inp.value, 10); if (!Number.isFinite(v) || v < 0) v = 0;
			counts[inp.dataset.color] = v; recompute();
		}));
		root.querySelectorAll('.qty-step').forEach((b) => b.addEventListener('click', () => {
			const c = b.dataset.color; const dir = Number(b.dataset.dir);
			counts[c] = Math.max(0, counts[c] + dir);
			const inp = inputFor(c); if (inp) inp.value = String(counts[c]);
			recompute();
		}));
		recompute();

		btn?.addEventListener('click', async () => {
			if (btn.disabled) return;
			const label = btn.textContent;
			btn.disabled = true; btn.textContent = 'Starting checkout…';
			try {
				const r = await fetch('/print-checkout', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ counts }) });
				const d = await r.json();
				if (d.url) { window.location.href = d.url; return; }
				if (msg) { msg.style.display = 'block'; msg.textContent = d.disabled ? 'Bulk checkout is opening soon — check back shortly.' : (d.error === 'below_minimum' ? 'A 25-copy minimum is required for bulk pricing.' : 'Sorry, something went wrong starting checkout. Please try again.'); }
			} catch {
				if (msg) { msg.style.display = 'block'; msg.textContent = 'Network error — please try again.'; }
			}
			btn.disabled = false; btn.textContent = label;
		});
	})();
</script>


