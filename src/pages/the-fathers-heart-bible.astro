---
import Footer from '../components/Footer.astro';
import ImageGrid from '../components/ImageGrid.astro';
import Navbar from '../components/Navbar.astro';
import ScriptureBlock from '../components/ScriptureBlock.astro';
import Section from '../components/Section.astro';
import VideoHeroInner from '../components/VideoHeroInner.astro';
import Layout from '../layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity';

const [pageData, media, biblePageData, latestPosts] = await Promise.all([
	sanityClient.fetch(`*[_type =="page" && slug =="the-fathers-heart-bible"][0] {
    seoTitle, seoDescription,
    heroHeading, heroSubheading,
    heroPrimaryCtaLabel, heroPrimaryCtaHref,
    heroSecondaryCtaLabel, heroSecondaryCtaHref
  }`),
	sanityClient.fetch(
		`*[_type =="siteSettings"][0] { theThersHeartBiblePageVideo, bookCoverUrl, fhbCoverImage, communityUrl }`,
	),
	sanityClient.fetch(
		`*[_type =="biblePageContent"][0] { distinctives, notItems, milestones, audience, shifts }`,
	),
	sanityClient.fetch(
		`*[_type == "blogPost" && defined(slug.current)] | order(publishDate desc) [0...3] {
      "slug": slug.current,
      title,
      excerpt,
      "image": coalesce(heroImage.asset->url + "?w=600&fm=webp", "/fhb-logo.png"),
      publishDate
    }`,
	),
]);

const seoTitle = pageData?.seoTitle || "What Is the Father's Heart Bible? | Father's Heart Bible";
const seoDescription =
	pageData?.seoDescription ||
	'Learn what the Father\u2019s Heart Bible is, why it exists, and how this new Bible translation reveals God as Father where Scripture reveals Him.';
const heroHeading = 'What is the Father\u2019s Heart Bible\u2122?';
const heroSubheading =
	'The Father\u2019s Heart Bible\u2122 is a new interpretive English Bible translation that reveals God as Father where Scripture reveals Him\u2014and helps readers encounter not only His name, but His heart.';
// June 2026 — Public Reading Month: secondary CTA repurposed to point to
// the community. Post-July-1 this can flip back to the free-book funnel.
const heroPrimaryCtaLabel = 'Read Sample Passages';
const heroPrimaryCtaHref = '/samples/';
const heroSecondaryCtaLabel = 'Read FHB →';
const heroSecondaryCtaHref = 'https://join.fathersheartbible.com/read';
const bookCoverUrl = media?.bookCoverUrl || '';

// FHB → Beloved Identity cover — prefer Sanity image, fall back to hardcoded
// The Sanity asset is a true RGBA PNG (alpha-channel transparency);
// Sanity preserves the alpha so the section bg shows through naturally.
const fhbCoverImageFromSanity = media?.fhbCoverImage;
const fhbiCoverUrl = fhbCoverImageFromSanity
	? urlFor(fhbCoverImageFromSanity).width(400).auto('format').url()
	: 'https://cdn.sanity.io/images/rusi1hyi/production/3ab3f8d98e6ac0913d382922f0983efe6cb5535f-1278x2118.png';
const communityUrl = media?.communityUrl || '/join';

const distinctives = biblePageData?.distinctives ?? [
	{
		title: 'Reveals the Father',
		body: "Wherever Scripture reveals God's fatherly heart — in name, in covenant, in direct address — this translation makes it unmistakable.",
	},
	{
		title: 'Heart-Language',
		body: 'The warmth, compassion, and affection of God is not softened or hidden. You feel His heart in every passage.',
	},
	{
		title: 'Trinitarian Clarity',
		body: 'Distinctions between Father, Son, and Spirit are carefully preserved. This translation enriches Trinitarian understanding, not blurs it.',
	},
	{
		title: 'Interpretive Translation',
		body: 'This is not a loose paraphrase. It is a careful interpretive translation — grounded in the original text, rendered to reveal intention.',
	},
	{
		title: 'Full Canon',
		body: "From Genesis to Revelation, the Father's voice runs through every book. FHB traces that thread from beginning to end.",
	},
	{
		title: 'Relational, Not Academic',
		body: 'This Bible reads like an invitation, not a lecture. It was written for encounter, not information.',
	},
];

const notItems = biblePageData?.notItems ?? [
	{
		label: 'Not a paraphrase',
		body: 'FHB is an interpretive translation — grounded in original texts, not loosely reworded for accessibility.',
	},
	{
		label: 'Not a replacement',
		body: 'FHB is not claiming to replace other faithful translations. It is a companion that draws out what Scripture has always contained.',
	},
	{
		label: 'Not the only faithful translation',
		body: 'We hold other translations with respect. FHB exists to add light, not to diminish the work of others.',
	},
	{
		label: 'Not a new theology',
		body: "The Father's Heart Bible™ is grounded in historic Christian and Trinitarian belief. It reveals what has always been there.",
	},
];

const milestones = biblePageData?.milestones ?? [
	{
		milestone: 'Full Canon',
		detail: "Genesis to Revelation — every book translated with the Father's heart in view.",
	},
	{
		milestone: 'Premium Edition',
		detail: 'A flagship print Bible designed to be held, given, and treasured for a lifetime.',
	},
	{
		milestone: 'Initial Print Run',
		detail: 'A planned first edition made available to those who have been waiting and partnering.',
	},
	{
		milestone: 'Future Expansion',
		detail: 'Study editions, audio, and language translations as the movement grows.',
	},
];

const shifts = biblePageData?.shifts ?? [
	{ from: 'Information', to: 'Relationship' },
	{ from: 'Distance', to: 'Intimacy' },
	{ from: 'Servant mindset', to: 'Beloved identity' },
];

// FAQ — AEO-optimized question-and-answer pairs that mirror what people
// actually search for. The visible section below renders these; the
// FAQPage JSON-LD below mirrors them for rich-result eligibility.
const faqs = [
	{
		q: "What is the Father's Heart Bible™?",
		a: "The Father's Heart Bible™ (FHB) is an interpretive English Bible translation that reveals God as Father wherever Scripture reveals Him. Where the Hebrew text uses YHWH (the personal covenant name) in a relational context, FHB renders it 'our Father' — recovering the warmth the name carried for Israel and continuing the apostles' own hermeneutic on the page.",
	},
	{
		q: "How is the Father's Heart Bible™ different from other translations?",
		a: "Most English translations flatten YHWH and Elohim into 'God' or 'the LORD,' which hides the Trinitarian and relational distinctions already in the original languages. FHB preserves those distinctions: when the text points to the Father, it reads 'our Father'; when the text points to a generic deity (or the serpent's distant 'God'), it reads 'God.' Footnotes document every distinctive choice.",
	},
	{
		q: 'Is the Father’s Heart Bible™ a paraphrase?',
		a: 'No. FHB is an interpretive translation grounded in the original Hebrew, Greek, and Aramaic — not a loosely reworded paraphrase. Translation choices are footnoted and traceable to the source text, and the work follows a documented methodology of canon-wide consistency.',
	},
	{
		q: 'Who translated the Father’s Heart Bible™?',
		a: "Kevin White serves as lead translator, supported by the Spirit Media Publishing team. Kevin is the author of Father's Heart → Beloved Identity (free download) and CEO of Spirit Media Publishing.",
	},
	{
		q: 'Which books of the Bible are included?',
		a: 'The full canon — Genesis to Revelation. Translation work proceeds book by book. Genesis, Joel, and John are currently in active draft; sample chapters are available on the Samples page.',
	},
	{
		q: 'Why does FHB render “God” as “our Father” in some places?',
		a: 'The Hebrew uses two distinct divine names — YHWH (personal covenant name) and Elohim (generic word for deity) — and they fall on different lips and in different contexts. The apostles already read these differences and applied them to specific Persons of the Trinity (e.g. Joel 2:32 → Romans 10:13 applies the verse to Jesus). FHB does this work on the page rather than leaving it for the reader to assemble.',
	},
	{
		q: 'How can I read or sample the Father’s Heart Bible™?',
		a: "Visit the Samples page for translated chapter excerpts, or download the free book Father's Heart → Beloved Identity — a short companion volume that opens the door into the heart behind the translation.",
	},
];

const formatDate = (dateString: string) => {
	if (!dateString) return '';
	const d = new Date(dateString);
	return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};
---

<Layout
	title={seoTitle}
	description={seoDescription}
	darkHero={true}
	jsonLd={[
		{
			"@context": "https://schema.org",
			"@graph": [
				{ "@type": "WebPage", "name": seoTitle, "description": seoDescription, "url": "https://fathersheartbible.com/the-fathers-heart-bible" },
				{ "@type": "BreadcrumbList", "itemListElement": [
					{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fathersheartbible.com/" },
					{ "@type": "ListItem", "position": 2, "name": "About FHB", "item": "https://fathersheartbible.com/the-fathers-heart-bible" }
				]}
			]
		},
		// Book schema — establishes FHB as a Bible translation entity for AI engines and search.
		{
			"@context": "https://schema.org",
			"@type": "Book",
			"@id": "https://fathersheartbible.com/#book",
			"name": "Father's Heart Bible",
			"alternateName": "FHB",
			"description": "An interpretive English Bible translation that reveals God as Father wherever Scripture reveals Him — rendering YHWH and Elohim through Trinitarian Persons where the original text points to them.",
			"inLanguage": "en-US",
			"url": "https://fathersheartbible.com",
			"image": "https://cdn.sanity.io/images/rusi1hyi/production/8b5d1c39f892218c978d3e3caf5720e09833bbc4-1024x1024.png?w=1200&h=630&fit=crop",
			"author": {
				"@type": "Person",
				"@id": "https://kevinwhite.us/#person",
				"name": "Kevin White",
				"url": "https://kevinwhite.us"
			},
			"publisher": {
				"@type": "Organization",
				"@id": "https://spiritmediapublishing.com/#organization",
				"name": "Spirit Media Publishing",
				"url": "https://spiritmediapublishing.com"
			},
			"about": [
				{ "@type": "Thing", "name": "Bible translation" },
				{ "@type": "Thing", "name": "Father heart of God" },
				{ "@type": "Thing", "name": "Trinitarian theology" }
			]
		},
		// FAQPage schema — AEO citation target.
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": faqs.map((f) => ({
				"@type": "Question",
				"name": f.q,
				"acceptedAnswer": { "@type": "Answer", "text": f.a }
			}))
		}
	]}
>
	<Navbar />
	<main>

		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 1 — PAGE HERO
		     ═══════════════════════════════════════════════════════════ -->
		<VideoHeroInner
			imageSrc="https://cdn.sanity.io/images/rusi1hyi/production/bfe28fe0177189b48118a5d4e571c670a786363a-1024x683.jpg?w=1920&q=80&auto=format"
			imagePosition="top"
			showLogo={false}
			heading={heroHeading}
			subheading={heroSubheading}
			primaryCtaLabel={heroPrimaryCtaLabel}
			primaryCtaHref={heroPrimaryCtaHref}
			secondaryCtaLabel={heroSecondaryCtaLabel}
			secondaryCtaHref={heroSecondaryCtaHref}
		/>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 2 — WHY THIS TRANSLATION EXISTS
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="light">
			<div class="max-w-2xl mx-auto">
				<p
					class="text-xs font-semibold tracking-widest uppercase mb-4"
					style="font-family: var(--font-sans); color: var(--color-gold);"
				>
					Why It Exists
				</p>
				<h2
					class="text-3xl md:text-4xl font-light mb-8"
					style="font-family: var(--font-serif); color: var(--color-ink);"
				>
					Many have read Scripture faithfully — and still never felt like a child of God.
				</h2>
				<div class="space-y-4" style="font-family: var(--font-sans); color: var(--color-muted);">
					<p class="leading-relaxed">
						Millions of believers have read the Bible their entire lives. They know the stories,
						the covenants, the teachings of Jesus. Yet many relate to God not as a beloved child
						to a loving Father, but as a servant to a distant master.
					</p>
					<p class="leading-relaxed">
						This is not because Scripture says that. It is because something has been lost in
						translation — the warmth of the Father's voice, the intimacy of His heart, the identity
						He is always extending to His people.
					</p>
					<p class="leading-relaxed">
						Jesus said it plainly: the destination has always been the Father. Every covenant,
						every promise, every act of redemption is leading somewhere — to a people who know
						God not by title, but by relationship.
					</p>
					<p class="leading-relaxed">
						The Father's Heart Bible™ was written to make that encounter unmistakable.
					</p>
				</div>
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 3 — THE BIG SHIFT
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="scripture">
			<div class="text-center max-w-3xl mx-auto">
				<div class="w-10 h-0.5 mx-auto mb-10" style="background-color: var(--color-gold);"></div>
				<h2
					class="text-3xl md:text-5xl font-light leading-tight mb-8"
					style="font-family: var(--font-serif); color: var(--color-ink);"
				>
					The destination was never merely forgiveness or heaven. The destination has always been the Father.
				</h2>
				<p
					class="text-lg leading-relaxed mb-12"
					style="font-family: var(--font-sans); color: var(--color-muted);"
				>
					The Father's Heart Bible™ is built on one conviction: God has always been reaching toward
					His children, not His servants. And Scripture has always been saying so.
				</p>
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-left">
					{shifts.map(({ from, to }) => (
						<div class="flex flex-col gap-3">
							<div
								class="text-sm line-through"
								style="font-family: var(--font-sans); color: var(--color-muted); opacity: 0.5;"
							>
								{from}
							</div>
							<div class="h-px w-8" style="background-color: var(--color-gold);"></div>
							<div
								class="text-lg font-medium"
								style="font-family: var(--font-serif); color: var(--color-brand);"
							>
								{to}
							</div>
						</div>
					))}
				</div>
				<div class="w-10 h-0.5 mx-auto mt-10" style="background-color: var(--color-gold);"></div>
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 4 — WHAT MAKES FHB DIFFERENT
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="light">
			<div class="text-center mb-12">
				<p
					class="text-xs font-semibold tracking-widest uppercase mb-3"
					style="font-family: var(--font-sans); color: var(--color-gold);"
				>
					What Makes It Different
				</p>
				<h2
					class="text-3xl md:text-4xl font-light"
					style="font-family: var(--font-serif); color: var(--color-ink);"
				>
					Built to reveal, not just inform.
				</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{distinctives.map(({ title, body }) => (
					<div
						class="p-6"
						style="background-color: var(--color-soft); border: 1px solid var(--color-hairline);"
					>
						<h3
							class="text-lg font-medium mb-3"
							style="font-family: var(--font-serif); color: var(--color-ink);"
						>
							{title}
						</h3>
						<p
							class="text-sm leading-relaxed"
							style="font-family: var(--font-sans); color: var(--color-muted);"
						>
							{body}
						</p>
					</div>
				))}
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 5 — SAMPLE COMPARISON PREVIEW
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="soft">
			<div class="text-center mb-14">
				<p
					class="text-xs font-semibold tracking-widest uppercase mb-3"
					style="font-family: var(--font-sans); color: var(--color-gold);"
				>
					See the Difference
				</p>
				<h2
					class="text-3xl md:text-4xl font-light"
					style="font-family: var(--font-serif); color: var(--color-ink);"
				>
					Hear the Father's voice in Scripture.
				</h2>
			</div>

			<div class="space-y-16 max-w-3xl mx-auto">

				<!-- John 3:16 -->
				<div>
					<p class="text-xs font-semibold tracking-widest uppercase mb-6 text-center" style="font-family: var(--font-sans); color: var(--color-muted);">John 3:16</p>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div class="p-6" style="background-color: var(--color-canvas); border: 1px solid var(--color-hairline);">
							<p class="text-xs tracking-widest uppercase mb-4" style="font-family: var(--font-sans); color: var(--color-muted); opacity: 0.6;">Traditional</p>
							<p class="italic leading-relaxed" style="font-family: var(--font-serif); color: var(--color-muted); font-size: 1.05rem;">"For God so loved the world that he gave his one and only Son…"
							</p>
						</div>
						<div class="p-6" style="background-color: var(--color-canvas); border: 1px solid var(--color-hairline); border-left: 3px solid var(--color-gold);">
							<p class="text-xs tracking-widest uppercase mb-4" style="font-family: var(--font-sans); color: var(--color-gold);">Father's Heart Bible™</p>
							<p class="italic leading-relaxed" style="font-family: var(--font-serif); color: var(--color-ink); font-size: 1.05rem;">"For our <strong style="font-style: normal; color: var(--color-brand);">Father</strong> so loved the world that he gave his one and only Son…"
							</p>
						</div>
					</div>
					<p class="text-sm mt-4 text-center" style="font-family: var(--font-sans); color: var(--color-muted);">One word shifts the entire emotional posture of the reader.</p>
				</div>

				<div class="h-px w-16 mx-auto" style="background-color: var(--color-hairline);"></div>

				<!-- Joel 2:28-29 -->
				<div>
					<p class="text-xs font-semibold tracking-widest uppercase mb-6 text-center" style="font-family: var(--font-sans); color: var(--color-muted);">Joel 2:28–29</p>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div class="p-6" style="background-color: var(--color-canvas); border: 1px solid var(--color-hairline);">
							<p class="text-xs tracking-widest uppercase mb-4" style="font-family: var(--font-sans); color: var(--color-muted); opacity: 0.6;">Traditional</p>
							<p class="italic leading-relaxed" style="font-family: var(--font-serif); color: var(--color-muted); font-size: 1.05rem;">"I will pour out my Spirit on all people. Your sons and daughters will prophesy…"
							</p>
						</div>
						<div class="p-6" style="background-color: var(--color-canvas); border: 1px solid var(--color-hairline); border-left: 3px solid var(--color-gold);">
							<p class="text-xs tracking-widest uppercase mb-4" style="font-family: var(--font-sans); color: var(--color-gold);">Father's Heart Bible™</p>
							<p class="italic leading-relaxed" style="font-family: var(--font-serif); color: var(--color-ink); font-size: 1.05rem;">"I will pour out my Spirit on all my <strong style="font-style: normal; color: var(--color-brand);">beloved sons and daughters</strong>…"
							</p>
						</div>
					</div>
					<p class="text-sm mt-4 text-center" style="font-family: var(--font-sans); color: var(--color-muted);">Beloved sons and daughters — not simply people. The Father's affection is explicit.</p>
				</div>

				<div class="h-px w-16 mx-auto" style="background-color: var(--color-hairline);"></div>

				<!-- Zephaniah 3:17 -->
				<div>
					<p class="text-xs font-semibold tracking-widest uppercase mb-6 text-center" style="font-family: var(--font-sans); color: var(--color-muted);">Zephaniah 3:17</p>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div class="p-6" style="background-color: var(--color-canvas); border: 1px solid var(--color-hairline);">
							<p class="text-xs tracking-widest uppercase mb-4" style="font-family: var(--font-sans); color: var(--color-muted); opacity: 0.6;">Traditional</p>
							<p class="italic leading-relaxed" style="font-family: var(--font-serif); color: var(--color-muted); font-size: 1.05rem;">"The Lord your God is with you, the Mighty Warrior who saves. He will take great delight in you…"
							</p>
						</div>
						<div class="p-6" style="background-color: var(--color-canvas); border: 1px solid var(--color-hairline); border-left: 3px solid var(--color-gold);">
							<p class="text-xs tracking-widest uppercase mb-4" style="font-family: var(--font-sans); color: var(--color-gold);">Father's Heart Bible™</p>
							<p class="italic leading-relaxed" style="font-family: var(--font-serif); color: var(--color-ink); font-size: 1.05rem;">"Your <strong style="font-style: normal; color: var(--color-brand);">Father</strong> is in your midst — the Mighty One who saves. He will rejoice over you with gladness, quiet you with His love…"
							</p>
						</div>
					</div>
					<p class="text-sm mt-4 text-center" style="font-family: var(--font-sans); color: var(--color-muted);">A Father who rejoices over you — not a God who merely tolerates you.</p>
				</div>

			</div>

			<div class="text-center mt-14">
				<a
					href="/samples/"
					class="inline-flex items-center px-8 py-3.5 text-base font-semibold no-underline transition-all duration-200"
					style="font-family: var(--font-sans); background-color: #FFD9E0; color: #4A4A4A;"
					onmouseover="this.style.opacity='0.9'"
					onmouseout="this.style.opacity='1'"
				>
					Read All Sample Passages
				</a>
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 6 — WHAT FHB IS NOT
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="light">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-start">
				<div>
					<p
						class="text-xs font-semibold tracking-widest uppercase mb-4"
						style="font-family: var(--font-sans); color: var(--color-gold);"
					>
						Clarity
					</p>
					<h2
						class="text-3xl md:text-4xl font-light mb-6"
						style="font-family: var(--font-serif); color: var(--color-ink);"
					>
						What the Father's Heart Bible™ is not.
					</h2>
					<p class="leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">
						We want readers to hold this translation with confidence. Here is what FHB is not, so
						you can pick it up knowing exactly what you have.
					</p>
				</div>
				<div class="space-y-6">
					{notItems.map(({ label, body }) => (
						<div class="flex gap-4">
							<div class="mt-1.5 w-1.5 h-1.5 rounded-full shrink-0" style="background-color: var(--color-gold);"></div>
							<div>
								<p class="font-semibold mb-1" style="font-family: var(--font-sans); color: var(--color-ink);">{label}</p>
								<p class="text-sm leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">{body}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 7 — WHAT IS COMING
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="soft">
			<div class="text-center mb-12">
				<p
					class="text-xs font-semibold tracking-widest uppercase mb-3"
					style="font-family: var(--font-sans); color: var(--color-gold);"
				>
					The Road Ahead
				</p>
				<h2
					class="text-3xl md:text-4xl font-light"
					style="font-family: var(--font-serif); color: var(--color-ink);"
				>
					A serious publishing project — built for the long haul.
				</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-4xl mx-auto">
				{milestones.map(({ milestone, detail }) => (
					<div class="p-6 text-center" style="border: 1px solid var(--color-hairline);">
						<div class="w-8 h-0.5 mx-auto mb-4" style="background-color: var(--color-gold);"></div>
						<h3 class="text-lg font-medium mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">{milestone}</h3>
						<p class="text-sm leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">{detail}</p>
					</div>
				))}
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION — MEET THE LEAD TRANSLATOR
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="light">
			<div class="text-center max-w-2xl mx-auto">
				<p
					class="text-xs font-semibold tracking-widest uppercase mb-3"
					style="font-family: var(--font-sans); color: var(--color-gold);"
				>
					Behind the Translation
				</p>
				<h2
					class="text-3xl md:text-4xl font-light mb-6"
					style="font-family: var(--font-serif); color: var(--color-ink);"
				>
					Meet the lead translator.
				</h2>
				<p
					class="text-lg leading-relaxed mb-10"
					style="font-family: var(--font-sans); color: var(--color-muted);"
				>
					The Father's Heart Bible™ was born from a forty-year journey through Scripture, ministry, and awakening. Learn the story behind the translation.
				</p>
				<a
					href="/the-fathers-heart-bible/lead-translator/"
					class="inline-flex items-center px-8 py-3.5 text-base font-semibold no-underline border transition-all duration-200"
					style="font-family: var(--font-sans); color: var(--color-brand); border-color: var(--color-brand);"
					onmouseover="this.style.opacity='1'; this.style.color='#fff';"
					onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--color-brand)';"
				>
					Read Kevin's Story
				</a>
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 9 — FREQUENTLY ASKED (AEO citation target)
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="light">
			<div class="max-w-4xl mx-auto">
				<p
					class="text-xs font-semibold tracking-widest uppercase mb-4"
					style="font-family: var(--font-sans); color: var(--color-brand);"
					data-reveal
				>
					Frequently asked
				</p>
				<h2
					class="text-3xl md:text-4xl font-light mb-12"
					style="font-family: var(--font-serif); color: var(--color-ink);"
					data-reveal
				>
					About the Father&rsquo;s Heart Bible
				</h2>
				<div class="space-y-8">
					{faqs.map((faq) => (
						<div data-reveal>
							<h3
								class="text-xl md:text-2xl font-medium mb-3 leading-snug"
								style="font-family: var(--font-serif); color: var(--color-ink);"
							>
								{faq.q}
							</h3>
							<p
								class="leading-relaxed"
								style="font-family: var(--font-sans); color: var(--color-muted);"
							>
								{faq.a}
							</p>
						</div>
					))}
				</div>
			</div>
		</Section>

		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 10 — FROM THE BLOG (internal linking + topic cluster)
		     ═══════════════════════════════════════════════════════════ -->
		{latestPosts && latestPosts.length > 0 && (
			<Section variant="soft">
				<div class="max-w-6xl mx-auto">
					<p
						class="text-xs font-semibold tracking-widest uppercase mb-4"
						style="font-family: var(--font-sans); color: var(--color-brand);"
						data-reveal
					>
						Read more
					</p>
					<h2
						class="text-3xl md:text-4xl font-light mb-10"
						style="font-family: var(--font-serif); color: var(--color-ink);"
						data-reveal
					>
						From the Father&rsquo;s Heart Bible Blog
					</h2>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-reveal>
						{latestPosts.map((post: any) => (
							<a
								href={`/blog/${post.slug}/`}
								class="group block no-underline"
								style="color: inherit;"
							>
								<div class="aspect-[4/3] overflow-hidden rounded-2xl mb-4">
									<img
										src={post.image}
										alt={post.title}
										class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
										style="object-position: center top;"
										loading="lazy"
									/>
								</div>
								<h3
									class="text-xl font-medium leading-snug mb-2 transition-colors"
									style="font-family: var(--font-serif); color: var(--color-ink);"
								>
									{post.title}
								</h3>
								<p
									class="text-sm leading-relaxed"
									style="font-family: var(--font-sans); color: var(--color-muted);"
								>
									{post.excerpt}
								</p>
							</a>
						))}
					</div>
					<div class="mt-12 text-center" data-reveal>
						<a
							href="/blog/"
							class="inline-flex items-center text-sm font-semibold no-underline transition-opacity hover:opacity-80"
							style="font-family: var(--font-sans); color: var(--color-brand);"
						>
							Read all posts &rarr;
						</a>
					</div>
				</div>
			</Section>
		)}

		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 11 — DOWNLOAD CTA
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="soft">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">
				<div class="flex justify-center" data-reveal="slide-left">
					<img
						src={fhbiCoverUrl}
						alt="Father's Heart → Beloved Identity — free PDF"
						class="w-52 md:w-64 block"
						style="filter: drop-shadow(0 16px 32px rgba(0,0,0,0.22));"
					/>
				</div>
				<div data-reveal="slide-right">
					<p
						class="text-xs font-semibold tracking-widest uppercase mb-4"
						style="font-family: var(--font-sans); color: var(--color-gold);"
					>
						Your Best Next Step
					</p>
					<h2
						class="text-3xl md:text-4xl font-light mb-4"
						style="font-family: var(--font-serif); color: var(--color-ink);"
					>
						Start with the free book.
					</h2>
					<p class="leading-relaxed mb-4" style="font-family: var(--font-sans); color: var(--color-muted);">
						<em>Father's Heart → Beloved Identity</em> is a free PDF that opens the door into
						the heart behind this translation. Concise, accessible, and designed to shift how
						you read every page of Scripture.
					</p>
					<p class="leading-relaxed mb-8" style="font-family: var(--font-sans); color: var(--color-muted);">
						No cost. No strings. Just an invitation to encounter the Father.
					</p>
					<a
						href="https://join.fathersheartbible.com/read"
						class="inline-flex items-center px-8 py-3.5 text-base font-semibold no-underline transition-all duration-200"
						style="font-family: var(--font-sans); background-color: #FFD9E0; color: #4A4A4A;"
						onmouseover="this.style.opacity='0.9'"
						onmouseout="this.style.opacity='1'"
					>
						Read FHB →
					</a>
				</div>
			</div>
		</Section>


		<Section variant="light">
			<ImageGrid cols={3} gap="md">
				<img src="https://cdn.sanity.io/images/rusi1hyi/production/27d9614f1213d74cea256e1ccacbd76a3b6a8cbe-6016x4016.jpg?w=800&auto=format" alt="Man reading the Bible" class="w-full aspect-square object-cover" />
				<img src="https://cdn.sanity.io/images/rusi1hyi/production/f72dbb7ddd982eaff12409f279acb87d25aa9297-5604x3741.jpg?w=800&auto=format" alt="Couple reading Scripture together" class="w-full aspect-square object-cover" />
				<img src="https://cdn.sanity.io/images/rusi1hyi/production/9618d5a555e40892802d587d0faa740a513035df-1024x1024.png?w=800&auto=format" alt="The Father's Heart Bible in nature" class="w-full aspect-square object-cover" />
			</ImageGrid>
		</Section>

	</main>
	<Footer />
</Layout>
