---
// /review — public testimonial wall. Visitors share what The Father's Heart
// Bible means to them. Separate from the /read verse comments.
//
// Static shell + client island. All data flows through the same-origin
// /review-api Pages Function (Supabase access is server-side; no key reaches
// the browser). GET returns the email-free published feed/stats/featured +
// reaction counts; POST submits a Turnstile-verified review (queued as pending)
// or records a love/like/dislike reaction. A Bethel cron
// (fhb-review-moderate.mjs) moderates pending rows → published within ~1 min.
// NB: path is /review-api, not /api/* — the apex router proxies /api/* to the
// community app, so the marketing function must live off that prefix.
export const prerender = true;

import Section from '../components/Section.astro';
import VideoHeroInner from '../components/VideoHeroInner.astro';
import Layout from '../layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity';

// Posting requires a verified FH Family member (magic-link sign-in) via the
// /api/review-submit endpoint; no Supabase key reaches the browser.

// Hero content + image come from the Sanity `page` doc (slug "review") so the
// team can edit copy and swap the hero image in Studio without a code change.
const page = await sanityClient.fetch(`*[_type == "page" && slug == "review"][0] {
	seoTitle, seoDescription, heroEyebrow, heroHeading, heroSubheading, heroImage
}`);

const title = page?.seoTitle || "Reader Reviews | Father's Heart Bible";
const description =
	page?.seoDescription ||
	"Read what The Father's Heart Bible means to readers around the world — and share your own experience.";
const heroHeading = page?.heroHeading || 'Read and loved around the world.';
const heroSubheading =
	page?.heroSubheading ||
	"Readers everywhere are sharing what The Father's Heart Bible means to them. Add your voice.";

// Sanity-driven hero image (client-editable). Fall back to the chosen asset if
// the field is ever cleared. Sized WebP for LCP + preload below.
const FALLBACK_HERO =
	'https://cdn.sanity.io/images/rusi1hyi/production/362afc437aae7cd4de58a226072819333667c3e0-5760x3840.jpg';
const heroImageDesktop = page?.heroImage
	? urlFor(page.heroImage)
			.width(1920)
			.height(760)
			.fit('crop')
			.format('webp')
			.quality(80)
			.auto('format')
			.url()
	: `${FALLBACK_HERO}?w=1920&h=760&fit=crop&auto=format`;
const heroImageMobile = page?.heroImage
	? urlFor(page.heroImage)
			.width(900)
			.height(620)
			.fit('crop')
			.format('webp')
			.quality(78)
			.auto('format')
			.url()
	: `${FALLBACK_HERO}?w=900&h=620&fit=crop&auto=format`;
---

<Layout
	title={title}
	description={description}
	darkHero={true}
	preloadImageMobile={heroImageMobile}
	preloadImageDesktop={heroImageDesktop}
>
	<!-- Hero — image + headline ONLY (no subheading/CTA section), so there is no
	     dead gap beneath it; the two-column content starts immediately below. -->
	<VideoHeroInner
		imageSrc={heroImageDesktop}
		imagePosition="center"
		showLogo={false}
		heading={heroHeading}
	/>

	<!-- Two columns: submission form (left, sticky) + reviews (right). On mobile
	     they stack with the form first, so submitting is always quick to reach. -->
	<Section variant="light">
		<div class="grid lg:grid-cols-[minmax(320px,380px)_1fr] gap-8 lg:gap-12 items-start">

			<!-- LEFT — global-reach stats + submission form -->
			<div id="share" class="lg:sticky lg:top-24">
				<div id="stats-strip" class="flex flex-wrap items-baseline gap-x-6 gap-y-1 mb-6 pb-5 border-b border-hairline">
					<span class="whitespace-nowrap"><span id="stat-readers" class="text-2xl md:text-3xl font-extrabold text-brand">0</span> <span class="text-muted">Readers</span></span>
					<span class="whitespace-nowrap"><span id="stat-countries" class="text-2xl md:text-3xl font-extrabold text-brand">0</span> <span class="text-muted">Countries</span></span>
				</div>
				<h2 class="font-bold text-2xl text-ink mb-1">Share your experience</h2>
				<p class="text-muted text-sm mb-5">{heroSubheading}</p>

				<!-- Guests sign in FIRST (so nobody fills out the form only to hit a
				     sign-in wall). Swapped for the form once signed in. -->
				<div id="review-guest" class="border border-hairline rounded-2xl p-6 text-center" style="background-color: #fdeaf1;">
					<p class="text-2xl mb-1">❤️</p>
					<p class="font-semibold text-ink mb-1">Sign in to write your review</p>
					<p class="text-muted text-sm mb-5">Reviews come from members of the Father's Heart family. We'll email you a secure one-tap link — no password.</p>
					<a href="/login?next=/review" id="review-signin" class="inline-block bg-brand text-on-primary font-bold px-6 py-3 rounded-lg hover:bg-brand-dark transition-colors">Sign in to write a review</a>
				</div>

				<form id="review-form" hidden class="grid gap-4 border border-hairline rounded-2xl p-5 md:p-6" style="background-color: #fdeaf1;">
					<!-- "Posting as <member>" — filled by JS once signed in. -->
					<div id="auth-status" class="flex items-center gap-3 text-sm text-muted bg-surface-lowest border border-hairline rounded-lg px-3 py-2.5"></div>

					<label class="grid gap-1.5">
						<span class="text-sm font-semibold text-ink">Location <span class="font-normal text-muted">(e.g. Lagos, Nigeria)</span></span>
						<input name="location" type="text" required maxlength="80"
							class="border border-hairline rounded-lg px-3 py-2.5 bg-surface text-ink" />
					</label>

					<div class="grid gap-1.5">
						<span class="text-sm font-semibold text-ink">Your rating</span>
						<div id="star-input" class="flex gap-1 text-3xl" role="radiogroup" aria-label="Star rating">
							<button type="button" data-v="1" aria-label="1 star" class="star text-surface-dim leading-none">★</button>
							<button type="button" data-v="2" aria-label="2 stars" class="star text-surface-dim leading-none">★</button>
							<button type="button" data-v="3" aria-label="3 stars" class="star text-surface-dim leading-none">★</button>
							<button type="button" data-v="4" aria-label="4 stars" class="star text-surface-dim leading-none">★</button>
							<button type="button" data-v="5" aria-label="5 stars" class="star text-surface-dim leading-none">★</button>
						</div>
						<input type="hidden" name="stars" id="stars-value" />
					</div>

					<label class="grid gap-1.5">
						<span class="text-sm font-semibold text-ink">Title</span>
						<input name="title" type="text" required maxlength="100"
							class="border border-hairline rounded-lg px-3 py-2.5 bg-surface text-ink" />
					</label>

					<label class="grid gap-1.5">
						<span class="text-sm font-semibold text-ink">Your review</span>
						<textarea name="body" required maxlength="2000" rows="4"
							class="border border-hairline rounded-lg px-3 py-2.5 bg-surface text-ink resize-y"></textarea>
					</label>

					<button type="submit" id="review-submit"
						class="bg-brand text-on-primary font-bold px-7 py-3 rounded-lg hover:bg-brand-dark transition-colors disabled:opacity-50">
						Post my review
					</button>
					<p id="form-msg" class="text-sm text-center hidden"></p>
				</form>
			</div>

			<!-- RIGHT — reviews ("What readers are saying" is the top of this column) -->
			<div>
				<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
					<h2 class="font-bold text-2xl text-ink">What readers are saying</h2>
					<label class="text-sm text-muted flex items-center gap-2">
						Country
						<select id="country-filter" class="border border-hairline rounded-md px-3 py-1.5 bg-surface-lowest text-ink text-sm">
							<option value="">All countries</option>
						</select>
					</label>
				</div>

				<div id="featured" class="hidden mb-8">
					<h2 class="font-bold text-lg text-ink mb-3">Featured</h2>
					<div id="featured-list" class="grid gap-4"></div>
				</div>
				<div id="reviews-list" class="grid gap-4"></div>
				<p id="reviews-empty" class="text-muted py-10 hidden">Be the first to share what this Bible means to you.</p>
				<div class="mt-6">
					<button id="load-more" class="hidden border border-brand text-brand font-semibold px-6 py-2.5 rounded-lg hover:bg-brand hover:text-on-primary transition-colors">
						Load more
					</button>
				</div>
			</div>
		</div>
	</Section>
</Layout>

<!-- is:global is REQUIRED: review cards are injected via JS (innerHTML), so
     Astro's scoped-style hash never lands on them — scoped rules would silently
     not apply. These names are review-specific. -->
<style is:global>
	#star-input .star { transition: color 0.12s; cursor: pointer; }
	#star-input .star.on { color: #f5a623; }
	.rv-card { background: var(--color-surface-lowest); border: 1px solid var(--color-hairline); border-radius: 12px; padding: 18px 20px; box-shadow: 0 1px 2px rgba(0,0,0,.04); }
	.rv-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--color-brand); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; flex: 0 0 auto; }
	.rv-avatar-img { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; flex: 0 0 auto; }
	.rv-stars { color: #f5a623; letter-spacing: 1px; }
	.rv-foot { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-top: 12px; padding-top: 10px; border-top: 1px solid var(--color-hairline); }
	.rv-actions { display: flex; gap: 6px; }
	.rv-react, .rv-share { display: inline-flex; align-items: center; gap: 4px; font-size: 13px; padding: 4px 9px; border: 1px solid var(--color-hairline); border-radius: 999px; background: #fff; color: var(--color-muted); cursor: pointer; transition: all .12s; }
	.rv-react:hover, .rv-share:hover { border-color: var(--color-brand); color: var(--color-brand); }
	.rv-react.on { background: var(--color-primary-fixed, #ffd9e0); border-color: var(--color-brand); color: var(--color-brand-dark, #8f0043); font-weight: 700; }
	.rv-n { font-variant-numeric: tabular-nums; }
	.rv-share-menu { position: absolute; right: 0; top: calc(100% + 6px); z-index: 30; background: #fff; border: 1px solid var(--color-hairline); border-radius: 10px; box-shadow: 0 6px 20px rgba(0,0,0,.14); display: flex; flex-direction: column; min-width: 150px; overflow: hidden; }
	.rv-share-menu a, .rv-share-menu button { text-align: left; padding: 9px 14px; font-size: 13px; color: var(--color-ink); background: #fff; border: 0; cursor: pointer; text-decoration: none; }
	.rv-share-menu a:hover, .rv-share-menu button:hover { background: var(--color-surface-low); }
	/* This page's below-hero content is interactive (form + live feed). Show it
	   immediately instead of hiding it behind the site's scroll-reveal entrance
	   (which left everything below the hero blank until the user scrolled). The
	   stat counters do their own scroll-triggered animation separately. Scoped to
	   /review — this <style is:global> only ships on this page. */
	[data-reveal] { opacity: 1 !important; transform: none !important; }
</style>

<script>
	let offset = 0;
	const PAGE_SIZE = 20;
	let country = '';
	const SHARE_URL = 'https://fathersheartbible.com/review';

	const api = (qs) => `/review-api${qs ? `?${qs}` : ''}`;

	const flag = (cc) =>
		cc && cc.length === 2
			? cc.toUpperCase().replace(/./g, (c) => String.fromCodePoint(0x1f1e6 + c.charCodeAt(0) - 65))
			: '';
	const stars = (n) => '★★★★★'.slice(0, n) + '☆☆☆☆☆'.slice(0, 5 - n);
	const ago = (iso) => {
		const s = Math.floor((Date.now() - new Date(iso).getTime()) / 1000);
		const map = [[31536000, 'year'], [2592000, 'month'], [604800, 'week'], [86400, 'day'], [3600, 'hour'], [60, 'minute']];
		for (const [secs, label] of map) { const v = Math.floor(s / secs); if (v >= 1) return `${v} ${label}${v > 1 ? 's' : ''} ago`; }
		return 'just now';
	};
	const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

	// Count-up that fires when the stats scroll into view (not on load) and ticks
	// LINEARLY at ~300ms per number so small totals (0,1,2,3…) are clearly visible;
	// total time is capped so large totals still finish quickly.
	const animateCount = (el, target) => {
		if (!el) return;
		const dur = Math.min(1500, Math.max(700, target * 300));
		const start = performance.now();
		const tick = (now) => {
			const p = Math.min(1, (now - start) / dur);
			el.textContent = Math.round(p * target).toLocaleString();
			if (p < 1) requestAnimationFrame(tick);
			else el.textContent = target.toLocaleString();
		};
		requestAnimationFrame(tick);
	};

	// Count up only when the strip is genuinely scrolled INTO the reading area.
	// rootMargin '-35%' on the bottom means it won't fire while it's only peeking
	// in at the very bottom on load — it must rise into the top ~65% of the
	// viewport. Reset to 0 whenever it leaves, so it always replays from 0.
	let statsTarget = null;
	let statsArmed = false; // baseline established (first observer callback)
	let statsCounted = false; // already counted during the current in-view session
	const rdEl = () => document.getElementById('stat-readers');
	const ctEl = () => document.getElementById('stat-countries');
	// Resting state = the REAL number (never a lonely "0" that looks broken).
	const showFinal = () => {
		if (!statsTarget) return;
		if (rdEl()) rdEl().textContent = statsTarget.readers.toLocaleString();
		if (ctEl()) ctEl().textContent = statsTarget.countries.toLocaleString();
	};
	const runCount = () => {
		if (!statsTarget) return;
		animateCount(rdEl(), statsTarget.readers);
		animateCount(ctEl(), statsTarget.countries);
	};
	const stripEl = document.getElementById('stats-strip');
	if (stripEl && 'IntersectionObserver' in window) {
		new IntersectionObserver((entries) => {
			for (const e of entries) {
				if (!statsArmed) {
					// First callback = initial state. Show the real number; only
					// ANIMATE later, when the strip is actively scrolled into view.
					statsArmed = true;
					statsCounted = e.isIntersecting;
					showFinal();
					continue;
				}
				if (e.isIntersecting) {
					if (!statsCounted) { statsCounted = true; runCount(); }
				} else {
					statsCounted = false; // re-arm; rest showing the real number
					showFinal();
				}
			}
		}, { threshold: 0.25 }).observe(stripEl);
	}

	// Local voter identity + remembered reactions (light, per-browser).
	const getVoter = () => {
		let v = localStorage.getItem('fhb_voter');
		if (!v) { v = (crypto.randomUUID && crypto.randomUUID()) || `${Date.now()}-${Math.round(Math.random() * 1e9)}`; localStorage.setItem('fhb_voter', v); }
		return v;
	};
	const getMine = () => { try { return JSON.parse(localStorage.getItem('fhb_my_reactions') || '{}'); } catch { return {}; } };
	const setMine = (m) => localStorage.setItem('fhb_my_reactions', JSON.stringify(m));

	const cardHTML = (r) => {
		const rx = r.reactions || { love: 0, like: 0, dislike: 0 };
		return `
		<article class="rv-card" data-id="${r.id}">
			<div class="flex items-center gap-3 mb-1.5">
				${r.avatar_url
					? `<img class="rv-avatar-img" src="${esc(r.avatar_url)}" alt="" loading="lazy" decoding="async" />`
					: `<div class="rv-avatar">${esc((r.first_name || '?').charAt(0).toUpperCase())}</div>`}
				<div>
					<div class="font-semibold text-ink">${esc(r.first_name)} ${flag(r.country_code)}</div>
					<div class="text-xs text-muted">${esc(r.location || '')}</div>
				</div>
			</div>
			<div class="rv-stars text-sm mb-1" aria-label="${r.stars} out of 5 stars">${stars(r.stars)}</div>
			<p class="font-bold text-ink mb-1">${esc(r.title)}</p>
			<p class="text-sm text-on-surface-variant leading-relaxed whitespace-pre-line">${esc(r.body)}</p>
			<div class="rv-foot">
				<div class="rv-actions">
					<button class="rv-react" type="button" data-kind="love" aria-label="Love this review">❤️ <span class="rv-n" data-kind="love">${rx.love}</span></button>
					<button class="rv-react" type="button" data-kind="like" aria-label="Like this review">👍 <span class="rv-n" data-kind="like">${rx.like}</span></button>
					<button class="rv-react" type="button" data-kind="dislike" aria-label="Dislike this review">👎 <span class="rv-n" data-kind="dislike">${rx.dislike}</span></button>
				</div>
				<button class="rv-share" type="button" data-title="${esc(r.title)}" data-name="${esc(r.first_name)}" aria-label="Share this review">↗ Share</button>
			</div>
			<div class="text-xs text-muted mt-2">${ago(r.created_at)}</div>
		</article>`;
	};

	const applyMine = (root) => {
		const mine = getMine();
		root.querySelectorAll('.rv-card').forEach((card) => {
			const k = mine[card.dataset.id];
			card.querySelectorAll('.rv-react').forEach((b) => b.classList.toggle('on', !!k && b.dataset.kind === k));
		});
	};

	async function loadStats() {
		try {
			const s = await fetch(api('stats=1')).then((r) => r.json());
			statsTarget = { readers: s.readers ?? 0, countries: s.countries ?? 0 };
			showFinal();
			const sel = document.getElementById('country-filter');
			for (const c of s.countryList || []) {
				const o = document.createElement('option');
				o.value = c; o.textContent = `${flag(c)} ${c}`;
				sel.appendChild(o);
			}
		} catch { /* leave the em-dashes */ }
	}

	async function loadFeatured() {
		try {
			const rows = await fetch(api('featured=1')).then((r) => r.json());
			if (Array.isArray(rows) && rows.length) {
				document.getElementById('featured-list').innerHTML = rows.map(cardHTML).join('');
				document.getElementById('featured').classList.remove('hidden');
				applyMine(document.getElementById('featured'));
			}
		} catch { /* no featured section */ }
	}

	async function loadReviews(reset = false) {
		if (reset) { offset = 0; document.getElementById('reviews-list').innerHTML = ''; }
		const qs = `offset=${offset}${country ? `&country=${country}` : ''}`;
		const rows = await fetch(api(qs)).then((r) => r.json()).catch(() => []);
		const list = document.getElementById('reviews-list');
		if (Array.isArray(rows)) list.insertAdjacentHTML('beforeend', rows.map(cardHTML).join(''));
		offset += (rows.length || 0);
		document.getElementById('reviews-empty').classList.toggle('hidden', list.children.length > 0);
		document.getElementById('load-more').classList.toggle('hidden', !Array.isArray(rows) || rows.length < PAGE_SIZE);
		applyMine(list);
	}

	document.getElementById('country-filter').addEventListener('change', (e) => { country = e.target.value; loadReviews(true); });
	document.getElementById('load-more').addEventListener('click', () => loadReviews(false));

	// Reactions + share — delegated (cards are injected dynamically).
	function openShareMenu(btn, text, url) {
		document.querySelector('.rv-share-menu')?.remove();
		const e = encodeURIComponent;
		const menu = document.createElement('div');
		menu.className = 'rv-share-menu';
		menu.innerHTML =
			`<a href="https://twitter.com/intent/tweet?text=${e(text)}&url=${e(url)}" target="_blank" rel="noopener">Share on X</a>` +
			`<a href="https://www.facebook.com/sharer/sharer.php?u=${e(url)}" target="_blank" rel="noopener">Share on Facebook</a>` +
			`<a href="https://wa.me/?text=${e(`${text} ${url}`)}" target="_blank" rel="noopener">Share on WhatsApp</a>` +
			`<button type="button" class="rv-copy">Copy link</button>`;
		btn.parentElement.style.position = 'relative';
		btn.parentElement.appendChild(menu);
		menu.querySelector('.rv-copy').addEventListener('click', () => {
			navigator.clipboard?.writeText(url);
			menu.querySelector('.rv-copy').textContent = 'Copied!';
			setTimeout(() => menu.remove(), 900);
		});
	}

	document.addEventListener('click', async (ev) => {
		const react = ev.target.closest('.rv-react');
		if (react) {
			const card = react.closest('.rv-card');
			const id = card?.dataset.id;
			const kind = react.dataset.kind;
			if (!id) return;
			const acts = react.closest('.rv-actions');
			acts.querySelectorAll('.rv-react').forEach((b) => (b.disabled = true));
			try {
				const data = await fetch('/review-api', {
					method: 'POST', headers: { 'content-type': 'application/json' },
					body: JSON.stringify({ action: 'react', review_id: id, voter: getVoter(), kind }),
				}).then((r) => r.json());
				if (data.ok) {
					for (const k of ['love', 'like', 'dislike']) {
						const n = acts.querySelector(`.rv-n[data-kind="${k}"]`);
						if (n) n.textContent = data.reactions[k] ?? 0;
					}
					const mine = getMine();
					if (data.mine) mine[id] = data.mine; else delete mine[id];
					setMine(mine);
					acts.querySelectorAll('.rv-react').forEach((b) => b.classList.toggle('on', b.dataset.kind === data.mine));
				}
			} catch { /* ignore */ } finally {
				acts.querySelectorAll('.rv-react').forEach((b) => (b.disabled = false));
			}
			return;
		}

		const share = ev.target.closest('.rv-share');
		if (share) {
			const text = `"${share.dataset.title}" — ${share.dataset.name || 'a reader'}'s review of The Father's Heart Bible`;
			if (navigator.share) { try { await navigator.share({ title: "Father's Heart Bible", text, url: SHARE_URL }); } catch { /* cancelled */ } }
			else openShareMenu(share, text, SHARE_URL);
			return;
		}

		const menu = document.querySelector('.rv-share-menu');
		if (menu && !ev.target.closest('.rv-share-menu')) menu.remove();
	});

	// Star picker.
	let starVal = 0;
	const starBtns = [...document.querySelectorAll('#star-input .star')];
	const paint = (n) => starBtns.forEach((b, i) => b.classList.toggle('on', i < n));
	starBtns.forEach((b) => {
		b.addEventListener('mouseenter', () => paint(Number(b.dataset.v)));
		b.addEventListener('mouseleave', () => paint(starVal));
		b.addEventListener('click', () => { starVal = Number(b.dataset.v); document.getElementById('stars-value').value = starVal; paint(starVal); });
	});

	// ── FH Family sign-in gating ───────────────────────────────────────────
	// Posting requires a verified FH Family member. Session + insert live behind
	// /api/review-submit (community app), reached via the apex proxy on the real
	// domain. On the dev preview there's no proxy, so this resolves to "guest".
	const SUBMIT_API = '/api/review-submit';
	const DRAFT_KEY = 'fhb_review_draft';
	let session = { signedIn: false };

	const form = document.getElementById('review-form');
	const msg = document.getElementById('form-msg');
	const authStatus = document.getElementById('auth-status');
	const field = (n) => form.querySelector(`[name="${n}"]`);
	const setMsg = (text, ok) => { msg.textContent = text; msg.className = `text-sm text-center ${ok ? 'text-brand' : 'text-red-600'}`; };

	function renderAuthStatus() {
		if (!authStatus || !session.signedIn) return;
		const av = session.avatarUrl
			? `<img class="rv-avatar-img" src="${esc(session.avatarUrl)}" alt="" />`
			: `<div class="rv-avatar" style="width:28px;height:28px;font-size:13px;">${esc((session.firstName || '?').charAt(0).toUpperCase())}</div>`;
		authStatus.innerHTML = `${av}<span>Posting as <strong class="text-ink">${esc(session.firstName || session.name || 'you')}</strong> — verified FH Family member.</span>`;
	}

	async function loadSession() {
		try {
			const r = await fetch(SUBMIT_API, { headers: { accept: 'application/json' } });
			if (r.ok) session = await r.json();
		} catch { /* guest */ }
		const guestEl = document.getElementById('review-guest');
		if (session.signedIn) {
			if (guestEl) guestEl.hidden = true;
			form.hidden = false;
			renderAuthStatus();
			if (session.location && !field('location').value) field('location').value = session.location;
		} else {
			if (guestEl) guestEl.hidden = false;
			form.hidden = true;
		}
	}

	const collectDraft = () => ({ location: field('location').value, stars: starVal, title: field('title').value, body: field('body').value });

	async function submitReview(draft) {
		const btn = document.getElementById('review-submit');
		btn.disabled = true; setMsg('Posting…', true);
		try {
			const res = await fetch(SUBMIT_API, {
				method: 'POST', headers: { 'content-type': 'application/json' },
				body: JSON.stringify(draft),
			});
			const data = await res.json().catch(() => ({}));
			if (res.ok && data.ok) {
				form.reset(); starVal = 0; paint(0);
				try { localStorage.setItem('fhb_reviewed', '1'); } catch { /* ignore */ }
				setMsg('Thank you! Your review will appear shortly, once reviewed.', true);
			} else if (res.status === 401 || data.error === 'signin-required') {
				localStorage.setItem(DRAFT_KEY, JSON.stringify(draft));
				window.location.href = '/login?next=/review';
			} else {
				setMsg('Something went wrong. Please try again.', false);
			}
		} catch { setMsg('Network error. Please try again.', false); } finally { btn.disabled = false; }
	}

	form.addEventListener('submit', (e) => {
		e.preventDefault();
		if (!field('location').value.trim() || !field('title').value.trim() || !field('body').value.trim()) { setMsg('Please add your location, a title, and your review.', false); return; }
		if (!starVal) { setMsg('Please choose a star rating.', false); return; }
		const draft = collectDraft();
		if (session.signedIn) { submitReview(draft); return; }
		// Guest → save the draft, then send them through the FH Family sign-in link.
		localStorage.setItem(DRAFT_KEY, JSON.stringify(draft));
		setMsg('Sending you a sign-in link to confirm your review…', true);
		window.location.href = '/login?next=/review';
	});

	// On return from sign-in: restore the saved draft and post it automatically.
	async function resumeDraftIfSignedIn() {
		if (!session.signedIn) return;
		let draft = null;
		try { draft = JSON.parse(localStorage.getItem(DRAFT_KEY) || 'null'); } catch { /* none */ }
		if (!draft) return;
		localStorage.removeItem(DRAFT_KEY);
		field('location').value = draft.location || '';
		field('title').value = draft.title || '';
		field('body').value = draft.body || '';
		starVal = Number(draft.stars) || 0; paint(starVal);
		if (draft.title && draft.body && starVal) await submitReview(draft);
	}

	// Initial loads (after paint).
	loadStats(); loadFeatured(); loadReviews(true);
	loadSession().then(resumeDraftIfSignedIn);
</script>
