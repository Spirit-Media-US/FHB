---
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Navbar from '../components/Navbar.astro';
// Phase 2 scaffold — Phase 3: Add hero, sections, content
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity';

const siteSettings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] { siteName, tagline }
`);
const siteName = siteSettings?.siteName || "Father's Heart Bible";
const tagline = siteSettings?.tagline || "A new translation revealing God's heart as Father.";
---
<Layout title={siteName} description={tagline}>
  <Navbar />
  <main class="pt-24">
    <Hero />
    <!-- Phase 3: Add sections -->
  </main>
  <Footer />
</Layout>
