---
import Footer from '../components/Footer.astro';
import ImageGrid from '../components/ImageGrid.astro';
import Navbar from '../components/Navbar.astro';
import ScriptureBlock from '../components/ScriptureBlock.astro';
import Section from '../components/Section.astro';
import Layout from '../layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity';

// Fetch hero poster bytes at build time for base64 LCP inlining (mobile speed win).
// Only inlines when the poster matches the known Sanity source; otherwise remote URL.
async function fetchPosterDataUri(url: string): Promise<string | null> {
	try {
		const res = await fetch(url);
		if (!res.ok) return null;
		const buf = Buffer.from(await res.arrayBuffer());
		if (buf.length > 15000) return null; // safety: don't bloat HTML
		return `data:image/webp;base64,${buf.toString('base64')}`;
	} catch {
		return null;
	}
}

// Fetch page content + media from Sanity (all values have hardcoded fallbacks)
const [pageData, media] = await Promise.all([
	sanityClient.fetch(`*[_type =="page" && slug =="home"][0] {
    seoTitle, seoDescription,
    heroHeading, heroSubheading,
    heroPrimaryCtaLabel, heroPrimaryCtaHref,
    heroSecondaryCtaLabel, heroSecondaryCtaHref
  }`),
	sanityClient.fetch(`*[_type =="siteSettings"][0] {
    heroVideoUrl, heroPosterUrl, bookCoverUrl, bibleCoverImage,
    fhbCoverImage,
    homePageHeroVideos,
    peoplePhoto1Url, peoplePhoto2Url, peoplePhoto3Url,
    communityUrl,
    logo
  }`),
]);

const seoTitle =
	pageData?.seoTitle ||
	"Father's Heart Bible | A New Bible Translation Revealing the Father's Heart";
const seoDescription =
	pageData?.seoDescription ||
	"Discover the Father's Heart Bible, a new Bible translation revealing God as Father where Scripture reveals Him. Download the free book, explore sample passages, join the movement, and be part of what the Father is doing.";
const heroHeading =
	'You were never meant to relate to God as a servant\u2026 but as a beloved child.';
const heroSubheading =
	'The Father\u2019s Heart Bible reveals what Scripture has always been showing: the destination was never merely forgiveness or heaven. The destination has always been the Father.';
const heroPrimaryCtaLabel = 'Download the Free Book';
const heroPrimaryCtaHref = '/download';
const heroSecondaryCtaLabel = 'Already have it? Start here';
const heroSecondaryCtaHref = '/join';
const heroVideoSrc =
	media?.heroVideoUrl ||
	'https://assets.spiritmediapublishing.com/fathers-heart-bible/woman-holding-bible-sky.mp4';
const heroPosterRaw =
	media?.heroPosterUrl ||
	'https://cdn.sanity.io/images/rusi1hyi/production/02221f907ae9855026e325f5ae27158f83531a1e-6000x1713.jpg';
// Transform the poster via Sanity CDN params for mobile-first responsive delivery.
// Keeps everything on Sanity (no re-upload). ?w=<>&fm=webp&q=<> works on any Sanity image URL.
const heroPosterBase = heroPosterRaw.split('?')[0];
const heroPosterSrc = `${heroPosterBase}?w=1600&fm=webp&q=75&auto=format`;
const heroPoster768 = `${heroPosterBase}?w=768&fm=webp&q=72&auto=format`;
const heroPoster1200 = `${heroPosterBase}?w=1200&fm=webp&q=74&auto=format`;
const heroPosterSrcset = `${heroPoster768} 768w, ${heroPoster1200} 1200w, ${heroPosterSrc} 1600w`;
const heroPosterSizes = '100vw';

// Inline the 768px WebP as base64 for instant mobile LCP (no network RTT).
const heroPoster768DataUri = await fetchPosterDataUri(heroPoster768);
const heroPoster768ForImg = heroPoster768DataUri || heroPoster768;

// Helper — append Sanity CDN transforms to any cdn.sanity.io URL safely
function sanityTransform(url: string, w: number, q = 75): string {
	if (!url) return url;
	if (!url.includes('cdn.sanity.io')) return url;
	const base = url.split('?')[0];
	return `${base}?w=${w}&fm=webp&q=${q}&auto=format`;
}

// Bible cover — prefer Sanity image, fall back to hardcoded (both go through webp transform)
// Responsive widths: mobile=512 (w-64 at DPR2), tablet=640 (w-80 at DPR2)
const bibleCoverImageFromSanity = media?.bibleCoverImage;
const bookCoverUrl = bibleCoverImageFromSanity
	? urlFor(bibleCoverImageFromSanity).width(512).format('webp').quality(72).url()
	: sanityTransform(
			'https://cdn.sanity.io/images/rusi1hyi/production/bf1efb2f6870a8f0257175a033f27222f6e1e6b9-2857x4000.png',
			512,
			72,
		);
const bookCoverUrl640 = bibleCoverImageFromSanity
	? urlFor(bibleCoverImageFromSanity).width(640).format('webp').quality(72).url()
	: sanityTransform(
			'https://cdn.sanity.io/images/rusi1hyi/production/bf1efb2f6870a8f0257175a033f27222f6e1e6b9-2857x4000.png',
			640,
			72,
		);
const bookCoverSrcset = `${bookCoverUrl} 512w, ${bookCoverUrl640} 640w`;
const bookCoverSizes = '(max-width: 767px) 256px, 320px';

// FHB → Beloved Identity cover — prefer Sanity image, fall back to hardcoded
const fhbCoverSanity = media?.fhbCoverImage;
const fhbiCoverUrl = fhbCoverSanity
	? urlFor(fhbCoverSanity).width(576).format('webp').quality(75).url()
	: sanityTransform(
			'https://cdn.sanity.io/images/rusi1hyi/production/3ab3f8d98e6ac0913d382922f0983efe6cb5535f-1278x2118.png',
			576,
		);

// Hero video array — prefer Sanity, fall back to hardcoded
const heroVideosFromSanity = media?.homePageHeroVideos;
// People photos — apply Sanity CDN transforms to shrink multi-MB originals
const photo1 = sanityTransform(media?.peoplePhoto1Url || '', 800, 72);
const photo2 = sanityTransform(media?.peoplePhoto2Url || '', 800, 72);
const photo3 = sanityTransform(media?.peoplePhoto3Url || '', 800, 72);
const communityUrl = media?.communityUrl || '/join';
const heroLogoUrl = media?.logo ? urlFor(media.logo).width(160).url() : null;
---

<Layout
	title={seoTitle}
	description={seoDescription}
	darkHero={true}
	preloadImage={heroPoster768DataUri ? undefined : heroPoster768}
	preloadImageSrcset={heroPoster768DataUri ? undefined : heroPosterSrcset}
	preloadImageSizes={heroPoster768DataUri ? undefined : heroPosterSizes}
	jsonLd={{
		"@context": "https://schema.org",
		"@graph": [
			{
				"@type": "Organization",
				"@id": "https://fathersheartbible.com/#organization",
				"name": "Father's Heart Bible",
				"url": "https://fathersheartbible.com",
				"logo": "https://fathersheartbible.com/fhb-logo.png",
				"publisher": { "@type": "Organization", "name": "Spirit Media Inc.", "url": "https://spiritmediapublishing.com" },
				"description": "A new Bible translation revealing God as Father where Scripture reveals Him."
			},
			{
				"@type": "WebSite",
				"@id": "https://fathersheartbible.com/#website",
				"url": "https://fathersheartbible.com",
				"name": "Father's Heart Bible",
				"publisher": { "@id": "https://fathersheartbible.com/#organization" }
			},
			{
				"@type": "WebPage",
				"@id": "https://fathersheartbible.com/",
				"url": "https://fathersheartbible.com/",
				"name": seoTitle,
				"description": seoDescription,
				"isPartOf": { "@id": "https://fathersheartbible.com/#website" },
				"about": { "@id": "https://fathersheartbible.com/#organization" }
			}
		]
	}}
>
	<Navbar />
	<main>

		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 1 — HERO
		     ═══════════════════════════════════════════════════════════ -->
		<section
			class="relative flex items-end justify-center overflow-hidden min-h-[500px] md:min-h-screen"
			style="background-color: var(--color-deep); margin-top: -1px;"
			id="hero-section"
		>
			<!-- LCP element: poster image. Video is deferred until after first paint.
			     When heroPoster768DataUri is set, src is a base64 data URI — zero network RTT.
			     The remote srcset is omitted in that case to avoid duplicate download. -->
			<img
				id="hero-poster"
				src={heroPoster768ForImg}
				srcset={heroPoster768DataUri ? undefined : heroPosterSrcset}
				sizes={heroPoster768DataUri ? undefined : heroPosterSizes}
				alt=""
				width="1600"
				height="457"
				fetchpriority="high"
				decoding="async"
				class="absolute inset-0 w-full h-full object-cover"
				aria-hidden="true"
				style="transition: opacity 1.5s ease; opacity: 1;"
			/>
			{heroVideoSrc && (
				<>
					<video
						id="hero-video-a"
						class="absolute inset-0 w-full h-full object-cover"
						data-hero-src={heroVideoSrc}
						poster={heroPoster768}
						muted
						playsinline
						preload="none"
						aria-hidden="true"
						style="transition: opacity 1.5s ease; opacity: 0;"
					/>
					<video
						id="hero-video-b"
						class="absolute inset-0 w-full h-full object-cover"
						muted
						playsinline
						preload="none"
						aria-hidden="true"
						style="transition: opacity 1.5s ease; opacity: 0;"
					/>
				</>
			)}
			<div id="hero-text" class="relative z-10 text-center px-6 max-w-3xl mx-auto pb-10 md:pb-16 lg:pb-24" style="transition: color 1.2s ease;">
				<img
					src="/fhb-logo-white-240.png"
					srcset="/fhb-logo-white-160.png 160w, /fhb-logo-white-240.png 240w, /fhb-logo-white-400.png 400w"
					sizes="(max-width: 767px) 160px, (max-width: 1023px) 240px, 400px"
					alt="Father's Heart Bible"
					width="240"
					height="117"
					fetchpriority="high"
					decoding="async"
					class="h-14 md:h-20 lg:h-28 w-auto mx-auto mb-4 md:mb-6" data-hero-entrance
				/>
				<h1
					id="hero-heading"
					class="text-4xl md:text-6xl font-medium leading-snug tracking-tight"
					style="font-family: var(--font-headline); color: #FFFFFF; transition: color 1.2s ease;" data-hero-entrance
				>
					{heroHeading}
				</h1>
			</div>
		</section>

		<!-- ═══════════════════════════════════════════════════════════
		     HERO SUBTEXT — Pulled out of the video hero
		     ═══════════════════════════════════════════════════════════ -->
		<section style="background-color: var(--color-canvas);" class="py-8 md:py-12 px-4 md:px-6">
			<div class="max-w-2xl mx-auto text-center" data-reveal>
				<p
					class="text-lg md:text-xl leading-relaxed mb-10"
					style="font-family: var(--font-body); color: var(--color-muted);"
				>
					{heroSubheading}
				</p>
				<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
					<a
						href={heroPrimaryCtaHref}
						class="inline-flex items-center px-8 py-3.5 text-base font-semibold no-underline transition-all duration-200"
						style="font-family: var(--font-body); background: linear-gradient(135deg, var(--color-primary), var(--color-primary-container)); color: var(--color-on-primary);"
						onmouseover="this.style.opacity='0.9'"
						onmouseout="this.style.opacity='1'"
					>
						{heroPrimaryCtaLabel}
					</a>
					<a
						href={heroSecondaryCtaHref}
						class="inline-flex items-center px-8 py-3.5 text-base font-medium no-underline border transition-all duration-200"
						style="font-family: var(--font-body); color: var(--color-primary); border-color: var(--color-primary);"
						onmouseover="this.style.backgroundColor='var(--color-primary)'; this.style.color='var(--color-on-primary)';"
						onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--color-primary)';"
					>
						{heroSecondaryCtaLabel}
					</a>
				</div>
			</div>
		</section>

		<script define:vars={{ heroVideosFromSanity }} is:inline>
			// Hero videos from Sanity (or hardcoded fallback)
			const R2 = 'https://assets.spiritmediapublishing.com/fathers-heart-bible';
			const heroVideos = heroVideosFromSanity || [
				// — Dark videos (light text: white) — initial video is dark, so these play first
				{ url: `${R2}/woman-holding-bible-sky.mp4`, theme: 'dark' },
				{ url: `${R2}/farmer-reading-bible.mp4`, theme: 'dark' },
				{ url: `${R2}/women-reading-bible-outdoors.mp4`, theme: 'dark' },
				{ url: `${R2}/bible-close-up.mp4`, theme: 'dark' },
				{ url: `${R2}/read-book.mp4`, theme: 'dark' },
				{ url: `${R2}/bible-open-pages.mp4`, theme: 'dark' },
				{ url: `${R2}/reading-bible-4k.mov`, theme: 'dark' },
				// — Light videos (dark text: charcoal #1a1c1c) —
				{ url: `${R2}/bible-lake-reading-hero.mp4`, theme: 'light' },
				{ url: `${R2}/holy-bible.mp4`, theme: 'light' },
				{ url: `${R2}/hands-holding-bible.mp4`, theme: 'light' },
				{ url: `${R2}/mother-son-praying.mp4`, theme: 'light' },
			];

			function applyTheme(theme) {
				// Title stays neon pink on all video backgrounds

			}

			const vA = document.getElementById('hero-video-a');
			const vB = document.getElementById('hero-video-b');
			const poster = document.getElementById('hero-poster');
			if (vA && vB) {
				const PLAYBACK_RATE = 0.75;
				const FADE_DURATION = 1500;
				const FADE_BEFORE = 1.5;

				let heroIdx = 0;
				let curr = vA;
				let next = vB;
				let fading = false;
				let started = false;

				function startVideos() {
					if (started) return;
					started = true;
					vA.src = vA.dataset.heroSrc || heroVideos[0].url;
					vA.load();
					vA.playbackRate = PLAYBACK_RATE;
					vA.play().then(() => {
						// Fade video in, fade poster out — poster stays as fallback
						vA.style.opacity = '1';
						if (poster) {
							setTimeout(() => { poster.style.opacity = '0'; }, 300);
						}
						// Preload the NEXT video once playback begins
						next.src = heroVideos[1].url;
						next.load();
					}).catch(() => { /* autoplay blocked — poster remains */ });
				}

				// Defer video start until after first paint + a small idle window so
				// it never competes with the LCP.
				if ('requestIdleCallback' in window) {
					requestIdleCallback(startVideos, { timeout: 2500 });
				} else {
					window.addEventListener('load', () => setTimeout(startVideos, 600));
				}

				function beginCrossfade() {
					if (fading) return;
					fading = true;
					heroIdx = (heroIdx + 1) % heroVideos.length;

					applyTheme(heroVideos[heroIdx].theme);

					next.play().then(() => {
						next.playbackRate = PLAYBACK_RATE;
						next.style.opacity = '1';
						curr.style.opacity = '0';

						const outgoing = curr;
						curr = next;
						next = outgoing;

						setTimeout(() => {
							next.pause();
							next.currentTime = 0;
							const preloadIdx = (heroIdx + 1) % heroVideos.length;
							next.src = heroVideos[preloadIdx].url;
							next.load();
							fading = false;
						}, FADE_DURATION + 200);
					}).catch(() => {
						curr.currentTime = 0;
						curr.play();
						fading = false;
					});
				}

				function onTimeUpdate() {
					if (this !== curr) return;
					if (!fading && this.duration && this.currentTime >= this.duration - FADE_BEFORE) {
						beginCrossfade();
					}
				}

				vA.addEventListener('timeupdate', onTimeUpdate);
				vB.addEventListener('timeupdate', onTimeUpdate);
			}
		</script>

		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 2 — BIG IDEA
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="soft">
			<div class="text-center max-w-2xl mx-auto">
				<h2
					class="text-4xl md:text-5xl font-light mb-6"
					style="font-family: var(--font-serif); color: var(--color-ink);"
				>
					The destination has always been the Father.
				</h2>
				<p
					class="text-lg leading-relaxed mb-6"
					style="font-family: var(--font-sans); color: var(--color-muted);"
				>
					Many believers have read the Bible faithfully and yet related to God
					more as a servant to a master than as a beloved son or daughter to a loving Father. That
					distance is not always obvious at first. It can hide beneath sincere devotion, sound
					doctrine, years of ministry, and disciplined prayer.
				</p>
				<p
					class="text-lg leading-relaxed"
					style="font-family: var(--font-sans); color: var(--color-muted);"
				>
					The message of Scripture has always been moving toward something deeper. Not merely
					forgiveness. Not merely heaven. Not merely religious correctness. The destination has
					always been the Father.
				</p>
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 3 — SCRIPTURE FEATURE: JOHN 3:16
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="scripture">
			<div class="text-center mb-8">
				<p
					class="text-xs font-semibold tracking-widest uppercase mb-3"
					style="font-family: var(--font-sans); color: var(--color-gold);"
				>
					See the Difference
				</p>
				<h2
					class="text-3xl md:text-4xl font-light"
					style="font-family: var(--font-serif); color: var(--color-ink);"
				>
					John 3:16 — Heard in a New Way
				</h2>
			</div>

			<div class="relative grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 max-w-4xl mx-auto">
				<!-- Standard rendering -->
				<div class="text-center">
					<p
						class="text-xs font-semibold tracking-widest uppercase mb-6"
						style="font-family: var(--font-sans); color: var(--color-muted);"
					>
						Traditional
					</p>
					<blockquote class="m-0">
						<p
							class="text-xl md:text-2xl italic font-light leading-relaxed"
							style="font-family: var(--font-serif); color: var(--color-muted);"
						>"For God so loved the world that he gave his one and only Son, that whoever believes
							in him shall not perish but have eternal life."
						</p>
						<footer class="mt-4">
							<cite
								class="not-italic text-sm tracking-widest uppercase"
								style="font-family: var(--font-sans); color: var(--color-muted); opacity: 0.6;"
							>
								— John 3:16
							</cite>
						</footer>
					</blockquote>
				</div>

				<!-- Divider on desktop -->
				<div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px" style="background-color: var(--color-hairline);"></div>

				<!-- FHB rendering -->
				<div class="text-center">
					<p
						class="text-xs font-semibold tracking-widest uppercase mb-6"
						style="font-family: var(--font-sans); color: var(--color-gold);"
					>
						Father's Heart Bible
					</p>
					<blockquote class="m-0">
						<p
							class="text-xl md:text-2xl italic font-light leading-relaxed"
							style="font-family: var(--font-serif); color: var(--color-ink);"
						>"For our <strong style="font-style: normal; color: var(--color-brand);">Father</strong> so loved the world that He gave His one and only Son, so that everyone
							who trusts in Him would not be lost, but would live in the life of the age to come."
						</p>
						<footer class="mt-4">
							<cite
								class="not-italic text-sm tracking-widest uppercase"
								style="font-family: var(--font-sans); color: var(--color-muted); opacity: 0.6;"
							>
								— John 3:16 · Father's Heart Bible
							</cite>
						</footer>
					</blockquote>
				</div>
			</div>

			<p
				class="text-center mt-12 text-base leading-relaxed max-w-xl mx-auto"
				style="font-family: var(--font-sans); color: var(--color-muted);"
			>
				In this passage, the One who loves and gives the Son is the Father. The Father&rsquo;s Heart
				Bible makes that explicit, helping readers hear this verse not as the action of a distant
				supreme being, but as the giving love of the Father Himself.
			</p>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 4 — WHAT IS FHB
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="soft">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">
				<!-- Book image -->
				<div class="flex justify-center" data-reveal="slide-left">
					{bookCoverUrl ? (
						<img
							src={bookCoverUrl}
							srcset={bookCoverSrcset}
							sizes={bookCoverSizes}
							alt="The Father's Heart Bible — brown cover"
							class="w-64 md:w-80 block"
							loading="lazy"
							decoding="async"
							width="512"
							height="768"
							style="filter: drop-shadow(0 12px 28px rgba(0,0,0,0.22));"
						/>
					) : (
						<div
							class="w-64 md:w-80 aspect-[2/3] flex items-end justify-center p-6"
							style="background-color: var(--color-brand);"
						>
							<p
								class="text-center text-lg font-light italic"
								style="font-family: var(--font-serif); color: rgba(255,255,255,0.9);"
							>
								The Father's Heart Bible
							</p>
						</div>
					)}
				</div>

				<!-- Content -->
				<div data-reveal="slide-right">
					<p
						class="text-xs font-semibold tracking-widest uppercase mb-4"
						style="font-family: var(--font-sans); color: var(--color-gold);"
					>
						What Is the Father's Heart Bible?
					</p>
					<h2
						class="text-3xl md:text-4xl font-light leading-tight mb-6"
						style="font-family: var(--font-serif); color: var(--color-ink);"
					>
						A translation that reveals not only His name — but His heart.
					</h2>
					<p
						class="leading-relaxed mb-4"
						style="font-family: var(--font-sans); color: var(--color-muted);"
					>
						The Father&rsquo;s Heart Bible is a new interpretive English translation that seeks to reveal
						God as Father where Scripture reveals Him. It is grounded in the conviction that from
						Genesis to Revelation, the Bible tells one story: a Father creating children in His
						image, pursuing them when they wander, and restoring them to Himself through His Son by
						His Spirit.
					</p>
					<p
						class="leading-relaxed mb-8"
						style="font-family: var(--font-sans); color: var(--color-muted);"
					>
						This is not only a Bible to study. It is a Bible to receive.
					</p>
					<div class="flex flex-col sm:flex-row gap-4">
						<a
							href="/samples"
							class="inline-flex items-center px-6 py-3 text-sm font-semibold no-underline transition-all duration-200"
							style="font-family: var(--font-sans); background-color: var(--color-brand); color: #fff;"
							onmouseover="this.style.backgroundColor='var(--color-brand-dark)'"
							onmouseout="this.style.backgroundColor='var(--color-brand)'"
						>
							Read Sample Passages
						</a>
						<a
							href="/download"
