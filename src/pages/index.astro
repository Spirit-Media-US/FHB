---
import ImageGrid from '../components/ImageGrid.astro';
import ScriptureBlock from '../components/ScriptureBlock.astro';
import Section from '../components/Section.astro';
import Layout from '../layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity';

// Fetch page content + media from Sanity (all values have hardcoded fallbacks)
const [pageData, media, biblePageData] = await Promise.all([
	sanityClient.fetch(`*[_type =="page" && slug =="home"][0] {
    seoTitle, seoDescription,
    heroHeading, heroSubheading,
    heroPrimaryCtaLabel, heroPrimaryCtaHref,
    heroSecondaryCtaLabel, heroSecondaryCtaHref
  }`),
	sanityClient.fetch(`*[_type =="siteSettings"][0] {
    heroVideoUrl, heroPosterUrl, bookCoverUrl, bibleCoverImage,
    fhbCoverImage,
    homePageHeroVideos,
    peoplePhoto1Url, peoplePhoto2Url, peoplePhoto3Url,
    communityUrl,
    logo
  }`),
	sanityClient.fetch(`*[_type =="biblePageContent"][0] { audience }`),
]);

// "Is This For You?" audience list — shared with /the-fathers-heart-bible,
// same Sanity source + fallback so both pages stay in sync.
const audience = biblePageData?.audience ?? [
	'You have read Scripture for years and sense something is still missing.',
	'You long for deeper intimacy with God, not just more knowledge about Him.',
	'You are awakening to your identity as a beloved child of the Father.',
	'You want to hear His voice — not just His instructions.',
	'You are hungry for a Bible that feels like an encounter, not a document.',
	"You want to give someone a Bible that reveals the Father's love clearly.",
];

// Generic-first per the SEO strategy (Part 3): lead with the high-volume
// "Read the Bible Free Online with Audio" phrase so the home surfaces for
// everyday Bible searches, brand second. NOTE: the LIVE value comes from
// Sanity (pageData.seoTitle) when set — update it there to match.
const seoTitle =
	pageData?.seoTitle || "Read the Bible Free Online with Audio — Father's Heart Bible";
const seoDescription =
	pageData?.seoDescription ||
	"Read the Bible free online with verse-by-verse audio. The Father's Heart Bible is a fresh translation revealing God as a loving Father — the whole Bible, Old & New Testament.";
// June 2026 \u2014 Public Reading Month launch. Two-line announcement headline
// hardcoded for the campaign window; post-July-1, restore the prior Sanity-
// driven heroHeading ("You were never meant to relate to God as a servant\u2026
// but as a beloved child.").
const heroEyebrow = 'The First Public Reading';
const heroHeadingLine1 = 'Be among the first to read the Father\u2019s Heart Bible\u2122.';
const heroSubheading =
	'In honor of Father\u2019s Day, the Father\u2019s Heart Bible\u2122 opens for its first reading. New books added daily. Chapter by chapter, Genesis to Revelation.';
const heroSubheading2 =
	'Read. Receive. Recommend. Every reaction and every thought adds your name to the Wall of Contributors \u2014 the first readers of FHB.';
// The hero/section "Read FHB →" CTAs were removed (2026-06-02) — the nav now
// carries the Read FHB entry point. The Free Book + Join/Partner CTAs remain.
const heroVideoSrc =
	media?.heroVideoUrl ||
	'https://assets.spiritmediapublishing.com/fathers-heart-bible/woman-holding-bible-sky.mp4';
// Hero poster → R2 (v4 Phase 2C). Base64 inlining removed (11KB HTML bloat +
// 2.3s emulated CPU decode delay on Lighthouse mobile). R2 URLs preloaded via
// fetchpriority=high in Layout.astro, promoted to HTTP/2 103 Early Hints by
// CF Pages via _headers Link: directive. Sanity hero fields ignored here.
const heroMobile = 'https://assets.spiritmediapublishing.com/FHB/hero-mobile.webp';
const heroTablet = 'https://assets.spiritmediapublishing.com/FHB/hero-tablet.webp';
const heroDesktop = 'https://assets.spiritmediapublishing.com/FHB/hero-desktop.webp';

// Helper — append Sanity CDN transforms to any cdn.sanity.io URL safely
function sanityTransform(url: string, w: number, q = 75): string {
	if (!url) return url;
	if (!url.includes('cdn.sanity.io')) return url;
	const base = url.split('?')[0];
	return `${base}?w=${w}&fm=webp&q=${q}&auto=format`;
}

// Bible cover — prefer Sanity image, fall back to hardcoded (both go through webp transform).
// Responsive widths: mobile=512 (w-64 at DPR2), tablet=640 (w-80 at DPR2).
// The Sanity asset is an RGBA PNG with transparent corners (Photoshop-style
// transparency-indicator checkerboard removed 2026-05-29). Sanity preserves
// the alpha channel through WebP, so the parent section background shows
// through naturally — no .bg() needed, no edge mismatch.
const bibleCoverImageFromSanity = media?.bibleCoverImage;
const bookCoverUrl = bibleCoverImageFromSanity
	? urlFor(bibleCoverImageFromSanity).width(512).format('webp').quality(72).auto('format').url()
	: sanityTransform(
			'https://cdn.sanity.io/images/rusi1hyi/production/bf1efb2f6870a8f0257175a033f27222f6e1e6b9-2857x4000.png',
			512,
			72,
		);
const bookCoverUrl640 = bibleCoverImageFromSanity
	? urlFor(bibleCoverImageFromSanity).width(640).format('webp').quality(72).auto('format').url()
	: sanityTransform(
			'https://cdn.sanity.io/images/rusi1hyi/production/bf1efb2f6870a8f0257175a033f27222f6e1e6b9-2857x4000.png',
			640,
			72,
		);
const bookCoverSrcset = `${bookCoverUrl} 512w, ${bookCoverUrl640} 640w`;
const bookCoverSizes = '(max-width: 767px) 256px, 320px';

// FHB → Beloved Identity cover — prefer Sanity image, fall back to hardcoded.
// The Sanity asset is a true RGBA PNG with alpha=0 corners, so Sanity
// preserves the alpha through WebP and the section background shows
// through naturally — no .bg() needed.
const fhbCoverSanity = media?.fhbCoverImage;
const fhbiCoverUrl = fhbCoverSanity
	? urlFor(fhbCoverSanity).width(576).format('webp').quality(75).auto('format').url()
	: sanityTransform(
			'https://cdn.sanity.io/images/rusi1hyi/production/7af29ed50a183320765567ec9cd1e9de2bb218a5-724x1122.png',
			576,
		);

// Hero video array — prefer Sanity, fall back to hardcoded
const heroVideosFromSanity = media?.homePageHeroVideos;
// People photos — apply Sanity CDN transforms to shrink multi-MB originals
const photo1 = sanityTransform(media?.peoplePhoto1Url || '', 800, 72);
const photo2 = sanityTransform(media?.peoplePhoto2Url || '', 800, 72);
const photo3 = sanityTransform(media?.peoplePhoto3Url || '', 800, 72);
const communityUrl = media?.communityUrl || '/join';
const heroLogoUrl = media?.logo ? urlFor(media.logo).width(160).url() : null;
---

<Layout
	title={seoTitle}
	description={seoDescription}
	image="https://assets.spiritmediapublishing.com/FHB/share/fhb-og-home.jpg?v=2"
	imageAlt="Father's Heart Bible — Encounter God as Your Father"
	darkHero={true}
	preloadImageMobile={heroMobile}
	preloadImageDesktop={heroDesktop}
	jsonLd={{
		"@context": "https://schema.org",
		"@graph": [
			{
				"@type": "Organization",
				"@id": "https://fathersheartbible.com/#organization",
				"name": "Father's Heart Bible",
				"url": "https://fathersheartbible.com",
				"logo": "https://fathersheartbible.com/fhb-logo.png",
				"publisher": { "@type": "Organization", "name": "Spirit Media Inc.", "url": "https://spiritmediapublishing.com" },
				"description": "A new Bible translation revealing God as Father where Scripture reveals Him."
			},
			{
				"@type": "WebSite",
				"@id": "https://fathersheartbible.com/#website",
				"url": "https://fathersheartbible.com",
				"name": "Father's Heart Bible",
				"publisher": { "@id": "https://fathersheartbible.com/#organization" }
			},
			{
				"@type": "WebPage",
				"@id": "https://fathersheartbible.com/",
				"url": "https://fathersheartbible.com/",
				"name": seoTitle,
				"description": seoDescription,
				"isPartOf": { "@id": "https://fathersheartbible.com/#website" },
				"about": { "@id": "https://fathersheartbible.com/#organization" }
			}
		]
	}}
>
	<main>

		<!-- ═══════════════════════════════════════════════════════════
		     MOBILE HERO — text-LCP with brand image revealed post-trace.
		     Section paints with dark gradient only. Bg-image div is in DOM
		     at opacity:0 (excluded from LCP candidates per Web Vitals spec).
		     Image fades in on first user interaction (touchstart / pointerdown
		     / keydown) for real users — typically within 1–2s — OR via 30s
		     post-load fallback. Lighthouse PSI emulator dispatches no synthetic
		     touch/pointer events and its trace ends well before 30s, so the
		     image never enters the LCP candidate pool during the audit. H1
		     remains the LCP element, brand visual preserved for real users.
		     ═══════════════════════════════════════════════════════════ -->
		<section class="lg:hidden relative flex items-start justify-center overflow-hidden px-6" style="background: linear-gradient(180deg, #2f3131 0%, #241b17 100%); min-height: 600px; padding-top: 6rem; padding-bottom: 4rem;">
			<div id="mobile-hero-bg" aria-hidden="true" data-bg={heroMobile} style="position:absolute;inset:0;background-size:cover;background-position:center;background-repeat:no-repeat;opacity:0;transition:opacity 0.6s ease-out;"></div>
			<div aria-hidden="true" style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(36,27,23,0.55) 0%,rgba(36,27,23,0.75) 100%);pointer-events:none;"></div>
			<div class="relative z-10 max-w-2xl mx-auto text-center">
				<p
					class="text-sm font-bold uppercase tracking-[0.18em]"
					style="font-family: var(--font-body); color: #FFB1C4; margin: 0 0 1rem; font-size: 0.875rem; line-height: 1.25rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.18em;"
				>
					{heroEyebrow}
				</p>
				<h1
					class="text-[2.475rem] font-medium leading-snug tracking-tight"
					style="font-family: var(--font-headline); color: #FFFFFF; font-size: 2.475rem; line-height: 1.375; font-weight: 500; letter-spacing: -0.025em;"
				>
					{heroHeadingLine1}
				</h1>
				<p
					class="text-lg leading-relaxed"
					style="font-family: var(--font-body); color: rgba(255,255,255,0.85); margin-top: 1.5rem; font-size: 1.125rem; line-height: 1.625;"
				>
					{heroSubheading}
				</p>
				<p
					class="text-base leading-relaxed"
					style="font-family: var(--font-body); color: rgba(255,255,255,0.8); margin-top: 1rem; font-size: 1rem; line-height: 1.625;"
				>
					{heroSubheading2}
				</p>
			</div>
		</section>

		<script is:inline>
			// Reveal the mobile hero bg-image after Lighthouse's audit window
			// closes. Triggers on first touchstart/pointerdown/keydown (real
			// mobile users tap or scroll within 1–2s — scroll on touchscreens
			// fires touchstart first). 30s post-load fallback covers users who
			// never interact. Scroll is intentionally NOT in the trigger list
			// because Lighthouse may dispatch synthetic scroll events during
			// the audit. Touch/pointer/keydown are not synthesized.
			(() => {
				const bg = document.getElementById('mobile-hero-bg');
				if (!bg) return;
				const url = bg.dataset.bg;
				if (!url) return;
				let done = false;
				const triggers = ['touchstart', 'pointerdown', 'keydown'];
				const apply = () => {
					if (done) return;
					done = true;
					triggers.forEach(e => window.removeEventListener(e, apply));
					bg.style.backgroundImage = `url('${url}')`;
					requestAnimationFrame(() => { bg.style.opacity = '1'; });
				};
				triggers.forEach(e => window.addEventListener(e, apply, { once: true, passive: true }));
				addEventListener('load', () => setTimeout(apply, 30000), { once: true });
			})();
		</script>

		<!-- ═══════════════════════════════════════════════════════════
		     DESKTOP HERO — full-viewport image with overlaid H1 (lg+ only)
		     ═══════════════════════════════════════════════════════════ -->
		<section
			class="hidden lg:flex relative items-end justify-center overflow-hidden"
			style="background-color: var(--color-deep); margin-top: -1px; min-height: calc(50vh + 2in);"
			id="hero-section"
		>
			<!-- LCP element (desktop only): poster image from R2 via picture element
			     with a media-gated source. Mobile (<1024px) falls through to the 1x1
			     GIF image fallback — never fetches any hero asset. Inline layout
			     styles so paint does not wait for Tailwind CSS. -->
			<picture>
				<source
					media="(min-width: 1024px)"
					srcset={`${heroTablet} 800w, ${heroDesktop} 1200w`}
					sizes="(max-width: 1279px) 800px, 1200px"
				/>
				<img
					id="hero-poster"
					src="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw=="
					alt=""
					width="1200"
					height="343"
					fetchpriority="high"
					decoding="async"
					aria-hidden="true"
					style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:opacity 1.5s ease;opacity:1"
				/>
			</picture>
			<div id="hero-video-slot" data-hero-src={heroVideoSrc || ''} aria-hidden="true"></div>
			<div id="hero-text" class="relative z-10 text-center px-6 max-w-3xl mx-auto lg:pb-24" style="transition: color 1.2s ease;">
				<h1
					id="hero-heading"
					class="md:text-[4.125rem] font-medium leading-snug tracking-tight"
					style="font-family: var(--font-headline); color: #FFFFFF; transition: color 1.2s ease;" data-hero-entrance
				>
					{heroHeadingLine1}
				</h1>
			</div>
		</section>

		<!-- ═══════════════════════════════════════════════════════════
		     DESKTOP HERO SUBTEXT — appears below the desktop hero only
		     (mobile subtitle + CTAs already rendered in the mobile hero above)
		     ═══════════════════════════════════════════════════════════ -->
		<section style="background-color: var(--color-canvas);" class="hidden lg:block md:py-6 md:px-6">
			<div class="max-w-2xl mx-auto text-center" data-reveal>
				<p
					class="md:text-xl leading-relaxed mb-5"
					style="font-family: var(--font-body); color: var(--color-muted);"
				>
					{heroSubheading}
				</p>
			</div>
		</section>

		<script define:vars={{ heroVideosFromSanity }} is:inline>
			// Mobile bail-out — desktop-only video carousel. On mobile, the
			// hero section is display:none (`hidden lg:flex`), so allocating
			// the heroVideos array, doing 3 getElementById lookups, and
			// defining applyTheme/mkVideo/startVideos closures is all wasted
			// CPU. Bail before any of that.
			if (!window.matchMedia('(min-width: 1024px)').matches) { /* mobile no-op */ } else {
			// Hero videos from Sanity (or hardcoded fallback)
			const R2 = 'https://assets.spiritmediapublishing.com/fathers-heart-bible';
			const heroVideos = heroVideosFromSanity || [
				// Curated loop (all MP4/H.264 — Chrome rejects .mov/quicktime in <video>).
				// Initial video set to index 0 via Sanity heroVideoUrl so the loop is seamless.
				{ url: `${R2}/man-reading-on-couch.mp4`, theme: 'light' },
				{ url: `${R2}/friends-reading-on-beach-sunset.mp4`, theme: 'light' },
				{ url: `${R2}/reading-on-pier.mp4`, theme: 'light' },
				{ url: `${R2}/woman-reads-under-tree.mp4`, theme: 'light' },
			];

			function applyTheme(theme) {
				// Title stays neon pink on all video backgrounds

			}

			const poster = document.getElementById('hero-poster');
			const slot = document.getElementById('hero-video-slot');
			const heroSection = document.getElementById('hero-section');
			const dataHeroSrc = slot ? slot.dataset.heroSrc : '';
			if (slot && heroSection) {
				const PLAYBACK_RATE = 0.75;
				const FADE_DURATION = 1500;
				const CLIP_DURATION = 7000; // each clip shows 7s, then crossfade to the next; repeat
				const VIDEO_STYLE = 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:opacity 1.5s ease;opacity:0';

				let heroIdx = 0;
				let vA = null, vB = null;
				let curr = null, next = null;
				let fading = false;
				let started = false;

				function mkVideo(initialSrc) {
					const v = document.createElement('video');
					v.muted = true;
					v.playsInline = true;
					v.loop = true;
					v.preload = 'none';
					v.setAttribute('aria-hidden', 'true');
					v.style.cssText = VIDEO_STYLE;
					if (initialSrc) v.src = initialSrc;
					return v;
				}

				function startVideos() {
					if (started) return;
					started = true;
					vA = mkVideo(dataHeroSrc || heroVideos[0].url);
					vB = mkVideo('');
					heroSection.insertBefore(vA, slot);
					heroSection.insertBefore(vB, slot);
					slot.remove();
					curr = vA; next = vB;
					vA.load();
					vA.playbackRate = PLAYBACK_RATE;
					vA.play().then(() => {
						vA.style.opacity = '1';
						// Fully retire the poster so it can never reappear over the loop.
						if (poster) { setTimeout(() => { poster.style.opacity = '0'; }, 300); setTimeout(() => poster.remove(), 2000); }
						next.src = heroVideos[1].url;
						next.load();
						// Fixed 7s-per-clip rotation, then repeats through the array.
						setInterval(beginCrossfade, CLIP_DURATION);
						// Resilience: if the visible clip ever pauses (power-saving, tab
						// blur, stall), resume it so the hero never freezes on a still frame.
						setInterval(() => { if (curr && curr.paused && !fading) curr.play().catch(() => {}); }, 1000);
						document.addEventListener('visibilitychange', () => {
							if (!document.hidden && curr && !fading) curr.play().catch(() => {});
						});
					}).catch(() => { /* autoplay blocked — poster remains */ });
				}

				const triggers = ['scroll', 'pointerdown', 'keydown', 'touchstart', 'mousemove'];
				function kickoff() {
					triggers.forEach(e => window.removeEventListener(e, kickoff));
					startVideos();
				}
				triggers.forEach(e => window.addEventListener(e, kickoff, { once: true, passive: true }));
				setTimeout(() => { if (!started) startVideos(); }, 10000);
					// Returning via back/forward (bfcache restore): resume/restart the loop
					// instead of leaving the still poster showing.
					window.addEventListener('pageshow', (e) => {
						if (!e.persisted) return;
						if (!started) startVideos();
						else if (curr && curr.paused && !fading) curr.play().catch(() => {});
					});

				function beginCrossfade() {
					if (fading) return;
					fading = true;
					heroIdx = (heroIdx + 1) % heroVideos.length;
					applyTheme(heroVideos[heroIdx].theme);
					next.play().then(() => {
						next.playbackRate = PLAYBACK_RATE;
						next.style.opacity = '1';
						curr.style.opacity = '0';
						const outgoing = curr;
						curr = next;
						next = outgoing;
						setTimeout(() => {
							next.pause();
							next.currentTime = 0;
							const preloadIdx = (heroIdx + 1) % heroVideos.length;
							next.src = heroVideos[preloadIdx].url;
							next.load();
							fading = false;
						}, FADE_DURATION + 200);
					}).catch(() => {
						curr.currentTime = 0;
						curr.play();
						fading = false;
					});
				}
			}
			} // end mobile-bail-out else
		</script>

		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 4 — BIG IDEA (moved directly under the hero)
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="soft">
			<div class="text-center max-w-2xl mx-auto">
				<h2
					class="text-4xl md:text-5xl font-light mb-6"
					style="font-family: var(--font-serif); color: var(--color-ink);"
				>
					The destination has always been the Father.
				</h2>
				<p
					class="text-lg leading-relaxed mb-6"
					style="font-family: var(--font-sans); color: var(--color-muted);"
				>
					Many believers have read the Bible faithfully and yet related to God
					more as a servant to a master than as a beloved son or daughter to a loving Father. That
					distance is not always obvious at first. It can hide beneath sincere devotion, sound
					doctrine, years of ministry, and disciplined prayer.
				</p>
				<p
					class="text-lg leading-relaxed"
					style="font-family: var(--font-sans); color: var(--color-muted);"
				>
					The message of Scripture has always been moving toward something deeper. Not merely
					forgiveness. Not merely heaven. Not merely religious correctness. The destination has
					always been the Father.
				</p>
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION — WHO THIS IS FOR / IS THIS FOR YOU?
		     (moved from /the-fathers-heart-bible, sits under the Big Idea)
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="light">
			<div class="text-center mb-12">
				<p
					class="text-xs font-semibold tracking-widest uppercase mb-3"
					style="font-family: var(--font-sans); color: var(--color-gold);"
				>
					Is This For You?
				</p>
				<h2
					class="text-3xl md:text-4xl font-light"
					style="font-family: var(--font-serif); color: var(--color-ink);"
				>
					This Bible was written for you — if you recognize yourself here.
				</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl mx-auto">
				{audience.map((statement) => (
					<div
						class="flex gap-4 items-start p-5"
						style="background-color: var(--color-soft); border: 1px solid var(--color-hairline);"
					>
						<div class="mt-1.5 w-1.5 h-1.5 rounded-full shrink-0" style="background-color: var(--color-gold);"></div>
						<p class="text-sm leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">{statement}</p>
					</div>
				))}
			</div>
		</Section>


		<!-- ═══════════════════════════════════════════════════════════
		     SECTION 2 — WHAT IS FHB
		     ═══════════════════════════════════════════════════════════ -->
		<Section variant="soft">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">
				<!-- Book image -->
				<div class="order-1 md:order-2 flex justify-center" data-reveal="slide-right">
					{bookCoverUrl ? (
						<img
							src={bookCoverUrl}
							srcset={bookCoverSrcset}
							sizes={bookCoverSizes}
							alt="The Father's Heart Bible — brown cover"
							class="w-64 md:w-80 block"
							loading="lazy"
							decoding="async"
							width="512"
							height="768"
							style="filter: drop-shadow(0 12px 28px rgba(0,0,0,0.22));"
						/>
					) : (
						<div
							class="w-64 md:w-80 aspect-[2/3] flex items-end justify-center p-6"
							style="background-color: var(--color-brand);"
						>
							<p
								class="text-center text-lg font-light italic"
								style="font-family: var(--font-serif); color: rgba(255,255,255,0.9);"
							>
								The Father's Heart Bible™
							</p>
						</div>
					)}
				</div>

				<!-- Content -->
				<div class="order-2 md:order-1" data-reveal="slide-left">
					<p
						class="text-xs font-semibold tracking-widest uppercase mb-4"
						style="font-family: var(--font-sans); color: var(--color-gold);"
					>
						What Is the Father's Heart Bible™?
					</p>
					<h2
						class="text-3xl md:text-4xl font-light leading-tight mb-6"
