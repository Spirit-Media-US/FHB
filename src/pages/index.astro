---
import { sanityClient, urlFor } from '../lib/sanity';
import Layout from '../layouts/Layout.astro';

// Fetch siteSettings from Sanity
const siteSettings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    siteName,
    heroHeadline,
    heroSubtext,
    tagline,
    heroImage,
    logo
  }
`);

const {
  siteName = "Fathers Heart Bible",
  heroHeadline = "Revealing Our Father's Heart",
  heroSubtext = "The Father's Heart Bible is a new interpretive English translation that faithfully renders the original texts while revealing God's identity as Father — and His heart toward His children — throughout Scripture.",
  tagline = "A New Bible Translation",
  heroImage,
  logo
} = siteSettings || {};
---

<Layout title={siteName}>
  <main class="min-h-screen flex flex-col">
    <!-- Hero Section -->
    <section class="relative h-screen flex items-center justify-center overflow-hidden bg-gradient-to-b from-blue-900 to-blue-800">
      {heroImage && (
        <img
          src={urlFor(heroImage).url()}
          alt="Hero Background"
          class="absolute inset-0 w-full h-full object-cover opacity-30"
        />
      )}
      <div class="relative z-10 text-center text-white px-4">
        {logo && (
          <img
            src={urlFor(logo).url()}
            alt="Fathers Heart Bible Logo"
            class="h-24 mx-auto mb-8"
          />
        )}
        <h1 class="text-5xl md:text-6xl font-bold mb-4">{heroHeadline}</h1>
        <p class="text-2xl md:text-3xl mb-6 text-blue-100">{tagline}</p>
        <p class="text-lg max-w-2xl mx-auto text-blue-50">{heroSubtext}</p>
      </div>
    </section>

    <!-- About Section -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-8 text-gray-900">Our Mission</h2>
        <p class="text-lg text-gray-700 leading-relaxed">
          We are committed to bringing people closer to God's Word through deep study, authentic community, and transformative biblical teaching.
        </p>
      </div>
    </section>
  </main>
</Layout>
