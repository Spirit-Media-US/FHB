---
import BlogCTA from '../../../components/BlogCTA.astro';
import ChapterEmbed from '../../../components/ChapterEmbed.astro';
import Footer from '../../../components/Footer.astro';
import Navbar from '../../../components/Navbar.astro';
import ShareBar from '../../../components/ShareBar.astro';
import Layout from '../../../layouts/Layout.astro';
import { previewClient, urlFor } from '../../../lib/sanity';

// Dev-only route. Generates pages only when PUBLIC_PREVIEW_DRAFTS=1 is set
// at build time (deploy-preview.sh sets it on the dev branch). Production
// builds (deploy-live.sh) don't set it, so getStaticPaths returns [] and
// no preview pages are emitted into dist/.
export async function getStaticPaths() {
	if (import.meta.env.PUBLIC_PREVIEW_DRAFTS !== '1') return [];
	const posts = await previewClient.fetch(
		`*[_type == "blogPost" && defined(slug.current)] { "slug": slug.current }`,
	);
	return posts.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;

const post = await previewClient.fetch(
	`*[_type == "blogPost" && slug.current == $slug][0]`,
	{ slug },
);

if (!post) {
	return Astro.redirect('/blog');
}

function renderPortableText(blocks: any[]): string {
	if (!Array.isArray(blocks)) return '';

	return blocks
		.map((block: any) => {
			if (!block || block._type !== 'block') return '';

			const children = Array.isArray(block.children) ? block.children : [];
			const rawText = children.map((c: any) => c?.text || '').join('');
			if (/^\{[\w]+\}\s*[—–-]\s*\{[\w]+\}$/.test(rawText.trim())) return '';

			const textContent = children
				.map((child: any) => {
					if (!child) return '';
					let text = child.text || '';
					const marks = Array.isArray(child.marks) ? child.marks : [];
					if (marks.length > 0) {
						if (marks.includes('strong')) text = `<strong>${text}</strong>`;
						if (marks.includes('em')) text = `<em>${text}</em>`;
						const linkMark = marks.find(
							(m: any) => m && typeof m === 'object' && m._type === 'link',
						);
						if (linkMark?.href) {
							text = `<a href="${linkMark.href}" style="color: var(--color-brand);" class="hover:underline" target="_blank" rel="noopener noreferrer">${text}</a>`;
						}
					}
					return text;
				})
				.join('');

			const style = block.style || 'normal';
			if (style === 'h2')
				return `<h2 class="text-2xl font-bold mt-12 mb-4" style="font-family: var(--font-serif); color: var(--color-ink);">${textContent}</h2>`;
			if (style === 'h3')
				return `<h3 class="text-xl font-bold mt-8 mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">${textContent}</h3>`;
			// Blockquote = inline FHB verse quote. Pink card matching the
			// chapter-embed palette so FHB renderings always read FHB-pink.
			if (style === 'blockquote')
				return `<blockquote class="my-6 px-6 py-5 lg:px-8 rounded-2xl text-lg leading-relaxed" style="background-color: #fdf2f5; border: 1px solid #f9d6e0; font-family: var(--font-serif); color: var(--color-ink);">${textContent}</blockquote>`;
			return `<p class="text-lg leading-relaxed mb-4" style="font-family: var(--font-sans); color: var(--color-muted);">${textContent}</p>`;
		})
		.join('');
}

const formatDate = (dateString: string) => {
	if (!dateString) return 'Draft';
	const date = new Date(dateString);
	return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};

const publishDate = formatDate(post.publishDate);
const heroImage = post.heroImage
	? urlFor(post.heroImage).width(1200).format('webp').url()
	: '/fhb-logo.png';
const author = post.author || 'Kevin White';
const tags = post.tags || [];

type BodySegment =
	| { kind: 'html'; html: string }
	| { kind: 'chapter'; book: string; chapter: number };

function segmentBody(blocks: any[]): BodySegment[] {
	const segments: BodySegment[] = [];
	let buf: any[] = [];
	const flush = () => {
		if (buf.length) {
			segments.push({ kind: 'html', html: renderPortableText(buf) });
			buf = [];
		}
	};
	for (const b of blocks || []) {
		if (b?._type === 'fhbChapter') {
			flush();
			segments.push({ kind: 'chapter', book: b.book, chapter: b.chapter });
		} else {
			buf.push(b);
		}
	}
	flush();
	return segments;
}

const bodySegments = segmentBody(post.body || []);
---

<Layout
  title={`[DRAFT] ${post.title} | Father's Heart Bible Blog`}
  description={post.seoDescription || post.excerpt || "Draft preview."}
  image={heroImage}
  noindex={true}
>
  <Navbar />

  <main id="main-content">
    <!-- DRAFT BANNER -->
    <div style="background-color: #fef3c7; border-bottom: 1px solid #f59e0b; padding: 0.75rem 1.5rem; margin-top: 80px; text-align: center; font-family: var(--font-sans); font-size: 0.875rem; color: #92400e;">
      <strong>DRAFT PREVIEW</strong> — This post is a Sanity draft, not published. Visible on dev preview only.
    </div>

    <!-- HERO IMAGE -->
    <div class="w-full">
      <img src={heroImage} alt={post.heroImage?.alt || post.title} class="w-full h-72 lg:h-[600px] object-cover" style="object-position: center top;" />
    </div>

    <!-- POST HEADER -->
    <section class="px-6 pt-10 pb-2 lg:px-8" style="background-color: var(--color-surface-low);">
      <div class="mx-auto max-w-3xl">
        <a href="/blog/" class="inline-flex items-center gap-1.5 text-sm font-semibold hover:opacity-80 transition-opacity mb-5 no-underline" style="color: var(--color-brand);">&larr; Back to Blog</a>
        <h1 class="text-4xl md:text-5xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{post.title}</h1>
        {post.excerpt && <p class="mt-3 text-lg leading-relaxed max-w-2xl" style="font-family: var(--font-sans); color: var(--color-muted);">{post.excerpt}</p>}
        <div class="flex items-center gap-3 mt-4 pb-8 text-sm border-b" style="color: var(--color-muted); font-family: var(--font-sans); border-color: var(--color-hairline);">
          <span>By <span class="font-semibold" style="color: var(--color-ink);">{author}</span></span>
          <span>&middot;</span>
          <span>{publishDate}</span>
        </div>
      </div>
    </section>

    <!-- TAGS -->
    {tags.length > 0 && (
      <section class="px-6 pb-6 lg:px-8 border-b" style="background-color: var(--color-surface-low); border-color: var(--color-hairline);">
        <div class="mx-auto max-w-3xl">
          <div class="flex flex-wrap gap-2">
            {tags.map((tag: string) => (
              <span class="text-xs font-semibold rounded-full px-3 py-1" style="color: var(--color-muted); background-color: var(--color-surface);">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- POST CONTENT -->
    <section class="px-6 py-10 lg:px-8 lg:py-16" style="background-color: var(--color-surface);">
      <div class="mx-auto max-w-3xl space-y-4">
        {bodySegments.map((seg) =>
          seg.kind === 'chapter'
            ? <ChapterEmbed book={seg.book} chapter={seg.chapter} />
            : <div set:html={seg.html} />
        )}
        <BlogCTA />
      </div>
    </section>

    <!-- SHARE BAR (disabled in preview — links would 404) -->
    <ShareBar title={post.title} url={`https://fathersheartbible.com/blog/${post.slug?.current || slug}`} />
  </main>

  <Footer />
</Layout>
