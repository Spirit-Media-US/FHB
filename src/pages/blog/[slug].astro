---
import AuthorBio from '../../components/AuthorBio.astro';
import BlogCTA from '../../components/BlogCTA.astro';
import ChapterEmbed from '../../components/ChapterEmbed.astro';
import FeatureChapter from '../../components/FeatureChapter.astro';
import HowToHubCards from '../../components/HowToHubCards.astro';
import PullQuote from '../../components/PullQuote.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import ShareBar from '../../components/ShareBar.astro';
import Layout from '../../layouts/Layout.astro';
import { sanityClient, urlFor } from '../../lib/sanity';

export async function getStaticPaths() {
	const posts = await sanityClient.fetch(`*[_type == "blogPost"] { "slug": slug.current }`);
	return posts.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;

const post = await sanityClient.fetch(`*[_type == "blogPost" && slug.current == $slug][0]`, {
	slug,
});

if (!post) {
	return Astro.redirect('/blog');
}

// Slugify heading text for jump-link anchors. Lowercases, strips punctuation,
// collapses whitespace to single hyphens. Keep this in sync with preview/[slug].astro.
function slugifyHeading(s: string): string {
	return s
		.toLowerCase()
		.replace(/[‘’“”]/g, '')
		.replace(/[^\w\s-]/g, '')
		.trim()
		.replace(/\s+/g, '-');
}

function renderPortableText(blocks: any[]): string {
	if (!Array.isArray(blocks)) return '';
	let html = '';
	let listType: string | null = null;
	const closeList = () => {
		if (listType) {
			html += listType === 'number' ? '</ol>' : '</ul>';
			listType = null;
		}
	};
	for (const block of blocks) {
		if (!block || block._type !== 'block') continue;
		const children = Array.isArray(block.children) ? block.children : [];
		const rawText = children.map((c: any) => c?.text || '').join('');
		if (/^\{[\w]+\}\s*[—–-]\s*\{[\w]+\}$/.test(rawText.trim())) continue;
		const markDefs = Array.isArray(block.markDefs) ? block.markDefs : [];
		const linkByKey: Record<string, string> = {};
		for (const md of markDefs) {
			if (md && md._type === 'link' && md._key && md.href) linkByKey[md._key] = md.href;
		}
		const textContent = children
			.map((child: any) => {
				if (!child) return '';
				let text = child.text || '';
				const marks = Array.isArray(child.marks) ? child.marks : [];
				if (marks.length > 0) {
					if (marks.includes('strong')) text = `<strong>${text}</strong>`;
					if (marks.includes('em')) text = `<em>${text}</em>`;
					const linkKey = marks.find((m: any) => typeof m === 'string' && linkByKey[m]);
					if (linkKey) {
						const href = linkByKey[linkKey];
						const isExternal = /^https?:\/\//i.test(href);
						const targetAttrs = isExternal ? ' target="_blank" rel="noopener noreferrer"' : '';
						text = `<a href="${href}" style="color: var(--color-brand);" class="hover:underline"${targetAttrs}>${text}</a>`;
					}
				}
				return text;
			})
			.join('');
		const listItem = block.listItem;
		if (listItem === 'bullet' || listItem === 'number') {
			if (listType && listType !== listItem) closeList();
			if (!listType) {
				listType = listItem;
				html +=
					listItem === 'number'
						? '<ol class="list-decimal pl-7 my-6 space-y-2 text-lg leading-relaxed" style="font-family: var(--font-serif); color: var(--color-ink);">'
						: '<ul class="list-disc pl-7 my-6 space-y-2 text-lg leading-relaxed" style="font-family: var(--font-serif); color: var(--color-ink);">';
			}
			html += `<li>${textContent}</li>`;
			continue;
		}
		closeList();
		const style = block.style || 'normal';
		if (style === 'h2') {
			const id = slugifyHeading(rawText);
			html += `<h2 id="${id}" class="text-2xl font-bold mt-12 mb-4 scroll-mt-24" style="font-family: var(--font-serif); color: var(--color-ink);">${textContent}</h2>`;
		} else if (style === 'h3') {
			html += `<h3 class="text-xl font-bold mt-8 mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">${textContent}</h3>`;
		} else if (style === 'blockquote') {
			html += `<blockquote class="my-6 px-6 py-5 lg:px-8 rounded-2xl text-lg leading-relaxed" style="background-color: #fdf2f5; border: 1px solid #f9d6e0; font-family: var(--font-serif); color: var(--color-ink);">${textContent}</blockquote>`;
		} else {
			html += `<p class="text-lg leading-relaxed mb-4" style="font-family: var(--font-sans); color: var(--color-muted);">${textContent}</p>`;
		}
	}
	closeList();
	return html;
}

const formatDate = (dateString: string) => {
	const date = new Date(dateString);
	return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};

const publishDate = formatDate(post.publishDate);
const modifiedDate =
	post.dateModified && post.dateModified.slice(0, 10) !== post.publishDate
		? formatDate(post.dateModified)
		: null;
const heroImage = post.heroImage
	? urlFor(post.heroImage).width(1200).format('webp').url()
	: '/fhb-logo.png';
const author = post.author || 'Kevin White';
const tags = post.tags || [];

// Body is rendered block-by-block so we can interleave custom block types
// (currently `fhbChapter` → <ChapterEmbed>). Runs of regular `block` items
// are batched into single HTML fragments to preserve normal portable-text
// behavior; `fhbChapter` items break the run and render the component.
// A `fhbChapter` block renders the older text-only <ChapterEmbed> by default.
// When the block carries an optional `slug` (the reader url slug, e.g. "john"),
// it upgrades to <FeatureChapter> — real reader text + working audio + an
// "Open <ref> in the reader" link, matching the guide pages. Old posts have no
// slug, so they keep their current ChapterEmbed rendering untouched.
type BodySegment =
	| { kind: 'html'; html: string }
	| { kind: 'chapter'; book: string; chapter: number; slug?: string; verseLimit?: number }
	| { kind: 'image'; src: string; alt: string; caption?: string }
	| { kind: 'pullquote'; quote: string; attribution?: string };

function segmentBody(blocks: any[]): BodySegment[] {
	const segments: BodySegment[] = [];
	let buf: any[] = [];
	const flush = () => {
		if (buf.length) {
			segments.push({ kind: 'html', html: renderPortableText(buf) });
			buf = [];
		}
	};
	for (const b of blocks || []) {
		if (b?._type === 'fhbChapter') {
			flush();
			segments.push({
				kind: 'chapter',
				book: b.book,
				chapter: b.chapter,
				slug: b.slug,
				verseLimit: b.verseLimit,
			});
		} else if (b?._type === 'image' && b?.asset) {
			flush();
			const src = urlFor(b).width(1000).format('webp').url();
			segments.push({ kind: 'image', src, alt: b.alt || '', caption: b.caption });
		} else if (b?._type === 'pullQuote') {
			flush();
			segments.push({ kind: 'pullquote', quote: b.quote || '', attribution: b.attribution });
		} else {
			buf.push(b);
		}
	}
	flush();
	return segments;
}

const bodySegments = segmentBody(post.body || []);

// Kevin White's author entity, with sameAs links to his real-world properties.
// Inlined as a Person schema on every blog post so AI engines / search crawlers
// can resolve "Kevin White" as the same author across the web (E-E-A-T signal).
const KEVIN_WHITE_AUTHOR = {
	'@type': 'Person',
	'@id': 'https://kevinwhite.us/#person',
	name: 'Kevin White',
	url: 'https://kevinwhite.us',
	jobTitle: "Lead Translator, Father's Heart Bible | CEO, Spirit Media Publishing",
	affiliation: {
		'@type': 'Organization',
		'@id': 'https://spiritmediapublishing.com/#organization',
		name: 'Spirit Media Publishing',
	},
	sameAs: [
		'https://kevinwhite.us',
		'https://kevinwhite.us/about/',
		'https://www.linkedin.com/in/kevinwhiteus/',
		'https://www.youtube.com/@KevinWhiteus',
		'https://www.amazon.com/Fathers-Heart-Beloved-Identity-Heavenly-ebook/dp/B0GQJQLMTC',
		'https://spiritmediapublishing.com',
	],
};

const postUrl = `https://fathersheartbible.com/blog/${post.slug.current}`;

// Normalize dateModified — accept full ISO datetime or fall back to publishDate.
const dateModified = post.dateModified || post.publishDate;

const blogPostingSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: post.title,
	description: post.excerpt || post.seoDescription || post.title,
	image: heroImage,
	author: KEVIN_WHITE_AUTHOR,
	publisher: {
		'@type': 'Organization',
		'@id': 'https://spiritmediapublishing.com/#organization',
		name: 'Spirit Media Publishing',
		url: 'https://spiritmediapublishing.com',
	},
	url: postUrl,
	mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
	datePublished: post.publishDate,
	dateModified,
	inLanguage: 'en-US',
	isPartOf: {
		'@type': 'Blog',
		'@id': 'https://fathersheartbible.com/blog/#blog',
		name: "Father's Heart Bible Blog",
		url: 'https://fathersheartbible.com/blog/',
	},
	keywords: tags.join(', '),
	articleSection: tags[0] || undefined,
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://fathersheartbible.com/' },
		{ '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://fathersheartbible.com/blog/' },
		{ '@type': 'ListItem', position: 3, name: post.title, item: postUrl },
	],
};

// FAQPage schema — only emitted when the post defines FAQ pairs in Sanity.
// Each H2 Q&A in the SMP Gold-Level structure is a natural FAQ item; AI
// engines (AI Overviews, Perplexity) extract these verbatim.
const faqs = Array.isArray(post.faqs) ? post.faqs : [];
const faqSchema =
	faqs.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'FAQPage',
				mainEntity: faqs
					.filter((f: any) => f?.question && f?.answer)
					.map((f: any) => ({
						'@type': 'Question',
						name: f.question,
						acceptedAnswer: { '@type': 'Answer', text: f.answer },
					})),
			}
		: null;

const jsonLd = [blogPostingSchema, breadcrumbSchema, faqSchema].filter(Boolean);
---

<Layout
  title={post.seoTitle || `${post.title} | Father's Heart Bible Blog`}
  description={post.seoDescription || post.excerpt || "Read this article on the Father's Heart Bible blog."}
  image={heroImage}
  jsonLd={jsonLd}
  darkHero={true}
  pageType="article"
  articleAuthor={author}
  articlePublishedTime={post.publishDate}
  articleSection={tags[0]}
  articleTags={tags}
>

  <main id="main-content">
    <!-- HERO IMAGE — full-bleed, starts at top behind the transparent nav (matches homepage/guides) -->
    <div class="relative w-full overflow-hidden h-72 lg:h-[600px]">
      <img src={heroImage} alt={post.heroImage?.alt || post.title} class="absolute inset-0 w-full h-full object-cover" style="object-position: center center;" fetchpriority="high" decoding="async" />
      <div class="absolute inset-x-0 top-0 z-10" style="height: 160px; background: linear-gradient(to bottom, rgba(0,0,0,0.45), rgba(0,0,0,0));"></div>
    </div>

    <!-- POST HEADER -->
    <section class="px-6 pt-10 pb-2 lg:px-8" style="background-color: var(--color-surface-low);">
      <div class="mx-auto max-w-3xl">
        <a href="/blog/" class="inline-flex items-center gap-1.5 text-sm font-semibold hover:opacity-80 transition-opacity mb-5 no-underline" style="color: var(--color-brand);">&larr; Back to Blog</a>
        <h1 class="text-4xl md:text-5xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">{post.title}</h1>
        {post.excerpt && <p class="mt-3 text-lg leading-relaxed max-w-2xl" style="font-family: var(--font-sans); color: var(--color-muted);">{post.excerpt}</p>}
        <div class="flex items-center gap-3 mt-4 pb-8 text-sm border-b flex-wrap" style="color: var(--color-muted); font-family: var(--font-sans); border-color: var(--color-hairline);">
          <span>By <span class="font-semibold" style="color: var(--color-ink);">{author}</span></span>
          <span>&middot;</span>
          <span>{publishDate}</span>
          {modifiedDate && (
            <>
              <span>&middot;</span>
              <span>Updated {modifiedDate}</span>
            </>
          )}
        </div>
      </div>
    </section>

    <!-- TAGS -->
    {tags.length > 0 && (
      <section class="px-6 pb-6 lg:px-8 border-b" style="background-color: var(--color-surface-low); border-color: var(--color-hairline);">
        <div class="mx-auto max-w-3xl">
          <div class="flex flex-wrap gap-2">
            {tags.map((tag: string) => (
              <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="text-xs font-semibold rounded-full px-3 py-1 transition-colors no-underline" style="color: var(--color-muted); background-color: var(--color-surface);">
                {tag}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- POST CONTENT -->
    <section class="px-6 py-10 lg:px-8 lg:py-16" style="background-color: var(--color-surface);">
      <div class="mx-auto max-w-3xl space-y-4">
        {bodySegments.map((seg) =>
          seg.kind === 'chapter'
            ? (seg.slug
                ? <FeatureChapter book={seg.book} slug={seg.slug} chapter={seg.chapter} verseLimit={seg.verseLimit} playable={true} />
                : <ChapterEmbed book={seg.book} chapter={seg.chapter} />)
            : seg.kind === 'image'
              ? <figure class="my-8">
                  <img src={seg.src} alt={seg.alt} class="w-full max-w-md mx-auto rounded-lg shadow-sm" loading="lazy" decoding="async" />
                  {seg.caption && <figcaption class="mt-3 text-center text-sm" style="color: var(--color-muted); font-family: var(--font-sans);">{seg.caption}</figcaption>}
                </figure>
              : seg.kind === 'pullquote'
                ? <PullQuote quote={seg.quote} attribution={seg.attribution} />
                : <div set:html={seg.html} />
        )}
        <BlogCTA />
      </div>
    </section>

    <!-- SHARE BAR -->
    <AuthorBio author={author} />

    <ShareBar title={post.title} url={`https://fathersheartbible.com/blog/${post.slug.current}`} />

    <!-- RELATED POSTS -->
    <RelatedPosts currentSlug={`/blog/${post.slug.current}`} currentTags={tags} />

    <!-- HOW-TO HUB — cross-link the guide cluster from every blog post -->
    <HowToHubCards heading="Bible Reading Guides" />
  </main>

</Layout>
