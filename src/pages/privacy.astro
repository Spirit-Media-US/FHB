---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import Section from '../components/Section.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Privacy Policy | Father's Heart Bible"
  description="How the Father's Heart Bible website handles the information you share — cookies, analytics, third-party services, and your rights over your data."
  noindex={true}
>
  <Navbar />

  <main id="main-content" style="margin-top: 80px;">
    <Section variant="soft">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-light mb-8" style="font-family: var(--font-serif); color: var(--color-ink);">Privacy Policy</h1>
        <p class="text-sm mb-8" style="color: var(--color-muted); font-family: var(--font-sans);">Last updated: April 2026</p>

        <div class="space-y-8" style="font-family: var(--font-sans); color: var(--color-muted);">
          <div>
            <h2 class="text-xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">Who We Are</h2>
            <p class="leading-relaxed">This website is operated by Spirit Media Inc. on behalf of the Father's Heart Bible project. Our website address is https://fathersheartbible.com.</p>
          </div>

          <div>
            <h2 class="text-xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">Information We Collect</h2>
            <p class="leading-relaxed mb-3">We may collect the following types of information:</p>
            <ul class="list-disc pl-6 space-y-2 leading-relaxed">
              <li><strong>Contact information</strong> — such as your name and email address, when you voluntarily submit a form on our site (e.g., to download the free book or join the movement).</li>
              <li><strong>Usage data</strong> — such as pages visited, time spent, and referring URLs, collected automatically through Google Analytics and similar tools.</li>
              <li><strong>Cookies</strong> — we use cookies for analytics and to improve your experience. You can disable cookies in your browser settings.</li>
            </ul>
          </div>

          <div>
            <h2 class="text-xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">How We Use Your Information</h2>
            <ul class="list-disc pl-6 space-y-2 leading-relaxed">
              <li>To deliver content and resources you request (e.g., the free book download).</li>
              <li>To send occasional updates about the Father's Heart Bible project, if you have opted in.</li>
              <li>To understand how visitors use our site so we can improve it.</li>
            </ul>
          </div>

          <div>
            <h2 class="text-xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">Third-Party Services</h2>
            <p class="leading-relaxed">We use the following third-party services that may collect data:</p>
            <ul class="list-disc pl-6 space-y-2 leading-relaxed">
              <li><strong>Google Analytics</strong> — for website usage analytics.</li>
              <li><strong>Givebutter</strong> — for processing donations. Givebutter has its own privacy policy.</li>
              <li><strong>Sanity</strong> — for content management (does not collect visitor data).</li>
            </ul>
          </div>

          <div>
            <h2 class="text-xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">Your Rights</h2>
            <p class="leading-relaxed">You may request access to, correction of, or deletion of your personal data at any time by contacting us at hello@fathersheartbible.com.</p>
          </div>

          <div>
            <h2 class="text-xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">Contact</h2>
            <p class="leading-relaxed">If you have questions about this privacy policy, please email us at hello@fathersheartbible.com.</p>
          </div>
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</Layout>
