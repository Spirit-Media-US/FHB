---
import fs from 'node:fs';
import path from 'node:path';
import Footer from '../../../components/Footer.astro';
import Navbar from '../../../components/Navbar.astro';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
	const MANIFEST_PATH = path.resolve(process.cwd(), 'src/content/bible/_manifest.json');
	if (!fs.existsSync(MANIFEST_PATH)) return [];
	const manifest = JSON.parse(fs.readFileSync(MANIFEST_PATH, 'utf8'));
	return Object.values(manifest.books || {}).map((b: any) => ({
		params: { book: b.slug },
		props: {
			book: b.book,
			slug: b.slug,
			testament: b.testament,
			totalChapters: b.totalChapters,
			lockedChapters: b.lockedChapters,
		},
	}));
}

const { book, slug, testament, totalChapters, lockedChapters } = Astro.props;
const seoTitle = `${book} — Father's Heart Bible`;
const seoDescription = `Read ${book} in the Father's Heart Bible — a new translation that reveals our Father's heart through every chapter.`;
---

<Layout title={seoTitle} description={seoDescription}>
	<Navbar />

	<main id="main-content" class="pt-32 pb-20">
		<section class="max-w-3xl mx-auto px-6">
			<nav class="text-sm mb-6">
				<a href="/read/" class="text-[var(--color-muted)] no-underline hover:text-[var(--color-primary)]">← All books</a>
			</nav>

			<header class="text-center mb-10">
				<p class="text-xs uppercase tracking-[0.18em] text-[var(--color-muted)] font-semibold">
					{testament === 'OT' ? 'Old Testament' : 'New Testament'}
				</p>
				<h1 class="font-serif text-4xl md:text-5xl font-bold text-[var(--color-ink)] mt-2">{book}</h1>
				<p class="mt-3 text-sm text-[var(--color-muted)]">
					{lockedChapters.length} of {totalChapters} chapters locked
				</p>
			</header>

			<div class="grid grid-cols-5 sm:grid-cols-7 md:grid-cols-10 gap-2">
				{Array.from({ length: totalChapters }, (_, i) => i + 1).map((n: number) => {
					const isLocked = lockedChapters.includes(n);
					return isLocked ? (
						<a
							href={`/read/${slug}/${n}/`}
							class="aspect-square flex items-center justify-center rounded-lg border border-[var(--color-hairline)] bg-white text-[var(--color-ink)] font-semibold no-underline hover:bg-[var(--color-primary)] hover:text-white hover:border-[var(--color-primary)] transition-colors"
						>
							{n}
						</a>
					) : (
						<span
							class="aspect-square flex items-center justify-center rounded-lg border border-dashed border-[var(--color-hairline)] text-[var(--color-muted)] text-sm bg-[var(--color-soft)] cursor-not-allowed"
							aria-label={`${book} ${n} not yet released`}
							title="Coming soon"
						>
							{n}
						</span>
					);
				})}
			</div>
		</section>
	</main>

	<Footer />
</Layout>
