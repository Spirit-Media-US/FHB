---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import Section from '../components/Section.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Terms of Use | Father's Heart Bible"
  description="Terms of use for fathersheartbible.com — covering intellectual property, the free PDF download, donations through Givebutter, and acceptable use."
  noindex={true}
>
  <Navbar />

  <main id="main-content" style="margin-top: 80px;">
    <Section variant="soft">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-light mb-8" style="font-family: var(--font-serif); color: var(--color-ink);">Terms of Use</h1>
        <p class="text-sm mb-8" style="color: var(--color-muted); font-family: var(--font-sans);">Last updated: April 2026</p>

        <div class="space-y-8" style="font-family: var(--font-sans); color: var(--color-muted);">
          <div>
            <h2 class="text-xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">Acceptance of Terms</h2>
            <p class="leading-relaxed">By accessing and using fathersheartbible.com, you agree to be bound by these terms. If you do not agree, please do not use this website.</p>
          </div>

          <div>
            <h2 class="text-xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">Intellectual Property</h2>
            <p class="leading-relaxed">All content on this website — including text, images, logos, and the Father's Heart Bible translation — is the property of Spirit Media Inc. and is protected by copyright law. You may not reproduce, distribute, or create derivative works from this content without written permission, except for personal, non-commercial use.</p>
          </div>

          <div>
            <h2 class="text-xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">Free Book Download</h2>
            <p class="leading-relaxed">The free PDF download of "Father's Heart → Beloved Identity" is provided for personal use. You may share the download link but may not host, redistribute, or modify the PDF itself.</p>
          </div>

          <div>
            <h2 class="text-xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">Donations</h2>
            <p class="leading-relaxed">Donations made through our website are processed by Givebutter, a third-party platform. All donations are voluntary and non-refundable unless otherwise required by law. Spirit Media Inc. is a registered organization.</p>
          </div>

          <div>
            <h2 class="text-xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">Disclaimer</h2>
            <p class="leading-relaxed">This website is provided "as is" without warranties of any kind. We make no guarantees regarding the accuracy, completeness, or availability of the site or its content.</p>
          </div>

          <div>
            <h2 class="text-xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">Changes to These Terms</h2>
            <p class="leading-relaxed">We may update these terms from time to time. Continued use of the site after changes are posted constitutes acceptance of the updated terms.</p>
          </div>

          <div>
            <h2 class="text-xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-ink);">Contact</h2>
            <p class="leading-relaxed">Questions about these terms? Email us at hello@fathersheartbible.com.</p>
          </div>
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</Layout>
