---
import Section from '../components/Section.astro';
import Layout from '../layouts/Layout.astro';

// 20 cumulative unlocks — donor goal mapped to language + reach.
// Flag emojis chosen for the most populous nation in each language family
// so the visual feels concrete. Two India-spoken languages (Marathi, Telugu,
// Tamil) all share the India flag intentionally — same nation, distinct
// language groups inside it.
interface UnlockRow {
	dollar: string;
	language: string;
	flag: string; // emoji
	parenthetical?: string;
	reach: string;
	highlight?: boolean; // for the launch row + the final row
}

const unlocks: UnlockRow[] = [
	{
		dollar: '$100K',
		language: 'Base English First Edition launch — 20,000 Bibles + audio',
		flag: '🇺🇸',
		reach: '1.5B',
		highlight: true,
	},
	{
		dollar: '$150K',
		language: 'Spanish',
		flag: '🇪🇸',
		parenthetical: '550M speakers',
		reach: '2.05B',
	},
	{
		dollar: '$200K',
		language: 'Portuguese',
		flag: '🇧🇷',
		parenthetical: '257M — Brazil + Lusophone Africa',
		reach: '2.31B',
	},
	{
		dollar: '$250K',
		language: 'French',
		flag: '🇫🇷',
		parenthetical: '280M — includes Francophone Africa',
		reach: '2.59B',
	},
	{
		dollar: '$300K',
		language: 'Hindi',
		flag: '🇮🇳',
		parenthetical: "600M — India's growing church",
		reach: '3.19B',
	},
	{
		dollar: '$350K',
		language: 'Arabic',
		flag: '🇪🇬',
		parenthetical: '274M — Middle East + N. Africa',
		reach: '3.46B',
	},
	{
		dollar: '$400K',
		language: 'Mandarin',
		flag: '🇨🇳',
		parenthetical: '1.1B — China underground church',
		reach: '4.56B',
	},
	{
		dollar: '$450K',
		language: 'Indonesian',
		flag: '🇮🇩',
		parenthetical: '199M — largest Muslim-majority nation',
		reach: '4.76B',
	},
	{
		dollar: '$500K',
		language: 'Bengali',
		flag: '🇧🇩',
		parenthetical: '272M speakers',
		reach: '5.03B',
	},
	{ dollar: '$550K', language: 'Urdu', flag: '🇵🇰', parenthetical: '231M speakers', reach: '5.26B' },
	{
		dollar: '$600K',
		language: 'Russian',
		flag: '🇷🇺',
		parenthetical: '258M speakers',
		reach: '5.52B',
	},
	{
		dollar: '$650K',
		language: 'German',
		flag: '🇩🇪',
		parenthetical: '135M speakers',
		reach: '5.65B',
	},
	{
		dollar: '$700K',
		language: 'Japanese',
		flag: '🇯🇵',
		parenthetical: '125M speakers',
		reach: '5.78B',
	},
	{
		dollar: '$750K',
		language: 'Nigerian Pidgin',
		flag: '🇳🇬',
		parenthetical: '121M speakers',
		reach: '5.90B',
	},
	{
		dollar: '$800K',
		language: 'Marathi',
		flag: '🇮🇳',
		parenthetical: '99M speakers',
		reach: '6.00B',
	},
	{
		dollar: '$850K',
		language: 'Telugu',
		flag: '🇮🇳',
		parenthetical: '96M speakers',
		reach: '6.10B',
	},
	{
		dollar: '$900K',
		language: 'Turkish',
		flag: '🇹🇷',
		parenthetical: '88M speakers',
		reach: '6.18B',
	},
	{ dollar: '$950K', language: 'Tamil', flag: '🇮🇳', parenthetical: '86M speakers', reach: '6.27B' },
	{
		dollar: '$1.0M',
		language: 'Yue Chinese',
		flag: '🇭🇰',
		parenthetical: '86M speakers',
		reach: '6.35B',
	},
	{
		dollar: '$1.05M',
		language: 'Vietnamese — all 20 languages live · 75% of humanity',
		flag: '🇻🇳',
		parenthetical: '85M speakers',
		reach: '6.43B',
		highlight: true,
	},
];
---

<Layout
	title="Nations | Father's Heart Bible"
	description="Father's Heart Bible international expansion. Every $50,000 unlocks another language — together, the top 20 languages reach 6.43 billion people, 75% of humanity. Inviting beloved sons and daughters worldwide to come home to the Father."
>

	<main id="main-content" style="margin-top: 80px;">

		<!-- HERO -->
		<section class="py-8 md:py-12 lg:py-16 px-4 md:px-6" style="background-color: #ffd9e0;">
			<div class="max-w-4xl mx-auto px-4 md:px-6 text-center" data-reveal>
				<p class="text-xs font-semibold tracking-widest uppercase mb-4" style="font-family: var(--font-sans); color: var(--color-primary);">
					The Nations
				</p>
				<h1 class="text-4xl md:text-6xl font-light leading-tight mb-6" style="font-family: var(--font-serif); color: var(--color-ink);">
					Come home to the Father — in every tongue.
				</h1>
				<p class="text-lg md:text-xl leading-relaxed max-w-2xl mx-auto" style="font-family: var(--font-sans); color: var(--color-muted);">
					The Father's Heart Bible™ exists to make the Father-heart interpretive lens
					available where existing translations obscure it — for beloved sons and
					daughters in every nation. Every $50,000 unlocks another language.
				</p>
			</div>
		</section>

		<!-- VISION -->
		<Section variant="light">
			<div class="max-w-3xl mx-auto" data-reveal>
				<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-sans); color: var(--color-gold);">
					The Vision
				</p>
				<h2 class="text-3xl md:text-4xl font-light leading-tight mb-6" style="font-family: var(--font-serif); color: var(--color-ink);">
					75% of humanity in 20 languages.
				</h2>
				<p class="leading-relaxed mb-4" style="font-family: var(--font-sans); color: var(--color-muted);">
					Phase 2 begins after the English First Edition launches in fall 2026.
					Every language unlock includes the full Father's Heart Bible™ — translated,
					reviewed by native theologians, formatted for print and digital release,
					and narrated as an audio Bible in the target language.
				</p>
				<p class="leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">
					The priority order is set by speaker count, the size of the Christian
					church in each region, spiritual openness, and distribution feasibility.
					Together the top 20 languages reach <strong style="color: var(--color-primary);">6.43 billion people</strong>
					— roughly <strong style="color: var(--color-primary);">75% of humanity</strong>.
				</p>
			</div>
		</Section>

		<!-- UNLOCK TABLE -->
		<Section variant="soft">
			<div class="max-w-2xl mx-auto" data-reveal>
				<header class="mb-8 text-center">
					<p class="text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-sans); color: var(--color-gold);">
						Unlock Map
					</p>
					<h2 class="text-3xl md:text-4xl font-light" style="font-family: var(--font-serif); color: var(--color-ink);">
						$100K to $1.05M — every dollar a doorway.
					</h2>
				</header>

				<div class="overflow-hidden rounded-2xl border" style="border-color: var(--color-outline-variant); background: var(--color-surface);">
					<div class="hidden md:grid grid-cols-[88px_64px_1fr_72px] gap-2 px-5 py-3" style="background: var(--color-surface-low); font-family: var(--font-sans); font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-ink);">
						<span>Total Raised</span>
						<span></span>
						<span>Unlock</span>
						<span class="text-right">Reach</span>
					</div>

					{unlocks.map((u) => (
						<div
							class="grid grid-cols-[64px_1fr_auto] md:grid-cols-[88px_64px_1fr_72px] gap-3 md:gap-2 items-center px-5 py-4"
							style={`border-top: 1px solid var(--color-outline-variant); ${u.highlight ? 'background: var(--color-surface-low);' : ''}`}
						>
							<span class="hidden md:inline" style="font-family: var(--font-sans); font-size: 14px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.02em;">
								{u.dollar}
							</span>
							<span style="font-size: 44px; line-height: 1; text-align: center;" aria-hidden="true">{u.flag}</span>
							<div>
								<p class="md:hidden" style="font-family: var(--font-sans); font-size: 12px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.02em; margin: 0 0 2px;">
									{u.dollar}
								</p>
								<p style="font-family: var(--font-sans); font-size: 15px; font-weight: 600; color: var(--color-ink); margin: 0;">
									{u.language}
								</p>
								{u.parenthetical && (
									<p style="font-family: var(--font-sans); font-size: 13px; color: var(--color-muted); margin: 2px 0 0;">
										{u.parenthetical}
									</p>
								)}
							</div>
							<span class="text-right" style="font-family: var(--font-sans); font-size: 14px; font-weight: 700; color: var(--color-ink);">
								{u.reach}
							</span>
						</div>
					))}
				</div>

				<p class="text-center mt-6 text-sm" style="font-family: var(--font-sans); color: var(--color-muted);">
					Reach numbers are cumulative — Sons and daughters who can finally read the
					Father's heart in their own tongue.
				</p>
			</div>
		</Section>

		<!-- CLOSING CTA -->
		<section class="py-10 md:py-14 px-4 md:px-6" style="background-color: #ffd9e0;">
			<div class="max-w-3xl mx-auto px-4 md:px-6 text-center" data-reveal>
				<h2 class="text-3xl md:text-4xl font-light leading-tight mb-6" style="font-family: var(--font-serif); color: var(--color-ink);">
					Help us open the door for every nation.
				</h2>
				<p class="leading-relaxed mb-8" style="font-family: var(--font-sans); color: var(--color-muted);">
					Your gift to the First Edition fuels the English launch and lights the way
					into Phase 2. Every $50,000 raised beyond $100K unlocks another language.
				</p>
				<a
					href="/partner/#donate"
					class="inline-flex items-center px-8 py-3.5 text-base font-semibold no-underline transition-all duration-200"
					style="font-family: var(--font-sans); background-color: #FFD9E0; color: #4A4A4A; border-radius: 8px;"
					onmouseover="this.style.opacity='0.92'"
					onmouseout="this.style.opacity='1'"
				>
					Make a Gift →
				</a>
			</div>
		</section>

	</main>

</Layout>
