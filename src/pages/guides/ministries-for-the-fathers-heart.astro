---
// FH Ministries page (Kevin-approved 2026-07-15) — a curated, honest list of
// ministries and voices on the Father's heart that we recommend. Companion to
// the best-books list and the resource hub. "Personally Known" is a BADGE, not a
// gate: every listing is trusted and equal; the badge only marks people Kevin &
// Shelly know personally. NOTE (pre-prod): book cover thumbs currently hotlink
// Amazon's media CDN as review placeholders — move to R2/Sanity before main.
import AuthorBio from '../../components/AuthorBio.astro';
import BlogAudioPlayer from '../../components/BlogAudioPlayer.astro';
import BlogPrintCTA from '../../components/BlogPrintCTA.astro';
import ReviewLink from '../../components/ReviewLink.astro';
import Layout from '../../layouts/Layout.astro';

const PAGE_URL = 'https://fathersheartbible.com/guides/ministries-for-the-fathers-heart';
const TITLE =
	"Father Heart of God Ministries — Intentional about our Father’s Heart | Father's Heart Bible™";
const DESCRIPTION =
	'A curated, honest list of father heart of God ministries and teachers — Kerry & Chiqui Wood, George LaDu, Sandra Steen, Barbara Kohler, Fatherheart Ministries, and more.';
const PUBLISHED = '2026-07-15';
const MODIFIED = '2026-07-16';

// Hero uses OUR FHB mock-up (M001) per the mock-ups-only hero rule, hosted on R2.
const HERO_1400 = 'https://assets.spiritmediapublishing.com/FHB/heroes/ministries-hero-1400.webp';
const HERO_640 = 'https://assets.spiritmediapublishing.com/FHB/heroes/ministries-hero-640.webp';
const HERO_ALT = 'Three generations reading the Father’s Heart Bible together by the fire';
const OG_IMG = 'https://assets.spiritmediapublishing.com/FHB/heroes/ministries-hero-og.jpg';
// "Listen to this guide" narration — rotation voice 10 (Algieba); Charon is Scripture-only.
const AUDIO_SRC =
	'https://media.spiritmediapublishing.com/audio/guide/en/ministries-for-the-fathers-heart.mp3';

const formatDate = (iso: string) =>
	new Date(`${iso}T12:00:00Z`).toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	});

const KEVIN_WHITE_AUTHOR = {
	'@type': 'Person',
	'@id': 'https://kevinwhite.us/#person',
	name: 'Kevin White',
	url: 'https://kevinwhite.us',
	jobTitle: 'Founder & CEO, Spirit Media Publishing',
	affiliation: {
		'@type': 'Organization',
		'@id': 'https://spiritmediapublishing.com/#organization',
		name: 'Spirit Media Publishing',
	},
	sameAs: [
		'https://kevinwhite.us',
		'https://kevinwhite.us/about/',
		'https://www.linkedin.com/in/kevinwhiteus/',
		'https://www.youtube.com/@KevinWhiteus',
		'https://spiritmediapublishing.com',
	],
	knowsAbout: [
		'the Father heart of God',
		'the fatherhood of God',
		'Bible translation',
		'Christian discipleship',
	],
};

interface MinLink {
	label: string;
	href: string;
}
interface Ministry {
	id: string;
	name: string;
	role: string;
	known?: boolean; // "Personally Known" badge
	blurb: string; // HTML
	links: MinLink[];
}
const MINISTRIES: Ministry[] = [
	{
		id: 'wood',
		name: 'Dr. Kerry Wood & Dr. Chiqui Polo-Wood',
		role: 'Table of Friends Church · authors of the Abba Series',
		known: true,
		blurb:
			'A husband-and-wife team who have spent decades discipling leaders into a settled life as sons and daughters of Abba. Their Abba Series — <em>The Abba Foundation</em>, <em>The Abba Factor</em>, and <em>The Abba Formation</em> — moves from knowing the Father, to knowing yourself in His eyes, to the Spirit’s work of transformation. Grounded, pastoral, and deeply on-theme.',
		links: [
			{ label: 'Table of Friends', href: 'https://tableoffriends.com/' },
			{ label: 'drkerrywood.com', href: 'https://drkerrywood.com/' },
			{ label: 'chiquipolowood.com', href: 'https://chiquipolowood.com/' },
			{ label: 'The Abba Foundation', href: 'https://www.amazon.com/dp/B079Z8J4YN' },
			{ label: 'The Abba Factor', href: 'https://www.amazon.com/dp/B07B8RJDMG' },
		],
	},
	{
		id: 'ladu',
		name: 'George & Randi LaDu',
		role: 'Kingdom Living — an online academy on identity in the Father',
		known: true,
		blurb:
			'George and Randi LaDu lead Kingdom Living, teaching believers to experience the Father’s love and discover who He made them to be. Their courses — <em>The Beloved</em> and <em>The Identity Project</em> — are self-paced journeys with group and one-to-one coaching, built for people ready to trade striving for belovedness.',
		links: [
			{ label: 'George’s page', href: 'https://www.kingdomliving.global/georgeladu' },
			{ label: 'The Beloved (course)', href: 'https://www.kingdomliving.global/course/beloved' },
			{
				label: 'The Identity Project (course)',
				href: 'https://www.kingdomliving.global/course/identity-intro-call',
			},
		],
	},
	{
		id: 'steen',
		name: 'Dr. Sandra Steen',
		role: 'First Love Reset — spiritual renewal ministry',
		known: true,
		blurb:
			'Dr. Sandra Steen leads the First Love Reset movement, a Christ-centered call back to nearness with the Father when love has cooled to routine. Her book <em>First Love Reset</em> offers eight practical strategies to renew the heart and reignite a first-love passion for God; more resources are on the way.',
		links: [
			{ label: 'firstlovereset.org', href: 'https://firstlovereset.org/' },
			{ label: 'First Love Reset (book)', href: 'https://www.amazon.com/dp/B0FS3YCG5S' },
		],
	},
	{
		id: 'kohler',
		name: 'Barbara Kohler',
		role: 'The Kohler Group — faith-based Christian counseling',
		known: true,
		blurb:
			'A licensed Christian therapist whose work centers on healing father wounds and instilling a Father-Heart identity — including her “throne room of heaven” training. Through The Kohler Group she offers marriage and individual intensives and therapy (in North Carolina and via telehealth) for those carrying the ache an earthly father left behind.',
		links: [{ label: 'thekohlergroup.net', href: 'https://thekohlergroup.net' }],
	},
	{
		id: 'fatherheart',
		name: 'Fatherheart Ministries',
		role: 'Founded by Jack Winter & James Jordan · now led by Denise Jordan',
		blurb:
			'A global movement carrying the Father’s love to more than 60 nations, known for its A Schools (experiencing the Father’s love) and B Schools (walking in sonship). Its founders — Jack Winter, who first carried the “Father’s embrace” message, and James Jordan, author of <em>Sonship</em> — have both gone home to the Lord; the ministry continues. Their books <em>Sonship</em> and <em>The Homecoming</em> remain formative reads.',
		links: [
			{ label: 'fatherheart.net', href: 'https://fatherheart.net' },
			{ label: 'Sonship (James Jordan)', href: 'https://www.amazon.com/dp/0994101619' },
			{ label: 'The Homecoming (Jack Winter)', href: 'https://www.amazon.com/dp/1576580040' },
		],
	},
	{
		id: 'shiloh',
		name: 'Shiloh Place Ministries',
		role: 'Founded by Jack Frost · continued by the Frost family',
		blurb:
			'The ministry Jack Frost founded to help strivers and performers move from earning God’s approval into resting as beloved sons and daughters. Frost’s <em>Experiencing Father’s Embrace</em> became a father-heart staple; his family carries the work forward today through schools and conferences.',
		links: [{ label: 'shilohplace.org', href: 'https://www.shilohplace.org' }],
	},
	{
		id: 'fll',
		name: 'Father’s Love Letter — Barry Adams',
		role: 'A message from the Father, in 125+ languages',
		blurb:
			'What began in 1999 as a sermon illustration became a global phenomenon: a compilation of paraphrased Scripture written as a personal love letter from the Father to His child. Barry Adams’ ministry, Father Heart Communications, keeps it freely available — read, watched, and shared by millions worldwide.',
		links: [{ label: 'fathersloveletter.com', href: 'https://www.fathersloveletter.com' }],
	},
	{
		id: 'galpin',
		name: 'Trevor & Linda Galpin',
		role: 'Father-heart teaching · author of The Tender Father',
		blurb:
			'Longtime father-heart teachers in the UK, Trevor and Linda Galpin help people encounter God as their real Father as revealed by Jesus. Trevor is a conference speaker and author (<em>The Tender Father</em>), and they continue to lead refreshing retreats and mission partnerships.',
		links: [{ label: 'trevorandlinda.uk', href: 'https://www.trevorandlinda.uk' }],
	},
	{
		id: 'hetland',
		name: 'Leif Hetland — Global Mission Awareness',
		role: 'Missions through the paradigm of Kingdom family',
		blurb:
			'A forerunner in modern missions, Leif Hetland ministers globally out of a paradigm of the Father’s love and Kingdom family. His books <em>Called to Reign</em> and <em>Seeing Through Heaven’s Eyes</em> teach believers to see themselves, and others, through the eyes of a loving Father.',
		links: [{ label: 'leifhetland.com', href: 'https://www.leifhetland.com' }],
	},
];

// Alpha order by surname / ministry name (Kevin 2026-07-15).
const SORT_KEY: Record<string, string> = {
	fatherheart: 'Fatherheart Ministries',
	fll: 'Fathers Love Letter',
	galpin: 'Galpin',
	hetland: 'Hetland',
	kohler: 'Kohler',
	ladu: 'LaDu',
	shiloh: 'Shiloh Place',
	steen: 'Steen',
	wood: 'Wood',
};
// Verified official photos hosted on R2; entries without one fall back to a monogram tile.
const PHOTO: Record<string, string> = {
	fatherheart: 'https://assets.spiritmediapublishing.com/FHB/ministries/min-fatherheart.webp',
	hetland: 'https://assets.spiritmediapublishing.com/FHB/ministries/min-hetland.webp',
	shiloh: 'https://assets.spiritmediapublishing.com/FHB/ministries/min-shiloh.webp',
	kohler: 'https://assets.spiritmediapublishing.com/FHB/ministries/min-kohler.webp',
	ladu: 'https://assets.spiritmediapublishing.com/FHB/ministries/min-ladu.webp',
	steen: 'https://assets.spiritmediapublishing.com/FHB/ministries/min-steen.webp',
	wood: 'https://assets.spiritmediapublishing.com/FHB/ministries/min-wood.webp',
	galpin: 'https://assets.spiritmediapublishing.com/FHB/ministries/min-galpin.webp',
	fll: 'https://assets.spiritmediapublishing.com/FHB/ministries/min-fll.webp',
};
const ORDERED_MIN = [...MINISTRIES].sort((a, b) =>
	(SORT_KEY[a.id] ?? a.name).localeCompare(SORT_KEY[b.id] ?? b.name, 'en'),
);
// Ministries whose book appears on the best-books reading list — cross-linked.
const BOOK_OF: Record<string, string> = {
	wood: 'abba-foundation',
	steen: 'steen',
	fatherheart: 'jordan',
	shiloh: 'frost',
	fll: 'fll',
};
// "At a glance" extraction table (focus + format) — engines cite tables verbatim.
const COMPARE: Record<string, { focus: string; format: string }> = {
	wood: { focus: 'Sonship & the Abba life', format: 'Books + local church' },
	ladu: { focus: 'Identity in the Father', format: 'Online courses + coaching' },
	steen: { focus: 'Renewing first love for God', format: 'Book + movement' },
	kohler: { focus: 'Healing father wounds', format: 'Christian counseling & intensives' },
	fatherheart: { focus: 'The Father’s love & sonship', format: 'Schools + books' },
	shiloh: { focus: 'From performance to rest', format: 'Schools + conferences' },
	fll: { focus: 'The Father’s love, personally', format: 'Free letter + book' },
	galpin: { focus: 'Encountering God as Father', format: 'Retreats + book' },
	hetland: { focus: 'The Father’s love in missions', format: 'Books + missions' },
};

const FAQS = [
	{
		question: 'Which ministries teach the father heart of God?',
		answer:
			"Trusted father-heart ministries and teachers include Dr. Kerry and Chiqui Wood (Table of Friends and the Abba Series), George and Randi LaDu (Kingdom Living), Dr. Sandra Steen (First Love Reset), Barbara Kohler (The Kohler Group), Fatherheart Ministries (founded by Jack Winter and James Jordan), Shiloh Place Ministries (Jack Frost), Father's Love Letter (Barry Adams), Trevor and Linda Galpin, and Leif Hetland's Global Mission Awareness. Each teaches, from a different angle, the same revelation: God is a loving Father who welcomes His children home.",
	},
	{
		question: 'Are these ministries affiliated with the Father’s Heart Bible?',
		answer:
			"No. These are independent ministries we recommend because their message aligns with the heart of the Father's Heart Bible™ — that God reveals Himself as a loving Father. We don't speak for them and they don't speak for us; we simply point you to voices we trust on this theme.",
	},
	{
		question: 'What does the “Personally Known” badge mean?',
		answer:
			'It marks a person we know personally. Every ministry on this page is one we genuinely recommend — that is the only bar for being listed. The badge is not a ranking or a higher tier; it simply tells you, honestly, where we have a personal relationship rather than a recommendation based on their published work.',
	},
	{
		question: 'Where should I start?',
		answer:
			"Start with Scripture itself — read Luke 15, the prodigal's homecoming, free with audio at fathersheartbible.com/read/luke/15. Then follow whichever voice here meets your season: the Woods or George LaDu for identity, Sandra Steen for renewal, Barbara Kohler for father-wound healing, or the classic reading list of father-heart books.",
	},
];

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: 'Father Heart of God Ministries We Recommend',
	description: DESCRIPTION,
	image: OG_IMG,
	author: KEVIN_WHITE_AUTHOR,
	publisher: {
		'@type': 'Organization',
		'@id': 'https://spiritmediapublishing.com/#organization',
		name: 'Spirit Media Publishing',
		url: 'https://spiritmediapublishing.com',
	},
	url: PAGE_URL,
	mainEntityOfPage: { '@type': 'WebPage', '@id': PAGE_URL },
	datePublished: PUBLISHED,
	dateModified: MODIFIED,
	inLanguage: 'en-US',
	articleSection: 'Bible Reading Guides',
	keywords:
		'father heart of God ministries, father heart of God teachers, sonship ministries, father’s heart teaching',
};
const listSchema = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: 'Ministries Intentional about our Father’s Heart',
	itemListElement: ORDERED_MIN.map((m, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		item: {
			'@type': 'Organization',
			name: m.name,
			url: m.links[0]?.href,
			sameAs: m.links.map((l) => l.href),
		},
	})),
};
// Course entities for George & Randi LaDu's Kingdom Living academy.
const courseSchema = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: 'Kingdom Living courses — George & Randi LaDu',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			item: {
				'@type': 'Course',
				name: 'The Beloved',
				description:
					'A course to experience your Heavenly Father’s love and live as His beloved child.',
				provider: {
					'@type': 'Organization',
					name: 'Kingdom Living',
					url: 'https://www.kingdomliving.global',
				},
				url: 'https://www.kingdomliving.global/course/beloved',
			},
		},
		{
			'@type': 'ListItem',
			position: 2,
			item: {
				'@type': 'Course',
				name: 'The Identity Project',
				description:
					'A self-paced journey into your God-given identity, with group and one-to-one coaching.',
				provider: {
					'@type': 'Organization',
					name: 'Kingdom Living',
					url: 'https://www.kingdomliving.global',
				},
				url: 'https://www.kingdomliving.global/course/identity-intro-call',
			},
		},
	],
};
const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://fathersheartbible.com/' },
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Guides',
			item: 'https://fathersheartbible.com/guides/',
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: 'Ministries Intentional about our Father’s Heart',
			item: PAGE_URL,
		},
	],
};
const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: FAQS.map((f) => ({
		'@type': 'Question',
		name: f.question,
		acceptedAnswer: { '@type': 'Answer', text: f.answer },
	})),
};
const jsonLd = [articleSchema, listSchema, courseSchema, breadcrumbSchema, faqSchema];
---
<Layout
	title={TITLE}
	description={DESCRIPTION}
	image={OG_IMG}
	darkHero={true}
	jsonLd={jsonLd}
	pageType="article"
	articleAuthor="Kevin White"
	articlePublishedTime={PUBLISHED}
	articleSection="Bible Reading Guides"
	articleTags={['father heart of God', 'ministries', 'sonship']}
	preloadImageMobile={HERO_640}
	preloadImageDesktop={HERO_1400}
>
	<main id="main-content">
		<BlogAudioPlayer src={AUDIO_SRC} />
		<section class="relative w-full overflow-hidden min-h-[600px] lg:min-h-[calc(50vh_+_2in)]">
			<img src={HERO_1400} srcset={`${HERO_640} 640w, ${HERO_1400} 1400w`} sizes="(max-width: 1023px) 640px, 1400px" alt={HERO_ALT} class="absolute inset-0 w-full h-full object-cover" style="object-position: center top;" fetchpriority="high" decoding="async" />
			<div class="absolute inset-0 z-10" style="background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.22) 40%, rgba(0,0,0,0.22) 100%);" aria-hidden="true"></div>
		</section>

		<section class="px-6 pt-10 pb-2 lg:px-8" style="background-color: var(--color-surface-low);">
			<div class="mx-auto max-w-3xl">
				<nav aria-label="Breadcrumb" class="mb-5 text-sm" style="color: var(--color-muted); font-family: var(--font-sans);">
					<a href="/" class="hover:underline">Home</a><span class="px-1.5" aria-hidden="true">/</span>
					<a href="/guides/" class="hover:underline">Guides</a><span class="px-1.5" aria-hidden="true">/</span>
					<span style="color: var(--color-ink);">Ministries Intentional about our Father’s Heart</span>
				</nav>
				<p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-brand); font-family: var(--font-sans);">Ministries We Recommend</p>
				<h1 class="text-4xl md:text-5xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">Ministries Intentional about our Father’s Heart</h1>
				<div class="flex items-center gap-3 mt-5 pb-8 text-sm border-b flex-wrap" style="color: var(--color-muted); font-family: var(--font-sans); border-color: var(--color-hairline);">
					<span>By <a href="/the-fathers-heart-bible/leadership/" class="font-semibold hover:underline" style="color: var(--color-ink);">Kevin White</a> &mdash; leading the Father&rsquo;s Heart Bible&trade; translation</span>
					<span aria-hidden="true">&middot;</span><span>{formatDate(PUBLISHED)}</span>
				</div>
			</div>
		</section>

		<section class="px-6 py-10 lg:px-8 lg:py-14" style="background-color: var(--color-surface);">
			<div class="mx-auto max-w-3xl">
				<p class="text-lg leading-relaxed mb-5" style="font-family: var(--font-sans); color: var(--color-muted);">
					<strong style="color: var(--color-ink);">These are ministries and voices on our Father&rsquo;s heart that we know, trust, and recommend.</strong> Teachers, authors, counselors, global movements &mdash; each carries the same revelation of the father heart of God: God is a loving Father who welcomes His children home. They come from different streams and countries, and that is a strength. Explore whoever meets your season.
				</p>

				<p class="text-base leading-relaxed mb-2" style="font-family: var(--font-sans); color: var(--color-muted);">
					The <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold align-middle" style="background-color: #fdf2f5; color: var(--color-brand); border: 1px solid #f9d6e0;"><span aria-hidden="true">&#10003;</span> Personally Known</span> mark means we know that person personally &mdash; it is not a ranking. Every ministry here is one we genuinely recommend, and nothing is ranked above anything else.
				</p>

				<aside class="my-7 px-6 py-5 rounded-2xl" style="background-color: #fdf2f5; border: 1px solid #f9d6e0;">
					<p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color: var(--color-brand); font-family: var(--font-sans);">Key takeaway</p>
					<p class="text-lg leading-relaxed" style="font-family: var(--font-serif); color: var(--color-ink);">Good teachers point past themselves. Every voice on this page leads to the same place &mdash; the Father&rsquo;s heart revealed in Scripture. Let them guide you there, then read it for yourself.</p>
				</aside>

				<div class="my-4 overflow-x-auto">
					<table class="w-full text-left" style="border-collapse: collapse; font-family: var(--font-sans);">
						<caption class="sr-only">Father heart of God ministries at a glance — focus and format</caption>
						<thead>
							<tr style="border-bottom: 2px solid var(--color-hairline);">
								<th scope="col" class="py-2 pr-4 text-sm font-semibold align-bottom" style="color: var(--color-ink);">Ministry</th>
								<th scope="col" class="py-2 pr-4 text-sm font-semibold align-bottom" style="color: var(--color-ink);">Focus</th>
								<th scope="col" class="py-2 text-sm font-semibold align-bottom" style="color: var(--color-ink);">Format</th>
							</tr>
						</thead>
						<tbody>
							{ORDERED_MIN.map((m) => (
								<tr style="border-bottom: 1px solid var(--color-hairline);">
									<td class="py-2 pr-4 text-sm align-top"><a href={`#${m.id}`} class="hover:underline" style="color: var(--color-brand);">{m.name}</a></td>
									<td class="py-2 pr-4 text-sm align-top" style="color: var(--color-muted);">{COMPARE[m.id]?.focus}</td>
									<td class="py-2 text-sm align-top" style="color: var(--color-muted);">{COMPARE[m.id]?.format}</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
					{ORDERED_MIN.map((m) => (
						<div id={m.id} class="scroll-mt-28 rounded-2xl overflow-hidden flex flex-col" style="background-color: var(--color-surface-lowest); border: 1px solid var(--color-hairline);">
							{PHOTO[m.id] ? (
								<img src={PHOTO[m.id]} alt={m.name} width="1000" height="667" loading="lazy" decoding="async" class="w-full object-cover" style="aspect-ratio: 3 / 2; object-position: center;" />
							) : (
								<div class="w-full flex items-center justify-center" style="aspect-ratio: 3 / 2; background-color: #fdf2f5;" aria-hidden="true">
									<span class="text-5xl font-light" style="font-family: var(--font-serif); color: var(--color-brand);">{(SORT_KEY[m.id] ?? m.name).charAt(0)}</span>
								</div>
							)}
							<div class="p-6 flex flex-col grow">
								<div class="flex items-center gap-2 flex-wrap mb-1">
									<h2 class="text-xl md:text-2xl font-light" style="font-family: var(--font-serif); color: var(--color-ink);">{m.name}</h2>
									{m.known && (<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold" style="background-color: #fdf2f5; color: var(--color-brand); border: 1px solid #f9d6e0;"><span aria-hidden="true">&#10003;</span> Personally Known</span>)}
								</div>
								<p class="text-sm font-semibold mb-3" style="font-family: var(--font-sans); color: var(--color-brand);">{m.role}</p>
								<p class="text-base leading-relaxed mb-4 grow" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={m.blurb}></p>
								<ul class="flex flex-wrap gap-x-4 gap-y-2 list-none m-0 p-0 text-sm" style="font-family: var(--font-sans);">
									{m.links.map((l) => (
										<li><a href={l.href} target="_blank" rel="noopener noreferrer" class="hover:underline" style="color: var(--color-brand);">{l.label}<span aria-hidden="true"> &nearr;</span></a></li>
									))}
								</ul>
								{BOOK_OF[m.id] && (
									<p class="mt-3 text-sm"><a href={`/guides/best-books-on-the-fathers-heart/#${BOOK_OF[m.id]}`} class="hover:underline font-semibold" style="color: var(--color-brand);">See on our reading list <span aria-hidden="true">&rarr;</span></a></p>
								)}
							</div>
						</div>
					))}
				</div>

				<aside class="my-12 px-6 py-10 lg:px-10 lg:py-12 rounded-2xl text-center" style="background-color: #fdf2f5; border: 1px solid #f9d6e0;">
					<p class="text-2xl md:text-3xl font-light leading-tight max-w-2xl mx-auto" style="font-family: var(--font-serif); color: var(--color-ink);">Every voice here points to one Father</p>
					<p class="mt-4 max-w-2xl mx-auto text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">Meet Him directly in Scripture &mdash; the Father&rsquo;s Heart Bible&trade; reveals God as a loving Father on every page, free to read and listen to online.</p>
					<a href="https://fathersheartbible.com/read" class="inline-flex items-center gap-2 mt-7 px-7 py-3 rounded-full text-sm font-semibold no-underline transition-opacity hover:opacity-90" style="background-color: #FFD9E0; color: #4A4A4A; font-family: var(--font-sans);">Read &amp; Listen Free<span aria-hidden="true">&rarr;</span></a>
				</aside>

				<h2 id="faq" class="text-2xl md:text-3xl font-light mt-12 mb-6 scroll-mt-28" style="font-family: var(--font-serif); color: var(--color-ink);">Frequently asked questions</h2>
				<div class="space-y-3">
					{FAQS.map((f) => (
						<details class="group rounded-xl overflow-hidden" style="background-color: var(--color-surface-low); border: 1px solid var(--color-hairline);">
							<summary class="flex items-center justify-between gap-4 cursor-pointer list-none px-5 py-4">
								<h3 class="text-lg md:text-xl font-medium m-0" style="font-family: var(--font-serif); color: var(--color-ink);">{f.question}</h3>
								<span class="shrink-0 transition-transform duration-200 group-open:rotate-45" style="color: var(--color-brand); font-size: 1.5rem; line-height: 1;" aria-hidden="true">+</span>
							</summary>
							<p class="px-5 pb-5 -mt-1 text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">{f.answer}</p>
						</details>
					))}
				</div>
				<style>details > summary::-webkit-details-marker { display: none; }</style>

				<div class="mt-12 pt-8 border-t" style="border-color: var(--color-hairline);">
					<p class="text-sm leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">
						Keep going: see the <a href="/guides/best-books-on-the-fathers-heart/" style="color: var(--color-brand);" class="hover:underline">best books on receiving our Father’s heart</a>, browse the <a href="/guides/resources-for-the-fathers-heart/" style="color: var(--color-brand);" class="hover:underline">our Father’s heart resource hub</a>, or find <a href="/verses/god-as-father/" style="color: var(--color-brand);" class="hover:underline">verses about God as Father</a>.
					</p>
				</div>
			</div>
		</section>

		<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface-low);">
			<div class="mx-auto max-w-2xl text-center">
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">Read the Father&rsquo;s Heart Bible free</h2>
				<p class="mt-4 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">Every ministry here points to the same Father. Meet Him directly &mdash; read the Father&rsquo;s Heart Bible free online with audio, or take home a <a href="/print/" class="hover:underline" style="color: var(--color-brand);">print edition</a>.</p>
				<a href="https://fathersheartbible.com/read" class="inline-flex items-center gap-2 mt-6 px-7 py-3 rounded-full text-sm font-semibold no-underline transition-colors" style="background-color: var(--color-brand); color: var(--color-on-primary); font-family: var(--font-sans);">Read FHB<span aria-hidden="true">&rarr;</span></a>
			</div>
		</section>

		<section class="px-6 pb-6 lg:px-8" style="background-color: var(--color-surface-low);">
			<div class="mx-auto max-w-3xl">
				<BlogPrintCTA />
			</div>
		</section>

		<ReviewLink class="mb-10" />

		<AuthorBio author="Kevin White" />
	</main>
</Layout>
