---
// Phase-5 section hub — /guides/  (fixes the breadcrumb that every guide links to)
// Lists every live guide as a card. NOTE: only real, published guides are listed
// — never link a guide that doesn't exist yet (no broken links). Add a row to
// GUIDES when a new /guides/<slug> page ships. Targets "bible reading guide".
import HowToHubCards from '../../components/HowToHubCards.astro';
import ReviewLink from '../../components/ReviewLink.astro';
import { GUIDES } from '../../data/guides';
import Layout from '../../layouts/Layout.astro';

const PAGE_URL = 'https://fathersheartbible.com/guides/';
const TITLE = "Bible Reading Guides — How to Read, Study & Begin | Father's Heart Bible";
const DESCRIPTION =
	'Free Bible reading guides for beginners — how to read the Bible, where to start, and how to study it. Read free online with audio.';

const HERO_BASE =
	'https://cdn.sanity.io/images/rusi1hyi/production/5c79ea5c7847e8a64dea32438633334fa53becd4-6000x4000.jpg';
const HERO_ALT = 'Friends reading books together indoors';
const HERO_IMG = `${HERO_BASE}?w=1400&h=560&fit=crop&crop=entropy&fm=webp&q=72`;
const OG_IMG = `${HERO_BASE}?w=1200&h=630&fit=crop&crop=entropy&fm=jpg&q=80`;

const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Bible Reading Guides',
	description: DESCRIPTION,
	url: PAGE_URL,
	inLanguage: 'en-US',
	isPartOf: {
		'@type': 'WebSite',
		name: "Father's Heart Bible",
		url: 'https://fathersheartbible.com/',
	},
	mainEntity: {
		'@type': 'ItemList',
		itemListElement: GUIDES.map((g, i) => ({
			'@type': 'ListItem',
			position: i + 1,
			name: g.title,
			url: `https://fathersheartbible.com/guides/${g.slug}`,
		})),
	},
};
const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://fathersheartbible.com/' },
		{ '@type': 'ListItem', position: 2, name: 'Guides', item: PAGE_URL },
	],
};
// Hub FAQ — visible AND FAQPage schema (AEO). Targets real beginner "how to read the Bible" intent.
const FAQS = [
	{
		q: 'How do I start reading the Bible as a beginner?',
		a: 'Start small and start free. A good first step is one of the Gospels — try the Gospel of John — reading or listening to a chapter at a time. Our <a href="/guides/where-to-start-reading-the-bible/" style="color: var(--color-brand);" class="hover:underline">where-to-start guide</a> walks you through it, and you can read along free with audio at <a href="https://fathersheartbible.com/read" style="color: var(--color-brand);" class="hover:underline">fathersheartbible.com/read</a>.',
	},
	{
		q: 'In what order should I read the Bible?',
		a: "You don't have to read front to back. Many beginners start with a Gospel to meet Jesus, then Genesis for the story's beginning, then a Psalm a day for prayer. Our reading-order guides above lay out simple, unintimidating paths through Scripture.",
	},
	{
		q: 'How do I understand what the Bible means?',
		a: "Read it as one unfolding story that leads to Jesus, notice who God shows Himself to be, and ask what it reveals about the Father's heart. Our how-to-read and how-to-study guides above give you simple tools — context, prayer, and a few questions to ask of any passage.",
	},
	{
		q: 'Are these Bible study guides free?',
		a: 'Yes — every guide here is completely free, and each one links into the Father\'s Heart Bible™, free to <a href="https://fathersheartbible.com/read" style="color: var(--color-brand);" class="hover:underline">read online with audio</a> with no account, no purchase, and no app.',
	},
];
const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: FAQS.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
	})),
};
const jsonLd = [collectionSchema, breadcrumbSchema, faqSchema];
---

<Layout
	title={TITLE}
	description={DESCRIPTION}
	image={OG_IMG}
	darkHero={true}
	jsonLd={jsonLd}
	preloadImageMobile={HERO_IMG.replace('w=1400', 'w=640')}
	preloadImageDesktop={HERO_IMG}
>
	<main id="main-content">
		<section class="relative w-full overflow-hidden min-h-[600px] lg:min-h-[calc(50vh_+_2in)]">
			<img src={HERO_IMG} srcset={`${HERO_IMG.replace('w=1400', 'w=640')} 640w, ${HERO_IMG} 1400w`} sizes="(max-width: 1023px) 640px, 1400px" alt={HERO_ALT} class="absolute inset-0 w-full h-full object-cover" style="object-position: center top;" fetchpriority="high" decoding="async" />
			<div class="absolute inset-0 z-10" style="background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.22) 40%, rgba(0,0,0,0.22) 100%);" aria-hidden="true"></div>
		</section>

		<section class="px-6 pt-10 pb-2 lg:px-8" style="background-color: var(--color-surface-low);">
			<div class="mx-auto max-w-3xl">
				<nav aria-label="Breadcrumb" class="mb-5 text-sm" style="color: var(--color-muted); font-family: var(--font-sans);">
					<a href="/" class="hover:underline">Home</a><span class="px-1.5" aria-hidden="true">/</span>
					<span style="color: var(--color-ink);">Guides</span>
				</nav>
				<p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-brand); font-family: var(--font-sans);">Bible Reading Guides</p>
				<h1 class="text-4xl md:text-5xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">Bible Reading Guides</h1>
				<p class="mt-5 text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">
					Simple, free guides to help you read the Bible &mdash; where to begin, how to understand it, and how to study it for yourself. Each one starts where the story starts, in Genesis, and reads toward the Father&rsquo;s heart revealed in Jesus. Every guide links you straight into the <a href="https://fathersheartbible.com/read" style="color: var(--color-brand);" class="hover:underline">Father&rsquo;s Heart Bible</a>, free to read online with audio.
				</p>
			</div>
		</section>

		<HowToHubCards bg="var(--color-surface)" />

		<section id="hub-faq" class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface); scroll-margin-top: 1.5rem;">
			<div class="mx-auto max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color: var(--color-gold); font-family: var(--font-sans);">Questions &amp; answers</p>
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">Starting to read the Bible</h2>
				<dl class="mt-8 space-y-7">
					{FAQS.map((f) => (
						<div>
							<dt class="text-lg font-medium leading-snug" style="font-family: var(--font-serif); color: var(--color-ink);">{f.q}</dt>
							<dd class="mt-2 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);" set:html={f.a}></dd>
						</div>
					))}
				</dl>
			</div>
		</section>

		<section class="px-6 py-12 lg:px-8 lg:py-16" style="background-color: var(--color-surface-low);">
			<div class="mx-auto max-w-2xl text-center">
				<h2 class="text-2xl md:text-3xl font-light leading-tight" style="font-family: var(--font-serif); color: var(--color-ink);">Read the Father&rsquo;s Heart Bible free</h2>
				<p class="mt-4 text-base lg:text-lg leading-relaxed" style="font-family: var(--font-sans); color: var(--color-muted);">Pick a guide above, then open the Bible itself &mdash; the whole thing free online with audio, in a fresh translation that reveals God as a loving Father.</p>
				<a href="https://fathersheartbible.com/read" class="inline-flex items-center gap-2 mt-6 px-7 py-3 rounded-full text-sm font-semibold no-underline transition-colors" style="background-color: var(--color-brand); color: var(--color-on-primary); font-family: var(--font-sans);">Read FHB<span aria-hidden="true">&rarr;</span></a>
			</div>
		</section>

		<ReviewLink class="mb-12" />
	</main>
</Layout>
