					"verse": 8,
					"fragments": ["‘I am Jesus of Nazareth, whom you are persecuting,’"]
				},
				{
					"verse": 10,
					"fragments": [
						"‘Get up and go into Damascus,’",
						"‘There you will be told all that you have been appointed to do.’"
					]
				},
				{
					"verse": 18,
					"fragments": [
						"‘Hurry! Leave Jerusalem quickly, because the people here will not accept your testimony about Me.’"
					]
				},
				{
					"verse": 21,
					"fragments": ["‘Go! I will send you far away to the Gentiles.’"]
				}
			]
