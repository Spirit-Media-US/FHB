			"bsbJesusWords": [
				{
					"verse": 4,
					"fragments": [
						"“Do not leave Jerusalem, but wait for the gift the Father promised, which you have heard Me discuss."
					]
				},
				{
					"verse": 5,
					"fragments": [
						"5 For John baptized with water, but in a few days you will be baptized with the Holy Spirit.”"
					]
				},
				{
					"verse": 7,
					"fragments": [
						"“It is not for you to know times or seasons that the Father has fixed by His own authority."
					]
				},
				{
					"verse": 8,
					"fragments": [
						"8 But you will receive power when the Holy Spirit comes upon you, and you will be My witnesses in Jerusalem, and in all Judea and Samaria, and to the ends of the earth.”"
					]
				}
			]
		},
