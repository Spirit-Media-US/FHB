			"bsbJesusWords": [
				{
					"verse": 11,
					"fragments": [
						"“Write on a scroll what you see and send it to the seven churches: to Ephesus, Smyrna, Pergamum, Thyatira, Sardis, Philadelphia, and Laodicea.”"
					]
				},
				{
					"verse": 17,
					"fragments": ["“Do not be afraid. I am the First and the Last,"]
				},
				{
					"verse": 18,
					"fragments": [
						"18 the Living One. I was dead, and behold, now I am alive forever and ever! And I hold the keys of Death and of Hades."
					]
				},
				{
					"verse": 19,
					"fragments": [
						"Therefore write down the things you have seen, the things that are, and the things that will happen after this."
					]
				},
				{
					"verse": 20,
					"fragments": [
						"20 This is the mystery of the seven stars you saw in My right hand and of the seven golden lampstands: The seven stars are the angels of the seven churches, and the seven lampstands are the seven churches.[’’]"
					]
				}
			]
		},
