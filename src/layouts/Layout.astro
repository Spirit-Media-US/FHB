---
import { sanityClient, urlFor } from '../lib/sanity';

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const {
	title,
	description = "A new Bible translation revealing our Father's heart — from Genesis to Revelation.",
	image,
} = Astro.props;

// Fetch siteName and ogImage from Sanity
const siteSettings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    siteName,
    heroImage
  }
`);

const siteName = siteSettings?.siteName || "Father's Heart Bible";

// Use provided image, or fallback to Sanity heroImage, or fallback to static OG image
let ogImage = image;
if (!ogImage && siteSettings?.heroImage) {
	ogImage = urlFor(siteSettings.heroImage).width(1200).height(630).url();
} else if (!ogImage) {
	ogImage = '/og-image.png';
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalURL} />

		<!-- Preconnect to Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:site_name" content={siteName} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
	</head>
	<body class="min-h-screen flex flex-col">
		<slot />
	</body>
</html>
