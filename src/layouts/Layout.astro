---
import Footer from '../chrome/Footer.astro';
import Header from '../chrome/Header.astro';
// Canonical global nav — generated from communities/fhb.json by sync-chrome.mjs
// (app-relative hrefs resolved to absolute join.fathersheartbible.com). Single
// source of truth shared with the app so the global menu never drifts.
import globalNav from '../chrome/nav.generated.json';
import MailtoLink from '../components/MailtoLink.astro';
import WelcomeTour from '../components/WelcomeTour.astro';
import { sanityClient } from '../lib/sanity';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
	imageAlt?: string;
	noindex?: boolean;
	darkHero?: boolean;
	// jsonLd accepts a single schema.org object OR an array. The Organization
	// schema for Spirit Media Publishing is appended automatically on every
	// page so AI engines and search crawlers always see the publisher entity.
	jsonLd?: Record<string, any> | Record<string, any>[];
	preloadImageMobile?: string;
	preloadImageDesktop?: string;
	// Open Graph article metadata — set pageType="article" on blog post pages
	// to emit og:type=article + article:* meta. Other pages use og:type=website.
	pageType?: 'website' | 'article';
	articleAuthor?: string;
	articlePublishedTime?: string;
	articleSection?: string;
	articleTags?: string[];
}

const {
	title,
	description = "A new Bible translation revealing our Father's heart — from Genesis to Revelation.",
	image,
	imageAlt,
	noindex = false,
	darkHero = false,
	jsonLd,
	preloadImageMobile,
	preloadImageDesktop,
	pageType = 'website',
	articleAuthor,
	articlePublishedTime,
	articleSection,
	articleTags = [],
} = Astro.props;

// Fetch siteName and ogImage from Sanity
const siteSettings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    siteName,
    heroImage,
    logo,
    footerQuote
  }
`);

const siteName = siteSettings?.siteName || "Father's Heart Bible";

// ── Global chrome (shared Header/Footer mounted once here, per the SMP model;
// synced from the community repo into src/chrome at build) ──
const brandName = `${siteName}`.replace(/™$/, '') + '™';
// Same R2 logo the community app uses (fhb.json brand.logoUrl) so both navs are identical: text + logo.
const headerLogoUrl = 'https://assets.spiritmediapublishing.com/FHB/fhb-logo.png';
const footerQuote =
	siteSettings?.footerQuote || 'I will be their Father, and they will be my sons and daughters.';
const currentYear = new Date().getFullYear();

// Footer nav mirrors the header global nav (same `globalNav` source) so the two
// never drift. The "Family" item is a header-only dropdown whose top-level href
// is /login (which we don't advertise), so it's dropped from the flat footer.
const fhbFooterNav = globalNav
	.filter((item: { label: string }) => item.label !== 'Family')
	.map((item: { label: string; href: string }) => ({ label: item.label, href: item.href }));
// Surface the country hub in the footer (it's a Resources dropdown child in the
// header, but the footer is flat top-level, so add it explicitly here).
fhbFooterNav.push({ label: 'Nations', href: '/bible-in/' });
const fhbFooterLegal = [
	{ label: 'Privacy', href: '/privacy/' },
	{ label: 'Terms', href: '/terms/' },
];

// OG image — default to the branded 1200×630 share card, allow per-page override
const ogImage =
	image || 'https://assets.spiritmediapublishing.com/FHB/share/fhb-og-default.jpg?v=2';
const ogImageAlt = imageAlt || "Father's Heart Bible — Come home to Me as your Father";
// Emit explicit dimensions/type only for known 1200×630 JPG cards (our share
// cards + w=1200&h=630 Sanity crops); skip for arbitrary blog hero images.
const ogSized = ogImage.includes('/FHB/share/') || ogImage.includes('w=1200&h=630');

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Site-wide Organization schema — Spirit Media Publishing as the publisher.
// Always emitted alongside any page-specific JSON-LD so AI engines and
// search crawlers consistently see the publisher entity.
const ORGANIZATION_SCHEMA = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	'@id': 'https://spiritmediapublishing.com/#organization',
	name: 'Spirit Media Publishing',
	url: 'https://spiritmediapublishing.com',
	logo: 'https://cdn.sanity.io/images/rusi1hyi/production/bf1efb2f6870a8f0257175a033f27222f6e1e6b9-2857x4000.png?w=400&fm=webp',
	sameAs: ['https://www.linkedin.com/company/spirit-media-publishing', 'https://kevinwhite.us'],
};

// Combine page-specific JSON-LD with the site-wide Organization
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allJsonLd = [...pageJsonLd, ORGANIZATION_SCHEMA];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="canonical" href={canonicalURL} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}

		<!-- Bing Webmaster Tools site verification (AEO rubric row A3) -->
		<meta name="msvalidate.01" content="477910DF31D77AFDFCAE62DF5E095405" />

		<!-- Preconnect to Sanity CDN (hero images) -->
		<link rel="preconnect" href="https://cdn.sanity.io" crossorigin />

		<!-- Preconnect + preload self-hosted fonts (R2) — @font-face declarations live in src/styles/global.css -->
		<!-- Preload the TWO weights actually used above the fold: Epilogue-500 (H1 font-medium) + Manrope-400 (body) -->
		<link rel="preconnect" href="https://assets.spiritmediapublishing.com" crossorigin />
		<link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/epilogue/epilogue-500.woff2" crossorigin />
		<link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/manrope/manrope-400.woff2" crossorigin />

		<!-- Preload hero LCP image — separate mobile + desktop with media gates.
		     Avoids DPR-aware imagesrcset upscaling that pulled the 1200w image
		     on retina mobile (Moto G PSI). Each viewport fetches one file only.
		     Mobile hero image is post-LCP (deferred via interaction reveal in
		     index.astro) so no fetchpriority — keeps it from competing with
		     font preloads in the LCP window. Desktop hero image is the LCP
		     candidate so retains fetchpriority="high". -->
		{preloadImageMobile && (
			<link
				rel="preload"
				as="image"
				href={preloadImageMobile}
				media="(max-width: 1023px)"
			/>
		)}
		{preloadImageDesktop && (
			<link
				rel="preload"
				as="image"
				href={preloadImageDesktop}
				media="(min-width: 1024px)"
				fetchpriority="high"
			/>
		)}

		<!-- Hand-rolled critical CSS (v4 Phase 2D). Paired with inlineStylesheets:'auto' +
		     async-css.mjs which defers the full Tailwind bundle. Everything inside @layer base
		     — Tailwind utilities also live in @layer utilities, so above-fold layout survives
		     the cascade once the external sheet arrives. The two LCP-critical @font-face decls
		     (Epilogue 500 + Manrope 400) are inline below with font-display:optional — matches
		     spirit-media-publishing pattern. The rest of the @font-face decls live in global.css
		     (loaded async). -->
		<style is:inline>
			@keyframes heroEntrance{to{opacity:1;transform:scale(1)}}
			@font-face{font-family:'Epilogue';font-style:normal;font-weight:500;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/epilogue/epilogue-500.woff2') format('woff2')}
			@font-face{font-family:'Manrope';font-style:normal;font-weight:400;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/manrope/manrope-400.woff2') format('woff2')}
			/* Metric-adjusted fallbacks — eliminate FCP→LCP gap from font-swap re-paint.
			   Liberation/DejaVu/Arial as local sans base, metrics tuned to Epilogue/Manrope.
			   When the real font isn't ready (font-display:optional locks fallback after 100ms),
			   the page paints with the fallback at the same dimensions as the real font, so
			   Lighthouse doesn't see a re-paint when the real font would otherwise arrive.

			   REVERTED 2026-05-23 from calibrator-measured values that regressed mobile PSI
			   from 98 → 87-89 bimodal between 2026-05-18 and 2026-05-23. The approximated
			   values below are the empirically-verified good state. DO NOT swap to calibrator
			   output without re-measuring delta — calibrator values that are mathematically
			   precise can still produce a worse Lighthouse outcome than coarser values that
			   happen to suppress the bimodal flip. */
			@font-face{font-family:'Epilogue fallback';font-style:normal;font-weight:300;src:local('Liberation Sans'),local('DejaVu Sans'),local('Arial'),local('Helvetica');size-adjust:98.60%;ascent-override:80.12%;descent-override:23.83%;line-gap-override:0%}
			@font-face{font-family:'Epilogue fallback';font-style:normal;font-weight:400;src:local('Liberation Sans'),local('DejaVu Sans'),local('Arial'),local('Helvetica');size-adjust:98.60%;ascent-override:80.12%;descent-override:23.83%;line-gap-override:0%}
			@font-face{font-family:'Epilogue fallback';font-style:normal;font-weight:500;src:local('Liberation Sans'),local('DejaVu Sans'),local('Arial'),local('Helvetica');size-adjust:98.60%;ascent-override:80.12%;descent-override:23.83%;line-gap-override:0%}
			@font-face{font-family:'Epilogue fallback';font-style:normal;font-weight:600;src:local('Liberation Sans'),local('DejaVu Sans'),local('Arial'),local('Helvetica');size-adjust:98.60%;ascent-override:80.12%;descent-override:23.83%;line-gap-override:0%}
			@font-face{font-family:'Epilogue fallback';font-style:normal;font-weight:700;src:local('Liberation Sans'),local('DejaVu Sans'),local('Arial'),local('Helvetica');size-adjust:98.60%;ascent-override:80.12%;descent-override:23.83%;line-gap-override:0%}
			@font-face{font-family:'Manrope fallback';font-style:normal;font-weight:400;src:local('Liberation Sans'),local('DejaVu Sans'),local('Arial'),local('Helvetica');size-adjust:98.55%;ascent-override:108.17%;descent-override:30.44%;line-gap-override:0%}
			@font-face{font-family:'Manrope fallback';font-style:normal;font-weight:500;src:local('Liberation Sans'),local('DejaVu Sans'),local('Arial'),local('Helvetica');size-adjust:98.55%;ascent-override:108.17%;descent-override:30.44%;line-gap-override:0%}
			@font-face{font-family:'Manrope fallback';font-style:normal;font-weight:600;src:local('Liberation Sans'),local('DejaVu Sans'),local('Arial'),local('Helvetica');size-adjust:98.55%;ascent-override:108.17%;descent-override:30.44%;line-gap-override:0%}
			@font-face{font-family:'Manrope fallback';font-style:normal;font-weight:700;src:local('Liberation Sans'),local('DejaVu Sans'),local('Arial'),local('Helvetica');size-adjust:98.55%;ascent-override:108.17%;descent-override:30.44%;line-gap-override:0%}
			@layer base{
				:root{--color-canvas:#f9f9f9;--color-soft:#f3f3f3;--color-deep:#2f3131;--color-primary:#b60057;--color-primary-container:#e4006f;--color-on-primary:#f9f9f9;--color-muted:#5b3f46;--color-ink:#1a1c1c;--color-on-surface:#1a1c1c;--color-on-surface-variant:#5b3f46;--color-surface-lowest:#ffffff;--color-outline-variant:#e4bdc4;--font-headline:"Epilogue","Epilogue fallback",system-ui,sans-serif;--font-body:"Manrope","Manrope fallback",system-ui,sans-serif;--font-serif:"Epilogue","Epilogue fallback",system-ui,sans-serif;--font-sans:"Manrope","Manrope fallback",system-ui,sans-serif}
				*,*::before,*::after{box-sizing:border-box;border:0 solid}
				html{font-size:18px;line-height:1.7;-webkit-text-size-adjust:100%;-webkit-font-smoothing:antialiased}
				body{margin:0;background:#f9f9f9;color:#1a1c1c;font-family:"Manrope","Manrope fallback",system-ui,sans-serif;line-height:1.7}
				img,picture,svg,video,canvas{display:block;max-width:100%;height:auto}
				h1,h2,h3,h4,h5,h6{margin:0;font-family:"Epilogue","Epilogue fallback",system-ui,sans-serif;color:#1a1c1c;line-height:1.2;font-weight:500;overflow-wrap:break-word}
				p{margin:0;overflow-wrap:break-word}
				a{color:inherit;text-decoration:none}
				button{font:inherit;color:inherit;background:transparent;cursor:pointer;padding:0;border:0}
				[data-hero-entrance]{opacity:0;transform:scale(1.03);animation:heroEntrance 1.4s ease forwards;animation-delay:.3s}
				.fixed{position:fixed}.relative{position:relative}.absolute{position:absolute}
				.top-0{top:0}.left-0{left:0}.right-0{right:0}.top-full{top:100%}
				.inset-0{inset:0}
				.z-10{z-index:10}.z-50{z-index:50}
				.flex{display:flex}.flex-col{flex-direction:column}.hidden{display:none}.block{display:block}
				.items-center{align-items:center}.items-end{align-items:flex-end}
				.justify-between{justify-content:space-between}.justify-center{justify-content:center}
				.text-center{text-align:center}
				.gap-0\.5{gap:.125rem}.gap-1\.5{gap:.375rem}.gap-3{gap:.75rem}.gap-4{gap:1rem}
				.max-w-2xl{max-width:42rem}.max-w-3xl{max-width:48rem}.max-w-6xl{max-width:72rem}
				.min-h-screen{min-height:100vh}.min-h-\[500px\]{min-height:500px}.min-h-\[600px\]{min-height:600px}
				.m-0{margin:0}.mx-auto{margin-left:auto;margin-right:auto}.mb-4{margin-bottom:1rem}.mb-5{margin-bottom:1.25rem}.mb-10{margin-bottom:2.5rem}.mt-5{margin-top:1.25rem}
				.p-0{padding:0}.p-2{padding:.5rem}.pb-2{padding-bottom:.5rem}.pb-8{padding-bottom:2rem}.pb-10{padding-bottom:2.5rem}.pt-2{padding-top:.5rem}.pt-10{padding-top:2.5rem}
				.px-1\.5{padding-left:.375rem;padding-right:.375rem}.border-b{border-bottom-width:1px}.flex-wrap{flex-wrap:wrap}
				.px-1{padding-left:.25rem;padding-right:.25rem}.px-4{padding-left:1rem;padding-right:1rem}.px-5{padding-left:1.25rem;padding-right:1.25rem}.px-6{padding-left:1.5rem;padding-right:1.5rem}.px-8{padding-left:2rem;padding-right:2rem}
				.py-2{padding-top:.5rem;padding-bottom:.5rem}.py-2\.5{padding-top:.625rem;padding-bottom:.625rem}.py-5{padding-top:1.25rem;padding-bottom:1.25rem}.py-6{padding-top:1.5rem;padding-bottom:1.5rem}.py-8{padding-top:2rem;padding-bottom:2rem}.py-3\.5{padding-top:.875rem;padding-bottom:.875rem}
				.w-auto{width:auto}.w-6{width:1.5rem}.w-full{width:100%}
				.h-14{height:3.5rem}.h-0\.5{height:.125rem}.h-full{height:100%}
				.no-underline{text-decoration:none}.shrink-0{flex-shrink:0}
				.list-none{list-style:none}
				.leading-snug{line-height:1.375}.leading-relaxed{line-height:1.625}.leading-tight{line-height:1.25}
				.overflow-hidden{overflow:hidden}.object-cover{object-fit:cover}
				.bg-transparent{background-color:transparent}
				.border-none{border-style:none}
				.cursor-pointer{cursor:pointer}
				.origin-center{transform-origin:center}
				.text-xs{font-size:.75rem;line-height:1rem}.text-sm{font-size:.875rem;line-height:1.25rem}.text-base{font-size:1rem;line-height:1.5rem}.text-lg{font-size:1.125rem;line-height:1.75rem}.text-4xl{font-size:2.25rem;line-height:2.5rem}
				.font-semibold{font-weight:600}.font-medium{font-weight:500}.font-light{font-weight:300}
				.tracking-\[0\.15em\]{letter-spacing:.15em}.tracking-\[0\.1em\]{letter-spacing:.1em}.tracking-\[0\.08em\]{letter-spacing:.08em}.tracking-tight{letter-spacing:-.025em}.tracking-widest{letter-spacing:.1em}
				.uppercase{text-transform:uppercase}
				.opacity-0{opacity:0}.invisible{visibility:hidden}
				.duration-300{transition-duration:300ms}.duration-200{transition-duration:200ms}
				.transition-all{transition-property:all;transition-duration:150ms}
				.transition-colors{transition-property:color,background-color,border-color;transition-duration:150ms}
				.inline-flex{display:inline-flex}
				.absolute.left-1\/2{left:50%}
				.grid{display:grid}.grid-cols-1{grid-template-columns:repeat(1,minmax(0,1fr))}
				.border{border-width:1px}
				@media(min-width:640px){.sm\:flex-row{flex-direction:row}}
				@media(min-width:768px){.md\:min-h-screen{min-height:100vh}.md\:pb-16{padding-bottom:4rem}.md\:mb-6{margin-bottom:1.5rem}.md\:py-12{padding-top:3rem;padding-bottom:3rem}.md\:text-6xl{font-size:3.75rem;line-height:1}.md\:text-xl{font-size:1.25rem;line-height:1.75rem}.md\:h-20{height:5rem}.md\:px-6{padding-left:1.5rem;padding-right:1.5rem}}
				@media(min-width:1024px){.lg\:block{display:block}.lg\:flex{display:flex}.lg\:hidden{display:none}.lg\:inline-flex{display:inline-flex}.lg\:h-28{height:7rem}.lg\:pb-24{padding-bottom:6rem}.lg\:min-h-screen{min-height:100vh}}
				@media(min-width:1280px){.xl\:gap-7{gap:1.75rem}}
			}
		</style>

		<title>{title}</title>
		<meta name="description" content={description} />
		{!noindex && <meta name="robots" content="index, follow" />}
		<meta name="author" content="Spirit Media Inc." />
		<meta name="publisher" content="Spirit Media Inc." />

		<!-- Open Graph -->
		<meta property="og:type" content={pageType} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content={ogImageAlt} />
		{ogSized && <meta property="og:image:width" content="1200" />}
		{ogSized && <meta property="og:image:height" content="630" />}
		{ogSized && <meta property="og:image:type" content="image/jpeg" />}
		<meta property="og:site_name" content={siteName} />
		<meta property="og:locale" content="en_US" />

		{pageType === 'article' && articleAuthor && (
			<meta property="article:author" content={articleAuthor} />
		)}
		{pageType === 'article' && articlePublishedTime && (
			<meta property="article:published_time" content={articlePublishedTime} />
		)}
		{pageType === 'article' && articleSection && (
			<meta property="article:section" content={articleSection} />
		)}
		{pageType === 'article' && articleTags.map((tag) => (
			<meta property="article:tag" content={tag} />
		))}

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<meta name="twitter:image:alt" content={ogImageAlt} />

		<!-- JSON-LD Structured Data — page-specific schemas + site-wide Organization -->
		{allJsonLd.map((schema) => (
			<script type="application/ld+json" set:html={JSON.stringify(schema)} />
		))}

		<!-- Analytics: Cloudflare Web Analytics only (cookieless, zone-injected).
		     GA4 was removed 2026-06-10 — it set non-essential _ga cookies that
		     would have required a consent banner for EU/UK visitors. Cookieless
		     CF analytics needs no consent, so the site sets zero non-essential
		     cookies and needs no cookie banner. (Kevin, load-scaling review.) -->
	</head>
	<body class="min-h-screen flex flex-col" data-dark-hero={darkHero ? 'true' : 'false'}>
		<Header
			brandName={brandName}
			navLinks={globalNav}
			currentPath={Astro.url.pathname}
			logoUrl={headerLogoUrl}
			ctaLabel="Read FHB →"
			ctaHref="/read"
			sticky={true}
			inFlow={true}
			transparentOverHero={darkHero}
		/>
		<slot />
		<Footer
			variant="full"
			quote={footerQuote}
			citation="Revelation 21:7"
			navLinks={fhbFooterNav}
			legalLinks={fhbFooterLegal}
			copyrightName={brandName}
			year={currentYear}
		>
			<MailtoLink slot="contact" email="hello@spiritmediapublishing.com" style="text-decoration: none; color: var(--color-inverse-on-surface, #f1f1f1); opacity: 0.65; font-family: var(--font-body); font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase;">Contact</MailtoLink>
		</Footer>
		<WelcomeTour />
		<script>
			// Scroll reveal observer
			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add('revealed');
						observer.unobserve(entry.target);
					}
				});
			}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

			document.querySelectorAll('[data-reveal], [data-stagger], [data-grow-line]').forEach((el) => observer.observe(el));

			// Counter animation
			const counterObserver = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const el = entry.target as HTMLElement;
						const target = parseInt(el.dataset.counter || '0', 10);
						const prefix = el.dataset.prefix || '';
						const suffix = el.dataset.suffix || '';
						let current = 0;
						const duration = 1200;
						const step = Math.max(1, Math.floor(target / (duration / 16)));
						const tick = () => {
							current = Math.min(current + step, target);
							el.textContent = prefix + current.toLocaleString('en-US') + suffix;
							if (current < target) requestAnimationFrame(tick);
						};
						requestAnimationFrame(tick);
						counterObserver.unobserve(el);
					}
				});
			}, { threshold: 0.3 });

			document.querySelectorAll('[data-counter]').forEach((el) => counterObserver.observe(el));

		</script>
	</body>
</html>
